<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>管理员后台</title>
    <script src="https://telegram.org/js/telegram-widget.js?22" data-telegram-login="games888bot" data-size="large" data-onauth="onTelegramAuth(user)" data-request-access="write"></script>
    <style>
        body { background: #1a2a1a; color: white; font-family: system-ui; padding: 20px; }
        .container { max-width: 800px; margin: 0 auto; background: #2a323f; border-radius: 20px; padding: 20px; }
        .user-card { background: #1e1e2f; margin: 10px 0; padding: 15px; border-radius: 16px; display: flex; justify-content: space-between; align-items: center; }
        button { background: #ffaa66; border: none; padding: 8px 16px; border-radius: 40px; cursor: pointer; }
        button.danger { background: #6a1a1a; color: white; }
        .strength-slider { width: 150px; }
    </style>
</head>
<body>
<div class="container" id="loginArea">
    <h2>🔐 管理员登录</h2>
    <div id="telegram-login"></div>
    <p>请使用 Telegram 账号登录，仅 @arnan66666 可访问。</p>
</div>
<div id="adminPanel" style="display: none;">
    <h2>👑 管理员控制台</h2>
    <button id="refreshBtn">🔄 刷新列表</button>
    <div id="userList"></div>
</div>

<script>
    const API_BASE_URL = "https://random-name.trycloudflare.com"; // 替换为你的 cloudflared 地址
    let currentAdminId = null;

    function onTelegramAuth(user) {
        // 验证用户名是否为 arnan66666
        if (user.username === 'arnan66666') {
            currentAdminId = user.id;
            document.getElementById('loginArea').style.display = 'none';
            document.getElementById('adminPanel').style.display = 'block';
            loadUsers();
        } else {
            alert('你没有管理员权限！');
        }
    }

    async function loadUsers() {
        const res = await fetch(`${API_BASE_URL}/api/admin/users`);
        const users = await res.json();
        const container = document.getElementById('userList');
        container.innerHTML = '';
        for (const user of users) {
            const card = document.createElement('div');
            card.className = 'user-card';
            card.innerHTML = `
                <div><strong>用户ID:</strong> ${user.user_id}<br>
                <strong>状态:</strong> ${user.enabled ? '回血模式' : '普通模式'} ${user.enabled ? `(强度 ${user.strength}%)` : ''}</div>
                <div>
                    <button class="compassion-btn" data-id="${user.user_id}">🩸 回血</button>
                    <button class="normal-btn" data-id="${user.user_id}">⚖️ 普通</button>
                    <input type="range" min="0" max="100" value="${user.strength}" class="strength-slider" data-id="${user.user_id}" ${!user.enabled ? 'disabled' : ''}>
                    <span class="strength-val">${user.strength}%</span>
                </div>
            `;
            container.appendChild(card);
        }
        // 绑定按钮事件
        document.querySelectorAll('.compassion-btn').forEach(btn => {
            btn.onclick = () => setMode(btn.dataset.id, true, 50);
        });
        document.querySelectorAll('.normal-btn').forEach(btn => {
            btn.onclick = () => setMode(btn.dataset.id, false, 0);
        });
        document.querySelectorAll('.strength-slider').forEach(slider => {
            slider.oninput = (e) => {
                const val = e.target.value;
                const userId = slider.dataset.id;
                document.querySelector(`.strength-val[data-id="${userId}"]`).innerText = val + '%';
                setMode(userId, true, parseInt(val));
            };
        });
    }

    async function setMode(userId, enabled, strength) {
        const res = await fetch(`${API_BASE_URL}/api/admin/set`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: userId, enabled, strength })
        });
        if (res.ok) {
            loadUsers(); // 刷新列表
        } else {
            alert('设置失败');
        }
    }

    document.getElementById('refreshBtn').onclick = loadUsers;
</script>
</body>
</html>