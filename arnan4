        /* 音频开关 */
        .audio-toggle { position: absolute; top: 15px; right: 15px; z-index: 200; width: 40px; height: 40px; background: rgba(0,0,0,0.5); border: 1px solid var(--neon); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; box-shadow: 0 0 10px var(--neon); }

        .header { width: 100%; height: 22%; display: flex; flex-direction: column; align-items: center; justify-content: center; }
        .bal-card { width: 85%; background: rgba(255,255,255,0.03); border: 1px solid rgba(0,242,255,0.4); border-radius: 20px; padding: 12px; text-align: center; box-shadow: 0 0 20px rgba(0,242,255,0.1); }
        .bal-val { font-size: 38px; font-weight: 900; color: #fff; text-shadow: 0 0 15px var(--neon); }

        .main-game { flex: 1; width: 100%; display: flex; align-items: center; justify-content: center; position: relative; }
        .wheel-box { position: relative; width: 82vw; max-width: 340px; aspect-ratio: 1 / 1; }
