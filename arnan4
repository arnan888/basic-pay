        .footer { width: 100%; height: 20%; display: flex; flex-direction: column; align-items: center; gap: 10px; }
        .bet-box { display: flex; align-items: center; gap: 20px; background: rgba(255,255,255,0.05); padding: 8px 20px; border-radius: 30px; }
        .btn-adj { width: 40px; height: 40px; border-radius: 50%; border: 1px solid #555; background: #222; color: #fff; font-size: 20px; }
        #msg { color: var(--gold); font-weight: bold; font-size: 18px; text-shadow: 0 0 5px #000; }
    </style>
</head>
<body>

    <div class="audio-toggle" onclick="toggleMute()" id="muteBtn">🔊</div>

    <div class="header">
        <div class="bal-card">
            <div style="font-size:11px; color:var(--neon); letter-spacing:1px;">VIP BALANCE</div>
            <div class="bal-val">🪙 <span id="bal">1,000</span></div>
        </div>
    </div>

    <div class="main-game">
        <div class="wheel-box">
            <div class="pointer"></div>
            <div class="wheel" id="wheel">
                <div class="sector" style="transform:rotate(-90deg); background:rgba(255,215,0,0.1)">
                    <div class="item"><b>👑</b><span>至尊 MAX</span></div>
                </div>
                <div class="sector" style="transform:rotate(-30deg); background:rgba(255,0,0,0.05)">
                    <div class="item"><b>🦁</b><span>威武 LION</span></div>
                </div>
                <div class="sector" style="transform:rotate(30deg); background:rgba(255,165,0,0.1)">
                    <div class="item"><b>🐯</b><span>霸气 TIGER</span></div>
                </div>
                <div class="sector" style="transform:rotate(90deg); background:rgba(0,255,0,0.05)">
                    <div class="item"><b>🦅</b><span>睿智 EAGLE</span></div>
                </div>
                <div class="sector" style="transform:rotate(150deg); background:rgba(147,112,219,0.1)">
                    <div class="item"><b>🐺</b><span>孤狼 WOLF</span></div>
                </div>
                <div class="sector" style="transform:rotate(210deg); background:rgba(240,230,140,0.05)">
                    <div class="item"><b>🐕</b><span>忠诚 DOG</span></div>
                </div>
            </div>
            <div class="spin-btn" onclick="spin()">SPIN</div>
        </div>
    </div>

    <div class="footer">
        <div class="bet-box">
            <button class="btn-adj" onclick="setB(-10)">-</button>
            <div style="font-size:20px; font-weight:bold; width:80px; text-align:center;"><span id="bet" style="color:var(--gold)">1</span></div>
            <button class="btn-adj" onclick="setB(10)">+</button>
        </div>
        <div id="msg">祝您好运连连！</div>
    </div>

    <!-- 隐藏音频源 -->
    <audio id="bgMusic" loop src="https://assets.mixkit.co/music/preview/mixkit-tech-house-vibes-130.mp3">
    <audio id="spinSound" src="https://assets.mixkit.co/sfx/preview/mixkit-fast-sword-whoosh-2325.mp3">
    <audio id="winSound" src="https://assets.mixkit.co/sfx/preview/mixkit-winning-chimes-2015.mp3">

    <script>
        const tg = window.Telegram.WebApp; tg.expand();
        let b = parseFloat(localStorage.getItem('g_v108') || '1000');
        let bet = 1, r = 0, isS = false, isMuted = false;

        const audios = {
            bg: document.getElementById('bgMusic'),
            spin: document.getElementById('spinSound'),
            win: document.getElementById('winSound')
        };
        audios.bg.volume = 0.3;

        function toggleMute() {
            isMuted = !isMuted;
            document.getElementById('muteBtn').innerText = isMuted ? "🔇" : "🔊";
            if(isMuted) audios.bg.pause(); else audios.bg.play().catch(()=>{});
        }

        function sync() {
            document.getElementById('bal').innerText = Math.floor(b).toLocaleString();
            document.getElementById('bet').innerText = bet;
            localStorage.setItem('g_v108', b);
        }

        window.setB = (v) => { 
            if(!isS) { 
                bet = Math.max(1, Math.min(b, bet+v)); sync(); 
                tg.HapticFeedback.selectionChanged();
                if(!isMuted) audios.bg.play().catch(()=>{}); // 用户点击时尝试开启BGM
            } 
        };

        function spin() {
            if(isS || b < bet) return;
            isS = true; b -= bet; sync();

            tg.HapticFeedback.impactOccurred('heavy');
            if(!isMuted) { audios.spin.play(); audios.bg.volume = 0.1; }

            let idx = Math.floor(Math.random()*6);
            r += (3600 + idx*60);
            document.getElementById('wheel').style.transform = `rotate(-${r}deg)`;
            document.getElementById('msg').innerText = "🎰 幸运转动中...";

            setTimeout(() => {
                const multi = [88, 15, 10, 5, 2, 0];
                let win = Math.floor(bet * multi[idx]);
                b += win; sync();

                if(win > 0) {
                    document.getElementById('msg').innerText = "🎊 恭喜！赢取 " + win + " 金币！";
                    if(!isMuted) audios.win.play();
                    tg.HapticFeedback.notificationOccurred('success');
                } else {
                    document.getElementById('msg').innerText = "💔 差点运气，再来一把！";
                }

                if(!isMuted) audios.bg.volume = 0.3;
                isS = false;
            }, 5000);
        }
        sync();
    </script>
</body>
</html>









