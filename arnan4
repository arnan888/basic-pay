        .pointer { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); width: 0; height: 0; border-left: 18px solid transparent; border-right: 18px solid transparent; border-top: 40px solid var(--neon); z-index: 100; filter: drop-shadow(0 0 10px var(--neon)); }
