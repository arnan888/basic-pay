<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
    <title>五兽至尊_V1000_SINGULARITY</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        :root { --c-cyan: #00f2ff; --c-pink: #ff0055; --c-gold: #ffcc00; --c-bg: #000; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin: 0; padding: 0; outline: none; }
        
        body { background: var(--c-bg); color: #fff; font-family: 'Exo 2', sans-serif; height: 100vh; overflow: hidden; position: relative; }

        /* 全屏粒子场：更细腻、更灵动 */
        #fxCanvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }

        .ui-root { position: relative; z-index: 10; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 30px 0; }

        /* 顶部：全息余额卡 */
        .top-panel {
            background: rgba(255,255,255,0.02); border: 1px solid rgba(0,242,255,0.3);
            padding: 12px 50px; border-radius: 100px; backdrop-filter: blur(25px);
            box-shadow: 0 0 30px rgba(0,242,255,0.2), inset 0 0 15px rgba(0,242,255,0.1);
            animation: float 4s ease-in-out infinite;
        }
        @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
        .val-num { font-size: 56px; font-weight: 900; background: linear-gradient(135deg, #fff, var(--c-cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0 0 15px var(--c-cyan)); }

        /* 转盘：3D 分层构造 */
        .stage-box { position: relative; width: 90vw; max-width: 400px; aspect-ratio: 1/1; }
        .wheel-body {
            width: 100%; height: 100%; border-radius: 50%; border: 4px solid #1a1a1a;
            background: radial-gradient(circle at center, #222 0%, #000 70%);
            box-shadow: 0 0 100px rgba(0,0,0,0.8), inset 0 0 50px rgba(0,242,255,0.1);
            position: relative; transition: transform 7s cubic-bezier(0.1, 0, 0, 1);
            overflow: hidden;
        }
        /* 动态流光边框 */
        .stage-box::before {
            content: ""; position: absolute; inset: -10px; border-radius: 50%;
            background: conic-gradient(from 0deg, transparent, var(--c-cyan), transparent, var(--c-pink), transparent);
            animation: rotate-flow 4s linear infinite; opacity: 0.3; z-index: -1;
        }
        @keyframes rotate-flow { 100% { transform: rotate(360deg); } }

        .slice-item { position: absolute; width: 100%; height: 100%; clip-path: polygon(50% 50%, 100% 17%, 100% 83%); transform-origin: center; display: flex; align-items: center; justify-content: flex-end; padding-right: 8%; }
        .slice-item b { font-size: 82px; transform: rotate(90deg); filter: drop-shadow(0 0 15px rgba(255,255,255,0.5)); transition: 0.3s; }

