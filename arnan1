        /* 指针：改为一条极细的光束 */
        .laser-line { position: absolute; top: 0; width: 2px; height: 50px; background: #fff; box-shadow: 0 0 15px #fff; z-index: 20; }
    </style>
</head>
<body onclick="init()">

    <canvas id="starfield"></canvas>

    <div class="ui-overlay">
        <div class="bal-wrap">
            <div class="bal-num"><span id="b-val">1,000</span></div>
            <div class="bal-label">CREDITS AVAILABLE</div>
        </div>

        <div class="orbit-container">
            <div class="laser-line"></div>
            <div class="neon-ring" id="ring"></div>
            <div id="orbit" class="icon-orbit">
                <!-- 动态生成图标位置 -->
            </div>
            <div class="core-btn" onclick="spin()">RUN</div>
        </div>

        <div class="bottom-ctrl">
            <div id="msg-status">SYSTEM IDLE</div>
            <div class="bet-input">
                <div class="step" onclick="adjBet(-10)">-</div>
                <div class="bet-val" id="bet-txt">1</div>
                <div class="step" onclick="adjBet(10)">+</div>
            </div>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp; tg.expand();
        let balance = 1000, bet = 1, rot = 0, isSpinning = false, ctx, stars = [];
        const canvas = document.getElementById('starfield');
        const icons = ['👑','🦁','🐯','🦅','🐺','🐕'];

        function init() {
            if(ctx) return;
            ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth; canvas.height = window.innerHeight;
            for(let i=0; i<200; i++) stars.push({x:Math.random()*canvas.width, y:Math.random()*canvas.height, z:Math.random()*canvas.width, s:Math.random()*2});
            
            // 动态创建图标节点，彻底摆脱“圆盘图”
            const orbit = document.getElementById('orbit');
            icons.forEach((icon, i) => {
                const node = document.createElement('div');
                node.className = 'icon-node';
                const angle = (i * 60) * (Math.PI / 180);
                const radius = 150; 
                node.style.left = (radius * Math.cos(angle - Math.PI/2) + 210 - 50) + 'px';
                node.style.top = (radius * Math.sin(angle - Math.PI/2) + 210 - 50) + 'px';
                node.innerHTML = `<b>${icon}</b>`;
                orbit.appendChild(node);
            });
            updateStars();
        }

        function updateStars() {
            ctx.fillStyle = 'black'; ctx.fillRect(0,0,canvas.width, canvas.height);
            stars.forEach(s => {
                s.z -= isSpinning ? 20 : 1; 
                if(s.z <= 0) s.z = canvas.width;
                const px = (s.x - canvas.width/2) * (canvas.width/s.z) + canvas.width/2;
                const py = (s.y - canvas.height/2) * (canvas.width/s.z) + canvas.height/2;
                const sz = (1 - s.z/canvas.width) * 3;
                ctx.fillStyle = isSpinning ? '#ff0055' : 'white';
                ctx.beginPath(); ctx.arc(px, py, sz, 0, Math.PI*2); ctx.fill();
            });
            requestAnimationFrame(updateStars);
        }

        function adjBet(v) {
            if(isSpinning) return;
            bet = Math.max(1, Math.min(balance, bet+v));
            document.getElementById('bet-txt').innerText = bet;
            tg.HapticFeedback.selectionChanged();
        }

        function spin() {
            if(isSpinning || balance < bet) return;
            isSpinning = true; balance -= bet;
            document.getElementById('b-val').innerText = balance.toLocaleString();
            document.getElementById('ring').classList.add('active-ring');
            document.getElementById('msg-status').innerText = "WARPING...";
            tg.HapticFeedback.impactOccurred('heavy');

            let target = Math.floor(Math.random()*6);
            rot += (3600 + target*60);
            document.getElementById('orbit').style.transform = `rotate(-${rot}deg)`;
            
            // 图标反向旋转，保持正立感（高级感细节）
            const nodes = document.querySelectorAll('.icon-node b');
            nodes.forEach(n => n.style.transform = `rotate(${rot}deg)`);

            setTimeout(() => {
                const multi = [88, 15, 10, 5, 2, 0];
                let win = Math.floor(bet * multi[target]);
                balance += win;
                document.getElementById('b-val').innerText = balance.toLocaleString();
                document.getElementById('ring').classList.remove('active-ring');
                
                if(win > 0) {
                    document.getElementById('msg-status').innerText = "SUCCESS: +" + win;
                    tg.HapticFeedback.notificationOccurred('success');
                } else {
                    document.getElementById('msg-status').innerText = "FAILED";
                }
                isSpinning = false;
            }, 6000);
        }
    </script>
</body>
</html>