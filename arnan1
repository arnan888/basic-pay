<body onclick="bootSystem()">

    <canvas id="fxCanvas"></canvas>

    <div class="ui-root">
        <div class="top-panel">
            <div class="val-num">💎 <span id="bal-txt">1,000</span></div>
        </div>

        <div class="stage-box">
            <div class="laser-pointer"></div>
            <div id="wheel-obj" class="wheel-body">
                <div class="slice-item" style="transform:rotate(-90deg)"><b>👑</b></div>
                <div class="slice-item" style="transform:rotate(-30deg)"><b>🦁</b></div>
                <div class="slice-item" style="transform:rotate(30deg)"><b>🐯</b></div>
                <div class="slice-item" style="transform:rotate(90deg)"><b>🦅</b></div>
                <div class="slice-item" style="transform:rotate(150deg)"><b>🐺</b></div>
                <div class="slice-item" style="transform:rotate(210deg)"><b>🐕</b></div>
            </div>
            <div class="run-btn" onclick="executeSpin()">RUN</div>
        </div>

        <div class="console">
            <div class="bet-row">
                <button class="adj" onclick="changeBet(-10)">-</button>
                <div style="font-size:52px; font-weight:900; min-width:110px; text-align:center;" id="bet-txt">1</div>
                <button class="adj" onclick="changeBet(10)">+</button>
            </div>
            <div id="msg-ui">AWAITING INPUT...</div>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp; tg.expand();
        let balance = 1000, bet = 1, currentRot = 0, active = false, aCtx, dots = [];
        const cvs = document.getElementById('fxCanvas');
        const ctx = cvs.getContext('2d');

        function bootSystem() {
            if(aCtx) return;
            aCtx = new (window.AudioContext || window.webkitAudioContext)();
            cvs.width = window.innerWidth; cvs.height = window.innerHeight;
            for(let i=0; i<180; i++) dots.push({
                x: Math.random()*cvs.width, y: Math.random()*cvs.height,
                vx: (Math.random()-0.5)*0.8, vy: (Math.random()-0.5)*0.8,
                s: Math.random()*2.5, c: Math.random() > 0.5 ? '#00f2ff' : '#ff0055'
            });
            draw();
            document.getElementById('msg-ui').innerText = "SYSTEM ONLINE";
        }

        function draw() {
            ctx.fillStyle = 'rgba(0,0,0,0.2)'; ctx.fillRect(0,0,cvs.width, cvs.height);
            dots.forEach(p => {
                p.x += p.vx; p.y += p.vy;
                if(p.x<0 || p.x>cvs.width) p.vx *= -1;
                if(p.y<0 || p.y>cvs.height) p.vy *= -1;
                ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, Math.PI*2);
                ctx.fillStyle = p.c; ctx.fill();
                // 连线特效
                if(Math.random() > 0.98) {
                    ctx.strokeStyle = p.c; ctx.lineWidth = 0.2;
                    ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(cvs.width/2, cvs.height/2); ctx.stroke();
                }
            });
            requestAnimationFrame(draw);
        }

        function sound(f, d, t='sine', v=0.1) {
            if(!aCtx) return;
            const o = aCtx.createOscillator(); const g = aCtx.createGain();
            o.type = t; o.frequency.setTargetAtTime(f, aCtx.currentTime, 0.01);
            g.gain.setValueAtTime(v, aCtx.currentTime);
            g.gain.exponentialRampToValueAtTime(0.0001, aCtx.currentTime + d);
            o.connect(g); g.connect(aCtx.destination);
            o.start(); o.stop(aCtx.currentTime + d);
        }

        function changeBet(v) {
            if(active) return;
            bet = Math.max(1, Math.min(balance, bet+v));
            document.getElementById('bet-txt').innerText = bet;
            tg.HapticFeedback.selectionChanged();
            sound(1200, 0.1, 'square', 0.05);
        }

        function executeSpin() {
            if(active || balance < bet) return;
            active = true; balance -= bet;
            document.getElementById('bal-txt').innerText = balance.toLocaleString();
            tg.HapticFeedback.impactOccurred('heavy');
            
            // 坍缩脉冲：粒子流向中心
            dots.forEach(p => { p.vx = (cvs.width/2 - p.x)*0.1; p.vy = (cvs.height/2 - p.y)*0.1; });

            let target = Math.floor(Math.random()*6);
            currentRot += (3600 + target*60);
            document.getElementById('wheel-obj').style.transform = `rotate(-${currentRot}deg)`;
            document.getElementById('msg-ui').innerText = "CALCULATING PROBABILITY...";

            setTimeout(() => {
                const multi = [88, 15, 10, 5, 2, 0];
                let win = Math.floor(bet * multi[target]);
                balance += win;
                document.getElementById('bal-txt').innerText = balance.toLocaleString();
                
                // 爆炸释放
                dots.forEach(p => { p.vx = (Math.random()-0.5)*15; p.vy = (Math.random()-0.5)*15; });

                if(win > 0) {
                    document.getElementById('msg-ui').innerText = "CRITICAL WIN: +" + win;
                    tg.HapticFeedback.notificationOccurred('success');
                    for(let i=0; i<20; i++) setTimeout(() => sound(400 + i*120, 0.3, 'sine', 0.1), i*60);
                } else {
                    document.getElementById('msg-ui').innerText = "REBOOTING...";
                    sound(80, 0.8, 'sawtooth', 0.1);
                }
                setTimeout(() => { 
                    dots.forEach(p => { p.vx *= 0.05; p.vy *= 0.05; });
                    active = false; 
                }, 1000);
            }, 7000);
        }
    </script>
</body>
</html>




<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
    <title>五兽至尊_V2000_CORE</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        :root { --c-main: #00f2ff; --c-alt: #ff0055; --bg: #000; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin: 0; padding: 0; outline: none; }
        
        body { background: var(--bg); color: #fff; font-family: 'Inter', sans-serif; height: 100vh; overflow: hidden; }

        /* 全屏星海背景 */
        #starfield { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; transition: transform 0.5s; }

        .ui-overlay { position: relative; z-index: 10; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 50px 0; pointer-events: none; }
        .ui-overlay * { pointer-events: auto; }

        /* 顶部余额：纯数字发光 */
        .bal-wrap { text-align: center; }
        .bal-num { font-size: 64px; font-weight: 900; color: #fff; text-shadow: 0 0 20px var(--c-main), 0 0 40px var(--c-main); letter-spacing: -2px; }
        .bal-label { font-size: 14px; color: var(--c-main); letter-spacing: 5px; opacity: 0.8; }

        /* 核心区：悬浮星轨系统 */
        .orbit-container { position: relative; width: 95vw; max-width: 420px; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; }
        
        /* 霓虹光环 */
        .neon-ring {
            position: absolute; width: 85%; height: 85%; border-radius: 50%;
            border: 2px solid rgba(0, 242, 255, 0.1);
            box-shadow: 0 0 20px rgba(0, 242, 255, 0.05);
            transition: 0.5s;
        }
        .active-ring { border: 2px solid var(--c-main); box-shadow: 0 0 40px var(--c-main); }

        /* 图标组：取消圆盘，改为直接旋转 */
        .icon-orbit { 
            position: absolute; width: 100%; height: 100%; 
            transition: transform 6s cubic-bezier(0.15, 0, 0, 1);
        }
        .icon-node { 
            position: absolute; width: 100px; height: 100px; 
            display: flex; align-items: center; justify-content: center;
            transform-origin: center;
        }
        .icon-node b { font-size: 85px; filter: drop-shadow(0 0 15px rgba(255,255,255,0.3)); transition: 0.3s; }

        /* 核心启动点 */
        .core-btn {
            position: relative; width: 110px; height: 110px; border-radius: 50%;
            background: rgba(0,0,0,0.8); border: 1px solid var(--c-alt);
            display: flex; align-items: center; justify-content: center;
            font-size: 20px; font-weight: 900; color: var(--c-alt);
            box-shadow: 0 0 30px var(--c-alt); cursor: pointer;
        }
        .core-btn::after { content: ""; position: absolute; inset: -5px; border-radius: 50%; border: 1px solid var(--c-alt); opacity: 0.3; animation: pulse 2s infinite; }
        @keyframes pulse { 0% { transform: scale(1); opacity: 0.3; } 100% { transform: scale(1.4); opacity: 0; } }

        /* 底部控制：极简线性设计 */
        .bottom-ctrl { width: 100%; display: flex; flex-direction: column; align-items: center; gap: 20px; }
