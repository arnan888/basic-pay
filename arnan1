            border: 1px solid var(--neon); border-radius: 10px; 
            padding: 10px; text-align: center; z-index: 100;
            backdrop-filter: blur(10px); box-shadow: 0 0 20px rgba(0,242,255,0.3);
        }
        .hud b { font-size: 22px; color: var(--neon); text-shadow: 0 0 10px var(--neon); }

        /* 转盘容器：绝对定位，确保在背景之上 */
        .wheel-box { 
            position: absolute; top: 110px; left: 50%; 
            transform: translateX(-50%); 
            z-index: 50; /* 确保高于背景 */
        }

        .wheel { 
            width: 280px; height: 280px; border-radius: 50%; 
            border: 6px solid #111;
            background: conic-gradient(from 0deg, #ff0055 0 60deg, #1a1a1a 60deg 120deg, #00f2ff 120deg 180deg, #1a1a1a 180deg 240deg, #ffcc00 240deg 300deg, #1a1a1a 300deg 360deg);
            box-shadow: 0 0 50px rgba(0,0,0,0.8), 0 0 20px var(--neon);
            transition: transform 4s cubic-bezier(0.1, 0, 0.1, 1);
            display: flex; align-items: center; justify-content: center;
            position: relative;
        }

        .item { position: absolute; font-size: 28px; }
        .i1 { transform: rotate(30deg) translateY(-105px); } 
        .i2 { transform: rotate(90deg) translateY(-105px); } 
        .i3 { transform: rotate(150deg) translateY(-105px); } 
        .i4 { transform: rotate(210deg) translateY(-105px); } 
        .i5 { transform: rotate(270deg) translateY(-105px); } 
        .i6 { transform: rotate(330deg) translateY(-105px); }

        .btn { 
            position: absolute; width: 60px; height: 60px; background: #000; 
            border: 3px solid var(--pink); border-radius: 50%; 
            color: #fff; font-size: 14px; font-weight: bold; cursor: pointer; z-index: 60; 
            display: flex; align-items: center; justify-content: center; 
            box-shadow: 0 0 20px var(--pink); 
