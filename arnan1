    <script>
        let b=1000, r=0;
        function spin(){ 
            if(b<50)return alert('余额不足'); b-=50; document.getElementById('bal').innerText=b; 
            let add=1800+Math.floor(Math.random()*360); r+=add; 
            document.getElementById('wheel').style.transform="rotate("+r+"deg)";
            setTimeout(()=>{ 
                let win=[0,100,0,200,0,500][Math.floor(Math.random()*6)]; b+=win; 
                document.getElementById('bal').innerText=b; document.getElementById('ovl').style.display='flex'; 
