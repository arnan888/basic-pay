    <div class="nav-n">📜 历史记录</div>
    <div class="nav-n act">🎛️ 量化终端</div>
</div>

<script>
    // ---------- 配置 ----------
    const API_BASE_URL = "https://你的cloudflared地址"; 
    const urlParams = new URLSearchParams(window.location.search);
    const userId = urlParams.get('user_id');

    const beasts = [
        { icon: "🐺", name: "孤狼", multiplier: 0, display: "0倍" },
        { icon: "🦢", name: "仙鹤", multiplier: 0, display: "0倍" },
        { icon: "🐢", name: "玄武", multiplier: 0.5, display: "0.5倍" },
        { icon: "🦅", name: "大鹏", multiplier: 1, display: "1倍" },
        { icon: "🐯", name: "猛虎", multiplier: 2, display: "2倍" },
        { icon: "鹿", name: "麒麟", multiplier: 5, display: "5倍" },
        { icon: "🐲", name: "神龙", multiplier: 20, display: "20倍" },
        { icon: "🔥", name: "凤凰", multiplier: 100, display: "100倍" }
    ];
    const normalProbs = [650, 120, 100, 70, 40, 15, 3, 2];
    const maxCompassionProbs = [300, 100, 180, 150, 120, 90, 40, 20];

    let currentProbs = [...normalProbs];
    let balance = 1000.0, bet = 10.0, rot = 0, busy = false, isAuto = false, speedMode = 1;
    let audioCtx = null, isAudioEnabled = true, currentVolume = 0.7, audioUnlocked = false;

    // ---------- API & 状态 ----------
    if (userId && API_BASE_URL.includes("http")) {
        fetch(`${API_BASE_URL}/api/status?user_id=${userId}`)
            .then(res => res.json())
            .then(data => { if (data.enabled) updateProbs(data.strength); })
            .catch(err => console.log("API Offline"));
    }

    function updateProbs(strength = 0) {
        const t = strength / 100;
        currentProbs = normalProbs.map((p, i) => Math.round(p * (1 - t) + maxCompassionProbs[i] * t));
        let sum = currentProbs.reduce((a,b)=>a+b,0);
        if (sum !== 1000) currentProbs[0] += 1000 - sum;
    }

    // ---------- 音效 ----------
    function initAudio() { if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
    function playEffect(type) {
        if (!isAudioEnabled || !audioCtx) return;
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        gain.connect(audioCtx.destination);
        osc.connect(gain);
        gain.gain.value = currentVolume;
        if (type === 'spin') { osc.frequency.value = 400; osc.start(); osc.stop(audioCtx.currentTime+0.1); }
        else { osc.frequency.value = 800; osc.start(); osc.stop(audioCtx.currentTime+0.1); }
    }

    // ---------- 核心逻辑 ----------
    function buildWheel() {
        const wheel = document.getElementById('ui_wheel');
        const angleStep = 360 / beasts.length;
        beasts.forEach((beast, idx) => {
            const slot = document.createElement('div');
            slot.className = 'slot-content';
            slot.style.transform = `rotate(${idx * angleStep}deg)`;
            slot.innerHTML = `<div class="slot-content-inner" style="transform:rotate(-${idx * angleStep}deg)">
                <span class="beast-ico">${beast.icon}</span><span class="beast-txt">${beast.name}</span>
            </div>`;
            wheel.appendChild(slot);
        });
    }

    function updateUI() {
        document.getElementById('ui_bal').innerText = balance.toFixed(2);
        document.getElementById('ui_bet').innerText = bet.toFixed(1);
    }

    function go() {
        if (busy || balance < bet) { if(balance < bet && isAuto) toggleAuto(); return; }
        busy = true;
        if (!audioUnlocked) { initAudio(); audioUnlocked = true; }

        balance -= bet; // 先扣费
        updateUI();
        playEffect('spin');

        const idx = Math.floor(Math.random() * beasts.length); // 示例随机，实际可用权重逻辑
        const angleStep = 360 / beasts.length;
        const extra = (speedMode === 1 ? 5 : 2) * 360;
        const targetAngle = (360 - (idx * angleStep));
        rot += extra + (targetAngle - (rot % 360) + 360) % 360;

        document.getElementById('ui_wheel').style.transform = `rotate(${rot}deg)`;

        const delay = {1:5000, 2:1200, 3:500}[speedMode];
        setTimeout(() => {
            const win = beasts[idx].multiplier * bet;
            balance += win;
            updateUI();
            document.getElementById('center_val').innerText = beasts[idx].display;
            playEffect('stop');
            busy = false;
            if (isAuto) setTimeout(go, 300);
        }, delay + 50);
    }

    function toggleAuto() {
        isAuto = !isAuto;
        document.getElementById('auto_btn').className = isAuto ? 'mode-btn on' : 'mode-btn';
        document.getElementById('auto_btn').innerText = `🤖 自动模式: ${isAuto ? '开' : '关'}`;
        if (isAuto) go();
    }

    function changeBet(val) { if(!busy) { bet = Math.max(0.5, Math.min(balance, bet + val)); updateUI(); } }

    // ---------- 初始化 ----------
    window.onload = () => {
        buildWheel();
        updateUI();
        document.getElementById('go_btn').onclick = go;
        document.getElementById('auto_btn').onclick = toggleAuto;
        document.getElementById('decBetBtn').onclick = () => changeBet(-1);
        document.getElementById('incBetBtn').onclick = () => changeBet(1);
        document.getElementById('speed_btn').onclick = () => {
            speedMode = (speedMode % 3) + 1;
            const ds = {1:"5s", 2:"1.2s", 3:"0.5s"};
            document.getElementById('ui_wheel').style.transitionDuration = ds[speedMode];
            document.getElementById('speed_btn').innerText = `⚡ 变速: ${speedMode}X`;
        };
        document.getElementById('volumeSlider').oninput = (e) => { currentVolume = e.target.value / 100; };
        document.getElementById('audioToggleBtn').onclick = () => {
            isAudioEnabled = !isAudioEnabled;
            document.getElementById('audioToggleBtn').innerText = isAudioEnabled ? "🔊 音效开" : "🔇 音效关";
        };
    };
</script>
</body>
</html>