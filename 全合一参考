<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>双游戏大厅 | 葫芦鱼+骰宝 | 自动开奖 | 推荐码注册 | 管理员后台</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { background: #1a120c; background-image: radial-gradient(circle at 20% 30%, rgba(200,140,70,0.15) 10%, transparent 5.5%); background-size: 28px 28px; font-family: 'Segoe UI', 'PingFang SC', Roboto, sans-serif; padding: 12px; }
        .app { max-width: 550px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px; }
        .game-nav { background: linear-gradient(145deg, #2a241e 5%, #1f1a15 100%); border-radius: 60px; padding: 6px; display: flex; gap: 8px; border: 1px solid #ffaa44; flex-wrap: wrap; }
        .game-tab { flex: 1; background: transparent; border: none; padding: 8px 0; border-radius: 50px; font-weight: bold; font-size: 0.85rem; color: #ccaa77; cursor: pointer; transition: 0.2s; text-align: center; }
        .game-tab.active { background: #c47c3a; color: #2f1b0a; box-shadow: 0 2px 6px rgba(0,0,0,0.9); }
        .user-section { background: #1f1711; border-radius: 40px; padding: 8px 16px; display: flex; flex-direction: column; gap: 8px; margin-bottom: 8px; }
        .user-info-row { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
        .user-info-row span { color: #ffdd99; font-size: 0.75rem; }
        .btn-group { display: flex; gap: 8px; }
        .logout-btn, .service-btn { background: #734c2e; border: none; padding: 4px 12px; border-radius: 30px; color: #ffe3b3; font-size: 0.7rem; cursor: pointer; }
        .service-btn { background: #2e7d32; }
        .charge-withdraw-row { display: flex; gap: 10px; justify-content: center; }
        .charge-btn, .withdraw-btn { background: #c47c3a; border: none; padding: 5px 20px; border-radius: 30px; color: #2f1b0a; font-weight: bold; font-size: 0.75rem; cursor: pointer; flex: 1; text-align: center; box-shadow: 0 2px 0 #764e26; }
        .withdraw-btn { background: #734c2e; color: #ffe3b3; box-shadow: 0 2px 0 #3f2a1a; }
        .game-container { background: linear-gradient(145deg, #362a1f 0%, #251e16 100%); border-radius: 48px; box-shadow: 0 12px 25px rgba(0,0,0,0.3); overflow: hidden; min-height: 550px; }
        .auth-panel { background: linear-gradient(145deg, #362a1f 0%, #251e16 100%); border-radius: 48px; padding: 30px 20px; text-align: center; border: 2px solid #ffaa44; }
        .auth-panel h2 { color: #ffdd99; font-size: 1.5rem; margin-bottom: 20px; }
        .auth-input { width: 100%; padding: 12px; margin: 10px 0; background: #2a241e; border: 1px solid #ffaa44; border-radius: 40px; color: white; font-size: 0.9rem; text-align: center; }
        .auth-buttons { display: flex; gap: 12px; margin: 20px 0; }
        .auth-btn { flex: 1; background: #c47c3a; border: none; padding: 10px; border-radius: 40px; color: #2f1b0a; font-weight: bold; cursor: pointer; }
        .auth-note { color: #aa8855; font-size: 0.65rem; }
        .chip { background: #ebbc7e; color: #3a240f; font-weight: bold; font-size: 0.7rem; padding: 3px 10px; border-radius: 35px; cursor: pointer; box-shadow: 0 2px 0 #8b5a2e; display: inline-block; }
        .chip.selected { background: #f7c56e; box-shadow: 0 0 0 1px #ffefb0, 0 2px 0 #7a4b22; }
        .bet-card { background: #1f1712; border-radius: 28px; padding: 4px 2px; text-align: center; box-shadow: 0 2px 0 #0a0705; border: 1px solid #6f4f34; cursor: pointer; }
        .bet-name { font-size: 0.65rem; font-weight: bold; color: #ffddb0; }
        .bet-odds { font-size: 0.55rem; color: #dba959; }
        .bet-amount { background: #0c0907; border-radius: 30px; padding: 2px 4px; margin: 4px 3px 0; display: flex; justify-content: space-between; align-items: center; gap: 2px; }
        .btn-chip { background: #523b26; border: none; color: #fce2b4; width: 24px; height: 24px; border-radius: 25px; font-size: 0.8rem; cursor: pointer; }
        .grab-btn { background: #ffaa44; color: #2f1b0a; border: none; padding: 6px 20px; border-radius: 30px; font-weight: bold; cursor: pointer; box-shadow: 0 2px 6px rgba(0,0,0,0.3); }
        .grab-btn:disabled { background: #888; cursor: not-allowed; }
        .online-count-box { background: #2a1f16; margin: 12px 12px 8px; padding: 8px 12px; border-radius: 40px; text-align: center; font-size: 0.8rem; color: #ffdd99; border: 1px solid #ffaa44; display: flex; justify-content: space-between; align-items: center; }
        .online-number { font-size: 1.2rem; font-weight: bold; color: #ffaa44; margin-left: 8px; }
        .dice { width: 60px; height: 60px; position: relative; transform-style: preserve-3d; }
        .dice-face { position: absolute; width: 60px; height: 60px; background: linear-gradient(145deg, #fffff0, #f5f5dc); border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(200,180,120,0.5); }
        .front { transform: translateZ(30px); }
        .back { transform: rotateY(180deg) translateZ(30px); }
        .right { transform: rotateY(90deg) translateZ(30px); }
        .left { transform: rotateY(-90deg) translateZ(30px); }
        .top { transform: rotateX(90deg) translateZ(30px); }
        .bottom { transform: rotateX(-90deg) translateZ(30px); }
        .pip { position: absolute; width: 9px; height: 9px; border-radius: 50%; background: radial-gradient(circle at 35% 35%, #e74c3c, #c0392b); }
        .result-popup { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.6); background: linear-gradient(145deg, #ffcc44, #ff9933); color: #1a1a2a; padding: 24px 40px; border-radius: 80px; font-size: 2rem; font-weight: 900; z-index: 2000; opacity: 0; transition: 0.25s; pointer-events: none; white-space: nowrap; }
        .result-popup.show { opacity: 1; transform: translate(-50%, -50%) scale(1); }
        .result-popup.win { background: linear-gradient(145deg, #ffcc44, #ffaa22); }
        .result-popup.lose { background: linear-gradient(145deg, #555, #333); color: #ffaa66; }
        .toast-message { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #000000cc; color: #ffaa44; padding: 8px 16px; border-radius: 40px; z-index: 2001; animation: fadeInOut 2s forwards; font-size: 0.8rem; }
        @keyframes fadeInOut { 0% { opacity:0; transform: translateX(-50%) translateY(20px); } 15% { opacity:1; transform: translateX(-50%) translateY(0); } 85% { opacity:1; } 100% { opacity:0; transform: translateX(-50%) translateY(-20px); } }
        .modal { position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.95); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 3000; }
        .modal-content { background: #1a2a1a; border-radius: 48px; padding: 24px; border: 2px solid #ffaa44; width: 90%; max-width: 600px; text-align: center; color: #ffdd99; max-height: 80vh; overflow-y: auto; }
        .qr-img { width: 200px; height: 200px; margin: 15px auto; display: block; background: white; border-radius: 20px; padding: 10px; object-fit: contain; box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
        .points-grid, .trio-grid, .special-grid { display: grid; gap: 8px; margin-bottom: 12px; }
        .points-grid { grid-template-columns: repeat(4,1fr); }
        .trio-grid { grid-template-columns: repeat(4,1fr); }
        .special-grid { grid-template-columns: repeat(4,1fr); }
        .countdown-warning { animation: warningPulse 0.5s infinite; color: #ff3300 !important; }
        @keyframes warningPulse { 0%,100% { opacity:1; } 50% { opacity:0.6; } }
        .admin-table { width: 100%; border-collapse: collapse; margin-top: 12px; font-size: 0.7rem; }
        .admin-table th, .admin-table td { padding: 6px; border-bottom: 1px solid #c6a15b; text-align: left; color: #ffefbf; }
        .admin-table th { background: #2a1f16; }
        .fish-wrapper .action-bar { display: flex; justify-content: center; gap: 8px; margin: 0 12px 12px; }
        .fish-wrapper .grab-bar { display: flex; justify-content: center; margin: 8px 12px; }
        .fish-wrapper .bet-icon { font-size: 1.4rem; background: #2f231c; width: 36px; height: 36px; line-height: 36px; margin: 0 auto 3px; border-radius: 50%; }
        .fish-wrapper .bet-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-bottom: 8px; }
        .dice-wrapper .chip.selected-chip { box-shadow: 0 0 0 3px #ffaa44; transform: scale(1.02); }
        @media (max-width: 480px) { .dice { width: 50px; height: 50px; } .dice-face { width: 50px; height: 50px; } .front { transform: translateZ(25px); } .back { transform: rotateY(180deg) translateZ(25px); } .right { transform: rotateY(90deg) translateZ(25px); } .left { transform: rotateY(-90deg) translateZ(25px); } .top { transform: rotateX(90deg) translateZ(25px); } .bottom { transform: rotateX(-90deg) translateZ(25px); } }
        .countdown-timer { font-size: 1.2rem; font-weight: bold; color: #ffaa44; background: #1f1711; display: inline-block; padding: 4px 12px; border-radius: 30px; margin: 8px auto; }
        .phase-badge { background: #2a1f16; padding: 4px 12px; border-radius: 30px; font-size: 0.7rem; }
    </style>
</head>
<body>
<div class="app" id="app"></div>

<script>
// ==================== 全局用户系统 ====================
const USERS_KEY = 'double_games_final_v4';
let usersData = JSON.parse(localStorage.getItem(USERS_KEY)) || {};
let currentUser = null;
let validReferralCodes = JSON.parse(localStorage.getItem('valid_referral_codes')) || ['VIP888', 'ABC123', 'GAME2024', 'TEST001'];
let adminPassword = localStorage.getItem('admin_pwd') || 'admin123';

function saveUsers() { localStorage.setItem(USERS_KEY, JSON.stringify(usersData)); }
function getUserBalance() { return currentUser ? (usersData[currentUser.phone]?.balance || 1000) : 0; }
function setUserBalance(amt) { if(currentUser) { usersData[currentUser.phone].balance = Math.max(0, amt); saveUsers(); } }
function showToast(msg) { let t = document.createElement('div'); t.className = 'toast-message'; t.textContent = msg; document.body.appendChild(t); setTimeout(()=>t.remove(),2000); }
function showServiceModal() { let m = document.createElement('div'); m.className='modal'; m.innerHTML=`<div class="modal-content"><h3>📞 客服</h3><p>微信: game_kf_888</p><button id="closeSvc" style="background:#734c2e; padding:8px 20px; border-radius:40px;">关闭</button></div>`; document.body.appendChild(m); m.querySelector('#closeSvc').onclick = ()=>m.remove(); }

// 充值弹窗 - 带收款码
function showRechargeModal() { 
    let m = document.createElement('div'); 
    m.className='modal'; 
    m.innerHTML=`
        <div class="modal-content">
            <h3>💎 充值</h3>
            <p style="margin:10px 0;">充值比例 <strong style="color:#ffaa44;">1元 = 1000文</strong></p>
            <p>请扫码支付后联系客服上分</p>
            <div style="background:#fff; border-radius:16px; padding:12px; margin:10px auto; display:inline-block;">
                <img class="qr-img" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200'%3E%3Crect width='200' height='200' fill='white'/%3E%3Crect x='30' y='30' width='140' height='140' fill='black'/%3E%3Crect x='40' y='40' width='120' height='120' fill='white'/%3E%3Crect x='50' y='50' width='20' height='20' fill='black'/%3E%3Crect x='80' y='50' width='20' height='20' fill='black'/%3E%3Crect x='110' y='50' width='20' height='20' fill='black'/%3E%3Crect x='50' y='80' width='20' height='20' fill='black'/%3E%3Crect x='80' y='80' width='20' height='20' fill='black'/%3E%3Crect x='110' y='80' width='20' height='20' fill='black'/%3E%3Crect x='50' y='110' width='20' height='20' fill='black'/%3E%3Crect x='80' y='110' width='20' height='20' fill='black'/%3E%3Crect x='110' y='110' width='20' height='20' fill='black'/%3E%3C/svg%3E" alt="收款二维码">
            </div>
            <p style="color:#aaa; font-size:0.7rem;">↑ 模拟收款码（实际请替换为真实二维码）↑</p>
            <p style="margin-top:10px;">📱 客服微信: <strong style="color:#ffaa44;">game_kf_888</strong></p>
            <p style="margin-top:5px;">💰 收款账号: 6222****1234 (财付通)</p>
            <button id="closeRecharge" style="background:#c47c3a; margin-top:15px; padding:8px 20px; border-radius:40px;">关闭</button>
        </div>
    `; 
    document.body.appendChild(m); 
    m.querySelector('#closeRecharge').onclick = ()=>m.remove(); 
}
function recharge() { showRechargeModal(); }
function withdraw() { showToast("提现请联系客服微信: game_kf_888"); }

// 在线人数模拟
let onlineInterval = null;
function startMockOnline() { 
    if(onlineInterval) clearInterval(onlineInterval);
    let count = 48;
    const updateSpan = () => { const span = document.getElementById('onlineCount'); if(span) span.innerText = count; count = count + Math.floor(Math.random() * 5) - 2; if(count<25) count=32; if(count>99) count=87; };
    updateSpan();
    onlineInterval = setInterval(updateSpan, 5000);
}

// ==================== 管理员后台 ====================
let adminClickCount = 0, adminClickTimer = null;
function openAdminModal() {
    let pwdModal = document.createElement('div'); pwdModal.className='modal'; pwdModal.innerHTML=`<div class="modal-content"><h2>🔐 管理员验证</h2><input type="password" id="adminPwdInput" class="auth-input" placeholder="管理密码"><div style="display:flex; gap:12px; margin-top:20px;"><button id="submitPwdBtn" style="background:#c47c3a; padding:8px 20px; border-radius:40px;">确认</button><button id="cancelPwdBtn" style="background:#734c2e; padding:8px 20px; border-radius:40px;">取消</button></div></div>`;
    document.body.appendChild(pwdModal);
    let input = pwdModal.querySelector('#adminPwdInput');
    let submit = () => { if(input.value === adminPassword) { pwdModal.remove(); showAdminPanel(); } else { showToast("密码错误"); input.value = ''; input.focus(); } };
    pwdModal.querySelector('#submitPwdBtn').onclick = submit;
    pwdModal.querySelector('#cancelPwdBtn').onclick = () => pwdModal.remove();
    input.onkeypress = e => { if(e.key === 'Enter') submit(); };
    input.focus();
}
function showAdminPanel() {
    let allUsers = Object.keys(usersData).map(phone => ({ phone, balance: usersData[phone].balance, referralCode: usersData[phone].referralCode || '无', registerTime: usersData[phone].registerTime || '未知' }));
    let searchKeyword = '';
    function renderUserTable() {
        let filtered = searchKeyword ? allUsers.filter(u => u.phone.includes(searchKeyword)) : allUsers;
        let rows = filtered.map(u => `<tr><td style="padding:6px;">${u.phone}</td><td style="padding:6px;">💰 ${u.balance.toFixed(2)}</td><td style="padding:6px;">🎫 ${u.referralCode}</td><td style="padding:6px;">${u.registerTime}</td></tr>`).join('');
        document.querySelector('#adminUserTableBody').innerHTML = rows || '<tr><td colspan="4" style="padding:20px;">暂无数据</td></tr>';
    }
    let modalHtml = `<div class="modal-content" style="max-width:650px;"><h2>🎛️ 管理员后台</h2><div style="display:flex; gap:8px; margin:12px 0;"><input type="text" id="adminSearchInput" class="auth-input" placeholder="搜索手机号" style="flex:2;"><button id="adminSearchBtn" style="background:#2980b9; padding:8px 16px; border-radius:40px;">🔍 搜索</button><button id="adminResetSearchBtn" style="background:#555; padding:8px 16px; border-radius:40px;">重置</button></div><div style="max-height:300px; overflow-y:auto; margin-bottom:12px;"><table style="width:100%; border-collapse:collapse;"><thead style="background:#2a1f16;"><tr><th>手机号</th><th>余额</th><th>推荐码</th><th>注册时间</th></tr></thead><tbody id="adminUserTableBody"></tbody></table></div><div style="display:flex; gap:8px; margin:12px 0;"><select id="adminTargetUser" style="background:#1a1a1a; color:#ffdd99; border-radius:20px; padding:6px; flex:1;">${allUsers.map(u => `<option value="${u.phone}">${u.phone} (${u.balance.toFixed(2)})</option>`).join('')}</select></div><div style="display:flex; gap:8px; flex-wrap:wrap; margin:12px 0;"><input type="number" id="adminAmount" class="auth-input" placeholder="金额" value="0" style="flex:1;"><button id="adminAdd" style="background:#2e7d32; padding:6px 12px; border-radius:30px;">➕ 上分</button><button id="adminSub" style="background:#c0392b; padding:6px 12px; border-radius:30px;">➖ 下分</button><button id="adminReset" style="background:#f39c12; padding:6px 12px; border-radius:30px;">🔄 重置1000</button></div><div style="display:flex; gap:8px; flex-wrap:wrap; margin:12px 0;"><button id="adminQuery" style="background:#2980b9; padding:6px 12px; border-radius:30px;">🔍 查询余额</button><button id="adminExport" style="background:#27ae60; padding:6px 12px; border-radius:30px;">📋 导出用户</button><button id="adminAddCode" style="background:#8e44ad; padding:6px 12px; border-radius:30px;">➕ 新增推荐码</button><button id="adminListCodes" style="background:#16a085; padding:6px 12px; border-radius:30px;">📜 查看推荐码</button><button id="adminChangePwd" style="background:#9b59b6; padding:6px 12px; border-radius:30px;">🔑 改密</button></div><button id="adminClose" style="background:#734c2e; padding:8px; border-radius:40px; width:100%;">关闭后台</button></div>`;
    let modal = document.createElement('div'); modal.className = 'modal'; modal.innerHTML = modalHtml; document.body.appendChild(modal);
    renderUserTable();
    document.querySelector('#adminSearchBtn').onclick = () => { searchKeyword = document.querySelector('#adminSearchInput').value.trim(); renderUserTable(); };
    document.querySelector('#adminResetSearchBtn').onclick = () => { searchKeyword = ''; document.querySelector('#adminSearchInput').value = ''; renderUserTable(); };
    document.querySelector('#adminExport').onclick = () => { let data = allUsers.map(u => `${u.phone},${u.balance},${u.referralCode},${u.registerTime}`).join('\n'); navigator.clipboard.writeText("手机号,余额,推荐码,注册时间\n" + data).then(() => showToast(`已复制 ${allUsers.length} 条用户数据`)).catch(() => showToast("复制失败")); };
    document.querySelector('#adminAddCode').onclick = () => { let newCode = prompt("请输入新的推荐码（大写字母+数字）:"); if(newCode && newCode.trim()) { let code = newCode.trim().toUpperCase(); if(!validReferralCodes.includes(code)) { validReferralCodes.push(code); localStorage.setItem('valid_referral_codes', JSON.stringify(validReferralCodes)); showToast(`推荐码 ${code} 已添加`); } else showToast("推荐码已存在"); } };
    document.querySelector('#adminListCodes').onclick = () => { alert(`当前有效推荐码：\n${validReferralCodes.join(', ')}`); };
    let getUserSelect = () => modal.querySelector('#adminTargetUser').value;
    let getAmount = () => parseInt(modal.querySelector('#adminAmount').value) || 0;
    modal.querySelector('#adminAdd').onclick = () => { let target = getUserSelect(), amt = getAmount(); if(amt <= 0){ showToast("金额必须大于0"); return; } usersData[target].balance += amt; saveUsers(); showToast(`${target} +${amt}，新余额 ${usersData[target].balance.toFixed(2)}`); if(target === currentUser.phone){ currentUser.balance = usersData[target].balance; let balSpan = document.getElementById("userBalanceDisplay"); if(balSpan) balSpan.innerText = currentUser.balance.toFixed(2); } modal.remove(); showAdminPanel(); };
    modal.querySelector('#adminSub').onclick = () => { let target = getUserSelect(), amt = getAmount(); if(amt <= 0){ showToast("金额必须大于0"); return; } if(usersData[target].balance < amt){ showToast("余额不足"); return; } usersData[target].balance -= amt; saveUsers(); showToast(`${target} -${amt}，新余额 ${usersData[target].balance.toFixed(2)}`); if(target === currentUser.phone){ currentUser.balance = usersData[target].balance; let balSpan = document.getElementById("userBalanceDisplay"); if(balSpan) balSpan.innerText = currentUser.balance.toFixed(2); } modal.remove(); showAdminPanel(); };
    modal.querySelector('#adminReset').onclick = () => { if(confirm("重置余额为1000文？")){ let target = getUserSelect(); usersData[target].balance = 1000; saveUsers(); showToast(`${target} 余额已重置为1000文`); if(target === currentUser.phone){ currentUser.balance = 1000; let balSpan = document.getElementById("userBalanceDisplay"); if(balSpan) balSpan.innerText = "1000.00"; } modal.remove(); showAdminPanel(); } };
    modal.querySelector('#adminQuery').onclick = () => { let target = getUserSelect(); showToast(`${target} 余额: ${usersData[target].balance.toFixed(2)}`); };
    modal.querySelector('#adminChangePwd').onclick = () => { let old = prompt("请输入当前管理密码:"); if(old !== adminPassword){ showToast("当前密码错误"); return; } let newPwd = prompt("请输入新密码（至少4位）:"); if(newPwd && newPwd.length >= 4){ adminPassword = newPwd; localStorage.setItem('admin_pwd', newPwd); showToast("管理密码修改成功"); } else if(newPwd){ showToast("密码至少4位"); } };
    modal.querySelector('#adminClose').onclick = () => modal.remove();
}

// ==================== 游戏一：葫芦鱼（完整自动开奖版）====================
function initFishGame(container) {
    container.innerHTML = `<div class="fish-wrapper" style="padding:12px; text-align:center; color:#ffdd99;">加载葫芦鱼游戏中...</div>`;
    
    const patternList = ["鱼","虾","蟹","葫芦","金钱","鸡"];
    const patternMap = { fish:"鱼", shrimp:"虾", crab:"蟹", calabash:"葫芦", coin:"金钱", chicken:"鸡" };
    const PATTERNS = [{ id:"fish", name:"鱼", icon:"🐟" },{ id:"shrimp", name:"虾", icon:"🦐" },{ id:"crab", name:"蟹", icon:"🦀" },{ id:"calabash", name:"葫芦", icon:"🏺" },{ id:"coin", name:"金钱", icon:"💰" },{ id:"chicken", name:"鸡", icon:"🐔" }];
    
    let patternBets = { fish:0, shrimp:0, crab:0, calabash:0, coin:0, chicken:0 };
    let specialBets = { big:0, small:0, doubleBet:0 };
    let currentChip = 100;
    let isRolling = false;
    let autoTimer = null;
    let countdownInterval = null;
    let remainingSeconds = 25;
    let roundActive = true;
    let currentRoom = "room1";
    let hasGrabbed = false;
    let playerBankerBalance = 0;
    const MAX_SINGLE = 500, MAX_TOTAL = 2000;
    
    function getTotalBet() { return Object.values(patternBets).reduce((a,b)=>a+b,0) + Object.values(specialBets).reduce((a,b)=>a+b,0); }
    
    function updateUI() {
        for(let k in patternBets) { let el = document.getElementById(`bet_${k}`); if(el) el.innerText = patternBets[k]; }
        for(let k in specialBets) { let el = document.getElementById(`bet_special_${k}`); if(el) el.innerText = specialBets[k]; }
        let totalEl = document.getElementById('totalBetValue');
        if(totalEl) totalEl.innerText = getTotalBet();
        let balSpan = document.getElementById("userBalanceDisplay");
        if(balSpan) balSpan.innerText = getUserBalance().toFixed(2);
        let phaseHint = document.getElementById('fishPhaseHint');
        if(phaseHint && roundActive && !isRolling) phaseHint.innerHTML = `🎲 下注中 · 倒计时 ${remainingSeconds}秒`;
    }
    
    function modifyBalance(delta) { let nb = getUserBalance() + delta; setUserBalance(nb); updateUI(); }
    
    function addBetPattern(id,val) {
        if(hasGrabbed) { showToast("庄家不能下注"); return; }
        let total = getTotalBet();
        if(val > MAX_SINGLE) { showToast(`单注上限${MAX_SINGLE}文`); return; }
        if(total + val > MAX_TOTAL) { showToast(`总注上限${MAX_TOTAL}文`); return; }
        if(val > getUserBalance()) { showToast("余额不足"); return; }
        patternBets[id] += val; modifyBalance(-val); updateUI();
    }
    
    function subBetPattern(id,val) { let cur = patternBets[id]; if(cur < val) val = cur; if(val === 0) return; patternBets[id] -= val; modifyBalance(val); updateUI(); }
    
    function addBetSpecial(type,val) {
        if(hasGrabbed) { showToast("庄家不能下注"); return; }
        let total = getTotalBet();
        if(val > MAX_SINGLE) return;
        if(total + val > MAX_TOTAL) return;
        if(val > getUserBalance()) return;
        specialBets[type] += val; modifyBalance(-val); updateUI();
    }
    
    function clearAllBets() { 
        for(let k in patternBets) patternBets[k]=0; 
        for(let k in specialBets) specialBets[k]=0; 
        updateUI(); 
        showToast("已清空下注");
    }
    
    async function settleGame(diceNames) {
        let totalBet = getTotalBet();
        if(totalBet === 0) return false;
        if(totalBet > getUserBalance()) { showToast("余额异常"); return false; }
        
        // 扣除下注金额
        modifyBalance(-totalBet);
        
        let winAmount = 0;
        // 六门赔付
        for(let [pid, val] of Object.entries(patternBets)) {
            if(val === 0) continue;
            let occur = diceNames.filter(n => n === patternMap[pid]).length;
            if(occur > 0) winAmount += val * (occur + 1);
        }
        
        // 计算总和
        let sum = diceNames.map(n => ["鱼","虾","蟹","葫芦","金钱","鸡"].indexOf(n) + 1).reduce((a,b)=>a+b, 0);
        let isTriplet = diceNames[0] === diceNames[1] && diceNames[1] === diceNames[2];
        
        // 大小赔付
        if(!isTriplet) {
            if(sum >= 11 && specialBets.big) winAmount += specialBets.big * 2;
            if(sum <= 10 && specialBets.small) winAmount += specialBets.small * 2;
        }
        
        // 双押赔付（鱼和虾同时出现）
        if(diceNames.includes("鱼") && diceNames.includes("虾") && specialBets.doubleBet) {
            winAmount += specialBets.doubleBet * 4.5;
        }
        
        if(winAmount > 0) modifyBalance(winAmount);
        
        // 庄家逻辑
        if(hasGrabbed) {
            playerBankerBalance -= winAmount;
            if(playerBankerBalance < 0) {
                hasGrabbed = false;
                playerBankerBalance = 0;
                localStorage.setItem(`fish_player_banker_${currentRoom}`, 0);
                let grabBtn = document.getElementById('grabBtn');
                if(grabBtn) { grabBtn.disabled = false; grabBtn.textContent = "🎲 抢庄 (需2001文)"; }
                showToast("庄家破产，权限回收");
            } else {
                localStorage.setItem(`fish_player_banker_${currentRoom}`, playerBankerBalance);
            }
            let balanceEl = document.getElementById('fishBalanceValue');
            if(balanceEl) balanceEl.innerText = hasGrabbed ? playerBankerBalance.toFixed(2) : "∞";
        }
        
        // 显示结果弹窗
        let pop = document.createElement('div');
        pop.className = `result-popup ${winAmount > 0 ? 'win' : 'lose'}`;
        pop.textContent = winAmount > 0 ? `🎉 赢 ${winAmount} 🎉` : `😭 输 ${totalBet} 😭`;
        document.body.appendChild(pop);
        setTimeout(() => pop.classList.add('show'), 10);
        setTimeout(() => { pop.classList.remove('show'); setTimeout(() => pop.remove(), 300); }, 2000);
        
        // 清空下注
        clearAllBets();
        return true;
    }
    
    async function rollDice() {
        if(isRolling) return;
        if(getTotalBet() === 0) { 
            showToast("请先下注");
            // 如果没有下注，重启倒计时
            if(roundActive) startAutoTimer();
            return; 
        }
        
        isRolling = true;
        let phaseHint = document.getElementById('fishPhaseHint');
        if(phaseHint) phaseHint.innerHTML = "🎲 开奖中 · 摇骰子 🎲";
        
        // 随机开奖结果
        let finalResult = [
            patternList[Math.floor(Math.random() * 6)],
            patternList[Math.floor(Math.random() * 6)],
            patternList[Math.floor(Math.random() * 6)]
        ];
        
        // 动画效果
        const diceDivs = document.querySelectorAll('.fish-dice-item');
        const iconMap = { "鱼":"🐟", "虾":"🦐", "蟹":"🦀", "葫芦":"🏺", "金钱":"💰", "鸡":"🐔" };
        
        for(let step = 0; step < 12; step++) {
            await new Promise(r => setTimeout(r, 80));
            for(let i = 0; i < 3; i++) {
                let rand = patternList[Math.floor(Math.random() * 6)];
                diceDivs[i].innerHTML = iconMap[rand];
            }
        }
        
        for(let i = 0; i < 3; i++) {
            diceDivs[i].innerHTML = iconMap[finalResult[i]];
        }
        
        await settleGame(finalResult);
        
        isRolling = false;
        
        // 开奖完成后重启倒计时
        if(roundActive) startAutoTimer();
    }
    
    function startAutoTimer() {
        if(autoTimer) clearTimeout(autoTimer);
        if(countdownInterval) clearInterval(countdownInterval);
        
        remainingSeconds = 25;
        let phaseHint = document.getElementById('fishPhaseHint');
        if(phaseHint) phaseHint.innerHTML = `🎲 下注阶段 · 倒计时 ${remainingSeconds} 秒`;
        
        countdownInterval = setInterval(() => {
            if(!roundActive) { clearInterval(countdownInterval); return; }
            if(!isRolling) {
                remainingSeconds--;
                if(phaseHint) phaseHint.innerHTML = `🎲 下注阶段 · 倒计时 ${remainingSeconds} 秒`;
                if(remainingSeconds <= 0) {
                    clearInterval(countdownInterval);
                    if(roundActive && !isRolling) {
                        rollDice();
                    }
                }
            }
        }, 1000);
        
        autoTimer = setTimeout(() => {
            if(roundActive && !isRolling && getTotalBet() > 0) {
                rollDice();
            } else if(roundActive && !isRolling && getTotalBet() === 0) {
                // 无人下注，重置倒计时
                if(countdownInterval) clearInterval(countdownInterval);
                startAutoTimer();
            }
        }, 25000);
    }
    
