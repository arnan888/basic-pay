<body>
<div class="app" id="app"></div>
<script>
    // =====================================================================
    // 全局用户系统模块
    // 功能：用户注册/登录、余额管理、本地存储、公共提示函数
    // =====================================================================
    
    // 存储键名
    const USERS_KEY = 'double_games_final_v10';
    let usersData = JSON.parse(localStorage.getItem(USERS_KEY)) || {};
    let currentUser = null;
    
    // 保存用户数据到 localStorage
    function saveUsers() {
        localStorage.setItem(USERS_KEY, JSON.stringify(usersData));
    }
    
    // 获取当前登录用户的余额
    function getUserBalance() {
        if (!currentUser) return 0;
        return usersData[currentUser.phone]?.balance || 1000;
    }
    
    // 设置当前用户余额（自动保存）
    function setUserBalance(amount) {
        if (currentUser) {
            usersData[currentUser.phone].balance = Math.max(0, amount);
            saveUsers();
        }
    }
    
    // 全局提示消息
    function showToast(message) {
        let toast = document.createElement('div');
        toast.className = 'toast-message';
        toast.textContent = message;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
    }
    
    // 充值弹窗
    function showRechargeModal() {
        let modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `
            <div class="modal-content">
                <h3>💎 充值</h3>
                <p style="margin:15px 0">充值比例 1元 = 1000文</p>
                <p>请联系客服微信: <strong>game_kf_888</strong></p>
                <button id="closeRecharge" style="background:#734c2e; padding:8px 20px; border-radius:40px; margin-top:16px;">关闭</button>
            </div>
        `;
        document.body.appendChild(modal);
        modal.querySelector('#closeRecharge').onclick = () => modal.remove();
    }
    
    // 客服弹窗
    function showServiceModal() {
        let modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `
            <div class="modal-content">
                <h3>📞 客服</h3>
                <p style="margin:15px 0">微信: game_kf_888</p>
                <p>电话: 400-888-XXXX</p>
                <button id="closeSvc" style="background:#734c2e; padding:8px 20px; border-radius:40px; margin-top:16px;">关闭</button>
            </div>
        `;
        document.body.appendChild(modal);
        modal.querySelector('#closeSvc').onclick = () => modal.remove();
    }
    
    function recharge() { showRechargeModal(); }
    function withdraw() { showToast("提现请联系客服"); }
    
    // =====================================================================
    // 游戏1：潮汕葫芦鱼（全自动循环、六图押注、抢庄、50条记录）
    // =====================================================================
    let fishDestroy = null;
    
    function initFishGame(container) {
        // 清理之前的实例，防止内存泄漏
        if (fishDestroy) {
            fishDestroy();
            fishDestroy = null;
        }
        container.innerHTML = '';
        
        // 六门押注图片配置（请根据实际图片文件名修改）
        const patternImages = [
            { id: "fish", name: "鱼", img: "1776322917299(2).png" },
            { id: "shrimp", name: "虾", img: "1776322917299(4).png" },
            { id: "crab", name: "蟹", img: "1776322917299(6).png" },
            { id: "calabash", name: "葫芦", img: "1776322917299(1).png" },
            { id: "coin", name: "金钱", img: "1776322917299(5).png" },
            { id: "chicken", name: "鸡", img: "1776322917299(4).png" }
        ];
        
        // 构建HTML结构
        const fishHTML = `
            <div class="fish-wrapper">
                <!-- 统计面板 -->
                <div style="display:flex; gap:6px; padding:8px; background:#1f1711; border-radius:20px; margin-bottom:8px;">
                    <div style="flex:1; background:#1a130d; border-radius:30px; padding:4px; text-align:center;">
                        <div style="font-size:0.65rem;">💰 庄家余额</div>
                        <div id="fishBalanceValue" style="font-weight:bold; font-size:1rem;">∞</div>
                    </div>
                    <div style="flex:1; background:#1a130d; border-radius:30px; padding:4px; text-align:center;">
                        <div style="font-size:0.65rem;">🎲 总押注</div>
                        <div id="totalBetValue" style="font-weight:bold;">0</div>
                    </div>
                    <div style="flex:1; background:#1a130d; border-radius:30px; padding:4px; text-align:center;">
                        <div style="font-size:0.65rem;">🏆 上局净利</div>
                        <div id="lastWinValue" style="font-weight:bold;">0</div>
                    </div>
                </div>
                <!-- 抢庄按钮和房间选择 -->
                <div style="display:flex; justify-content:center; gap:12px; margin:8px; flex-wrap:wrap;">
                    <button id="grabBtn" class="grab-btn">🎲 抢庄 (需2001文)</button>
                    <select id="roomSelect" style="background:#2a1f16; color:#ffdd99; border-radius:20px; padding:4px 8px;">
                        <option value="room1">初级房</option>
                        <option value="room2">中级房</option>
                        <option value="room3">高级房</option>
                    </select>
                </div>
                <!-- 骰子区域 -->
                <div class="dice-area" style="background:#2a211a; margin:12px; border-radius:50px; padding:12px; position:relative;">
                    <div style="display:flex; justify-content:center; gap:12px;">
                        <div class="dice" style="background:#fff2df; width:70px;height:70px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:2.8rem;">🎲</div>
                        <div class="dice" style="background:#fff2df; width:70px;height:70px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:2.8rem;">🎲</div>
                        <div class="dice" style="background:#fff2df; width:70px;height:70px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:2.8rem;">🎲</div>
                    </div>
                    <div id="fishDiceCover" style="position:absolute; top:0; left:0; width:100%; height:100%; background:radial-gradient(circle, rgba(0,0,0,0.9), #2c1e14); backdrop-filter:blur(6px); border-radius:50px; display:flex; align-items:center; justify-content:center; flex-direction:column;">
                        <span style="font-size:3rem;">🏺</span>
                        <div style="background:#00000099; padding:2px 12px; border-radius:30px; font-size:0.7rem;">骰盅未开</div>
                    </div>
                </div>
                <!-- 筹码栏 -->
                <div class="chip-bar" style="display:flex; justify-content:center; gap:8px; margin:8px; flex-wrap:wrap;">
                    <div class="chip" data-chip="20">20</div>
                    <div class="chip" data-chip="50">50</div>
                    <div class="chip selected" data-chip="100">100</div>
                    <div class="chip" data-chip="500">500</div>
                    <div class="chip" data-chip="1000" id="adminTriggerChip">1k</div>
                </div>
                <!-- 操作按钮 -->
                <div style="display:flex; justify-content:center; gap:12px; margin:8px;">
                    <button id="fishResetBetBtn" style="background:#734c2e; padding:6px 16px; border-radius:35px;">清空下注</button>
                    <button id="fishResetGameBtn" style="background:#734c2e; padding:6px 16px; border-radius:35px;">重置庄家</button>
                </div>
                <!-- 押注区域 -->
                <div style="padding:0 12px;">
                    <div style="font-size:0.8rem; color:#ffd49f; margin:8px 0 4px;">🐟 六门押注</div>
                    <div id="patternGrid"></div>
                    <div style="font-size:0.8rem; color:#ffd49f; margin:12px 0 4px;">🎯 特殊投注</div>
                    <div id="specialGrid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:8px;"></div>
                </div>
                <!-- 记录和规则 -->
                <div style="margin:12px;">
                    <button id="showRecordBtn" style="width:100%; background:#2a1f16; border:1px solid #ffaa44; border-radius:40px; padding:8px;">📜 开奖记录查询</button>
                </div>
                <div class="online-count-box" style="margin:8px;">
                    <div>🎮 在线人数 <span id="onlineCount">128</span></div>
                    <button id="showRulesBtn" style="background:#ffaa44; border-radius:30px; padding:4px 12px;">赔付规则</button>
                </div>
                <div id="fishPhaseHint" style="text-align:center; background:#00000088; margin:8px; border-radius:30px; padding:6px; font-size:0.7rem;">⏳ 等待开局...</div>
            </div>
        `;
        container.innerHTML = fishHTML;
        
        // ========== 游戏状态变量 ==========
        let patternBets = { fish:0, shrimp:0, crab:0, calabash:0, coin:0, chicken:0 };
        let specialBets = { big:0, small:0, odd:0, even:0, allTriplets:0, doubleBet:0 };
        let currentChip = 100;
        let lastWinAmount = 0;
        let hasGrabbed = false;
        let playerBankerBalance = 0;
        let currentRoom = "room1";
        
        // 房间存储键
        function getBankerKey() { return `fish_banker_${currentRoom}`; }
        function getPlayerBankerKey() { return `fish_player_banker_${currentRoom}`; }
        
        // 加载庄家数据
        let savedPlayer = parseInt(localStorage.getItem(getPlayerBankerKey())) || 0;
        if (savedPlayer > 0) {
            hasGrabbed = true;
            playerBankerBalance = savedPlayer;
        }
        
        const MAX_SINGLE_BET = 500;
        const MAX_TOTAL_BET = 2000;
        
        // 计算总押注额
        function getTotalBet() {
            let patternTotal = Object.values(patternBets).reduce((a,b)=>a+b,0);
            let specialTotal = Object.values(specialBets).reduce((a,b)=>a+b,0);
            return patternTotal + specialTotal;
        }
        
        // 更新UI
        function updateUI() {
            let balanceSpan = document.getElementById('fishBalanceValue');
            if (balanceSpan) balanceSpan.innerText = hasGrabbed ? playerBankerBalance.toFixed(2) : "∞";
            let totalSpan = document.getElementById('totalBetValue');
            if (totalSpan) totalSpan.innerText = getTotalBet();
            let lastSpan = document.getElementById('lastWinValue');
            if (lastSpan) lastSpan.innerText = lastWinAmount;
            for (let k in patternBets) {
                let el = document.getElementById(`bet_${k}`);
                if (el) el.innerText = patternBets[k];
            }
            for (let k in specialBets) {
                let el = document.getElementById(`bet_special_${k}`);
                if (el) el.innerText = specialBets[k];
            }
        }
        
        // 增加下注
        function addBet(type, id, val) {
            let target = (type === 'pattern') ? patternBets : specialBets;
            if (target[id] === undefined) return;
            let total = getTotalBet();
            if (val > MAX_SINGLE_BET) {
                showToast(`单注上限${MAX_SINGLE_BET}文`);
                return;
            }
            if (total + val > MAX_TOTAL_BET) {
                showToast(`本局总下注不能超过${MAX_TOTAL_BET}文`);
                return;
            }
            if (total + val > getUserBalance()) {
                showToast("余额不足");
                return;
            }
            target[id] += val;
            updateUI();
        }
        
        // 减少下注
        function subBet(type, id, val) {
            let target = (type === 'pattern') ? patternBets : specialBets;
            target[id] = Math.max(0, target[id] - val);
            updateUI();
        }
        
        // 清空所有下注
        function clearBets() {
            for (let k in patternBets) patternBets[k] = 0;
            for (let k in specialBets) specialBets[k] = 0;
            updateUI();
        }
        
        // 开奖记录（最多50条）
        let gameRecords = [];
        function addRecord(dice, winAmount, totalBet) {
            gameRecords.unshift({
                time: new Date().toLocaleTimeString(),
                dice: dice.join(','),
                result: winAmount > 0 ? `赢${winAmount}` : `输${totalBet}`,
                win: winAmount
            });
            if (gameRecords.length > 50) gameRecords.pop();
        }
        
        // 核心开奖与动画函数（5秒动画+结算）
        async function settleAndAnimate(final) {
            const diceEls = document.querySelectorAll('.fish-wrapper .dice');
            const cover = document.getElementById('fishDiceCover');
            // 打开骰盅动画
            if (cover) {
                cover.style.transform = "translateY(-70px) scale(0.6)";
                cover.style.opacity = "0";
                await new Promise(r => setTimeout(r, 400));
                cover.style.display = "none";
            }
            const iconMap = {"鱼":"🐟","虾":"🦐","蟹":"🦀","葫芦":"🏺","金钱":"💰","鸡":"🐔"};
            // 5秒滚动动画（30步，每步约166ms）
            for (let i = 0; i < 30; i++) {
                await new Promise(r => setTimeout(r, 166));
                for (let d = 0; d < 3; d++) {
                    let rand = ["鱼","虾","蟹","葫芦","金钱","鸡"][Math.floor(Math.random()*6)];
                    diceEls[d].innerHTML = iconMap[rand];
                }
            }
            // 显示最终结果
            for (let i = 0; i < 3; i++) diceEls[i].innerHTML = iconMap[final[i]];
            
            // 计算点数
            let points = final.map(n => {
                let m = {"鱼":1,"虾":2,"蟹":3,"葫芦":4,"金钱":5,"鸡":6};
                return m[n];
            });
            let sum = points.reduce((a,b)=>a+b,0);
            let isTriplet = (final[0] === final[1] && final[1] === final[2]);
            let totalBet = getTotalBet();
            let winAmount = 0;
            
            // 只有下注时才计算赔付和扣款
            if (totalBet > 0) {
                let userBal = getUserBalance();
                if (totalBet <= userBal) setUserBalance(userBal - totalBet);
                const pidMap = { fish:"鱼", shrimp:"虾", crab:"蟹", calabash:"葫芦", coin:"金钱", chicken:"鸡" };
                // 六门赔付
                for (let [pid, val] of Object.entries(patternBets)) {
                    if (val === 0) continue;
                    let occur = final.filter(n => n === pidMap[pid]).length;
                    if (occur > 0) winAmount += val * (occur + 1);
                }
                // 特殊投注
                if (!isTriplet) {
                    if (sum >= 11 && sum <= 17 && specialBets.big) winAmount += specialBets.big * 2;
                    if (sum >= 4 && sum <= 10 && specialBets.small) winAmount += specialBets.small * 2;
                    if (sum % 2 === 1 && specialBets.odd) winAmount += specialBets.odd * 2;
                    if (sum % 2 === 0 && specialBets.even) winAmount += specialBets.even * 2;
                }
                if (isTriplet && specialBets.allTriplets) winAmount += specialBets.allTriplets * 24;
                if (final.includes("鱼") && final.includes("虾") && specialBets.doubleBet) winAmount += specialBets.doubleBet * 4.5;
                
                setUserBalance(getUserBalance() + winAmount);
                // 庄家赔付（如果抢庄）
                if (hasGrabbed) {
                    playerBankerBalance -= winAmount;
                    if (playerBankerBalance < 0) {
                        hasGrabbed = false;
                        playerBankerBalance = 0;
                        localStorage.setItem(getPlayerBankerKey(), 0);
                        updateGrabButton();
                        showToast("庄家破产，权限回收");
                    } else {
                        localStorage.setItem(getPlayerBankerKey(), playerBankerBalance);
                    }
                }
                lastWinAmount = winAmount - totalBet;
                let balanceDisplay = document.getElementById("userBalanceDisplay");
                if (balanceDisplay) balanceDisplay.innerText = getUserBalance().toFixed(2);
            } else {
                lastWinAmount = 0;
            }
            
            // 记录开奖（无论是否下注）
            addRecord(final, winAmount, totalBet);
            clearBets();
            updateUI();
            
            // 重新盖上骰盅
            if (cover) {
                cover.style.display = "flex";
                cover.style.transform = "translateY(0) scale(1)";
                cover.style.opacity = "1";
            }
        }
        
        // 构建六门押注网格（带图片）
        const patternContainer = document.getElementById('patternGrid');
        if (patternContainer) {
            patternContainer.innerHTML = '';
            patternImages.forEach(p => {
                let card = document.createElement('div');
                card.className = 'bet-card';
                card.innerHTML = `
                    <img src="${p.img}" class="fish-pattern-img" onerror="this.src='data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%3E%3Crect%20width%3D%2260%22%20height%3D%2260%22%20fill%3D%22%23c47c3a%22%2F%3E%3Ctext%20x%3D%2250%25%22%20y%3D%2250%25%22%20dominant-baseline%3D%22middle%22%20text-anchor%3D%22middle%22%20fill%3D%22white%22%20font-size%3D%2220%22%3E${p.name}%3C%2Ftext%3E%3C%2Fsvg%3E'">
                    <div class="bet-name">${p.name}</div>
                    <div class="bet-amount">
                        <button class="btn-chip sub-pattern" data-id="${p.id}">-</button>
                        <span id="bet_${p.id}">0</span>
                        <button class="btn-chip add-pattern" data-id="${p.id}">+</button>
                    </div>
                `;
                patternContainer.appendChild(card);
            });
        }
        
        // 构建特殊投注网格
        const specialContainer = document.getElementById('specialGrid');
        if (specialContainer) {
            specialContainer.innerHTML = `
                <div class="bet-card" data-type="big">大<div id="bet_special_big">0</div></div>
                <div class="bet-card" data-type="doubleBet">👑双押<div id="bet_special_doubleBet">0</div></div>
                <div class="bet-card" data-type="small">小<div id="bet_special_small">0</div></div>
                <div class="bet-card" data-type="odd">单<div id="bet_special_odd">0</div></div>
                <div class="bet-card" data-type="allTriplets">🔥全围<div id="bet_special_allTriplets">0</div></div>
                <div class="bet-card" data-type="even">双<div id="bet_special_even">0</div></div>
            `;
            specialContainer.querySelectorAll('.bet-card').forEach(card => {
                let type = card.getAttribute('data-type');
                card.onclick = () => addBet('special', type, currentChip);
            });
        }
        
        // 事件绑定：六门加减按钮
        document.querySelector('.fish-wrapper .bet-grid')?.addEventListener('click', e => {
            let btn = e.target.closest('.btn-chip');
            if (!btn) return;
            let id = btn.dataset.id;
            if (btn.classList.contains('add-pattern')) addBet('pattern', id, currentChip);
            if (btn.classList.contains('sub-pattern')) subBet('pattern', id, currentChip);
        });
        
        // 筹码选择
        document.querySelectorAll('.chip').forEach(chip => {
            chip.onclick = () => {
                currentChip = parseInt(chip.dataset.chip);
                document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
                chip.classList.add('selected');
            };
        });
        
        // 清空下注按钮
        document.getElementById('fishResetBetBtn').onclick = clearBets;
        // 重置庄家按钮（重置骰盅和下注）
        document.getElementById('fishResetGameBtn').onclick = () => {
            clearBets();
            lastWinAmount = 0;
            updateUI();
            document.querySelectorAll('.fish-wrapper .dice').forEach(d => d.innerHTML = '🎲');
            let cv = document.getElementById('fishDiceCover');
            if (cv) cv.style.display = 'flex';
        };
        
        // 更新抢庄按钮状态
        function updateGrabButton() {
            let btn = document.getElementById('grabBtn');
            let bal = getUserBalance();
            if (hasGrabbed) {
                btn.disabled = true;
                btn.textContent = '🏆 已抢庄';
            } else if (bal >= 2001) {
                btn.disabled = false;
                btn.textContent = '🎲 抢庄 (需2001文)';
            } else {
                btn.disabled = true;
                btn.textContent = '🎲 抢庄 (余额不足)';
            }
        }
        
        // 抢庄逻辑
        document.getElementById('grabBtn').onclick = () => {
            if (hasGrabbed) return;
            if (getUserBalance() >= 2001) {
                setUserBalance(getUserBalance() - 2001);
                playerBankerBalance = 2001;
                hasGrabbed = true;
                localStorage.setItem(getPlayerBankerKey(), playerBankerBalance);
                updateUI();
                updateGrabButton();
                let balSpan = document.getElementById("userBalanceDisplay");
                if (balSpan) balSpan.innerText = getUserBalance().toFixed(2);
                showToast("抢庄成功");
            } else {
                showToast("余额不足2001");
            }
        };
        
        // 房间切换
        document.getElementById('roomSelect').addEventListener('change', (e) => {
            currentRoom = e.target.value;
            let saved = parseInt(localStorage.getItem(getPlayerBankerKey())) || 0;
            hasGrabbed = saved > 0;
            playerBankerBalance = saved;
            clearBets();
            updateUI();
            updateGrabButton();
        });
        
        // 开奖记录查询
        document.getElementById('showRecordBtn').onclick = () => {
            if (gameRecords.length === 0) {
                showToast("暂无记录");
                return;
            }
            let html = '<div style="max-height:400px; overflow-y:auto;">';
            gameRecords.forEach(r => {
                html += `<div style="background:#2a241e; margin:8px; padding:8px; border-left:3px solid #ffaa44;">
                            <div style="font-size:0.7rem; color:#ffaa66;">${r.time}</div>
