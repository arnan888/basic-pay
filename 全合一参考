        modal.querySelector('#adminSub').onclick = () => {
            let target = getUserSelect();
            let amt = getAmount();
            if (amt <= 0) { showToast("金额必须大于0"); return; }
            let cur = usersData[target].balance;
            if (cur < amt) { showToast(`${target} 余额不足，无法下分`); return; }
            usersData[target].balance = cur - amt;
            saveUsers();
            showToast(`${target} -${amt}，新余额 ${usersData[target].balance.toFixed(2)}`);
            if (target === currentUser.phone) {
                currentUser.balance = usersData[target].balance;
                let balSpan = document.getElementById("userBalanceDisplay");
                if (balSpan) balSpan.innerText = currentUser.balance.toFixed(2);
            }
            modal.remove();
            showAdminPanel();
        };

        modal.querySelector('#adminQuery').onclick = () => {
            let target = getUserSelect();
            showToast(`${target} 余额: ${usersData[target].balance.toFixed(2)}`);
        };

        modal.querySelector('#adminReset').onclick = () => {
            let target = getUserSelect();
