// ==================== 游戏二：至尊骰宝 ====================
function initDiceGame(container) {
    container.innerHTML = `<div class="dice-wrapper" style="padding:20px; text-align:center;">加载骰宝...</div>`;
    
    const oddsMap = {4:60,5:30,6:18,7:12,8:8,9:7,10:6,11:6,12:7,13:8,14:12,15:18,16:30,17:60};
    let bets = {'BIG':0,'SMALL':0,'ODD':0,'EVEN':0,4:0,5:0,6:0,7:0,8:0,9:0,10:0,11:0,12:0,13:0,14:0,15:0,16:0,17:0,'TRIPLE_1':0,'TRIPLE_2':0,'TRIPLE_3':0,'TRIPLE_4':0,'TRIPLE_5':0,'TRIPLE_6':0,'ALL_TRIPLE':0};
    let selectedChip = 100;
    let isDrawing = false, isBetLocked = false;
    let countdownInterval = null;
    let roundActive = true;
    
    function updateUI() { 
        for(let k in bets){ let el=container.querySelector(`#bet_${k}`); if(el) el.innerText=bets[k]; } 
        let total=Object.values(bets).reduce((a,b)=>a+b,0); 
        if(container.querySelector('#totalBet')) container.querySelector('#totalBet').innerText=total;
        let balSpan = document.getElementById("userBalanceDisplay");
        if(balSpan) balSpan.innerText = getUserBalance().toFixed(2);
    }
    
    function modifyBalance(delta){ let nb=getUserBalance()+delta; setUserBalance(nb); updateUI(); }
    
    function addBet(type){ 
        if(isBetLocked){ showToast("开奖中，请等待"); return; } 
        if(selectedChip<=0) return; 
        if(selectedChip>getUserBalance()){ showToast("余额不足"); return; } 
        modifyBalance(-selectedChip); 
        bets[type]+=selectedChip; 
        updateUI(); 
    }
    
    function clearAllBets(){ 
        let total=Object.values(bets).reduce((a,b)=>a+b,0); 
        modifyBalance(total); 
        for(let k in bets) bets[k]=0; 
        updateUI(); 
        showToast("已清空下注");
    }
    
    async function startDraw(){
        if(isDrawing) return;
        let totalBet=Object.values(bets).reduce((a,b)=>a+b,0);
        if(totalBet===0){ showToast("请先下注"); startCountdown(20); return; }
        if(totalBet>getUserBalance()){ showToast("余额不足，无法开奖"); startCountdown(20); return; }
        
        isDrawing=true; 
        isBetLocked=true;
        let cdSpan = container.querySelector('#countdownNum');
        if(cdSpan) cdSpan.innerText = "开奖中";
        
        let d1=Math.floor(Math.random()*6)+1, d2=Math.floor(Math.random()*6)+1, d3=Math.floor(Math.random()*6)+1;
        let total=d1+d2+d3;
        let types=[];
        if(total>=11 && total<=17) types.push('BIG');
        if(total>=4 && total<=10) types.push('SMALL');
        if(total%2===1) types.push('ODD');
        if(total%2===0) types.push('EVEN');
        if(d1===d2 && d2===d3){ types.push(`TRIPLE_${d1}`); types.push('ALL_TRIPLE'); }
        
        let winAmount=0;
        if(types.includes('BIG') && bets['BIG']) winAmount+=bets['BIG']*2;
        if(types.includes('SMALL') && bets['SMALL']) winAmount+=bets['SMALL']*2;
        if(types.includes('ODD') && bets['ODD']) winAmount+=bets['ODD']*2;
        if(types.includes('EVEN') && bets['EVEN']) winAmount+=bets['EVEN']*2;
        if(bets[total]) winAmount+=bets[total]*oddsMap[total];
        if(types.includes('ALL_TRIPLE') && bets['ALL_TRIPLE']) winAmount+=bets['ALL_TRIPLE']*30;
        for(let i=1;i<=6;i++){ if(types.includes(`TRIPLE_${i}`) && bets[`TRIPLE_${i}`]) winAmount+=bets[`TRIPLE_${i}`]*150; }
        
        if(winAmount>0) modifyBalance(winAmount);
        
        // 显示结果
        let pop=document.createElement('div'); 
        pop.className=`result-popup ${winAmount>0?'win':'lose'}`; 
        pop.textContent=winAmount>0?`🎉 赢 ${winAmount} 🎉`:`😭 输 ${totalBet} 😭`; 
        document.body.appendChild(pop); 
        setTimeout(()=>pop.classList.add('show'),10); 
        setTimeout(()=>{ pop.classList.remove('show'); setTimeout(()=>pop.remove(),300); },2000);
        
        // 更新骰子显示
        const diceEl = [container.querySelector('#dice1'), container.querySelector('#dice2'), container.querySelector('#dice3')];
        const rotMap = {1:'rotateX(0deg) rotateY(0deg)',2:'rotateX(-90deg) rotateY(0deg)',3:'rotateX(0deg) rotateY(90deg)',4:'rotateX(0deg) rotateY(-90deg)',5:'rotateX(90deg) rotateY(0deg)',6:'rotateX(180deg) rotateY(0deg)'};
        diceEl.forEach((d,i) => { if(d) d.style.transform = rotMap[[d1,d2,d3][i]]; });
        let totalEl = container.querySelector('#totalPoints');
        if(totalEl) totalEl.innerText = total;
        
        clearAllBets();
        isDrawing=false; 
        isBetLocked=false;
        if(roundActive) startCountdown(20);
    }
    
    function startCountdown(sec){
        if(countdownInterval) clearInterval(countdownInterval);
        let c=sec;
        let cdSpan=container.querySelector('#countdownNum');
        if(cdSpan) cdSpan.innerText=c;
        isBetLocked=false;
        countdownInterval=setInterval(()=>{ 
            if(!roundActive){clearInterval(countdownInterval); return;} 
            if(c<=1){ 
                clearInterval(countdownInterval); 
                startDraw(); 
            } else{ 
                c--; 
                if(cdSpan) cdSpan.innerText=c;
                if(c<=3) cdSpan?.classList.add('countdown-warning');
                else cdSpan?.classList.remove('countdown-warning');
