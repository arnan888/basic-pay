                        <div style="margin-top:6px;"><span id="totalPoints" style="font-size:22px; font-weight:bold; color:#ff3300;">3</span></div>
                    </div>
                    <div style="display:flex; justify-content:space-between; margin:12px 0; background:rgba(0,0,0,0.5); border-radius:30px; padding:8px;"><div>总押注:<span id="totalBet">0</span></div><div>🎲 本局中奖:<span id="rollingWinNumber">0.00</span></div></div>
                    <div style="display:flex; justify-content:space-between; background:rgba(0,0,0,0.5); border-radius:30px; padding:8px; margin-bottom:12px;"><div>⏱️ 下注倒计时 <span id="countdownNum">25</span></div><div>🎲 筹码 <span id="selectedChip">0</span></div></div>
                    <div style="display:flex; gap:8px; margin-bottom:12px;"><button id="clearAllBtn" style="flex:1; background:#e74c3c; border:none; border-radius:50px; padding:8px;">全部取消</button><button id="repeatBtn" style="flex:1; background:#f39c12; border:none; border-radius:50px; padding:8px;">续押</button><button id="refreshBtn" style="flex:1; background:#2ecc71; border:none; border-radius:50px; padding:8px;">刷新余额</button><button disabled style="flex:1; background:#3498db; border:none; border-radius:50px; padding:8px;">⏳ 等待自动开奖</button></div>
                    <div class="chips" style="display:flex; gap:8px; justify-content:center; flex-wrap:wrap; margin-bottom:12px;"><div class="chip" data-val="10">10</div><div class="chip" data-val="20">20</div><div class="chip" data-val="50">50</div><div class="chip" data-val="100">100</div><div class="chip" data-val="500">500</div><div class="chip" data-val="1000">1K</div></div>
                    <div style="font-size:0.7rem; color:#ffd49f;">🎲 大小单双 · 赔率2倍</div>
                    <div class="special-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:12px;"><div class="bet-card special-card" data-type="BIG">大<div id="bet_BIG">0</div></div><div class="bet-card special-card" data-type="SMALL">小<div id="bet_SMALL">0</div></div><div class="bet-card special-card" data-type="ODD">单<div id="bet_ODD">0</div></div><div class="bet-card special-card" data-type="EVEN">双<div id="bet_EVEN">0</div></div></div>
                    <div style="font-size:0.7rem; color:#ffd49f;">🎲 点数投注 · 4-17点</div>
                    <div class="points-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:12px;">${pointsHtml}</div>
                    <div style="font-size:0.7rem; color:#ffd49f;">🎲 围骰 · 豹子</div>
                    <div class="trio-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:12px;">${trioHtml}</div>
                    <button id="showDiceHistoryBtn" style="width:100%; background:#2a1f16; border:1px solid #ffaa44; border-radius:40px; padding:8px; margin-top:8px;">📜 开奖记录查询</button>
                </div>
            </div>
        `;

        let bets = { 'BIG':0,'SMALL':0,'ODD':0,'EVEN':0,4:0,5:0,6:0,7:0,8:0,9:0,10:0,11:0,12:0,13:0,14:0,15:0,16:0,17:0,'TRIPLE_1':0,'TRIPLE_2':0,'TRIPLE_3':0,'TRIPLE_4':0,'TRIPLE_5':0,'TRIPLE_6':0,'ALL_TRIPLE':0 };
        let selectedChip = 0;
        let currentBalance = getUserBalance();
        let isDrawing = false;
        let isBetLocked = false;
        let countdownInterval = null;
        let rollingAnimation = null;
        let lastBet = null;
        let hasGrabbed = false;
        let playerBankerBalance = 0;

        const diceEl = [document.getElementById('dice1'), document.getElementById('dice2'), document.getElementById('dice3')];
        const totalEl = document.getElementById('totalPoints');
        const rollingWinEl = document.getElementById('rollingWinNumber');
        const totalBetEl = document.getElementById('totalBet');

        // 构建3D骰子面
        function buildDiceFaces() {
            diceEl.forEach(dice => {
                if (!dice) return;
                dice.innerHTML = '';
                const faces = ['front','back','right','left','top','bottom'];
                const valMap = { front:1, back:6, right:4, left:3, top:2, bottom:5 };
                faces.forEach(face => {
                    let num = valMap[face];
                    let fd = document.createElement('div');
                    fd.className = `dice-face ${face} face-${num}`;
                    let pip = '';
                    if (num === 1) pip = '<div class="pip pip-center"></div>';
                    else if (num === 2) pip = '<div class="pip pip-tl"></div><div class="pip pip-br"></div>';
                    else if (num === 3) pip = '<div class="pip pip-tl"></div><div class="pip pip-center"></div><div class="pip pip-br"></div>';
                    else if (num === 4) pip = '<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                    else if (num === 5) pip = '<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-mid"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                    else pip = '<div class="pip pip-l1"></div><div class="pip pip-l2"></div><div class="pip pip-l3"></div><div class="pip pip-r1"></div><div class="pip pip-r2"></div><div class="pip pip-r3"></div>';
                    fd.innerHTML = pip;
                    dice.appendChild(fd);
                });
            });
        }
        buildDiceFaces();

        function setDiceValue(dice, val) {
            if (!dice) return;
            const rot = {1:'rotateX(0deg)',2:'rotateX(-90deg)',3:'rotateY(90deg)',4:'rotateY(-90deg)',5:'rotateX(90deg)',6:'rotateX(180deg)'};
            dice.style.transform = rot[val];
        }

        // 5秒滚动动画
        async function startRollingLong(finalVals, duration = 5000) {
            return new Promise(resolve => {
                let steps = 30;
                let step = 0;
                let interval = duration / steps;
                let iv = setInterval(() => {
                    diceEl.forEach(d => setDiceValue(d, Math.floor(Math.random() * 6) + 1));
                    step++;
                    if (step >= steps) {
                        clearInterval(iv);
                        diceEl.forEach((d, i) => setDiceValue(d, finalVals[i]));
                        resolve();
                    }
                }, interval);
            });
        }

        // 中奖金额滚动数字效果
        function startRollingNumber(finalAmount) {
            if (rollingAnimation) cancelAnimationFrame(rollingAnimation);
            let start = performance.now();
            let startVal = parseFloat(rollingWinEl.innerText) || 0;
            function update(now) {
                let p = Math.min(1, (now - start) / 5000);
                let ease = 1 - Math.pow(1 - p, 2);
                let cur = startVal + (finalAmount - startVal) * ease;
                rollingWinEl.innerText = cur.toFixed(2);
                if (p < 1) {
                    rollingAnimation = requestAnimationFrame(update);
                } else {
                    rollingWinEl.innerText = finalAmount.toFixed(2);
                    rollingAnimation = null;
                }
            }
            rollingAnimation = requestAnimationFrame(update);
        }

        function getResultInfo(d1, d2, d3) {
            let total = d1 + d2 + d3;
            let types = [];
            if (total >= 11 && total <= 17) types.push('BIG');
            if (total >= 4 && total <= 10) types.push('SMALL');
            if (total % 2 === 1) types.push('ODD');
            if (total % 2 === 0) types.push('EVEN');
            if (d1 === d2 && d2 === d3) {
                types.push(`TRIPLE_${d1}`);
                types.push('ALL_TRIPLE');
            }
            return { total, types };
        }

        function updateUI() {
            for (let k in bets) {
                let el = document.getElementById(`bet_${k}`);
                if (el) el.innerText = bets[k];
            }
            totalBetEl.innerText = Object.values(bets).reduce((a,b) => a + b, 0);
        }

        function addBet(type) {
            if (hasGrabbed) { showToast("庄家不能下注"); return; }
            if (selectedChip <= 0) { showToast("请先选择筹码"); return; }
            if (selectedChip > currentBalance) { showToast("余额不足"); return; }
            currentBalance -= selectedChip;
            setUserBalance(currentBalance);
            bets[type] += selectedChip;
            updateUI();
        }

        function clearAllBets() {
            let total = Object.values(bets).reduce((a,b) => a + b, 0);
            currentBalance += total;
            setUserBalance(currentBalance);
            for (let k in bets) bets[k] = 0;
            updateUI();
            showToast("已清空所有下注");
        }

        function repeatLastBet() {
            if (!lastBet) { showToast("无续押记录"); return; }
            let need = Object.values(lastBet).reduce((a,b) => a + b, 0);
            if (need > currentBalance) { showToast("余额不足，无法续押"); return; }
            for (let k in bets) bets[k] = 0;
            for (let k in lastBet) bets[k] = lastBet[k];
            currentBalance -= need;
            setUserBalance(currentBalance);
            updateUI();
            if (!isDrawing && !isBetLocked) startAutoDraw();
        }

        let gameRecords = [];
        function addRecord(d1, d2, d3, winAmount, totalBet) {
            gameRecords.unshift({
                time: new Date().toLocaleTimeString(),
                dice: `${d1},${d2},${d3}`,
                result: winAmount > 0 ? `赢${winAmount}` : `输${totalBet}`,
                win: winAmount
            });
            if (gameRecords.length > 50) gameRecords.pop();
        }

        // 自动开奖（无论下注与否）
        async function startAutoDraw() {
            if (isDrawing) return;
            let totalBetVal = Object.values(bets).reduce((a,b) => a + b, 0);
            isDrawing = true;
            isBetLocked = true;
            let d1 = Math.floor(Math.random() * 6) + 1;
            let d2 = Math.floor(Math.random() * 6) + 1;
            let d3 = Math.floor(Math.random() * 6) + 1;
            let { total, types } = getResultInfo(d1, d2, d3);
            let winAmount = 0;
            if (totalBetVal > 0) {
                if (types.includes('BIG') && bets['BIG']) winAmount += bets['BIG'] * 2;
                if (types.includes('SMALL') && bets['SMALL']) winAmount += bets['SMALL'] * 2;
                if (types.includes('ODD') && bets['ODD']) winAmount += bets['ODD'] * 2;
                if (types.includes('EVEN') && bets['EVEN']) winAmount += bets['EVEN'] * 2;
                if (bets[total]) winAmount += bets[total] * oddsMap[total];
                for (let t of types) {
                    if (t.startsWith('TRIPLE_') && bets[t]) winAmount += bets[t] * 150;
                    if (t === 'ALL_TRIPLE' && bets['ALL_TRIPLE']) winAmount += bets['ALL_TRIPLE'] * 30;
                }
            }
            startRollingNumber(winAmount);
            await startRollingLong([d1, d2, d3], 5000);
            totalEl.innerText = total;
            if (totalBetVal > 0) {
                if (winAmount > 0) currentBalance += winAmount;
                setUserBalance(currentBalance);
                if (hasGrabbed) {
                    playerBankerBalance -= winAmount;
                    if (playerBankerBalance < 0) {
                        hasGrabbed = false;
                        playerBankerBalance = 0;
                        localStorage.setItem('dice_player_banker', 0);
                        updateGrabBtn();
                        showToast("庄家破产，权限回收");
                    } else {
                        localStorage.setItem('dice_player_banker', playerBankerBalance);
                    }
                }
            }
            addRecord(d1, d2, d3, winAmount, totalBetVal);
            for (let k in bets) bets[k] = 0;
            lastBet = JSON.parse(JSON.stringify(bets));
            updateUI();
            let pop = document.createElement('div');
            pop.className = 'result-popup ' + (winAmount > 0 ? 'win' : 'lose');
            pop.textContent = winAmount > 0 ? `🎉 赢 ${winAmount} 🎉` : (totalBetVal > 0 ? `😭 输 ${totalBetVal} 😭` : `🎲 点数 ${total} 无人下注`);
            document.body.appendChild(pop);
            setTimeout(() => pop.classList.add('show'), 10);
            setTimeout(() => {
                pop.classList.remove('show');
                setTimeout(() => pop.remove(), 300);
            }, 2000);
            isDrawing = false;
            isBetLocked = false;
            startCountdown(25);
        }

        function startCountdown(sec) {
            if (countdownInterval) clearInterval(countdownInterval);
            let c = sec;
            let cdSpan = document.getElementById('countdownNum');
            if (!cdSpan) return;
            cdSpan.innerText = c;
            isBetLocked = false;
            countdownInterval = setInterval(() => {
                if (c <= 1) {
                    clearInterval(countdownInterval);
                    countdownInterval = null;
                    isBetLocked = true;
                    startAutoDraw();
                } else {
                    c--;
                    cdSpan.innerText = c;
                    if (c <= 5) cdSpan.classList.add('countdown-warning');
                    else cdSpan.classList.remove('countdown-warning');
                }
            }, 1000);
        }

        function refreshBalance() {
            currentBalance = getUserBalance();
            updateUI();
            showToast("余额已刷新");
        }

        function updateGrabBtn() {
            let btn = document.getElementById('diceGrabBtn');
            if (!btn) return;
            let bal = getUserBalance();
            if (hasGrabbed) {
                btn.disabled = true;
                btn.textContent = '🏆 已抢庄';
            } else if (bal >= 2001) {
                btn.disabled = false;
                btn.textContent = '🎲 抢庄 (需2001文)';
            } else {
                btn.disabled = true;
                btn.textContent = '🎲 抢庄 (余额不足)';
            }
        }

        document.getElementById('diceGrabBtn').onclick = () => {
            if (hasGrabbed) return;
            if (getUserBalance() >= 2001) {
                setUserBalance(getUserBalance() - 2001);
                playerBankerBalance = 2001;
                hasGrabbed = true;
                localStorage.setItem('dice_player_banker', playerBankerBalance);
                currentBalance = getUserBalance();
                updateUI();
                updateGrabBtn();
                showToast("抢庄成功，不可下注");
                document.querySelectorAll('.dice-wrapper .chip').forEach(c => c.style.pointerEvents = 'none');
            } else {
                showToast("余额不足2001");
            }
        };

        let savedBanker = localStorage.getItem('dice_player_banker');
        if (savedBanker && parseInt(savedBanker) > 0) {
            hasGrabbed = true;
            playerBankerBalance = parseInt(savedBanker);
            updateGrabBtn();
            document.querySelectorAll('.dice-wrapper .chip').forEach(c => c.style.pointerEvents = 'none');
        }

        // 筹码选择
        document.querySelectorAll('.dice-wrapper .chip').forEach(chip => {
            chip.onclick = function() {
                if (hasGrabbed) { showToast("庄家不能下注"); return; }
                selectedChip = parseInt(this.dataset.val);
                document.getElementById('selectedChip').innerText = selectedChip;
                document.querySelectorAll('.dice-wrapper .chip').forEach(c => c.classList.remove('selected'));
                this.classList.add('selected');
            };
        });

        // 投注事件绑定
        document.querySelectorAll('.special-card').forEach(c => {
            c.onclick = () => { if (!hasGrabbed) addBet(c.dataset.type); };
        });
        document.querySelectorAll('.point-card').forEach(c => {
            c.onclick = () => { if (!hasGrabbed) addBet(parseInt(c.dataset.point)); };
        });
        document.querySelectorAll('.trio-card').forEach(c => {
            c.onclick = () => { if (!hasGrabbed) addBet(c.dataset.type); };
        });

        document.getElementById('clearAllBtn').onclick = clearAllBets;
        document.getElementById('repeatBtn').onclick = repeatLastBet;
        document.getElementById('refreshBtn').onclick = refreshBalance;

        // 开奖记录查询
        document.getElementById('showDiceHistoryBtn').onclick = () => {
            if (gameRecords.length === 0) {
                showToast("暂无记录");
                return;
            }
            let html = '<div style="max-height:400px; overflow-y:auto;">';
            gameRecords.forEach(r => {
                html += `<div style="background:#2a241e; margin:8px; padding:8px; border-left:3px solid #ffaa44;">
                            <div style="font-size:0.7rem;">${r.time}</div>
                            <div style="font-size:1rem; font-weight:bold;">🎲 ${r.dice}</div>
                            <div style="color:${r.win > 0 ? '#4caf50' : '#f44336'}">${r.result}</div>
                         </div>`;
            });
            html += '</div><button id="closeRec" style="background:#ffaa44; margin-top:12px; padding:8px 20px; border-radius:40px;">关闭</button>';
            let modal = document.createElement('div');
            modal.className = 'modal';
            modal.innerHTML = `<div class="modal-content"><h3 style="margin-bottom:12px;">📜 开奖记录</h3>${html}</div>`;
            document.body.appendChild(modal);
            modal.querySelector('#closeRec').onclick = () => modal.remove();
        };

        diceEl.forEach(d => setDiceValue(d, 1));
        totalEl.innerText = 3;
        updateUI();
        startCountdown(25);

        diceDestroy = () => {
            if (countdownInterval) clearInterval(countdownInterval);
            if (rollingAnimation) cancelAnimationFrame(rollingAnimation);
            container.innerHTML = '';
        };

        return diceDestroy;
    }

    // =====================================================================
    // 游戏3、游戏4预留位
