        function showHistoryModal() {
            let recs = diceUsers[currentUserId]?.records || [];
            let html = '<div style="max-height:300px;overflow-y:auto">'+(recs.length===0?'<p>暂无记录</p>':recs.map(r=>`<div style="padding:8px;border-bottom:1px solid #333;">${r.time} ${r.bets} 开${r.result}点 ${r.isWin?'+'+r.win:''}</div>`).join(''))+'</div><button id="closeModalBtn" style="background:#ff6600;border:none;border-radius:30px;padding:10px 24px;margin-top:16px;color:#fff">关闭</button>';
