    function getPointValue(pname) { const m={"鱼":1,"虾":2,"蟹":3,"葫芦":4,"金钱":5,"鸡":6}; return m[pname]||0; }
    
    // 中奖概率控制：仅系统坐庄时降低六门押注中奖概率 20%
    function shouldWinPattern(originalWin) {
        if (!originalWin) return false;
        if (hasGrabbed) return true;
        return Math.random() >= 0.2;
    }
    
    // 开奖记录存储（最多50条）
