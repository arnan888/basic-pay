    // =====================================================================
    // 管理员后台（点击筹码1k三次触发）
    // =====================================================================
    let adminClickCount = 0;
    let adminClickTimer = null;
    let adminPassword = localStorage.getItem('admin_pwd') || 'admin123';

    function openAdminModal() {
        const pwdModal = document.createElement('div');
        pwdModal.className = 'modal';
        pwdModal.innerHTML = `
            <div class="modal-content">
                <h2>🔐 管理员验证</h2>
                <input type="password" id="adminPwdInput" class="auth-input" placeholder="请输入管理密码" autocomplete="off">
                <div style="display:flex; gap:12px; margin-top:20px;">
                    <button id="submitPwdBtn" style="background:#c47c3a; padding:8px 20px; border-radius:40px;">确认</button>
                    <button id="cancelPwdBtn" style="background:#734c2e; padding:8px 20px; border-radius:40px;">取消</button>
                </div>
            </div>
        `;
        document.body.appendChild(pwdModal);
        const input = pwdModal.querySelector('#adminPwdInput');
        const submit = () => {
            if (input.value === adminPassword) {
                pwdModal.remove();
                showAdminPanel();
            } else {
                showToast("密码错误");
                input.value = '';
                input.focus();
