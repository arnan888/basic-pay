                }
                function addHistory(msg) { historyList.unshift(msg); if(historyList.length>5) historyList.pop(); updatePokerUI(); }
                function dealAndArrange() {
                    if(currentDeck.length < 52) { currentDeck = shuffle(createDeck()); }
                    for(let i=0;i<playersData.length;i++) {
                        const hand = [];
