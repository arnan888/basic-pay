            refreshList();
            panel.querySelector('#adminAdd').onclick = () => { let amt = parseFloat(panel.querySelector('#adminAmount').value); if (isNaN(amt)||amt<=0) return; setUserBalance(getUserBalance()+amt); currentBalance=getUserBalance(); updateUI(); refreshList(); showToast('上分成功'); };
            panel.querySelector('#adminSub').onclick = () => { let amt = parseFloat(panel.querySelector('#adminAmount').value); if (isNaN(amt)||amt<=0) return; let cur=getUserBalance(); if(cur<amt) { showToast("余额不足"); return; } setUserBalance(cur-amt); currentBalance=getUserBalance(); updateUI(); refreshList(); showToast('下分成功'); };
            panel.querySelector('#adminQuery').onclick = () => showToast(currentUserId+' 余额: '+getUserBalance().toFixed(2));
            panel.querySelector('#adminReset').onclick = () => { if(confirm('重置 '+currentUserId+' 余额为 '+CONFIG.defaultBalance)) { setUserBalance(CONFIG.defaultBalance); currentBalance=getUserBalance(); updateUI(); refreshList(); showToast("重置成功"); } };
            panel.querySelector('#adminPwd').onclick = () => { let old=prompt("当前密码:"); if(old!==adminPwd) { showToast("密码错误"); return; } let newPwd=prompt("新密码(至少6位):"); if(newPwd&&newPwd.length>=6) { adminPwd=newPwd; localStorage.setItem('dice_admin_pwd',newPwd); showToast("密码修改成功"); } };
            panel.querySelector('#adminClose').onclick = () => { panel.remove(); adminPanel=null; };
