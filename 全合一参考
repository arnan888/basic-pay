        const diceCover = container.querySelector('#diceCover');

        function setDiceValue(dice, val) {
            const rot = {1:'rotateX(0deg) rotateY(0deg)',2:'rotateX(-90deg) rotateY(0deg)',3:'rotateX(0deg) rotateY(90deg)',4:'rotateX(0deg) rotateY(-90deg)',5:'rotateX(90deg) rotateY(0deg)',6:'rotateX(180deg) rotateY(0deg)'};
            dice.style.transform = rot[val];
        }
        async function startRolling(finalVals) {
            return new Promise(resolve => {
                diceEl[0].classList.add('rolling1'); diceEl[1].classList.add('rolling2'); diceEl[2].classList.add('rolling3');
                let step = 0, maxStep = 18;
                let iv = setInterval(() => {
                    step++;
                    diceEl.forEach(d => setDiceValue(d, Math.floor(Math.random() * 6) + 1));
                    if (step >= maxStep) {
                        clearInterval(iv);
                        diceEl.forEach(d => d.classList.remove('rolling1','rolling2','rolling3'));
                        diceEl.forEach((d,i) => { setDiceValue(d, finalVals[i]); d.classList.add('land'); setTimeout(() => d.classList.remove('land'), 200); });
                        resolve();
                    }
                }, 50);
            });
        }
        function startRollingNumber(finalAmount) {
            if (rollingAnimation) cancelAnimationFrame(rollingAnimation);
            let startTime = performance.now(), duration = 5000, startVal = 0.01;
            function update(now) {
                let elapsed = now - startTime, progress = Math.min(1, elapsed / duration), ease = 1 - Math.pow(1 - progress, 2);
                let current = startVal + (finalAmount - startVal) * ease;
                rollingWinEl.innerText = current.toFixed(2);
                if (progress < 1) rollingAnimation = requestAnimationFrame(update);
                else { rollingWinEl.innerText = finalAmount.toFixed(2); rollingAnimation = null; }
            }
            rollingAnimation = requestAnimationFrame(update);
        }
        function getResultInfo(d1,d2,d3) {
            let total = d1+d2+d3, types = [];
            if (total>=11 && total<=17) types.push('BIG');
            if (total>=4 && total<=10) types.push('SMALL');
            if (total%2===1) types.push('ODD');
            if (total%2===0) types.push('EVEN');
            if (d1===d2 && d2===d3) { types.push('TRIPLE_'+d1); types.push('ALL_TRIPLE'); }
            return { total, types };
        }
        function updateUI() {
            container.querySelector('#bet_BIG').innerText = bets['BIG'];
            container.querySelector('#bet_SMALL').innerText = bets['SMALL'];
            container.querySelector('#bet_ODD').innerText = bets['ODD'];
            container.querySelector('#bet_EVEN').innerText = bets['EVEN'];
            for (let i=4;i<=17;i++) { let el = container.querySelector('#bet_'+i); if(el) el.innerText = bets[i]; }
            for (let i=1;i<=6;i++) { let el = container.querySelector('#bet_TRIPLE_'+i); if(el) el.innerText = bets['TRIPLE_'+i]; }
            container.querySelector('#bet_ALL_TRIPLE').innerText = bets['ALL_TRIPLE'];
            let totalBet = Object.values(bets).reduce((a,b)=>a+b,0);
            container.querySelector('#totalBet').innerText = totalBet;
            container.querySelector('#balanceDisplay').innerText = currentBalance.toFixed(2);
            let pool = 50000 + (Math.random()-0.5)*3000;
            container.querySelector('#poolDisplay').innerText = Math.max(40000,Math.min(60000,pool)).toFixed(2);
        }
        function addBet(type) {
            if (selectedChip<=0) { showToast("请先选择筹码"); return; }
            if (selectedChip>currentBalance) { showToast("余额不足"); return; }
            currentBalance -= selectedChip;
            setUserBalance(currentBalance);
            bets[type] += selectedChip;
            updateUI();
            let selector = typeof type==='string' ? (type.startsWith('TRIPLE_')?'.trio-card[data-type="'+type+'"]':'.special-card[data-type="'+type+'"]') : '.point-card[data-point="'+type+'"]';
            let el = container.querySelector(selector);
            if (el) { el.classList.add('selected'); setTimeout(()=>el.classList.remove('selected'),800); }
        }
        function clearAllBets() {
            let total = Object.values(bets).reduce((a,b)=>a+b,0);
            currentBalance += total;
            setUserBalance(currentBalance);
            for (let k in bets) bets[k]=0;
            updateUI();
            showToast("已取消所有下注");
        }
        function repeatLastBet() {
            if (!lastBet) { showToast("没有可续押的记录"); return; }
            let totalNeed = Object.values(lastBet).reduce((a,b)=>a+b,0);
            if (totalNeed>currentBalance) { showToast("余额不足，无法续押"); return; }
            for (let k in bets) bets[k]=0;
            for (let k in lastBet) bets[k]=lastBet[k];
            currentBalance -= totalNeed;
            setUserBalance(currentBalance);
            updateUI();
            if (!isDrawing && !isBetLocked) drawWithCover();
        }
        function resetDiceCover() {
            if (diceCover) {
                diceCover.classList.remove('open-cover','hidden-cover');
                diceCover.style.display='flex'; diceCover.style.visibility='visible'; diceCover.style.opacity='1'; diceCover.style.transform='translateY(0) scale(1)';
            }
        }
        async function openCoverAndWait() {
            if (!diceCover) return;
            if (diceCover.classList.contains('hidden-cover') || diceCover.style.display==='none') resetDiceCover();
            diceCover.classList.add('open-cover');
            await new Promise(r=>setTimeout(r,600));
            diceCover.classList.add('hidden-cover');
            diceCover.style.display='none';
        }
        async function drawWithCover() {
            if (isDrawing) return;
            let totalBet = Object.values(bets).reduce((a,b)=>a+b,0);
            if (totalBet===0) { showToast("请先下注"); return; }
            if (totalBet>currentBalance){ showToast("余额不足，无法开奖"); return; }
            isDrawing=true; isBetLocked=true;
            await openCoverAndWait();
            let d1=Math.floor(Math.random()*6)+1, d2=Math.floor(Math.random()*6)+1, d3=Math.floor(Math.random()*6)+1;
            let {total,types} = getResultInfo(d1,d2,d3);
            let winAmounts = [];
            if (types.includes('BIG') && bets['BIG']>0) winAmounts.push(bets['BIG']*2);
            if (types.includes('SMALL') && bets['SMALL']>0) winAmounts.push(bets['SMALL']*2);
            if (types.includes('ODD') && bets['ODD']>0) winAmounts.push(bets['ODD']*2);
            if (types.includes('EVEN') && bets['EVEN']>0) winAmounts.push(bets['EVEN']*2);
            if (bets[total]>0) winAmounts.push(bets[total]*CONFIG.odds[total]);
            for (let t of types) {
                if (t.startsWith('TRIPLE_') && bets[t]>0) winAmounts.push(bets[t]*CONFIG.odds[t]);
                if (t==='ALL_TRIPLE' && bets['ALL_TRIPLE']>0) winAmounts.push(bets['ALL_TRIPLE']*CONFIG.odds['ALL_TRIPLE']);
            }
            let totalWin = winAmounts.reduce((a,b)=>a+b,0);
            startRollingNumber(totalWin);
            await startRolling([d1,d2,d3]);
            totalEl.innerText = total;
            currentBalance += totalWin;
            setUserBalance(currentBalance);
            let betSummary = [];
            for (let k in bets) if (bets[k]>0) {
                if (k==='BIG') betSummary.push('大'+bets[k]);
                else if (k==='SMALL') betSummary.push('小'+bets[k]);
                else if (k==='ODD') betSummary.push('单'+bets[k]);
                else if (k==='EVEN') betSummary.push('双'+bets[k]);
                else if (typeof k==='number') betSummary.push(k+'点'+bets[k]);
                else if (k.startsWith('TRIPLE_')) betSummary.push(k.split('_')[1]+'围'+bets[k]);
                else if (k==='ALL_TRIPLE') betSummary.push('豹子'+bets[k]);
            }
            let recs = diceUsers[currentUserId].records || [];
            recs.unshift({ time:new Date().toLocaleTimeString(), bets:betSummary.join(' '), result:total, resultType:types.join(','), win:totalWin, isWin:totalWin>0 });
            if (recs.length>30) recs.pop();
            diceUsers[currentUserId].records = recs;
            saveDiceUsers();
            updateHistory();
            for (let k in bets) bets[k]=0;
            updateUI();
            lastBet = JSON.parse(JSON.stringify(bets));
            let winText = totalWin>0 ? `🎉 恭喜！ 赢 ${totalWin.toFixed(2)} 🎉` : `😭 很遗憾 输 ${totalBet.toFixed(2)} 😭`;
            let pop = document.createElement('div'); pop.className='result-popup '+(totalWin>0?'win':'lose'); pop.textContent=winText; document.body.appendChild(pop); setTimeout(()=>pop.classList.add('show'),10); setTimeout(()=>{pop.classList.remove('show');setTimeout(()=>pop.remove(),300);},2000);
            setTimeout(()=>{ resetDiceCover(); isDrawing=false; isBetLocked=false; startCountdown(CONFIG.countdownSeconds); },5000);
        }
        function startCountdown(sec) {
            if (countdownInterval) clearInterval(countdownInterval);
            let c = sec, cdSpan = container.querySelector('#countdownNum');
            cdSpan.innerText = c; cdSpan.classList.remove('countdown-warning');
            isBetLocked = false;
            countdownInterval = setInterval(() => {
                if (c<=1) { clearInterval(countdownInterval); countdownInterval=null; isBetLocked=true; drawWithCover(); }
                else { c--; cdSpan.innerText = c; if (c<=5) cdSpan.classList.add('countdown-warning'); }
            }, 1000);
        }
        function updateHistory() {
            let histDiv = container.querySelector('#historyList');
            let recs = diceUsers[currentUserId]?.records || [];
            histDiv.innerHTML = recs.length===0 ? '<div style="text-align:center;color:#666">暂无记录</div>' : recs.slice(0,10).map(r=>`<div style="display:flex; justify-content:space-between; padding:4px; border-bottom:1px solid #333;"><span>${r.time}</span><span>${r.bets}</span><span>开${r.result}点</span><span style="color:${r.isWin?'#4caf50':'#f44336'}">${r.isWin?'+'+r.win:''}</span></div>`).join('');
        }
        function refreshBalance() { currentBalance = getUserBalance(); updateUI(); showToast("余额已刷新"); }
