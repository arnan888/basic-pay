                    let num=valMap[faceClass];
                    let faceDiv=document.createElement('div');
                    faceDiv.className='dice-face '+faceClass+' face-'+num;
                    let pipHtml='';
                    if (num===1) pipHtml='<div class="pip pip-center"></div>';
                    else if (num===2) pipHtml='<div class="pip pip-tl"></div><div class="pip pip-br"></div>';
                    else if (num===3) pipHtml='<div class="pip pip-tl"></div><div class="pip pip-center"></div><div class="pip pip-br"></div>';
                    else if (num===4) pipHtml='<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                    else if (num===5) pipHtml='<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-mid"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                    else if (num===6) pipHtml='<div class="pip pip-l1"></div><div class="pip pip-l2"></div><div class="pip pip-l3"></div><div class="pip pip-r1"></div><div class="pip pip-r2"></div><div class="pip pip-r3"></div>';
                    faceDiv.innerHTML=pipHtml;
                    d.appendChild(faceDiv);
                }
            });
            diceEl.forEach(d=>setDiceValue(d,1));
            totalEl.innerText=3;
            updateUI(); updateHistory(); startCountdown(CONFIG.countdownSeconds);
            let savedPwd = localStorage.getItem('dice_admin_pwd');
            if (savedPwd) adminPwd = savedPwd;
            resetDiceCover();
            initDrawers();
        }
        init();

        diceDestroy = () => {
            if (countdownInterval) clearInterval(countdownInterval);
            if (rollingAnimation) cancelAnimationFrame(rollingAnimation);
            container.innerHTML = '';
        };
        return diceDestroy;
    }

