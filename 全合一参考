                <div class="dice" id="dice3" style="width:60px;height:60px;"></div>
            </div>
            <div style="background:rgba(0,0,0,0.5); border-radius:30px; padding:4px;">
                <div style="font-size:10px; color:#88aa88;">总点数</div>
                <div id="totalPoints" style="font-size:22px; font-weight:bold; color:#ffaa44;">3</div>
            </div>
        </div>
        <div style="display:flex; justify-content:space-between; margin:12px 0; background:rgba(0,0,0,0.5); border-radius:30px; padding:8px;">
            <div>总押注:<span id="totalBet">0</span></div>
            <div>⏱️ 倒计时:<span id="countdownNum">20</span></div>
            <div>🎲 筹码:<span id="selectedChip">${selectedChip}</span></div>
        </div>
        <div style="display:flex; gap:6px; justify-content:center; flex-wrap:wrap; margin:12px 0;">
            <div class="chip ${selectedChip===10?'selected-chip':''}" data-val="10" style="background:#4a90d9; padding:5px 12px; border-radius:30px;">10</div>
            <div class="chip ${selectedChip===20?'selected-chip':''}" data-val="20" style="background:#50b86a; padding:5px 12px; border-radius:30px;">20</div>
            <div class="chip ${selectedChip===50?'selected-chip':''}" data-val="50" style="background:#e85d3a; padding:5px 12px; border-radius:30px;">50</div>
            <div class="chip ${selectedChip===100?'selected-chip':''}" data-val="100" style="background:#9b59b6; padding:5px 12px; border-radius:30px;">100</div>
            <div class="chip ${selectedChip===500?'selected-chip':''}" data-val="500" style="background:#f1c40f; padding:5px 12px; border-radius:30px;">500</div>
            <div class="chip ${selectedChip===1000?'selected-chip':''}" data-val="1000" style="background:#e74c3c; padding:5px 12px; border-radius:30px;">1K</div>
        </div>
        <div style="display:flex; gap:8px; margin:12px 0;">
            <button id="clearAllBtn" style="flex:1; background:#e74c3c; padding:8px; border-radius:40px; color:#fff;">清空</button>
            <button id="betBtn" style="flex:1; background:#3498db; padding:8px; border-radius:40px; color:#fff;">确认投注</button>
        </div>
        <div style="font-size:0.7rem; color:#ffd49f; margin:12px 0 6px;">🎲 大小单双 · 赔2倍</div>
        <div class="special-grid" style="grid-template-columns:repeat(4,1fr); display:grid; gap:8px;">
            <div class="bet-card" data-type="BIG">大<div id="bet_BIG">0</div></div>
            <div class="bet-card" data-type="SMALL">小<div id="bet_SMALL">0</div></div>
            <div class="bet-card" data-type="ODD">单<div id="bet_ODD">0</div></div>
            <div class="bet-card" data-type="EVEN">双<div id="bet_EVEN">0</div></div>
        </div>
        <div class="points-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin:12px 0;">${pointsHtml}</div>
        <div class="trio-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:8px;">${trioHtml}</div>
    </div>`;
    
    // 初始化骰子3D
    function initDice3D() {
        const diceEls = [container.querySelector('#dice1'), container.querySelector('#dice2'), container.querySelector('#dice3')];
        const faces = ['front','back','right','left','top','bottom'];
        const valMap = { front:1, back:6, right:4, left:3, top:2, bottom:5 };
        diceEls.forEach(dice => {
            if(!dice) return;
            dice.innerHTML = '';
            faces.forEach(face => {
                let num = valMap[face];
                let fd = document.createElement('div');
                fd.className = `dice-face ${face} face-${num}`;
                let pipHtml = '';
                if (num === 1) pipHtml = '<div class="pip pip-center"></div>';
                else if (num === 2) pipHtml = '<div class="pip pip-tl"></div><div class="pip pip-br"></div>';
                else if (num === 3) pipHtml = '<div class="pip pip-tl"></div><div class="pip pip-center"></div><div class="pip pip-br"></div>';
                else if (num === 4) pipHtml = '<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                else if (num === 5) pipHtml = '<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-mid"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                else pipHtml = '<div class="pip pip-l1"></div><div class="pip pip-l2"></div><div class="pip pip-l3"></div><div class="pip pip-r1"></div><div class="pip pip-r2"></div><div class="pip pip-r3"></div>';
                fd.innerHTML = pipHtml;
                dice.appendChild(fd);
            });
            dice.style.transform = 'rotateX(0deg) rotateY(0deg)';
        });
    }
    initDice3D();
    
    // 事件绑定
    container.querySelectorAll('.chip').forEach(chip => {
        chip.onclick = () => {
            selectedChip = parseInt(chip.dataset.val);
            container.querySelectorAll('.chip').forEach(c => c.classList.remove('selected-chip'));
            chip.classList.add('selected-chip');
            let chipSpan = container.querySelector('#selectedChip');
            if(chipSpan) chipSpan.innerText = selectedChip;
        };
    });
    
    container.querySelectorAll('.special-card, .point-card, .trio-card').forEach(el => {
        el.onclick = () => { let type = el.dataset.type || el.dataset.point; if(type) addBet(type); };
    });
    
    container.querySelector('#clearAllBtn').onclick = clearAllBets;
    container.querySelector('#betBtn').onclick = () => { if(!isDrawing && !isBetLocked) startDraw(); };
    container.querySelector('#diceAdminBtn').onclick = () => { let pwd = prompt("管理员密码:"); if(pwd===adminPassword) showAdminPanel(); else showToast("密码错误"); };
    
    startCountdown(20);
    
    return () => { roundActive=false; if(countdownInterval) clearInterval(countdownInterval); container.innerHTML=''; };
}

function initGame3(container) { container.innerHTML=`<div style="padding:30px; text-align:center; color:#ffdd99;">🎮 游戏3 即将开放</div>`; return ()=>{}; }
function initGame4(container) { container.innerHTML=`<div style="padding:30px; text-align:center; color:#ffdd99;">♠️ 游戏4 即将开放</div>`; return ()=>{}; }

// ==================== 注册登录 ====================
function renderAuthUI() {
    const savedPhone = localStorage.getItem('saved_phone') || '';
    const savedPwd = localStorage.getItem('saved_password') || '';
    const rememberChecked = localStorage.getItem('remember_me') === 'true';
    document.getElementById('app').innerHTML = `<div class="auth-panel"><h2>🎲 双游戏大厅</h2><input type="tel" id="regPhone" class="auth-input" placeholder="手机号" value="${savedPhone}"><input type="password" id="regPassword" class="auth-input" placeholder="密码 (至少4位)" value="${savedPwd}"><input type="text" id="regReferralCode" class="auth-input" placeholder="推荐码 (必填)"><div style="display:flex; align-items:center; gap:8px; margin:8px 0;"><input type="checkbox" id="rememberCheckbox" ${rememberChecked?'checked':''}><label style="color:#ffdd99;">记住账号密码</label></div><div class="auth-buttons"><button id="loginBtn" class="auth-btn">登录</button><button id="registerBtn" class="auth-btn">注册</button></div><div class="auth-note">🎮 需要有效推荐码才能注册 | 初始1000文<br>有效推荐码: ${validReferralCodes.join(', ')}</div></div>`;
    
    document.getElementById('registerBtn').onclick = () => {
        let phone = document.getElementById('regPhone').value.trim(), pwd = document.getElementById('regPassword').value, code = document.getElementById('regReferralCode').value.trim().toUpperCase();
        if(!phone || !pwd) return showToast("请填写手机号和密码");
        if(!/^1[3-9]\d{9}$/.test(phone)) return showToast("请输入有效11位手机号");
        if(pwd.length<4) return showToast("密码至少4位");
        if(!code) return showToast("请填写推荐码");
        if(!validReferralCodes.includes(code)) return showToast("推荐码无效，无法注册");
        if(usersData[phone]) return showToast("手机号已注册");
        usersData[phone] = { password:pwd, balance:1000, referralCode:code, registerTime:new Date().toLocaleString() };
        saveUsers(); showToast("注册成功！请登录");
    };
    
    document.getElementById('loginBtn').onclick = () => {
        let phone = document.getElementById('regPhone').value.trim(), pwd = document.getElementById('regPassword').value, rem = document.getElementById('rememberCheckbox').checked;
        if(!phone || !pwd) return showToast("请填写手机号和密码");
        let user = usersData[phone];
        if(!user || user.password !== pwd) return showToast("账号或密码错误");
        if(rem){ localStorage.setItem('saved_phone',phone); localStorage.setItem('saved_password',pwd); localStorage.setItem('remember_me','true'); }
        else{ localStorage.removeItem('saved_phone'); localStorage.removeItem('saved_password'); localStorage.setItem('remember_me','false'); }
        currentUser = { phone, ...user };
        showToast(`欢迎，${phone}`);
        renderGameLobby();
    };
}

function renderGameLobby() {
    document.getElementById('app').innerHTML = `<div class="user-section"><div class="user-info-row"><span>📱 ${currentUser.phone.substring(0,7)}... | 💰 余额: <span id="userBalanceDisplay">${getUserBalance().toFixed(2)}</span></span><div class="btn-group"><button id="serviceBtn" class="service-btn">📞 客服</button><button id="logoutBtn" class="logout-btn">退出</button></div></div><div class="charge-withdraw-row"><button id="rechargeBtn" class="charge-btn">💎 充值</button><button id="withdrawBtn" class="withdraw-btn">💰 提现</button></div></div><div class="game-nav"><button class="game-tab active" data-game="fish">🎲 葫芦鱼</button><button class="game-tab" data-game="dice">🎲 至尊骰宝</button><button class="game-tab" data-game="game3">🎮 游戏3</button><button class="game-tab" data-game="game4">♠️ 游戏4</button></div><div class="game-container"><div id="gamePanel"></div></div>`;
    
    document.getElementById('logoutBtn').onclick = () => { currentUser=null; renderAuthUI(); };
    document.getElementById('serviceBtn').onclick = showServiceModal;
    document.getElementById('rechargeBtn').onclick = recharge;
    document.getElementById('withdrawBtn').onclick = withdraw;
    
    const gamePanel = document.getElementById('gamePanel');
    let currentDestroy = null;
    const inits = { fish:initFishGame, dice:initDiceGame, game3:initGame3, game4:initGame4 };
    
    async function switchGame(id){ if(currentDestroy) currentDestroy(); gamePanel.innerHTML=''; currentDestroy=await inits[id](gamePanel); let balSpan=document.getElementById("userBalanceDisplay"); if(balSpan) balSpan.innerText=getUserBalance().toFixed(2); }
    
    document.querySelectorAll('.game-tab').forEach(btn=>{ btn.onclick=()=>{ document.querySelectorAll('.game-tab').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); switchGame(btn.dataset.game); }; });
    switchGame('fish');
    startMockOnline();
}

renderAuthUI();
</script>
