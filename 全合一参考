                        <button id="logoutBtn" class="logout-btn">退出</button>
                    </div>
                </div>
                <div class="charge-withdraw-row">
                    <button id="rechargeBtn" class="charge-btn">💎 充值</button>
                    <button id="withdrawBtn" class="withdraw-btn">💰 提现</button>
                </div>
            </div>
            <div class="game-nav">
                <button class="game-tab active" data-game="fish">🎲 葫芦鱼</button>
                <button class="game-tab" data-game="dice">🎲 至尊骰宝</button>
                <button class="game-tab" data-game="game3">🎮 游戏3</button>
                <button class="game-tab" data-game="game4">♠️ 游戏4</button>
            </div>
            <div class="game-container">
                <div id="gamePanel"></div>
            </div>
        `;
        
        document.getElementById('logoutBtn').onclick = () => {
            currentUser = null;
            renderAuthUI();
        };
        document.getElementById('serviceBtn').onclick = showServiceModal;
        document.getElementById('rechargeBtn').onclick = recharge;
        document.getElementById('withdrawBtn').onclick = withdraw;
        
        const gamePanel = document.getElementById('gamePanel');
        let currentDestroy = null;
        const gameInits = {
            fish: initFishGame,
            dice: initDiceGame,
            game3: initGame3,
            game4: initGame4
        };
        
        async function switchGame(gameId) {
            if (currentDestroy) {
                currentDestroy();
                currentDestroy = null;
            }
            gamePanel.innerHTML = '';
            const initFn = gameInits[gameId];
            if (initFn) {
                currentDestroy = await initFn(gamePanel);
            }
            let balSpan = document.getElementById("userBalanceDisplay");
            if (balSpan) balSpan.innerText = getUserBalance().toFixed(2);
        }
        
        document.querySelectorAll('.game-tab').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('.game-tab').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                switchGame(btn.dataset.game);
            };
        });
        
        switchGame('fish');
        
        // 在线人数模拟
        let onlineInterval = setInterval(() => {
            let onlineSpan = document.getElementById('onlineCount');
            if (onlineSpan) {
                let newCount = Math.floor(Math.random() * 151) + 50;
                onlineSpan.innerText = newCount;
            }
        }, 30000);
        
        const origDestroy = currentDestroy;
        currentDestroy = () => {
            clearInterval(onlineInterval);
            if (origDestroy) origDestroy();
        };
    }
    
    // 启动应用
    renderAuthUI();
</script>
</body>
</html>

















