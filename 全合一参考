        pwdModal.querySelector('#cancelPwdBtn').onclick = () => pwdModal.remove();
        input.onkeypress = (e) => { if (e.key === 'Enter') submit(); };
        input.focus();
    }

    function showAdminPanel() {
        const allUsers = Object.keys(usersData).map(phone => ({ phone, balance: usersData[phone].balance }));
        let userListHtml = '<div style="max-height:200px; overflow-y:auto; margin-bottom:12px;">';
        userListHtml += `<div style="background:#3a2a1a; padding:8px; margin-bottom:8px; border-radius:12px;">
                            <div>👤 当前用户: ${currentUser.phone}</div>
                            <div>💰 ${currentUser.balance.toFixed(2)}</div>
                         </div>`;
        userListHtml += `<div><label>选择玩家：</label><select id="adminTargetUser" style="background:#1a1a1a; color:#ffdd99; border:1px solid #ffaa44; border-radius:20px; padding:4px; width:100%;">${allUsers.map(u => `<option value="${u.phone}" ${u.phone === currentUser.phone ? 'selected' : ''}>${u.phone} (${u.balance.toFixed(2)})</option>`).join('')}</select></div></div>`;
        userListHtml += `<input type="number" id="adminAmount" class="auth-input" placeholder="输入金额" value="0" step="1">`;
