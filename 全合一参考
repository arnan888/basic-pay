            color: white;
            font-size: 0.9rem;
            text-align: center;
        }
        .auth-buttons { display: flex; gap: 12px; margin: 20px 0; }
        .auth-btn {
            flex: 1;
            background: #c47c3a;
            border: none;
            padding: 10px;
            border-radius: 40px;
