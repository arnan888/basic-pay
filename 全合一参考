    container.innerHTML = `<div class="dice-wrapper" style="background:linear-gradient(145deg,#1a4a2a,#0a2a1a); border-radius:40px; padding:12px;">
        <div style="display:flex; justify-content:center; gap:12px; margin-bottom:12px;">
            <button id="diceAdminBtn" class="grab-btn" style="background:#9b59b6;">👑 管理员</button>
        </div>
        <div style="background:rgba(0,0,0,0.7); border-radius:24px; padding:12px; text-align:center;">
            <div style="display:flex; justify-content:center; gap:12px; margin-bottom:6px;">
                <div class="dice" id="dice1" style="width:60px;height:60px;"></div>
