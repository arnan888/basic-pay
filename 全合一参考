        .admin-input { width: 100%; padding: 8px; margin: 8px 0; border-radius: 12px; background: #0a1a0a; border: 1px solid #ffaa44; color: #fff; }
        .admin-btns { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; margin: 12px 0; }
        .admin-btn { padding: 6px 12px; border-radius: 25px; border: none; font-weight: bold; cursor: pointer; }
        /* 骰宝桌面平铺样式 */
        .dice-wrapper .section-title { font-size: 0.7rem; color: #dddddd; margin: 12px 0 6px 4px; border-left: 3px solid #f7b05e; padding-left: 8px; }
        .dice-wrapper .special-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; margin-bottom: 12px; }
        .dice-wrapper .points-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; margin-bottom: 12px; }
        .dice-wrapper .trio-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; margin-bottom: 12px; }
        .dice-wrapper .bet-card { background: #1f1712; border-radius: 28px; padding: 6px 2px; text-align: center; box-shadow: 0 6px 0 #0a0705; border: 1px solid #6f4f34; cursor: pointer; transition: 0.05s linear; }
        .dice-wrapper .bet-card:active { transform: translateY(3px); box-shadow: 0 3px 0 #0a0705; }
        .dice-wrapper .bet-card.selected { background: #c47c3a; transform: translateY(3px); box-shadow: 0 3px 0 #0a0705; }
        .dice-wrapper .bet-name { font-size: 0.7rem; font-weight: bold; color: #ffddb0; }
        .dice-wrapper .bet-odds { font-size: 0.55rem; color: #dba959; }
        .dice-wrapper .bet-amount { font-size: 0.65rem; font-weight: bold; color: #ffdd88; margin-top: 4px; background: rgba(0,0,0,0.5); border-radius: 20px; padding: 2px; }
        .dice-wrapper .chip:active { transform: translateY(3px); box-shadow: 0 1px 0 #0a0705 !important; }
        .dice-wrapper .action-btn:active { transform: translateY(3px); box-shadow: 0 1px 0 #0a0705 !important; }
        @media (max-width: 480px) {
            .dice-wrapper .dice { width: 50px; height: 50px; }
            .dice-wrapper .dice-face { width: 50px; height: 50px; }
            .dice-wrapper .front { transform: translateZ(25px); }
            .dice-wrapper .back { transform: rotateY(180deg) translateZ(25px); }
            .dice-wrapper .right { transform: rotateY(90deg) translateZ(25px); }
            .dice-wrapper .left { transform: rotateY(-90deg) translateZ(25px); }
            .dice-wrapper .top { transform: rotateX(90deg) translateZ(25px); }
            .dice-wrapper .bottom { transform: rotateX(-90deg) translateZ(25px); }
            .qr-img { width: 140px; height: 140px; }
        }
    </style>
</head>
<body>
<div class="app" id="app"></div>

<script>
    // ==================== 全局用户系统 ====================
    const USERS_KEY = 'double_games_final';
    let usersData = JSON.parse(localStorage.getItem(USERS_KEY)) || {};
    let currentUser = null;

    function saveUsers() { localStorage.setItem(USERS_KEY, JSON.stringify(usersData)); }
    function getUserBalance() { return currentUser ? (usersData[currentUser.phone]?.balance || 1000) : 0; }
    function setUserBalance(amt) { if(currentUser) { usersData[currentUser.phone].balance = Math.max(0, amt); saveUsers(); } }

    function showToast(msg) {
        let toast = document.createElement('div');
        toast.textContent = msg;
        toast.style.cssText = 'position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#000000cc;backdrop-filter:blur(10px);color:#ffaa44;padding:8px 16px;border-radius:40px;font-size:0.7rem;z-index:2001;border:1px solid #ffaa44;';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
    }
    function showService() { showToast("📞 客服热线: 400-888-XXXX"); }

    // ==================== 充值二维码（两个同时显示） ====================
