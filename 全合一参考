            cursor: pointer;
        }
        .auth-note { color: #aa8855; font-size: 0.65rem; }

        /* 用户信息栏 + 充值提现按钮 */
        .user-section {
            background: #1f1711;
            border-radius: 40px;
            padding: 8px 16px;
            display: flex;
