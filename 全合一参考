            container.querySelector('#switchBtn').onclick = switchUser;
            container.querySelector('#historyBtn').onclick = showHistoryModal;
            container.querySelector('#adminEntry').onclick = () => { let pwd=prompt("管理员密码:"); if(pwd===adminPwd) showAdminPanel(); else if(pwd!==null) showToast("密码错误"); };
            container.querySelector('#newUserBtn').onclick = () => { let newId="player_"+Math.floor(Math.random()*100000); container.querySelector('#switchId').value=newId; switchUser(); showToast("新账户："+newId+" 初始余额 "+CONFIG.defaultBalance); };
            diceEl.forEach(d => {
