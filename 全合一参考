        function initDrawers() {
            container.querySelectorAll('.drawer-header').forEach(header => {
                header.addEventListener('click', function() {
                    let drawerId = this.getAttribute('data-drawer');
                    let content = container.querySelector('#'+drawerId);
                    let icon = this.querySelector('.drawer-icon');
                    if (content.classList.contains('open')) { content.classList.remove('open'); icon.innerHTML='▼'; }
