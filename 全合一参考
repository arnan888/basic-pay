    async function settleGame(diceNames) {
        let points = diceNames.map(n=>getPointValue(n)), sum = points.reduce((a,b)=>a+b,0);
        let isTriplet = diceNames[0]===diceNames[1] && diceNames[1]===diceNames[2];
        let totalBet = getFishTotalBet();
        if(totalBet===0) { return false; }
        let userBal = getUserBalance();
        if(totalBet > userBal) { return false; }
        
        setUserBalance(userBal - totalBet);
        
        let winAmount = 0;
        let winDetails = [];
        
        for(let [pid, betVal] of Object.entries(patternBets)) {
            if(betVal===0) continue;
            let occur = diceNames.filter(n=> n === patternIdMap[pid]).length;
            let originalWin = occur > 0;
            let finalWin = shouldWinPattern(originalWin);
            
            if (finalWin) {
                let prize = betVal * (occur + 1);
                winAmount += prize;
                winDetails.push(`${patternIdMap[pid]} x${occur}`);
            }
        }
        
        let bigWin=false, smallWin=false, oddWin=false, evenWin=false, allTripletWin=false, doubleWin=false;
        if(!isTriplet) {
            if(sum>=11 && sum<=17) bigWin=true;
            if(sum>=4 && sum<=10) smallWin=true;
            if(sum%2===1) oddWin=true;
            if(sum%2===0) evenWin=true;
        }
        if(isTriplet) allTripletWin=true;
        if(diceNames.includes("鱼") && diceNames.includes("虾")) doubleWin = true;
        
        if(specialBets.big>0 && bigWin) { winAmount += specialBets.big*2; winDetails.push("大"); }
        if(specialBets.small>0 && smallWin) { winAmount += specialBets.small*2; winDetails.push("小"); }
        if(specialBets.odd>0 && oddWin) { winAmount += specialBets.odd*2; winDetails.push("单"); }
        if(specialBets.even>0 && evenWin) { winAmount += specialBets.even*2; winDetails.push("双"); }
        if(specialBets.allTriplets>0 && allTripletWin) { winAmount += specialBets.allTriplets*24; winDetails.push("全围"); }
        if(specialBets.doubleBet>0 && doubleWin) { winAmount += specialBets.doubleBet*4.5; winDetails.push("双押(鱼+虾)"); }
        
        let net = winAmount - totalBet;
        let newBalance = getUserBalance() + winAmount;
        setUserBalance(newBalance);
        
        if (hasGrabbed) {
            playerBankerBalance -= winAmount;
            if (playerBankerBalance < 0) {
                showFishMsg(`⚠️ 庄家余额不足，自动回收庄家权限！`);
                hasGrabbed = false;
                playerBankerBalance = 0;
                localStorage.setItem(getPlayerBankerKey(), 0);
                updateGrabButtonState();
            } else {
                localStorage.setItem(getPlayerBankerKey(), playerBankerBalance);
            }
        }
        
        lastWinAmount = net;
        updateFishUI();
        
        // 记录开奖结果
        let resultText = diceNames.join("、");
        let winText = winAmount > 0 ? `中奖 ${winAmount}` : `未中奖 (输 ${totalBet})`;
        gameRecords.unshift({
            time: new Date().toLocaleTimeString(),
            dice: resultText,
            result: winText,
            winAmount: winAmount
        });
        if (gameRecords.length > 50) gameRecords.pop();
        
        clearAllBets();
        document.getElementById("userBalanceDisplay").innerText = newBalance.toFixed(2);
        
        updateGrabButtonState();
        return true;
    }
    async function onFishRoll() {
