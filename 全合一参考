                function getHandType(cards) { /* 完整牌型判断 */ const sorted = [...cards].sort((a,b)=>a.rankValue-b.rankValue); const isFlush = cards.every(c=>c.suitColor===cards[0].suitColor); let isStraight=true, straightHigh=0; for(let i=0;i<sorted.length-1;i++){ if(sorted[i+1].rankValue-sorted[i].rankValue!==1){ if(i===sorted.length-2 && sorted[i+1].rankValue===14 && sorted[0].rankValue===2){ const a2345=sorted.every((c,idx)=>idx===0?c.rankValue===2:idx===1?3:idx===2?4:idx===3?5:idx===4?14:false); if(a2345){isStraight=true; straightHigh=5; break;} else isStraight=false;} else isStraight=false; break;} } if(isStraight && !straightHigh) straightHigh=sorted[sorted.length-1].rankValue; const rankCount=new Map(); sorted.forEach(c=>rankCount.set(c.rankValue,(rankCount.get(c.rankValue)||0)+1)); const values=[...rankCount.values()].sort((a,b)=>b-a); const isFour=values[0]===4; const isFullHouse=values[0]===3 && values[1]===2; const isThree=values[0]===3 && values[1]===1; const isTwoPair=values[0]===2 && values[1]===2; const isOnePair=values[0]===2 && values[1]===1; if(isFlush&&isStraight) return {type:9, compareVal:straightHigh, name:'同花顺'}; if(isFour) { let fourRank=0; for(let [r,c] of rankCount) if(c===4) fourRank=r; return {type:8, compareVal:fourRank*100, name:'铁支'}; } if(isFullHouse) { let threeRank=0; for(let [r,c] of rankCount) if(c===3) threeRank=r; return {type:7, compareVal:threeRank*100, name:'葫芦'}; } if(isFlush) return {type:6, compareVal:sorted.map(c=>c.rankValue).reverse().reduce((a,b)=>a*15+b,0), name:'同花'}; if(isStraight) return {type:5, compareVal:straightHigh, name:'顺子'}; if(isThree) { let threeRank=0, kickers=[]; for(let [r,c] of rankCount) if(c===3) threeRank=r; else kickers.push(r); kickers.sort((a,b)=>b-a); return {type:4, compareVal:threeRank*225+kickers[0]*15+kickers[1], name:'三条'}; } if(isTwoPair) { let pairs=[], kicker=0; for(let [r,c] of rankCount) if(c===2) pairs.push(r); else kicker=r; pairs.sort((a,b)=>b-a); return {type:3, compareVal:pairs[0]*225+pairs[1]*15+kicker, name:'两对'}; } if(isOnePair) { let pairRank=0, kickers=[]; for(let [r,c] of rankCount) if(c===2) pairRank=r; else kickers.push(r); kickers.sort((a,b)=>b-a); return {type:2, compareVal:pairRank*3375+kickers[0]*225+kickers[1]*15+kickers[2], name:'一对'}; } const highVals=sorted.map(c=>c.rankValue).reverse(); let cmp=0; highVals.forEach(v=>cmp=cmp*15+v); return {type:1, compareVal:cmp, name:'散牌'}; }
                function compareDun(a,b) { const ta=getHandType(a), tb=getHandType(b); if(ta.type!==tb.type) return ta.type>tb.type?1:-1; if(ta.compareVal>tb.compareVal) return 1; if(ta.compareVal<tb.compareVal) return -1; return 0; }
                function isValidFront(cards) { if(cards.length!==3) return false; const type=getHandType(cards).type; return type<=4; }
                function autoArrange(handCards) { /* 枚举最优摆墩 */ const n=handCards.length; if(n!==13) return null; let best=null, bestScore=-1e9; function comb3(start, chosen){ if(chosen.length===3){ const front=chosen.map(i=>handCards[i]); if(!isValidFront(front)) return; const remaining=[]; for(let i=0;i<13;i++) if(!chosen.includes(i)) remaining.push(i); function comb5(startM, chosenM){ if(chosenM.length===5){ const mid=chosenM.map(i=>handCards[i]); const backIdx=remaining.filter(i=>!chosenM.includes(i)); const back=backIdx.map(i=>handCards[i]); if(compareDun(front,mid)<=0 && compareDun(mid,back)<=0){ const total=getHandType(front).type*10+getHandType(mid).type*30+getHandType(back).type*100; if(total>bestScore){ bestScore=total; best={front,mid,back}; } } return; } for(let i=startM;i<remaining.length;i++){ chosenM.push(remaining[i]); comb5(i+1,chosenM); chosenM.pop(); } } comb5(0,[]); return; } for(let i=start;i<13;i++){ chosen.push(i); comb3(i+1,chosen); chosen.pop(); } } comb3(0,[]); if(!best){ const sorted=[...handCards].sort((a,b)=>b.rankValue-a.rankValue); best={front:sorted.slice(0,3), mid:sorted.slice(3,8), back:sorted.slice(8,13)}; } return best; }
                
