
!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>潮汕葫芦鱼 · 广东十三张 | 双游戏大厅</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: #1a120c;
            background-image: radial-gradient(circle at 20% 30%, rgba(200, 140, 70, 0.15) 2%, transparent 2.5%);
            background-size: 28px 28px;
            font-family: 'Segoe UI', 'PingFang SC', Roboto, 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
            padding: 12px;
        }

        .app {
            max-width: 550px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* 游戏切换导航 */
        .game-nav {
            background: linear-gradient(145deg, #2a241e 0%, #1f1a15 100%);
            border-radius: 60px;
            padding: 6px;
            display: flex;
            gap: 8px;
            border: 1px solid #ffaa44;
        }
        .game-tab {
            flex: 1;
            background: transparent;
            border: none;
            padding: 8px 0;
            border-radius: 50px;
            font-weight: bold;
            font-size: 0.85rem;
            color: #ccaa77;
            cursor: pointer;
            transition: 0.2s;
        }
        .game-tab.active {
            background: #c47c3a;
            color: #2f1b0a;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
        }

        /* 用户信息栏 */
        .user-section {
            background: #1f1711;
            border-radius: 40px;
            padding: 8px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 8px;
        }
        .user-info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }
        .user-info-row span { color: #ffdd99; font-size: 0.75rem; }
        .btn-group { display: flex; gap: 8px; }
        .logout-btn, .service-btn {
            background: #734c2e;
            border: none;
            padding: 4px 12px;
            border-radius: 30px;
            color: #ffe3b3;
            font-size: 0.7rem;
            cursor: pointer;
        }
        .service-btn { background: #2e7d32; }
        .charge-withdraw-row {
            display: flex;
            gap: 10px;
            justify-content: center;
        }
        .charge-btn, .withdraw-btn {
            background: #c47c3a;
            border: none;
            padding: 5px 20px;
            border-radius: 30px;
            color: #2f1b0a;
            font-weight: bold;
            font-size: 0.75rem;
            cursor: pointer;
            flex: 1;
            text-align: center;
            box-shadow: 0 2px 0 #764e26;
        }
        .withdraw-btn { background: #734c2e; color: #ffe3b3; box-shadow: 0 2px 0 #3f2a1a; }

        /* 游戏容器 */
        .game-container {
            background: linear-gradient(145deg, #362a1f 0%, #251e16 100%);
            border-radius: 48px;
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            min-height: 550px;
        }
        .game-panel {
            display: none;
        }
        .game-panel.active {
            display: block;
        }

        /* 十三张专用容器 */
        #poker3d-container {
            width: 100%;
            height: 550px;
            position: relative;
            overflow: hidden;
            background: #0a1a1f;
        }
    </style>
</head>
<body>
<div class="app" id="app"></div>

<script>
    // ==================== 全局用户系统 (共享) ====================
    const USERS_KEY = 'double_game_users_v2';
    let usersData = JSON.parse(localStorage.getItem(USERS_KEY)) || {};
    let currentUser = null;
    let adminPassword = localStorage.getItem('admin_pwd') || 'admin123';

    function saveUsers() { localStorage.setItem(USERS_KEY, JSON.stringify(usersData)); }
    function getUserBalance() { return currentUser ? (usersData[currentUser.phone]?.balance || 1000) : 0; }
    function setUserBalance(amt) { if(currentUser) { usersData[currentUser.phone].balance = Math.max(0, amt); saveUsers(); } }

    function showToast(msg) {
        let toast = document.createElement('div');
        toast.textContent = msg;
        toast.style.cssText = 'position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#000000cc;backdrop-filter:blur(10px);color:#ffaa44;padding:8px 16px;border-radius:40px;font-size:0.7rem;z-index:2001;border:1px solid #ffaa44;';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
    }

    function showService() { showToast("📞 客服热线: 400-888-XXXX (24小时服务)"); }
    function recharge() { showToast("💎 充值请联系管理员（筹码1k连点三下进入后台）"); }
    function withdraw() { showToast("💰 提现请联系管理员（筹码1k连点三下进入后台）"); }

    // ============================================================
    // =================== 游戏一：潮汕葫芦鱼 (二十人房) ===================
    // ============================================================
    let fishDestroyFunc = null;
    let fishInterval = null;
    
    function initFishGame(container) {
        if (fishDestroyFunc) fishDestroyFunc();
        container.innerHTML = ''; // 清空
        
        // 注入葫芦鱼HTML结构 (完整游戏界面)
        const fishHTML = `
            <div class="fish-game-wrapper">
                <div class="stats-panel" style="display:flex; justify-content:space-between; gap:6px; padding:8px 12px; background:#1f1711; border-bottom:1px solid #644a33;">
                    <div class="stat-card" style="background:#1a130d; border-radius:30px; padding:4px 8px; flex:1; text-align:center;"><div class="stat-label" style="font-size:0.55rem; color:#e2bc89;">💰 庄家余额</div><div class="stat-value" id="fishBalanceValue" style="font-size:1rem; font-weight:800; color:#f9d792;">10000</div></div>
                    <div class="stat-card" style="background:#1a130d; border-radius:30px; padding:4px 8px; flex:1; text-align:center;"><div class="stat-label" style="font-size:0.55rem; color:#e2bc89;">🎲 总押注</div><div class="stat-value" id="totalBetValue">0</div></div>
                    <div class="stat-card" style="background:#1a130d; border-radius:30px; padding:4px 8px; flex:1; text-align:center;"><div class="stat-label" style="font-size:0.55rem; color:#e2bc89;">🏆 上局净利</div><div class="stat-value" id="lastWinValue">0</div></div>
                </div>
                <div class="dice-area" style="background:#2a211a; margin:12px 12px 8px; border-radius:50px; padding:12px; text-align:center; box-shadow:inset 0 0 0 2px #5e4230, 0 6px 12px black; position:relative;">
                    <div class="dice-title" style="font-size:0.65rem; color:#f5c28e; margin-bottom:6px;">⚡ 三骰开彩 · 鱼虾蟹葫芦金钱鸡 ⚡</div>
                    <div class="dice-box" style="display:flex; justify-content:center; gap:12px; position:relative;">
                        <div class="dice" style="background:#fff2df; width:70px; height:70px; border-radius:18px; display:flex; align-items:center; justify-content:center; font-size:2.8rem; box-shadow:0 5px 0 #926b42;">🎲</div>
                        <div class="dice" style="background:#fff2df; width:70px; height:70px; border-radius:18px; display:flex; align-items:center; justify-content:center; font-size:2.8rem; box-shadow:0 5px 0 #926b42;">🎲</div>
                        <div class="dice" style="background:#fff2df; width:70px; height:70px; border-radius:18px; display:flex; align-items:center; justify-content:center; font-size:2.8rem; box-shadow:0 5px 0 #926b42;">🎲</div>
                    </div>
                    <div id="fishDiceCover" style="position:absolute; top:0; left:0; width:100%; height:100%; background:radial-gradient(circle at 30% 30%, rgba(0,0,0,0.9), #2c1e14); backdrop-filter:blur(6px); border-radius:50px; display:flex; align-items:center; justify-content:center; flex-direction:column; z-index:15; transition:all 0.5s cubic-bezier(0.34,1.1,0.55,1); border:2px solid #cb9e6b;">
                        <span style="font-size:3rem;">🏺</span><div class="cover-text" style="font-size:0.65rem; background:#00000099; padding:2px 12px; border-radius:30px; margin-top:6px;">骰盅未开</div>
                    </div>
                </div>
                <div class="bet-sections" style="padding:0 12px 8px;">
                    <div class="section-title" style="font-size:0.7rem; color:#ffd49f; margin:8px 0 6px 4px; border-left:3px solid #f7b05e; padding-left:8px;">🐟 六门押注 (按次数赔)</div>
                    <div class="bet-grid" id="patternGrid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:8px;"></div>
                    <div class="section-title" style="font-size:0.7rem; color:#ffd49f; margin:8px 0 6px 4px; border-left:3px solid #f7b05e; padding-left:8px;">🎯 特殊投注</div>
                    <div class="special-grid" id="specialGrid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:8px;"></div>
                </div>
                <div class="chip-bar" style="background:#2a1f16; margin:6px 12px 10px; padding:6px 8px; border-radius:40px; display:flex; justify-content:center; gap:8px; flex-wrap:wrap;">
                    <div class="chip" data-chip="20" style="background:#ebbc7e; color:#3a240f; font-weight:bold; font-size:0.7rem; padding:3px 10px; border-radius:35px; cursor:pointer;">20</div>
                    <div class="chip" data-chip="50">50</div>
                    <div class="chip" data-chip="100" class="selected">100</div>
                    <div class="chip" data-chip="500">500</div>
                    <div class="chip" data-chip="1000" style="background:radial-gradient(#e74c3c, #c0392b); color:#fff;">1k</div>
                </div>
                <div class="action-bar" style="display:flex; justify-content:center; gap:8px; padding:6px 12px 14px; flex-wrap:wrap;">
                    <button id="fishRollBtn" class="action-btn primary" style="background:#c47c3a; border:none; padding:5px 14px; font-size:0.75rem; font-weight:bold; border-radius:35px; color:#2f1b0a; box-shadow:0 3px 0 #764e26; cursor:pointer;">🎲 开骰！</button>
                    <button id="fishResetBetBtn" class="action-btn" style="background:#734c2e; border:none; padding:5px 14px; font-size:0.75rem; font-weight:bold; border-radius:35px; color:#ffe3b3; box-shadow:0 3px 0 #3f2a1a; cursor:pointer;">🧹 清空下注</button>
                    <button id="fishResetGameBtn" class="action-btn" style="background:#734c2e; border:none; padding:5px 14px; font-size:0.75rem; font-weight:bold; border-radius:35px; color:#ffe3b3; box-shadow:0 3px 0 #3f2a1a; cursor:pointer;">💺 重置庄家</button>
                </div>
                <div class="message-area" id="fishMsgArea" style="background:#1c140e; margin:0 12px 12px; border-radius:35px; padding:6px 10px; font-size:0.65rem; color:#dbbc8c; text-align:center; min-height:48px;">庄家坐镇 | 骰盅缓慢开启 → 骰子摇动</div>
                <div class="seats-section" style="background:#1e1813; border-radius:48px; overflow:hidden;">
                    <div class="seats-header" style="background:#4a3322; padding:6px 12px; text-align:center;"><h3 style="color:#ffefcf; font-size:0.8rem;">🎲 二十人座席</h3></div>
                    <div class="seats-grid" id="seatsGrid" style="display:grid; grid-template-columns:repeat(5,1fr); gap:6px; padding:10px;"></div>
                    <footer style="background:transparent; padding:6px; text-align:center; color:#aa8259;">🎮 实时在线玩家 | 筹码1k连点三下打开管理后台</footer>
                </div>
            </div>
        `;
        container.innerHTML = fishHTML;
        
        // 添加局部样式 (作用域限定)
        const style = document.createElement('style');
        style.textContent = `
            .fish-game-wrapper .chip { background:#ebbc7e; color:#3a240f; font-weight:bold; font-size:0.7rem; padding:3px 10px; border-radius:35px; cursor:pointer; box-shadow:0 2px 0 #8b5a2e; display:inline-block; text-align:center; }
            .fish-game-wrapper .chip.selected { background:#f7c56e; box-shadow:0 0 0 1px #ffefb0, 0 2px 0 #7a4b22; }
            .fish-game-wrapper .bet-card { background:#1f1712; border-radius:28px; padding:4px 2px; text-align:center; box-shadow:0 2px 0 #0a0705; border:1px solid #6f4f34; }
            .fish-game-wrapper .bet-icon { font-size:1.4rem; background:#2f231c; width:36px; height:36px; line-height:36px; margin:0 auto 3px; border-radius:50%; }
            .fish-game-wrapper .bet-name { font-size:0.65rem; font-weight:bold; color:#ffddb0; }
            .fish-game-wrapper .bet-odds { font-size:0.5rem; color:#dba959; }
            .fish-game-wrapper .bet-amount { background:#0c0907; border-radius:30px; padding:2px 4px; margin:4px 3px 0; display:flex; justify-content:space-between; align-items:center; gap:2px; }
            .fish-game-wrapper .bet-amount span { color:#ffbc6e; font-size:0.7rem; background:#2a1c12; padding:1px 5px; border-radius:25px; min-width:32px; }
            .fish-game-wrapper .btn-chip { background:#523b26; border:none; color:#fce2b4; font-weight:bold; width:24px; height:24px; border-radius:25px; font-size:0.8rem; cursor:pointer; }
            .fish-game-wrapper .seat-card { background:#1a130d; border-radius:16px; padding:4px 2px; text-align:center; border:1px solid #6f4f34; }
            .fish-game-wrapper .seat-card.occupied { background:#2f4127; }
            .fish-game-wrapper .seat-number { font-size:0.5rem; color:#dba24b; }
            .fish-game-wrapper .player-name { font-weight:bold; font-size:0.55rem; margin:2px 0; color:#ffefcf; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        `;
        container.appendChild(style);
        
        // ========== 葫芦鱼游戏逻辑变量 ==========
        let fishBalance = parseInt(localStorage.getItem('fish_banker_balance')) || 10000;
        let patternBets = { fish:0, shrimp:0, crab:0, calabash:0, coin:0, chicken:0 };
        let specialBets = { big:0, small:0, odd:0, even:0, allTriplets:0 };
        let currentChip = 100;
        let lastWinAmount = 0;
        let isRolling = false;
        let fishPlayers = [];
        let nextPlayerId = 100;
        const namePool = ["阿强","老李","虾妹","蟹叔","金钱哥","鸡姐","小陈","骰子手","好运","锦鲤","鱼神","虾兵","蟹将","葫芦仙","铜钱","凤姐","阿珍","闲人","福仔","潮汕仔"];
        const patternList = ["鱼","虾","蟹","葫芦","金钱","鸡"];
        const patternIdMap = { fish:"鱼", shrimp:"虾", crab:"蟹", calabash:"葫芦", coin:"金钱", chicken:"鸡" };
        
        function getFishTotalBet() {
            return Object.values(patternBets).reduce((a,b)=>a+b,0) + Object.values(specialBets).reduce((a,b)=>a+b,0);
        }
        function updateFishUI() {
            const balanceSpan = container.querySelector('#fishBalanceValue');
            if(balanceSpan) balanceSpan.innerText = fishBalance;
            const totalSpan = container.querySelector('#totalBetValue');
            if(totalSpan) totalSpan.innerText = getFishTotalBet();
            const lastSpan = container.querySelector('#lastWinValue');
            if(lastSpan) lastSpan.innerText = lastWinAmount;
            for(let id of Object.keys(patternBets)) {
                let span = container.querySelector(`#bet_${id}`);
                if(span) span.innerText = patternBets[id];
            }
            for(let id of Object.keys(specialBets)) {
                let span = container.querySelector(`#bet_special_${id}`);
                if(span) span.innerText = specialBets[id];
            }
        }
        function showFishMsg(msg) {
            const msgDiv = container.querySelector('#fishMsgArea');
            if(msgDiv) msgDiv.innerText = msg;
            setTimeout(() => { if(msgDiv && msgDiv.innerText === msg) msgDiv.innerText = "🎲 点击开骰 | 骰盅缓慢开启开奖"; }, 2500);
        }
        function addBet(type, id, val) {
            let target = (type === 'pattern') ? patternBets : specialBets;
            if(target[id] === undefined) return;
            let totalNow = getFishTotalBet();
            let userBal = getUserBalance();
            if(totalNow + val > userBal) { showFishMsg(`余额不足，无法加注 ${val}`); return; }
            target[id] += val;
            updateFishUI();
            let name = (type === 'pattern') ? patternIdMap[id] : id;
            showFishMsg(`➕ ${name} +${val}`);
        }
        function subBet(type, id, val) {
            let target = (type === 'pattern') ? patternBets : specialBets;
            if(target[id] === undefined) return;
            let old = target[id];
            let newVal = Math.max(0, old - val);
            if(old !== newVal) {
                target[id] = newVal;
                updateFishUI();
                let name = (type === 'pattern') ? patternIdMap[id] : id;
                showFishMsg(`➖ ${name} -${val}`);
            }
        }
        function clearAllBets() {
            for(let k of Object.keys(patternBets)) patternBets[k]=0;
            for(let k of Object.keys(specialBets)) specialBets[k]=0;
            updateFishUI();
            showFishMsg("清空所有下注");
        }
        function resetFishGame() {
            fishBalance = 10000;
            localStorage.setItem('fish_banker_balance', fishBalance);
            clearAllBets();
            lastWinAmount = 0;
            updateFishUI();
            const diceEls = container.querySelectorAll(".dice");
            diceEls.forEach(d => d.innerHTML = "🎲");
            const cover = container.querySelector('#fishDiceCover');
            if(cover) {
                cover.style.display = "flex";
                cover.style.transform = "translateY(0) scale(1)";
                cover.style.opacity = "1";
                cover.style.visibility = "visible";
            }
            showFishMsg("庄家重置，本金 10000 文，骰盅已复位");
        }
        async function animateRolling(finalNames) {
            const diceEls = container.querySelectorAll(".dice");
            const iconMap = { "鱼":"🐟","虾":"🦐","蟹":"🦀","葫芦":"🏺","金钱":"💰","鸡":"🐔" };
            for(let step=0; step<8; step++) {
                await new Promise(r=>setTimeout(r, 70));
                for(let i=0;i<3;i++) {
                    let rand = patternList[Math.floor(Math.random()*6)];
                    diceEls[i].innerHTML = iconMap[rand];
                }
            }
            for(let i=0;i<3;i++) diceEls[i].innerHTML = iconMap[finalNames[i]];
        }
        function getPointValue(pname) { const m={"鱼":1,"虾":2,"蟹":3,"葫芦":4,"金钱":5,"鸡":6}; return m[pname]||0; }
        async function settleGame(diceNames) {
            let points = diceNames.map(n=>getPointValue(n));
            let sum = points.reduce((a,b)=>a+b,0);
            let isTriplet = diceNames[0]===diceNames[1] && diceNames[1]===diceNames[2];
            let totalBet = getFishTotalBet();
            if(totalBet===0) { showFishMsg("没有下注，无法结算"); return false; }
            let userBal = getUserBalance();
            if(totalBet > userBal) { showFishMsg("下注超额，请检查余额"); return false; }
            setUserBalance(userBal - totalBet);
            let winAmount = 0;
            let winDetails = [];
            for(let [pid, betVal] of Object.entries(patternBets)) {
                if(betVal===0) continue;
                let occur = diceNames.filter(n=> n === patternIdMap[pid]).length;
                if(occur>0) {
                    let prize = betVal * (occur+1);
                    winAmount += prize;
                    winDetails.push(`${patternIdMap[pid]} x${occur}`);
                }
            }
            let bigWin=false, smallWin=false, oddWin=false, evenWin=false, allTripletWin=false;
            if(!isTriplet) {
                if(sum>=11 && sum<=17) bigWin=true;
                if(sum>=4 && sum<=10) smallWin=true;
                if(sum%2===1) oddWin=true;
                if(sum%2===0) evenWin=true;
            }
            if(isTriplet) allTripletWin=true;
            if(specialBets.big>0 && bigWin) { winAmount += specialBets.big*2; winDetails.push("大"); }
            if(specialBets.small>0 && smallWin) { winAmount += specialBets.small*2; winDetails.push("小"); }
            if(specialBets.odd>0 && oddWin) { winAmount += specialBets.odd*2; winDetails.push("单"); }
            if(specialBets.even>0 && evenWin) { winAmount += specialBets.even*2; winDetails.push("双"); }
            if(specialBets.allTriplets>0 && allTripletWin) { winAmount += specialBets.allTriplets*25; winDetails.push("全围"); }
            
            let net = winAmount - totalBet;
            let newBalance = getUserBalance() + winAmount;
            setUserBalance(newBalance);
            lastWinAmount = net;
            updateFishUI();
            let diceShow = diceNames.join("、");
            if(winAmount>0) showFishMsg(`🎲 ${diceShow} 净赢+${net}  [${winDetails.join(',')}]`);
            else showFishMsg(`😢 ${diceShow} 亏损 ${totalBet}`);
            clearAllBets();
            // 更新顶部余额显示
            const balanceSpan = document.getElementById("userBalanceDisplay");
            if(balanceSpan) balanceSpan.innerText = newBalance.toFixed(2);
            return true;
        }
        async function onFishRoll() {
            if(isRolling) return;
            let total = getFishTotalBet();
            if(total === 0) { showFishMsg("请先下注再开骰！"); return; }
            if(total > getUserBalance()) { showFishMsg("下注总额超过余额，请减少下注"); return; }
            const diceCover = container.querySelector('#fishDiceCover');
            if(!diceCover) return;
            isRolling = true;
            diceCover.style.transform = "translateY(-70px) scale(0.6)";
            diceCover.style.opacity = "0";
            await new Promise(r=>setTimeout(r, 550));
            diceCover.style.display = "none";
            
            let finalResult = [
                patternList[Math.floor(Math.random()*6)],
                patternList[Math.floor(Math.random()*6)],
                patternList[Math.floor(Math.random()*6)]
            ];
            await animateRolling(finalResult);
            await settleGame(finalResult);
            await new Promise(r=>setTimeout(r, 1500));
            const diceEls = container.querySelectorAll(".dice");
            diceEls.forEach(d => d.innerHTML = "🎲");
            diceCover.style.display = "flex";
            diceCover.style.transform = "translateY(0) scale(1)";
            diceCover.style.opacity = "1";
            diceCover.style.visibility = "visible";
            isRolling = false;
            showFishMsg("骰盅已复位，可继续下注");
        }
        
        function renderSeats() {
            const seatsGrid = container.querySelector('#seatsGrid');
            if(!seatsGrid) return;
            seatsGrid.innerHTML = "";
            for(let i=1; i<=20; i++) {
                const player = fishPlayers.find(p => p.seatIndex === i);
                const isOccupied = !!player;
                const seatDiv = document.createElement("div");
                seatDiv.className = `seat-card ${isOccupied ? "occupied" : ""}`;
