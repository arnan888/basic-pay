        let totalNeed = Object.values(lastBet).reduce((a,b)=>a+b,0);
        if (totalNeed>currentBalance) { showToast("余额不足，无法续押"); return; }
        for (let k in bets) bets[k]=0;
        for (let k in lastBet) bets[k]=lastBet[k];
        currentBalance -= totalNeed;
        setUserBalance(currentBalance);
        updateUI();
        if (!isDrawing && !isBetLocked) drawWithCover();
    }
    
    // 抢庄功能
    const diceGrabBtn = container.querySelector('#diceGrabBtn');
    function updateGrabButtonState() {
        const curBalance = getUserBalance();
        if (hasGrabbed) {
            diceGrabBtn.disabled = true;
            diceGrabBtn.textContent = '🏆 已抢庄';
        } else if (curBalance >= 2001) {
            diceGrabBtn.disabled = false;
            diceGrabBtn.textContent = '🎲 抢庄 (需2001文)';
        } else {
            diceGrabBtn.disabled = true;
            diceGrabBtn.textContent = `🎲 抢庄 (余额不足，需2001文)`;
        }
    }
    
    async function grabBanker() {
        if (hasGrabbed) {
            showToast("您已经是庄家了！");
            return;
        }
        const userBalance = getUserBalance();
        if (userBalance < 2001) {
            showToast(`余额不足2001文，无法抢庄！当前余额: ${userBalance}`);
            return;
        }
        const newUserBalance = userBalance - 2001;
        setUserBalance(newUserBalance);
        playerBankerBalance = 2001;
        hasGrabbed = true;
        localStorage.setItem('dice_player_banker_balance', playerBankerBalance);
        updateUI();
        updateGrabButtonState();
        document.getElementById("userBalanceDisplay").innerText = newUserBalance.toFixed(2);
        showToast("抢庄成功！您现在不能下注，只能坐庄。");
        clearAllBets();
        container.querySelectorAll(".chip").forEach(chip => {
            chip.style.pointerEvents = "none";
            chip.style.opacity = "0.5";
        });
    }
    
    if (diceGrabBtn) {
        diceGrabBtn.onclick = grabBanker;
        updateGrabButtonState();
    }
    
    const savedBanker = localStorage.getItem('dice_player_banker_balance');
    if (savedBanker && parseInt(savedBanker) > 0) {
        hasGrabbed = true;
        playerBankerBalance = parseInt(savedBanker);
        updateGrabButtonState();
        container.querySelectorAll(".chip").forEach(chip => {
            chip.style.pointerEvents = "none";
            chip.style.opacity = "0.5";
        });
    }
    
    // 开奖记录存储
    let gameRecords = [];
    
    async function drawWithCover() {
        if (isDrawing) return;
        let totalBet = Object.values(bets).reduce((a,b)=>a+b,0);
        if (totalBet===0) { showToast("请先下注"); return; }
        if (totalBet>currentBalance) { showToast("余额不足，无法开奖"); return; }
        isDrawing=true; isBetLocked=true;
        
        // 生成随机点数（1-6）
        let d1 = Math.floor(Math.random() * 6) + 1;
        let d2 = Math.floor(Math.random() * 6) + 1;
        let d3 = Math.floor(Math.random() * 6) + 1;
        
        let {total,types} = getResultInfo(d1,d2,d3);
        let winAmounts = [];
        if (types.includes('BIG') && bets['BIG']>0) winAmounts.push(bets['BIG']*2);
        if (types.includes('SMALL') && bets['SMALL']>0) winAmounts.push(bets['SMALL']*2);
        if (types.includes('ODD') && bets['ODD']>0) winAmounts.push(bets['ODD']*2);
        if (types.includes('EVEN') && bets['EVEN']>0) winAmounts.push(bets['EVEN']*2);
        if (bets[total]>0) winAmounts.push(bets[total]*CONFIG.odds[total]);
        for (let t of types) {
            if (t.startsWith('TRIPLE_') && bets[t]>0) winAmounts.push(bets[t]*CONFIG.odds[t]);
            if (t==='ALL_TRIPLE' && bets['ALL_TRIPLE']>0) winAmounts.push(bets['ALL_TRIPLE']*CONFIG.odds['ALL_TRIPLE']);
        }
        let totalWin = winAmounts.reduce((a,b)=>a+b,0);
        
        startRollingNumber(totalWin);
        await startRolling([d1, d2, d3]);
        totalEl.innerText = total;
        currentBalance += totalWin;
        setUserBalance(currentBalance);
        
        if (hasGrabbed) {
            playerBankerBalance -= totalWin;
            if (playerBankerBalance < 0) {
                showToast(`⚠️ 庄家余额不足，自动回收庄家权限！`);
                hasGrabbed = false;
                playerBankerBalance = 0;
                localStorage.setItem('dice_player_banker_balance', 0);
                updateGrabButtonState();
                container.querySelectorAll(".chip").forEach(chip => {
                    chip.style.pointerEvents = "auto";
                    chip.style.opacity = "1";
                });
            } else {
                localStorage.setItem('dice_player_banker_balance', playerBankerBalance);
            }
        }
        
        // 记录开奖结果
        let resultText = `点数和${total}`;
        let winText = totalWin > 0 ? `中奖 ${totalWin}` : `未中奖`;
        gameRecords.unshift({
            time: new Date().toLocaleTimeString(),
            dice: `${d1},${d2},${d3}`,
            result: resultText,
            win: totalWin,
            isWin: totalWin > 0
        });
        if (gameRecords.length > 50) gameRecords.pop();
        
        // 清空下注
        for (let k in bets) bets[k]=0;
        updateUI();
        lastBet = JSON.parse(JSON.stringify(bets));
        
        let winTextPopup = totalWin>0 ? `🎉 恭喜！ 赢 ${totalWin.toFixed(2)} 🎉` : `😭 很遗憾 输 ${totalBet.toFixed(2)} 😭`;
        let pop = document.createElement('div'); pop.className='result-popup '+(totalWin>0?'win':'lose'); pop.textContent=winTextPopup; document.body.appendChild(pop); setTimeout(()=>pop.classList.add('show'),10); setTimeout(()=>{pop.classList.remove('show');setTimeout(()=>pop.remove(),300);},2000);
        
        setTimeout(()=>{ isDrawing=false; isBetLocked=false; startCountdown(CONFIG.countdownSeconds); },5000);
    }
    
    // 开奖记录弹窗（类似葫芦鱼）
    function showRecordModal() {
        if (gameRecords.length === 0) {
            showToast("暂无开奖记录");
            return;
        }
        let html = '<div style="max-height:400px; overflow-y:auto; padding:8px;">';
        gameRecords.forEach(rec => {
            html += `<div style="background:#2a241e; margin-bottom:8px; padding:8px; border-radius:12px; border-left:3px solid #ffaa44;">
                        <div style="display:flex; justify-content:space-between; font-size:0.7rem; color:#ffaa66;">${rec.time}</div>
                        <div style="font-size:1rem; font-weight:bold; color:#ffdd99; margin:4px 0;">🎲 ${rec.dice}</div>
                        <div style="font-size:0.8rem; color:${rec.win > 0 ? '#4caf50' : '#f44336'}">${rec.win > 0 ? `赢 ${rec.win}` : '输'}</div>
                     </div>`;
        });
        html += '</div><button id="closeRecordModal" style="background:#ffaa44; border:none; padding:8px 16px; border-radius:30px; margin-top:12px; cursor:pointer;">关闭</button>';
        
        const modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `<div class="modal-content" style="max-width:450px;"><h3 style="margin-bottom:12px;">📜 开奖记录</h3>${html}</div>`;
        document.body.appendChild(modal);
        modal.querySelector('#closeRecordModal').onclick = () => modal.remove();
    }
    
    function startCountdown(sec) {
        if (countdownInterval) clearInterval(countdownInterval);
        let c = sec, cdSpan = container.querySelector('#countdownNum');
        cdSpan.innerText = c; cdSpan.classList.remove('countdown-warning');
        isBetLocked = false;
        countdownInterval = setInterval(() => {
            if (c<=1) { clearInterval(countdownInterval); countdownInterval=null; isBetLocked=true; drawWithCover(); }
            else { c--; cdSpan.innerText = c; if (c<=5) cdSpan.classList.add('countdown-warning'); }
        }, 1000);
    }
    
    function refreshBalance() { currentBalance = getUserBalance(); updateUI(); showToast("余额已刷新"); }
    
    let adminPanel = null;
    function showAdminPanel() {
        if (adminPanel) { adminPanel.remove(); adminPanel=null; return; }
        let panel = document.createElement('div'); panel.className='modal';
        panel.innerHTML = `
            <div class="modal-content">
                <h3>🔐 管理员面板</h3>
                <div style="background:#2a2a2a; padding:8px; border-radius:16px; margin-bottom:12px;">
                    <div>👤 当前用户: ${currentUser.phone}</div>
                    <div>💰 余额: ${getUserBalance().toFixed(2)}</div>
                </div>
                <div id="adminUserList" class="admin-user-list"></div>
                <div>当前：<strong id="adminSelectedUser">${currentUserId}</strong></div>
                <input type="number" id="adminAmount" placeholder="金额" value="0">
                <div class="admin-btns">
                    <button id="adminAdd">上分</button>
                    <button id="adminSub">下分</button>
                    <button id="adminQuery">查询</button>
                    <button id="adminReset">重置</button>
                    <button id="adminPwd">改密</button>
                </div>
                <button id="adminClose">关闭</button>
            </div>
        `;
        document.body.appendChild(panel); adminPanel=panel;
        function refreshList() {
            let listDiv = panel.querySelector('#adminUserList');
            listDiv.innerHTML = Object.keys(usersData).map(uid => `<div class="admin-user ${uid===currentUserId?'selected':''}" data-uid="${uid}">${uid} (${usersData[uid].balance.toFixed(2)})</div>`).join('');
            listDiv.querySelectorAll('.admin-user').forEach(div => {
                div.onclick = () => {
                    currentUserId = div.dataset.uid;
                    panel.querySelector('#adminSelectedUser').innerText = currentUserId;
                    refreshList();
                };
            });
        }
        refreshList();
        panel.querySelector('#adminAdd').onclick = () => {
            let amt = parseFloat(panel.querySelector('#adminAmount').value);
            if (isNaN(amt)||amt<=0) return;
            let newBal = usersData[currentUserId].balance + amt;
            usersData[currentUserId].balance = newBal;
            saveUsers();
            if (currentUserId === currentUser.phone) {
                currentUser.balance = newBal;
                document.getElementById("userBalanceDisplay").innerText = newBal.toFixed(2);
                currentBalance = newBal;
                updateUI();
            }
            showToast(`上分成功，${currentUserId} 余额 ${newBal.toFixed(2)}`);
            refreshList();
            panel.querySelector('#adminAmount').value = '';
        };
        panel.querySelector('#adminSub').onclick = () => {
            let amt = parseFloat(panel.querySelector('#adminAmount').value);
            if (isNaN(amt)||amt<=0) return;
            let cur = usersData[currentUserId].balance;
            if (cur < amt) { showToast("余额不足"); return; }
            let newBal = cur - amt;
            usersData[currentUserId].balance = newBal;
            saveUsers();
            if (currentUserId === currentUser.phone) {
                currentUser.balance = newBal;
                document.getElementById("userBalanceDisplay").innerText = newBal.toFixed(2);
                currentBalance = newBal;
                updateUI();
            }
            showToast(`下分成功，${currentUserId} 余额 ${newBal.toFixed(2)}`);
            refreshList();
            panel.querySelector('#adminAmount').value = '';
        };
        panel.querySelector('#adminQuery').onclick = () => showToast(`${currentUserId} 余额: ${usersData[currentUserId].balance.toFixed(2)}`);
        panel.querySelector('#adminReset').onclick = () => {
            if(confirm(`重置 ${currentUserId} 余额为 ${CONFIG.defaultBalance}？`)) {
                usersData[currentUserId].balance = CONFIG.defaultBalance;
                saveUsers();
                if (currentUserId === currentUser.phone) {
                    currentUser.balance = CONFIG.defaultBalance;
                    document.getElementById("userBalanceDisplay").innerText = CONFIG.defaultBalance.toFixed(2);
                    currentBalance = CONFIG.defaultBalance;
                    updateUI();
                }
                showToast("重置成功");
                refreshList();
            }
        };
        panel.querySelector('#adminPwd').onclick = () => {
            let old = prompt("当前密码:");
            if(old !== adminPwd) { showToast("密码错误"); return; }
            let newPwd = prompt("新密码(至少6位):");
            if(newPwd && newPwd.length >= 6) {
                adminPwd = newPwd;
                localStorage.setItem('dice_admin_pwd', newPwd);
                showToast("密码修改成功");
            } else if(newPwd) showToast("密码至少6位");
        };
        panel.querySelector('#adminClose').onclick = () => { panel.remove(); adminPanel=null; };
    }
    
    function init() {
        container.querySelectorAll('.chip').forEach(chip => {
            chip.onclick = function() { 
                if (hasGrabbed) { showToast("您是庄家，不能下注！"); return; }
                selectedChip = parseInt(this.dataset.val); 
                container.querySelector('#selectedChip').innerText = selectedChip; 
                container.querySelectorAll('.chip').forEach(c=>c.classList.remove('selected-chip')); 
                this.classList.add('selected-chip'); 
            };
        });
        container.querySelectorAll('.special-card').forEach(card => card.onclick = () => { if (hasGrabbed) { showToast("您是庄家，不能下注！"); return; } addBet(card.dataset.type); });
        container.querySelectorAll('.point-card').forEach(card => card.onclick = () => { if (hasGrabbed) { showToast("您是庄家，不能下注！"); return; } addBet(parseInt(card.dataset.point)); });
        container.querySelectorAll('.trio-card').forEach(card => card.onclick = () => { if (hasGrabbed) { showToast("您是庄家，不能下注！"); return; } addBet(card.dataset.type); });
        container.querySelector('#clearAllBtn').onclick = clearAllBets;
        container.querySelector('#repeatBtn').onclick = repeatLastBet;
        container.querySelector('#refreshBtn').onclick = refreshBalance;
        container.querySelector('#betBtn').onclick = () => { if(!isDrawing && !isBetLocked) drawWithCover(); };
        container.querySelector('#adminEntry').onclick = () => { let pwd=prompt("管理员密码:"); if(pwd===adminPwd) showAdminPanel(); else if(pwd!==null) showToast("密码错误"); };
        
        // 开奖记录按钮
        const historyBtn = container.querySelector('#showDiceHistoryBtn');
        if (historyBtn) historyBtn.onclick = showRecordModal;
        
        // 初始化骰子显示为1点
        diceEl.forEach(d => setDiceValue(d, 1));
        totalEl.innerText = 3;
        updateUI(); startCountdown(CONFIG.countdownSeconds);
    }
    init();

    diceDestroy = () => {
        if (countdownInterval) clearInterval(countdownInterval);
        if (rollingAnimation) cancelAnimationFrame(rollingAnimation);
        container.innerHTML = '';
    };
    return diceDestroy;
} 
    // ==================== 预留游戏三、四 ====================
    function initGame3(container) { container.innerHTML = '<div style="padding:40px;text-align:center;color:#ffdd99;">🎮 游戏3预留位</div>'; return ()=>{}; }
    function initGame4(container) { container.innerHTML = '<div style="padding:40px;text-align:center;color:#ffdd99;">♠️ 游戏4预留位</div>'; return ()=>{}; }

    // ==================== 主界面 ====================
    function renderAuthUI() {
        const savedPhone = localStorage.getItem('saved_phone') || '';
        const savedPwd = localStorage.getItem('saved_password') || '';
        const rememberChecked = localStorage.getItem('remember_me') === 'true';
        const app = document.getElementById('app');
        app.innerHTML = `<div class="auth-panel"><h2>🎲 双游戏大厅</h2><input type="tel" id="regPhone" class="auth-input" placeholder="手机号" maxlength="11" value="${savedPhone}"><input type="password" id="regPassword" class="auth-input" placeholder="密码 (至少4位)" value="${savedPwd}"><div style="display:flex; align-items:center; gap:8px; margin:8px 0;"><input type="checkbox" id="rememberCheckbox" ${rememberChecked ? 'checked' : ''}><label style="color:#ffdd99;">记住账号密码</label></div><div class="auth-buttons"><button id="loginBtn" class="auth-btn">登录</button><button id="registerBtn" class="auth-btn">注册</button></div><div class="auth-note">🎮 测试手机号注册 | 初始1000</div></div>`;
        document.getElementById('loginBtn').onclick = () => {
            let phone = document.getElementById('regPhone').value.trim();
            let pwd = document.getElementById('regPassword').value;
            let remember = document.getElementById('rememberCheckbox').checked;
            if(!phone || !pwd) { showToast("请填写手机号和密码"); return; }
            let user = usersData[phone];
            if(!user) { showToast("手机号未注册"); return; }
            if(user.password !== pwd) { showToast("密码错误"); return; }
            if(remember) { localStorage.setItem('saved_phone', phone); localStorage.setItem('saved_password', pwd); localStorage.setItem('remember_me', 'true'); }
            else { localStorage.removeItem('saved_phone'); localStorage.removeItem('saved_password'); localStorage.setItem('remember_me', 'false'); }
            currentUser = { phone, ...user };
            showToast(`欢迎，${phone}`);
            renderGameLobby();
        };
        document.getElementById('registerBtn').onclick = () => {
            let phone = document.getElementById('regPhone').value.trim();
            let pwd = document.getElementById('regPassword').value;
            if(!phone || !pwd) { showToast("请填写手机号和密码"); return; }
            if(!/^1[3-9]\d{9}$/.test(phone)) { showToast("请输入有效11位手机号"); return; }
            if(pwd.length < 4) { showToast("密码至少4位"); return; }
            if(usersData[phone]) { showToast("手机号已注册"); return; }
            usersData[phone] = { password: pwd, balance: 1000 };
            saveUsers();
            showToast("注册成功！请登录");
        };
    }

    function renderGameLobby() {
        const app = document.getElementById('app');
        app.innerHTML = `
            <div class="user-section">
                <div class="user-info-row">
                    <span>📱 ${currentUser.phone.substring(0,7)}... | 💰 余额: <span id="userBalanceDisplay">${getUserBalance().toFixed(2)}</span></span>
                    <div class="btn-group"><button id="serviceBtn" class="service-btn">📞 客服</button><button id="logoutBtn" class="logout-btn">退出</button></div>
                </div>
                <div class="charge-withdraw-row"><button id="rechargeBtn" class="charge-btn">💎 充值</button><button id="withdrawBtn" class="withdraw-btn">💰 提现</button></div>
            </div>
            <div class="game-nav">
                <button class="game-tab active" data-game="fish">🎲 葫芦鱼</button>
                <button class="game-tab" data-game="dice">🎲 至尊骰宝</button>
                <button class="game-tab" data-game="game3">🎮 游戏3</button>
                <button class="game-tab" data-game="game4">♠️ 游戏4</button>
            </div>
            <div class="game-container"><div id="gamePanel"></div></div>
        `;
        document.getElementById('logoutBtn').onclick = () => { currentUser = null; renderAuthUI(); };
        document.getElementById('serviceBtn').onclick = showService;
        document.getElementById('rechargeBtn').onclick = recharge;
        document.getElementById('withdrawBtn').onclick = withdraw;

        const gameContainer = document.getElementById('gamePanel');
        let currentDestroy = null;
        const gameInits = { fish: initFishGame, dice: initDiceGame, game3: initGame3, game4: initGame4 };

        async function switchGame(gameId) {
            if (currentDestroy) { currentDestroy(); currentDestroy = null; }
            gameContainer.innerHTML = '';
            const initFn = gameInits[gameId];
            if (initFn) {
                const destroy = await initFn(gameContainer);
                if (typeof destroy === 'function') currentDestroy = destroy;
            }
            document.getElementById('userBalanceDisplay').innerText = getUserBalance().toFixed(2);
        }

        document.querySelectorAll('.game-tab').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('.game-tab').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                switchGame(btn.dataset.game);
            };
        });
        switchGame('fish');
    }

    renderAuthUI();
</script>
