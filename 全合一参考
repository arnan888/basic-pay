        let adminPanel = null;
        function showAdminPanel() {
            if (adminPanel) { adminPanel.remove(); adminPanel=null; return; }
            let panel = document.createElement('div'); panel.className='modal'; panel.innerHTML='<div class="modal-content"><h3>🔐 管理员面板</h3><div id="adminUserList" class="admin-user-list"></div><div>当前：<strong id="adminSelectedUser">'+currentUserId+'</strong></div><input type="number" id="adminAmount" placeholder="金额" value="0"><div class="admin-btns"><button id="adminAdd">上分</button><button id="adminSub">下分</button><button id="adminQuery">查询</button><button id="adminReset">重置</button><button id="adminPwd">改密</button></div><button id="adminClose">关闭</button></div>';
            document.body.appendChild(panel); adminPanel=panel;
            function refreshList() {
