    };
    
    // 抢庄逻辑
    document.getElementById('grabBtn').onclick = () => {
        if(hasGrabbed) return;
        if(getUserBalance() >= 2001) {
            modifyBalance(-2001);
            playerBankerBalance = 2001;
            hasGrabbed = true;
            localStorage.setItem(`fish_player_banker_${currentRoom}`, playerBankerBalance);
            updateGrabButton();
            let balanceEl = document.getElementById('fishBalanceValue');
            if(balanceEl) balanceEl.innerText = playerBankerBalance.toFixed(2);
            showToast("抢庄成功，不可下注");
        } else {
            showToast("余额不足2001文");
        }
    };
    
    // 管理员触发器
    const adminChip = document.getElementById('adminTriggerChip');
