                showToast(`${target} 余额已重置为 1000`);
                if (target === currentUser.phone) {
                    currentUser.balance = 1000;
                    let balSpan = document.getElementById("userBalanceDisplay");
                    if (balSpan) balSpan.innerText = "1000.00";
                }
                modal.remove();
                showAdminPanel();
            }
        };

        modal.querySelector('#adminChangePwd').onclick = () => {
            let old = prompt("请输入当前管理密码:");
            if (old !== adminPassword) { showToast("当前密码错误"); return; }
            let newPwd = prompt("请输入新密码（至少4位）:");
            if (newPwd && newPwd.length >= 4) {
                adminPassword = newPwd;
                localStorage.setItem('admin_pwd', newPwd);
                showToast("管理密码修改成功");
            } else if (newPwd) {
                showToast("密码至少4位");
            }
        };

        modal.querySelector('#adminClose').onclick = () => modal.remove();
    }

    // 监听管理员触发筹码（1k筹码点击三次）
    document.addEventListener('click', (e) => {
        if (e.target && e.target.id === 'adminTriggerChip') {
            adminClickCount++;
            if (adminClickTimer) clearTimeout(adminClickTimer);
            adminClickTimer = setTimeout(() => { adminClickCount = 0; }, 1000);
            if (adminClickCount >= 3) {
                adminClickCount = 0;
                clearTimeout(adminClickTimer);
                openAdminModal();
            }
        }
    });

    // =====================================================================
    // 主界面渲染（登录/注册/游戏大厅）
    // =====================================================================
    function renderAuthUI() {
        const savedPhone = localStorage.getItem('saved_phone') || '';
        const savedPwd = localStorage.getItem('saved_password') || '';
        const rememberChecked = localStorage.getItem('remember_me') === 'true';
        const app = document.getElementById('app');
        app.innerHTML = `
            <div class="auth-panel">
                <h2>🎲 双游戏大厅</h2>
                <input type="tel" id="regPhone" class="auth-input" placeholder="手机号" maxlength="11" value="${savedPhone}">
                <input type="password" id="regPassword" class="auth-input" placeholder="密码 (至少4位)" value="${savedPwd}">
                <div style="display:flex; align-items:center; gap:8px; margin:8px 0;">
                    <input type="checkbox" id="rememberCheckbox" ${rememberChecked ? 'checked' : ''}>
                    <label style="color:#ffdd99;">记住账号密码</label>
                </div>
                <div class="auth-buttons">
                    <button id="loginBtn" class="auth-btn">登录</button>
                    <button id="registerBtn" class="auth-btn">注册</button>
                </div>
                <div class="auth-note">🎮 测试手机号注册 | 初始1000文</div>
            </div>
        `;

        document.getElementById('loginBtn').onclick = () => {
            let phone = document.getElementById('regPhone').value.trim();
            let pwd = document.getElementById('regPassword').value;
            let rem = document.getElementById('rememberCheckbox').checked;
            if (!phone || !pwd) { showToast("请填写手机号和密码"); return; }
            let user = usersData[phone];
            if (!user || user.password !== pwd) { showToast("账号或密码错误"); return; }
            if (rem) {
                localStorage.setItem('saved_phone', phone);
                localStorage.setItem('saved_password', pwd);
                localStorage.setItem('remember_me', 'true');
            } else {
                localStorage.removeItem('saved_phone');
                localStorage.removeItem('saved_password');
                localStorage.setItem('remember_me', 'false');
            }
            currentUser = { phone, ...user };
            showToast(`欢迎，${phone}`);
            renderGameLobby();
        };

        document.getElementById('registerBtn').onclick = () => {
            let phone = document.getElementById('regPhone').value.trim();
            let pwd = document.getElementById('regPassword').value;
            if (!phone || !pwd) { showToast("请填写手机号和密码"); return; }
            if (!/^1[3-9]\d{9}$/.test(phone)) { showToast("请输入有效11位手机号"); return; }
            if (pwd.length < 4) { showToast("密码至少4位"); return; }
            if (usersData[phone]) { showToast("手机号已注册"); return; }
            usersData[phone] = { password: pwd, balance: 1000 };
            saveUsers();
            showToast("注册成功！请登录");
        };
    }

    function renderGameLobby() {
        const app = document.getElementById('app');
        app.innerHTML = `
            <div class="user-section">
                <div class="user-info-row">
                    <span>📱 ${currentUser.phone.substring(0,7)}... | 💰 余额: <span id="userBalanceDisplay">${getUserBalance().toFixed(2)}</span></span>
                    <div class="btn-group">
                        <button id="serviceBtn" class="service-btn">📞 客服</button>
                        <button id="logoutBtn" class="logout-btn">退出</button>
                    </div>
                </div>
                <div class="charge-withdraw-row">
                    <button id="rechargeBtn" class="charge-btn">💎 充值</button>
                    <button id="withdrawBtn" class="withdraw-btn">💰 提现</button>
                </div>
            </div>
            <div class="game-nav">
                <button class="game-tab active" data-game="fish">🎲 葫芦鱼</button>
                <button class="game-tab" data-game="dice">🎲 至尊骰宝</button>
                <button class="game-tab" data-game="game3">🎮 游戏3</button>
                <button class="game-tab" data-game="game4">♠️ 游戏4</button>
            </div>
            <div class="game-container">
                <div id="gamePanel"></div>
            </div>
        `;

        document.getElementById('logoutBtn').onclick = () => {
            currentUser = null;
            renderAuthUI();
        };
        document.getElementById('serviceBtn').onclick = showServiceModal;
        document.getElementById('rechargeBtn').onclick = recharge;
        document.getElementById('withdrawBtn').onclick = withdraw;

        const gamePanel = document.getElementById('gamePanel');
        let currentDestroy = null;
        const gameInits = {
            fish: initFishGame,
            dice: initDiceGame,
            game3: initGame3,
            game4: initGame4
        };

        async function switchGame(gameId) {
            if (currentDestroy) {
                currentDestroy();
                currentDestroy = null;
            }
            gamePanel.innerHTML = '';
            const initFn = gameInits[gameId];
            if (initFn) {
                currentDestroy = await initFn(gamePanel);
            }
            let balSpan = document.getElementById("userBalanceDisplay");
            if (balSpan) balSpan.innerText = getUserBalance().toFixed(2);
        }

        document.querySelectorAll('.game-tab').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('.game-tab').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                switchGame(btn.dataset.game);
            };
        });

        switchGame('fish');

        // 在线人数模拟
        let onlineInterval = setInterval(() => {
            let onlineSpan = document.getElementById('onlineCount');
            if (onlineSpan) {
                let newCount = Math.floor(Math.random() * 151) + 50;
                onlineSpan.innerText = newCount;
            }
        }, 30000);

        const origDestroy = currentDestroy;
        currentDestroy = () => {
            clearInterval(onlineInterval);
            if (origDestroy) origDestroy();
        };
    }

    // 启动应用
    renderAuthUI();
</script>
</body>
</html>











