                <div class="message-area" id="fishMsgArea" style="background:#1c140e; margin:0 12px 12px; border-radius:35px; padding:6px 10px; font-size:0.65rem; color:#dbbc8c; text-align:center; min-height:48px;">庄家坐镇 | 骰盅缓慢开启 → 骰子摇动</div>
                <div class="seats-section" style="background:#1e1813; border-radius:48px; overflow:hidden;">
                    <div class="seats-header" style="background:#4a3322; padding:6px 12px; text-align:center;"><h3 style="color:#ffefcf; font-size:0.8rem;">🎲 二十人座席</h3></div>
                    <div class="seats-grid" id="seatsGrid" style="display:grid; grid-template-columns:repeat(5,1fr); gap:6px; padding:10px;"></div>
                    <footer style="background:transparent; padding:6px; text-align:center; color:#aa8259;">🎮 实时在线玩家 | 筹码1k连点三下打开管理后台</footer>
                </div>
            </div>
        `;
        container.innerHTML = fishHTML;
        
        // 添加局部样式 (作用域限定)
        const style = document.createElement('style');
        style.textContent = `
            .fish-game-wrapper .chip { background:#ebbc7e; color:#3a240f; font-weight:bold; font-size:0.7rem; padding:3px 10px; border-radius:35px; cursor:pointer; box-shadow:0 2px 0 #8b5a2e; display:inline-block; text-align:center; }
            .fish-game-wrapper .chip.selected { background:#f7c56e; box-shadow:0 0 0 1px #ffefb0, 0 2px 0 #7a4b22; }
            .fish-game-wrapper .bet-card { background:#1f1712; border-radius:28px; padding:4px 2px; text-align:center; box-shadow:0 2px 0 #0a0705; border:1px solid #6f4f34; }
            .fish-game-wrapper .bet-icon { font-size:1.4rem; background:#2f231c; width:36px; height:36px; line-height:36px; margin:0 auto 3px; border-radius:50%; }
            .fish-game-wrapper .bet-name { font-size:0.65rem; font-weight:bold; color:#ffddb0; }
            .fish-game-wrapper .bet-odds { font-size:0.5rem; color:#dba959; }
            .fish-game-wrapper .bet-amount { background:#0c0907; border-radius:30px; padding:2px 4px; margin:4px 3px 0; display:flex; justify-content:space-between; align-items:center; gap:2px; }
            .fish-game-wrapper .bet-amount span { color:#ffbc6e; font-size:0.7rem; background:#2a1c12; padding:1px 5px; border-radius:25px; min-width:32px; }
            .fish-game-wrapper .btn-chip { background:#523b26; border:none; color:#fce2b4; font-weight:bold; width:24px; height:24px; border-radius:25px; font-size:0.8rem; cursor:pointer; }
            .fish-game-wrapper .seat-card { background:#1a130d; border-radius:16px; padding:4px 2px; text-align:center; border:1px solid #6f4f34; }
            .fish-game-wrapper .seat-card.occupied { background:#2f4127; }
            .fish-game-wrapper .seat-number { font-size:0.5rem; color:#dba24b; }
            .fish-game-wrapper .player-name { font-weight:bold; font-size:0.55rem; margin:2px 0; color:#ffefcf; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        `;
        container.appendChild(style);
        
        // ========== 葫芦鱼游戏逻辑变量 ==========
        let fishBalance = parseInt(localStorage.getItem('fish_banker_balance')) || 10000;
        let patternBets = { fish:0, shrimp:0, crab:0, calabash:0, coin:0, chicken:0 };
        let specialBets = { big:0, small:0, odd:0, even:0, allTriplets:0 };
        let currentChip = 100;
        let lastWinAmount = 0;
        let isRolling = false;
        let fishPlayers = [];
        let nextPlayerId = 100;
        const namePool = ["阿强","老李","虾妹","蟹叔","金钱哥","鸡姐","小陈","骰子手","好运","锦鲤","鱼神","虾兵","蟹将","葫芦仙","铜钱","凤姐","阿珍","闲人","福仔","潮汕仔"];
        const patternList = ["鱼","虾","蟹","葫芦","金钱","鸡"];
        const patternIdMap = { fish:"鱼", shrimp:"虾", crab:"蟹", calabash:"葫芦", coin:"金钱", chicken:"鸡" };
        
        function getFishTotalBet() {
            return Object.values(patternBets).reduce((a,b)=>a+b,0) + Object.values(specialBets).reduce((a,b)=>a+b,0);
        }
        function updateFishUI() {
            const balanceSpan = container.querySelector('#fishBalanceValue');
            if(balanceSpan) balanceSpan.innerText = fishBalance;
            const totalSpan = container.querySelector('#totalBetValue');
            if(totalSpan) totalSpan.innerText = getFishTotalBet();
            const lastSpan = container.querySelector('#lastWinValue');
            if(lastSpan) lastSpan.innerText = lastWinAmount;
            for(let id of Object.keys(patternBets)) {
                let span = container.querySelector(`#bet_${id}`);
                if(span) span.innerText = patternBets[id];
            }
            for(let id of Object.keys(specialBets)) {
                let span = container.querySelector(`#bet_special_${id}`);
                if(span) span.innerText = specialBets[id];
            }
        }
        function showFishMsg(msg) {
            const msgDiv = container.querySelector('#fishMsgArea');
            if(msgDiv) msgDiv.innerText = msg;
            setTimeout(() => { if(msgDiv && msgDiv.innerText === msg) msgDiv.innerText = "🎲 点击开骰 | 骰盅缓慢开启开奖"; }, 2500);
        }
        function addBet(type, id, val) {
            let target = (type === 'pattern') ? patternBets : specialBets;
            if(target[id] === undefined) return;
            let totalNow = getFishTotalBet();
            let userBal = getUserBalance();
            if(totalNow + val > userBal) { showFishMsg(`余额不足，无法加注 ${val}`); return; }
            target[id] += val;
            updateFishUI();
            let name = (type === 'pattern') ? patternIdMap[id] : id;
            showFishMsg(`➕ ${name} +${val}`);
        }
        function subBet(type, id, val) {
            let target = (type === 'pattern') ? patternBets : specialBets;
            if(target[id] === undefined) return;
            let old = target[id];
            let newVal = Math.max(0, old - val);
            if(old !== newVal) {
                target[id] = newVal;
                updateFishUI();
                let name = (type === 'pattern') ? patternIdMap[id] : id;
                showFishMsg(`➖ ${name} -${val}`);
            }
        }
        function clearAllBets() {
            for(let k of Object.keys(patternBets)) patternBets[k]=0;
            for(let k of Object.keys(specialBets)) specialBets[k]=0;
            updateFishUI();
            showFishMsg("清空所有下注");
        }
        function resetFishGame() {
            fishBalance = 10000;
            localStorage.setItem('fish_banker_balance', fishBalance);
            clearAllBets();
            lastWinAmount = 0;
            updateFishUI();
            const diceEls = container.querySelectorAll(".dice");
            diceEls.forEach(d => d.innerHTML = "🎲");
            const cover = container.querySelector('#fishDiceCover');
            if(cover) {
                cover.style.display = "flex";
                cover.style.transform = "translateY(0) scale(1)";
                cover.style.opacity = "1";
                cover.style.visibility = "visible";
            }
            showFishMsg("庄家重置，本金 10000 文，骰盅已复位");
        }
        async function animateRolling(finalNames) {
            const diceEls = container.querySelectorAll(".dice");
            const iconMap = { "鱼":"🐟","虾":"🦐","蟹":"🦀","葫芦":"🏺","金钱":"💰","鸡":"🐔" };
            for(let step=0; step<8; step++) {
                await new Promise(r=>setTimeout(r, 70));
                for(let i=0;i<3;i++) {
                    let rand = patternList[Math.floor(Math.random()*6)];
                    diceEls[i].innerHTML = iconMap[rand];
                }
            }
            for(let i=0;i<3;i++) diceEls[i].innerHTML = iconMap[finalNames[i]];
        }
        function getPointValue(pname) { const m={"鱼":1,"虾":2,"蟹":3,"葫芦":4,"金钱":5,"鸡":6}; return m[pname]||0; }
        async function settleGame(diceNames) {
            let points = diceNames.map(n=>getPointValue(n));
            let sum = points.reduce((a,b)=>a+b,0);
            let isTriplet = diceNames[0]===diceNames[1] && diceNames[1]===diceNames[2];
            let totalBet = getFishTotalBet();
            if(totalBet===0) { showFishMsg("没有下注，无法结算"); return false; }
            let userBal = getUserBalance();
            if(totalBet > userBal) { showFishMsg("下注超额，请检查余额"); return false; }
            setUserBalance(userBal - totalBet);
            let winAmount = 0;
            let winDetails = [];
            for(let [pid, betVal] of Object.entries(patternBets)) {
                if(betVal===0) continue;
                let occur = diceNames.filter(n=> n === patternIdMap[pid]).length;
                if(occur>0) {
                    let prize = betVal * (occur+1);
                    winAmount += prize;
                    winDetails.push(`${patternIdMap[pid]} x${occur}`);
                }
            }
            let bigWin=false, smallWin=false, oddWin=false, evenWin=false, allTripletWin=false;
            if(!isTriplet) {
                if(sum>=11 && sum<=17) bigWin=true;
                if(sum>=4 && sum<=10) smallWin=true;
                if(sum%2===1) oddWin=true;
                if(sum%2===0) evenWin=true;
            }
            if(isTriplet) allTripletWin=true;
            if(specialBets.big>0 && bigWin) { winAmount += specialBets.big*2; winDetails.push("大"); }
            if(specialBets.small>0 && smallWin) { winAmount += specialBets.small*2; winDetails.push("小"); }
            if(specialBets.odd>0 && oddWin) { winAmount += specialBets.odd*2; winDetails.push("单"); }
            if(specialBets.even>0 && evenWin) { winAmount += specialBets.even*2; winDetails.push("双"); }
            if(specialBets.allTriplets>0 && allTripletWin) { winAmount += specialBets.allTriplets*25; winDetails.push("全围"); }
            
            let net = winAmount - totalBet;
            let newBalance = getUserBalance() + winAmount;
            setUserBalance(newBalance);
            lastWinAmount = net;
            updateFishUI();
            let diceShow = diceNames.join("、");
            if(winAmount>0) showFishMsg(`🎲 ${diceShow} 净赢+${net}  [${winDetails.join(',')}]`);
            else showFishMsg(`😢 ${diceShow} 亏损 ${totalBet}`);
            clearAllBets();
            // 更新顶部余额显示
            const balanceSpan = document.getElementById("userBalanceDisplay");
            if(balanceSpan) balanceSpan.innerText = newBalance.toFixed(2);
            return true;
        }
        async function onFishRoll() {
            if(isRolling) return;
            let total = getFishTotalBet();
            if(total === 0) { showFishMsg("请先下注再开骰！"); return; }
            if(total > getUserBalance()) { showFishMsg("下注总额超过余额，请减少下注"); return; }
            const diceCover = container.querySelector('#fishDiceCover');
            if(!diceCover) return;
            isRolling = true;
            diceCover.style.transform = "translateY(-70px) scale(0.6)";
            diceCover.style.opacity = "0";
            await new Promise(r=>setTimeout(r, 550));
            diceCover.style.display = "none";
            
            let finalResult = [
                patternList[Math.floor(Math.random()*6)],
                patternList[Math.floor(Math.random()*6)],
                patternList[Math.floor(Math.random()*6)]
            ];
            await animateRolling(finalResult);
            await settleGame(finalResult);
            await new Promise(r=>setTimeout(r, 1500));
            const diceEls = container.querySelectorAll(".dice");
            diceEls.forEach(d => d.innerHTML = "🎲");
            diceCover.style.display = "flex";
            diceCover.style.transform = "translateY(0) scale(1)";
            diceCover.style.opacity = "1";
            diceCover.style.visibility = "visible";
            isRolling = false;
            showFishMsg("骰盅已复位，可继续下注");
        }
        
        function renderSeats() {
            const seatsGrid = container.querySelector('#seatsGrid');
            if(!seatsGrid) return;
            seatsGrid.innerHTML = "";
            for(let i=1; i<=20; i++) {
                const player = fishPlayers.find(p => p.seatIndex === i);
                const isOccupied = !!player;
                const seatDiv = document.createElement("div");
                seatDiv.className = `seat-card ${isOccupied ? "occupied" : ""}`;
                if(isOccupied) {
                    seatDiv.innerHTML = `<div class="seat-number">#${i}</div><div class="player-name" title="${player.name}">${player.name.length>6?player.name.slice(0,5)+"..":player.name}</div>`;
                } else {
                    seatDiv.innerHTML = `<div class="seat-number">#${i}</div><div class="player-name">🔲</div>`;
                }
                seatsGrid.appendChild(seatDiv);
            }
        }
        function addRandomPlayer() {
            if(fishPlayers.length >= 20) return;
            let emptySeats = [];
            for(let i=1;i<=20;i++) if(!fishPlayers.find(p=>p.seatIndex===i)) emptySeats.push(i);
            if(emptySeats.length===0) return;
            let randomSeat = emptySeats[Math.floor(Math.random()*emptySeats.length)];
            let randomName = namePool[Math.floor(Math.random() * namePool.length)] + (Math.floor(Math.random()*90)+10);
            fishPlayers.push({ id: nextPlayerId++, name: randomName, seatIndex: randomSeat });
            renderSeats();
        }
        
        // 构建下注网格
        const patternContainer = container.querySelector('#patternGrid');
        if(patternContainer) {
            const PATTERNS = [
                { id:"fish", name:"鱼", icon:"🐟" }, { id:"shrimp", name:"虾", icon:"🦐" }, { id:"crab", name:"蟹", icon:"🦀" },
                { id:"calabash", name:"葫芦", icon:"🏺" }, { id:"coin", name:"金钱", icon:"💰" }, { id:"chicken", name:"鸡", icon:"🐔" }
            ];
            patternContainer.innerHTML = "";
            PATTERNS.forEach(p=>{
                let card = document.createElement("div"); card.className="bet-card";
                card.innerHTML = `<div class="bet-icon">${p.icon}</div><div class="bet-name">${p.name}</div><div class="bet-odds">1~3倍</div>
                <div class="bet-amount"><button class="btn-chip sub-pattern" data-id="${p.id}">-</button><span id="bet_${p.id}">0</span><button class="btn-chip add-pattern" data-id="${p.id}">+</button></div>`;
                patternContainer.appendChild(card);
            });
        }
        const specialContainer = container.querySelector('#specialGrid');
        if(specialContainer) {
            const SPECIALS = [
                { id:"big", name:"大", icon:"🔴", odds:1 }, { id:"small", name:"小", icon:"🔵", odds:1 },
                { id:"odd", name:"单", icon:"⚪", odds:1 }, { id:"even", name:"双", icon:"⚫", odds:1 },
                { id:"allTriplets", name:"全围", icon:"🌀", odds:24 }
            ];
            specialContainer.innerHTML = "";
            SPECIALS.forEach(s=>{
                let card = document.createElement("div"); card.className="bet-card";
                card.innerHTML = `<div class="bet-icon">${s.icon}</div><div class="bet-name">${s.name}</div><div class="bet-odds">${s.odds===1?"1:1":"1:24"}</div>
                <div class="bet-amount"><button class="btn-chip sub-special" data-id="${s.id}">-</button><span id="bet_special_${s.id}">0</span><button class="btn-chip add-special" data-id="${s.id}">+</button></div>`;
                specialContainer.appendChild(card);
            });
        }
        
        // 事件绑定
        container.querySelector('.bet-grid')?.addEventListener('click', (e) => {
            let btn = e.target.closest(".btn-chip");
            if(!btn) return;
            let id = btn.dataset.id;
            if(btn.classList.contains("add-pattern")) addBet('pattern', id, currentChip);
            if(btn.classList.contains("sub-pattern")) subBet('pattern', id, currentChip);
        });
        container.querySelector('.special-grid')?.addEventListener('click', (e) => {
            let btn = e.target.closest(".btn-chip");
            if(!btn) return;
            let id = btn.dataset.id;
            if(btn.classList.contains("add-special")) addBet('special', id, currentChip);
            if(btn.classList.contains("sub-special")) subBet('special', id, currentChip);
        });
        container.querySelectorAll(".chip").forEach(chip => {
            chip.onclick = () => {
                let val = parseInt(chip.dataset.chip);
                if(!isNaN(val)) { currentChip=val; container.querySelectorAll(".chip").forEach(c=>c.classList.remove("selected")); chip.classList.add("selected"); showFishMsg(`筹码 ${val}`); }
            };
        });
        container.querySelector('#fishRollBtn').onclick = onFishRoll;
        container.querySelector('#fishResetBetBtn').onclick = clearAllBets;
        container.querySelector('#fishResetGameBtn').onclick = resetFishGame;
        
        // 初始化座位
        for(let i=1; i<=6; i++) {
            let name = namePool[(i-1)%namePool.length] + Math.floor(Math.random()*100);
            fishPlayers.push({ id: nextPlayerId++, name: name, seatIndex: i });
        }
        renderSeats();
        fishInterval = setInterval(addRandomPlayer, 30000);
        updateFishUI();
        
        // 返回销毁函数
        fishDestroyFunc = () => {
            if(fishInterval) clearInterval(fishInterval);
            container.innerHTML = '';
        };
        return fishDestroyFunc;
    }
    
    // ==================== 主界面渲染 ====================
    function renderAuthUI() {
        const savedPhone = localStorage.getItem('saved_phone') || '';
        const savedPwd = localStorage.getItem('saved_password') || '';
        const rememberChecked = localStorage.getItem('remember_me') === 'true';
        const app = document.getElementById('app');
        app.innerHTML = `
            <div class="auth-panel" style="background: linear-gradient(145deg, #362a1f 0%, #251e16 100%); border-radius: 48px; padding: 30px 20px; text-align: center; border: 2px solid #ffaa44;">
                <h2 style="color:#ffdd99;">🎲 潮汕双游戏大厅</h2>
                <input type="tel" id="regPhone" class="auth-input" placeholder="手机号" maxlength="11" value="${savedPhone}">
                <input type="password" id="regPassword" class="auth-input" placeholder="密码 (至少4位)" value="${savedPwd}">
                <div style="display: flex; align-items: center; justify-content: flex-start; gap: 8px; margin: 8px 0;">
                    <input type="checkbox" id="rememberCheckbox" style="width: 18px; height: 18px;" ${rememberChecked ? 'checked' : ''}>
                    <label style="color:#ffdd99; font-size:0.7rem;">记住账号密码</label>
                </div>
                <div class="auth-buttons" style="display:flex; gap:12px; margin:20px 0;">
                    <button id="loginBtn" class="auth-btn" style="flex:1;">登录</button>
                    <button id="registerBtn" class="auth-btn" style="flex:1;">注册</button>
                </div>
                <div class="auth-note">🎮 测试手机号注册 | 初始1000 | 筹码1k连点三下管理后台</div>
            </div>
        `;
        document.getElementById('loginBtn').onclick = () => {
            let phone = document.getElementById('regPhone').value.trim();
            let pwd = document.getElementById('regPassword').value;
            let remember = document.getElementById('rememberCheckbox').checked;
            if(!phone || !pwd) { showToast("请填写手机号和密码"); return; }
            let user = usersData[phone];
            if(!user) { showToast("手机号未注册"); return; }
            if(user.password !== pwd) { showToast("密码错误"); return; }
            if(remember) { localStorage.setItem('saved_phone', phone); localStorage.setItem('saved_password', pwd); localStorage.setItem('remember_me', 'true'); }
            else { localStorage.removeItem('saved_phone'); localStorage.removeItem('saved_password'); localStorage.setItem('remember_me', 'false'); }
            currentUser = { phone, ...user };
            showToast(`欢迎，${phone}`);
            renderGameLobby();
        };
        document.getElementById('registerBtn').onclick = () => {
            let phone = document.getElementById('regPhone').value.trim();
            let pwd = document.getElementById('regPassword').value;
            if(!phone || !pwd) { showToast("请填写手机号和密码"); return; }
            if(!/^1[3-9]\d{9}$/.test(phone)) { showToast("请输入有效11位手机号"); return; }
            if(pwd.length < 4) { showToast("密码至少4位"); return; }
            if(usersData[phone]) { showToast("手机号已注册"); return; }
            usersData[phone] = { password: pwd, balance: 1000 };
            saveUsers();
            showToast("注册成功！请登录");
        };
    }
    
    function renderGameLobby() {
        const app = document.getElementById('app');
        app.innerHTML = `
            <div class="user-section">
                <div class="user-info-row">
                    <span>📱 ${currentUser.phone.substring(0,7)}... | 💰 余额: <span id="userBalanceDisplay">${getUserBalance().toFixed(2)}</span></span>
                    <div class="btn-group"><button id="serviceBtn" class="service-btn">📞 客服</button><button id="logoutBtn" class="logout-btn">退出</button></div>
                </div>
                <div class="charge-withdraw-row"><button id="rechargeBtn" class="charge-btn">💎 充值</button><button id="withdrawBtn" class="withdraw-btn">💰 提现</button></div>
            </div>
            <div class="game-nav"><button class="game-tab active" data-game="fish">🎲 葫芦鱼·二十人房</button><button class="game-tab" data-game="poker">🃟 广东十三张·3D牌桌</button></div>
            <div class="game-container"><div id="fishGamePanel" class="game-panel active"></div><div id="pokerGamePanel" class="game-panel"></div></div>
        `;
        document.getElementById('logoutBtn').onclick = () => { currentUser = null; renderAuthUI(); };
        document.getElementById('serviceBtn').onclick = showService;
        document.getElementById('rechargeBtn').onclick = recharge;
        document.getElementById('withdrawBtn').onclick = withdraw;
        
        const fishPanel = document.getElementById('fishGamePanel');
        const pokerPanel = document.getElementById('pokerGamePanel');
        let currentFishDestroy = null;
        let currentPokerDestroy = null;
        
        function switchGame(game) {
            if(game === 'fish') {
                if(currentPokerDestroy) { currentPokerDestroy(); currentPokerDestroy = null; }
                if(!currentFishDestroy) { currentFishDestroy = initFishGame(fishPanel); }
                fishPanel.classList.add('active');
                pokerPanel.classList.remove('active');
            } else {
                if(currentFishDestroy) { currentFishDestroy(); currentFishDestroy = null; }
                if(!currentPokerDestroy) { initPokerGame(pokerPanel); currentPokerDestroy = () => destroyPokerGame(); }
                fishPanel.classList.remove('active');
                pokerPanel.classList.add('active');
            }
        }
        
        document.querySelectorAll('.game-tab').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('.game-tab').forEach(b=>b.classList.remove('active'));
                btn.classList.add('active');
                switchGame(btn.dataset.game);
            };
        });
        // 默认启动葫芦鱼
        switchGame('fish');
    }
    
    renderAuthUI();
</script>
</body>
</html>




