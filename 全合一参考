                         </div>`;
        userListHtml += `<button id="adminClose" style="background:#734c2e; padding:8px; border-radius:40px; width:100%;">关闭后台</button>`;
        const modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `<div class="modal-content"><h2>🎛️ 管理员后台</h2>${userListHtml}</div>`;
        document.body.appendChild(modal);
        const getUserSelect = () => modal.querySelector('#adminTargetUser').value;
        const getAmount = () => parseInt(modal.querySelector('#adminAmount').value) || 0;

        modal.querySelector('#adminAdd').onclick = () => {
            let target = getUserSelect();
            let amt = getAmount();
