    function getPlayerBankerKey() { return `player_banker_balance_${currentRoom}`; }
    
    let fishBalance = parseInt(localStorage.getItem(getBankerKey())) || 10000;
    let savedPlayerBalance = parseInt(localStorage.getItem(getPlayerBankerKey())) || 0;
