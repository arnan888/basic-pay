        state.pick = s; 
        update(); 
    } 
}

function adj(d) { 
    if(!state.rolling){ 
        state.bIdx = Math.max(0, Math.min(state.bets.length-1, state.bIdx + d)); 
        update(); 
    } 
}

function onExecute() {
    const cost = state.bets[state.bIdx];
    // 检查：必须选择押注项且余额足够
    if(state.rolling || !state.pick || state.bal < cost) return;
    
    state.rolling = true; 
    state.bal -= cost;
    // 计算预计奖金
    const winAmt = cost * oddsConfig[state.pick];
    document.getElementById('val-bet').innerText = cost.toFixed(2);
    document.getElementById('val-win').innerText = winAmt.toFixed(2);
    document.getElementById('wheel').classList.add('blur');
    update();

    const winIdx = Math.floor(Math.random()*8);
    const rounds = state.speed===3 ? 4 : 8;
    const target = (360 - (state.deg%360)) + rounds*360 - (winIdx*45);
    state.deg += target;
    
    const wheel = document.getElementById('wheel');
    wheel.style.transitionDuration = state.speed===3?'0.8s':state.speed===2?'2s':'4s';
    wheel.style.transform = `rotate(${state.deg}deg)`;

