        // 中奖判断
        if(state.pick === winResult) {
            state.bal += winAmt;
            document.getElementById('cell-'+winResult).classList.add('winner');
            setTimeout(()=>document.getElementById('cell-'+winResult).classList.remove('winner'), 2000);
        }
        update();
        if(state.auto) setTimeout(onExecute, 1200);
    }, parseFloat(wheel.style.transitionDuration)*1000);
}

function update() {
    document.getElementById('ui-bal').innerText = state.bal.toFixed(2);
    document.getElementById('ui-stake').innerText = state.bets[state.bIdx].toFixed(1);
    // 单独控制每个押注项的选中状态
    document.querySelectorAll('.side-cell').forEach(c => c.classList.remove('active'));
    if(state.pick) document.getElementById('cell-'+state.pick).classList.add('active');
