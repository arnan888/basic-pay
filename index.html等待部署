    {n:'狮子', i:'🦁'}, {n:'猛虎', i:'🐯'}, {n:'恶狼', i:'🐺'}, {n:'犀牛', i:'🦏'},
    {n:'巨象', i:'🐘'}, {n:'黑熊', i:'🐻'}, {n:'神龙', i:'🐲'}, {n:'雄鹰', i:'🦅'}
];

// 新增赔率配置
const oddsConfig = {
    DRAGON: 1,
    TIGER: 1,
    TIE: 8
};

let state = { 
    bal: 857.8, 
    bets: [10, 50, 100, 500, 1000], 
    bIdx: 2, 
    pick: null, // 单独存储当前选中的押注项
    rolling: false, 
    auto: false, 
    speed: 1, 
    deg: 0 
};

function init() {
    const w = document.getElementById('wheel');
    beastList.forEach((b, i) => {
        const d = document.createElement('div');
        d.className = 'slot'; d.style.transform = `rotate(${i*45}deg)`;
        d.innerHTML = `<span class="beast-ico">${b.i}</span><span class="beast-nm">${b.n}</span>`;
        w.appendChild(d);
    });
    update();
}

