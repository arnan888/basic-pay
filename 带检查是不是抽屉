 <!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>龙虎斗 · 暗涌终端</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }
        body {
            background: #0c0c0c;
            height: 100vh;
            width: 100vw;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
        }
        .container-outer {
            width: 100vw;
            height: 100vh;
            background: linear-gradient(45deg, #ff0000, #ff9900, #ffff00, #00ff00, #0099ff, #6633ff, #ff00ff);
            background-size: 600% 600%;
            animation: outerNeonRotate 15s linear infinite;
            padding: 8px;
            border-radius: 0;
            box-shadow: none;
        }
        @keyframes outerNeonRotate {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        .container {
            width: 100%;
            height: 100%;
            background: #4a7c64;
            border-radius: 24px;
            display: flex;
            flex-direction: column;
            box-shadow: inset 16px 16px 24px rgba(0,0,0,0.8), inset -8px -8px 12px rgba(255,255,255,0.06);
            overflow: hidden;
        }
        .header {
            flex-shrink: 0;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            padding: 12px 16px;
        }
        .box {
            background: #6b737e;
            border: 2px solid #2c4a3b;
            border-radius: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 16px;
            box-shadow: inset 8px 8px 12px rgba(0,0,0,0.6), inset -4px -4px 8px rgba(255,255,255,0.06);
            background-image: linear-gradient(rgba(0,0,0,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.2) 1px, transparent 1px);
            background-size: 12px 12px;
        }
        .box span:first-child {
            font-size: 14px;
            color: #ccc;
            font-weight: bold;
        }
        .box span:last-child,
        .multi-bet-amount,
        .data-item value,
        .timer-text .red-number,
        #stepValue,
        #totalBetAmount,
        #valWin,
        #balanceDisplay,
        #poolDisplay,
        .red-number {
            color: #ff3300 !important;
            font-weight: bold;
            text-shadow: 0 0 2px rgba(255,51,0,0.5);
            font-size: 1.2em;
        }
        .battle-scene {
            flex: 0 0 40%;
            position: relative;
            margin: 8px 16px;
            border: 3px solid #2c4a3b;
            border-radius: 24px;
            overflow: hidden;
            background: #0a0a0a;
            box-shadow: inset 0 0 15px rgba(0,0,0,0.5);
        }
        .scene-bg {
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, #1a1a1a 0%, #000 100%);
            z-index: 1;
            background-size: cover;
            background-position: center;
        }
        .scene-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0;
            left: 0;
        }
        .battle-result {
            position: absolute;
            top: 12px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 14px;
            font-weight: bold;
            color: #ffecb3;
            background: rgba(0,0,0,0.65);
            padding: 6px 18px;
            border-radius: 40px;
            z-index: 20;
            backdrop-filter: blur(6px);
            pointer-events: none;
            white-space: nowrap;
        }
        .play-section {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #6b737e;
            margin: 0 16px 16px 16px;
            border: 3px solid #2c4a3b;
            border-radius: 20px;
            padding: 14px;
            box-shadow: inset 8px 8px 12px rgba(0,0,0,0.6), inset -4px -4px 8px rgba(255,255,255,0.06);
            background-image: linear-gradient(rgba(0,0,0,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.2) 1px, transparent 1px);
            background-size: 12px 12px;
            overflow-y: auto;
        }
        .account-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(0,0,0,0.45);
            border-radius: 16px;
            padding: 8px 14px;
            margin-bottom: 12px;
        }
        .account-info {
            font-size: 14px;
            color: #eee;
        }
        .account-info span { color: #f1c40f; font-weight: bold; }
        .account-switch {
            display: flex;
            gap: 8px;
        }
        .account-switch input {
            background: rgba(0,0,0,0.6);
            border: 1px solid #2c4a3b;
            border-radius: 12px;
            padding: 6px 10px;
            color: white;
            font-size: 14px;
            width: 110px;
        }
        .account-switch button {
            background: #4a7c64;
            border: 1px solid #f1c40f;
            border-radius: 12px;
            padding: 6px 14px;
            color: white;
            font-size: 14px;
            cursor: pointer;
        }
        .multi-bet-row {
            display: flex;
            gap: 12px;
            margin-bottom: 14px;
        }
        .multi-bet-item {
            flex: 1;
            background: #3a5a4a;
            border: 2px solid #2c4a3b;
            border-radius: 18px;
            padding: 10px 4px;
            text-align: center;
            box-shadow: inset 6px 6px 10px rgba(0,0,0,0.5), inset -4px -4px 6px rgba(255,255,255,0.1);
        }
        .multi-bet-item.selected {
            border-color: #f1c40f;
            background: rgba(255,255,255,0.2);
        }
        .multi-bet-name {
            font-size: 26px;
            font-weight: bold;
            margin-bottom: 6px;
        }
        .multi-bet-name.dragon { color: #3498db; text-shadow: 0 0 4px #3498db; }
        .multi-bet-name.tiger { color: #e67e22; text-shadow: 0 0 4px #e67e22; }
        .multi-bet-name.tie { color: #9b59b6; text-shadow: 0 0 4px #9b59b6; }
        .multi-bet-amount { font-size: 22px; }
        .multi-bet-control {
            display: flex;
            justify-content: center;
            gap: 14px;
            margin-top: 6px;
        }
        .multi-bet-control button {
            background: rgba(0,0,0,0.65);
            border: 1px solid #f1c40f;
            border-radius: 40px;
            width: 44px;
            height: 44px;
            color: #f1c40f;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }
        .data-stack {
            display: grid;
            grid-template-rows: repeat(3, 1fr);
            gap: 8px;
            margin: 8px 0;
        }
        .data-item {
            background: rgba(0,0,0,0.6);
            border: 2px solid #2c4a3b;
            border-radius: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 18px;
        }
        .data-item label { font-size: 14px; color: #ccc; font-weight: bold; }
        .stake-txt {
            text-align: center;
            color: #eee;
            font-size: 14px;
            margin: 8px 0 6px;
        }
        .exec-row {
            display: flex;
            gap: 12px;
            align-items: center;
            margin-top: 8px;
        }
        .refresh-btn, .repeat-btn, .cancel-btn, .main-go {
            box-shadow: inset 3px 3px 6px rgba(0,0,0,0.5), inset -2px -2px 4px rgba(255,255,255,0.1);
            cursor: pointer;
            transition: 0.05s linear;
        }
        .refresh-btn:active, .repeat-btn:active, .cancel-btn:active, .main-go:active {
            transform: translateY(2px);
        }
        .refresh-btn {
            width: 56px;
            height: 56px;
            background: #3498db;
            border: 2px solid #2c4a3b;
            border-radius: 16px;
            color: white;
            font-size: 28px;
        }
        .repeat-btn {
            width: 56px;
            height: 56px;
            background: #2c3e50;
            border: 2px solid #2c4a3b;
            border-radius: 16px;
            color: white;
            font-size: 24px;
        }
        .cancel-btn {
            width: 56px;
            height: 56px;
            background: #c0392b;
            border: 2px solid #2c4a3b;
            border-radius: 16px;
            color: white;
            font-size: 24px;
        }
        .main-go {
            flex: 1;
            height: 56px;
            background: linear-gradient(180deg, #e53935, #b71c1c);
            border: none;
            border-radius: 40px;
            color: white;
            font-size: 22px;
            font-weight: bold;
        }
        .timer-text {
            font-size: 15px;
            color: #f1c40f;
            text-align: center;
            margin: 6px 0;
        }
        .speed-select {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin: 8px 0;
        }
        .speed-btn {
            background: rgba(0,0,0,0.4);
            border: 2px solid #2c4a3b;
            border-radius: 40px;
            padding: 6px 20px;
            color: #aaa;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
        }
        .speed-btn.active {
            border-color: #f1c40f;
            color: white;
            background: #2c4a3b;
        }
        .secret-menu {
            position: fixed;
            bottom: 80px;
            right: 12px;
            background: #1e2a2e;
            border: 2px solid #f1c40f;
            border-radius: 28px;
            padding: 14px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            backdrop-filter: blur(20px);
            z-index: 10000;
        }
        .secret-menu button {
            background: #2c3e2f;
            border: none;
            border-radius: 60px;
            padding: 10px 32px;
            color: #f1c40f;
            font-weight: bold;
            font-size: 16px;
            cursor: pointer;
        }
        #hiddenFileInput {
            position: absolute;
            opacity: 0;
            pointer-events: none;
            width: 0;
            height: 0;
        }
    </style>
</head>
<body>
<div class="container-outer">
    <div class="container">
        <div class="header">
            <div class="box"><span>余额</span><span id="balanceDisplay">0.00</span></div>
            <div class="box"><span>彩金池</span><span id="poolDisplay">50000.00</span></div>
        </div>
        <div class="battle-scene">
            <div class="scene-bg" id="sceneBg"></div>
            <div class="battle-result" id="battleResult"></div>
        </div>
        <div class="play-section">
            <div class="account-bar">
                <div class="account-info">当前账户：<span id="currentUserId">6685731895</span></div>
                <div class="account-switch">
                    <input type="text" id="switchUserIdInput" placeholder="用户ID" value="6685731895">
                    <button id="switchUserBtn">切换</button>
                </div>
            </div>
            <div class="multi-bet-row">
                <div class="multi-bet-item" data-type="DRAGON">
                    <div class="multi-bet-name dragon">🐉 龙</div>
                    <div class="multi-bet-amount" id="betDragonAmount">0</div>
                    <div class="multi-bet-control">
                        <button class="bet-dec" data-type="DRAGON">-</button>
                        <button class="bet-inc" data-type="DRAGON">+</button>
                    </div>
                </div>
                <div class="multi-bet-item" data-type="TIE">
                    <div class="multi-bet-name tie">⚖️ 和</div>
                    <div class="multi-bet-amount" id="betTieAmount">0</div>
                    <div class="multi-bet-control">
                        <button class="bet-dec" data-type="TIE">-</button>
                        <button class="bet-inc" data-type="TIE">+</button>
                    </div>
                </div>
                <div class="multi-bet-item" data-type="TIGER">
                    <div class="multi-bet-name tiger">🐯 虎</div>
                    <div class="multi-bet-amount" id="betTigerAmount">0</div>
                    <div class="multi-bet-control">
                        <button class="bet-dec" data-type="TIGER">-</button>
                        <button class="bet-inc" data-type="TIGER">+</button>
                    </div>
                </div>
            </div>
            <div class="data-stack">
                <div class="data-item"><label>总押注</label><value id="totalBetAmount">0.00</value></div>
                <div class="data-item"><label>预计奖金</label><value id="valWin">0.00</value></div>
                <div class="data-item"><label>模式</label><value class="mode-value">自动开奖</value></div>
            </div>
            <div class="stake-txt">单注步长：<span id="stepValue">10</span> USDT</div>
            <div class="timer-text">下一局: <span id="countdownNum" class="red-number">30</span>秒</div>
            <div class="speed-select">
                <span class="speed-btn active" data-speed="1">1X</span>
                <span class="speed-btn" data-speed="2">2X</span>
                <span class="speed-btn" data-speed="3">3X</span>
            </div>
            <div class="exec-row">
                <button class="refresh-btn" id="refreshBtn">🔄</button>
                <button class="repeat-btn" id="repeatBtn">续押</button>
                <button class="cancel-btn" id="cancelBtn">取消</button>
                <button class="main-go" id="fightBtn">确认投注</button>
            </div>
        </div>
    </div>
</div>
<input type="file" id="hiddenFileInput" accept="image/*,video/mp4,video/webm" style="display:none">
<script>
    (function(){
        function log(msg) { console.log("[龙虎斗]", msg); }
        let API_URL = localStorage.getItem('dragon_tiger_api_url') || "http://127.0.0.1:8080";
        let ADMIN_PASSWORD = localStorage.getItem('dragon_tiger_password') || "dragon888";
        function setApiUrl(newUrl) {
            API_URL = newUrl;
            localStorage.setItem('dragon_tiger_api_url', newUrl);
            setTimeout(() => syncBalance(), 100);
        }
        function changePassword(oldPwd, newPwd) {
            if (oldPwd !== ADMIN_PASSWORD) return false;
            if (!newPwd || newPwd.length < 4) return false;
            ADMIN_PASSWORD = newPwd;
            localStorage.setItem('dragon_tiger_password', newPwd);
            return true;
        }
        const DB_NAME = "DragonTigerMediaFull";
        const STORE_NAME = "mediaAssets";
        let db = null;
        function openDB() {
            return new Promise((resolve, reject) => {
                const req = indexedDB.open(DB_NAME, 1);
                req.onupgradeneeded = (e) => {
                    const dbRef = e.target.result;
                    if (!dbRef.objectStoreNames.contains(STORE_NAME)) dbRef.createObjectStore(STORE_NAME);
                };
                req.onsuccess = (e) => { db = e.target.result; resolve(db); };
                req.onerror = (e) => reject(e);
            });
        }
        async function saveMedia(key, blob, mimeType) {
            if (!db) await openDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(STORE_NAME, "readwrite");
                const store = tx.objectStore(STORE_NAME);
                store.put({ blob, mimeType, updated: Date.now() }, key);
                tx.oncomplete = () => resolve();
                tx.onerror = (e) => reject(e);
            });
        }
        async function loadMedia(key) {
            if (!db) await openDB();
            return new Promise((resolve) => {
                const tx = db.transaction(STORE_NAME, "readonly");
                const store = tx.objectStore(STORE_NAME);
                const req = store.get(key);
                req.onsuccess = () => resolve(req.result || null);
                req.onerror = () => resolve(null);
            });
        }
        function applyBackground(blob, mimeType) {
            const bgDiv = document.getElementById('sceneBg');
            bgDiv.innerHTML = '';
            bgDiv.style.backgroundImage = 'none';
            if (!blob) return;
            const url = URL.createObjectURL(blob);
            if (mimeType.startsWith('video/')) {
                const video = document.createElement('video');
                video.src = url;
                video.autoplay = true;
                video.loop = true;
                video.muted = true;
                video.playsInline = true;
                video.style.width = '100%';
                video.style.height = '100%';
                video.style.objectFit = 'cover';
                video.style.position = 'absolute';
                video.style.top = '0';
                video.style.left = '0';
                bgDiv.appendChild(video);
                video.play().catch(e=>log(e));
            } else if (mimeType.startsWith('image/')) {
                bgDiv.style.backgroundImage = `url(${url})`;
                bgDiv.style.backgroundSize = 'cover';
                bgDiv.style.backgroundPosition = 'center';
            }
        }
        async function restoreBackground() {
            try {
                const bg = await loadMedia('background');
                if (bg && bg.blob) applyBackground(bg.blob, bg.mimeType);
            } catch(e) { log(e); }
        }
        async function uploadBackground(file) {
            if (!file) return;
            await saveMedia('background', file, file.type);
            applyBackground(file, file.type);
        }
        async function uploadDragon(file) {
            if (!file) return;
            await saveMedia('dragon', file, file.type);
        }
        async function uploadTiger(file) {
            if (!file) return;
            await saveMedia('tiger', file, file.type);
        }
        let CURRENT_USER_ID = "6685731895";
        let state = {
            balance: 0,
            bets: { DRAGON: 0, TIGER: 0, TIE: 0 },
            betRolling: false,
            autoMode: true,
            speed: 1,
            pool: 50000,
            countdown: 30,
            countdownInterval: null
        };
        let lastBet = null;
        let resultTimer = null;
        function showGameResult(msg) {
            const el = document.getElementById('battleResult');
            if (!el) return;
            if (msg.includes('开奖') && (msg.includes('中奖') || msg.includes('未中') || msg.includes('+'))) {
                el.innerText = msg;
                el.style.opacity = '1';
                if (resultTimer) clearTimeout(resultTimer);
                resultTimer = setTimeout(() => {
                    el.style.opacity = '0';
                    setTimeout(() => { if (el.innerText === msg) el.innerText = ''; }, 200);
                }, 3000);
            } else console.log("[静默]", msg);
        }
        function getCountdownSec() { return state.speed===1?30:(state.speed===2?20:10); }
        async function syncBalance() {
            try {
                const res = await fetch(`${API_URL}/balance?user_id=${CURRENT_USER_ID}`);
                const data = await res.json();
                state.balance = data.balance;
                updateUI();
            } catch(e) { showGameResult("⚠️ 连接失败，请检查API地址"); }
        }
        async function placeBet(type, amount) {
            if (state.betRolling || amount<=0 || amount>state.balance) return false;
            state.betRolling = true;
            try {
                const res = await fetch(`${API_URL}/bet`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ user_id: CURRENT_USER_ID, type: type, amount: amount })
                });
                const data = await res.json();
                if (data.error) throw new Error(data.error);
                state.balance = data.balance;
                updateUI();
                const resultMsg = data.win > 0 ? `🎲 开奖: ${data.result}  ✅ 中奖 +${data.win} TRX` : `🎲 开奖: ${data.result}  ❌ 未中奖`;
                showGameResult(resultMsg);
                if (state.autoMode) { clearCountdown(); startCountdown(getCountdownSec()); }
                state.betRolling = false;
                return true;
            } catch(e) { showGameResult("❌ 押注失败"); state.betRolling = false; return false; }
        }
        function executeBet() {
            if (state.betRolling) return;
            const total = state.bets.DRAGON + state.bets.TIGER + state.bets.TIE;
            if (total <= 0) return;
            let selectedType = null, selectedAmount = 0;
            if (state.bets.DRAGON > selectedAmount) { selectedType = "DRAGON"; selectedAmount = state.bets.DRAGON; }
            if (state.bets.TIGER > selectedAmount) { selectedType = "TIGER"; selectedAmount = state.bets.TIGER; }
            if (state.bets.TIE > selectedAmount) { selectedType = "TIE"; selectedAmount = state.bets.TIE; }
            if (!selectedType) return;
            const betType = { DRAGON:"龙", TIGER:"虎", TIE:"和" }[selectedType];
            lastBet = { type: betType, amount: selectedAmount };
            placeBet(betType, selectedAmount).then(success => { if(success){ state.bets = { DRAGON:0, TIGER:0, TIE:0 }; updateUI(); } });
        }
        function repeatLastBet() { if(lastBet && !state.betRolling) placeBet(lastBet.type, lastBet.amount); }
        function cancelAllBets() { if(!state.betRolling){ state.bets = { DRAGON:0, TIGER:0, TIE:0 }; updateUI(); } }
        function updateUI() {
            document.getElementById('balanceDisplay').innerText = state.balance.toFixed(2);
            document.getElementById('poolDisplay').innerText = state.pool.toFixed(2);
            document.getElementById('betDragonAmount').innerText = state.bets.DRAGON;
            document.getElementById('betTigerAmount').innerText = state.bets.TIGER;
            document.getElementById('betTieAmount').innerText = state.bets.TIE;
            const total = state.bets.DRAGON + state.bets.TIGER + state.bets.TIE;
            document.getElementById('totalBetAmount').innerText = total.toFixed(2);
            let maxWin = 0;
            if (state.bets.DRAGON > 0) maxWin = Math.max(maxWin, state.bets.DRAGON * 2);
            if (state.bets.TIGER > 0) maxWin = Math.max(maxWin, state.bets.TIGER * 2);
            if (state.bets.TIE > 0) maxWin = Math.max(maxWin, state.bets.TIE * 8);
            document.getElementById('valWin').innerText = maxWin.toFixed(2);
            document.querySelectorAll('.multi-bet-item').forEach(el => {
                const type = el.dataset.type;
                if (state.bets[type] > 0) el.classList.add('selected');
                else el.classList.remove('selected');
            });
        }
        function adjustBet(type, delta) { if(!state.betRolling){ let newVal = state.bets[type] + delta; if(newVal<0) newVal=0; state.bets[type]=newVal; updateUI(); } }
        function startPoolFluctuation() { setInterval(() => { let change = Math.floor(Math.random()*61)-30; let newPool = state.pool+change; if(newPool<10000) newPool=10000; if(newPool>100000) newPool=100000; state.pool=newPool; document.getElementById('poolDisplay').innerText=state.pool.toFixed(2); }, 1000); }
        function startCountdown(sec) {
            if(state.countdownInterval) clearInterval(state.countdownInterval);
            state.countdown = sec;
            document.getElementById('countdownNum').innerText = state.countdown;
            state.countdownInterval = setInterval(() => {
                if(state.countdown <= 1){
                    clearInterval(state.countdownInterval);
                    state.countdownInterval = null;
                    if(state.bets.DRAGON+state.bets.TIGER+state.bets.TIE > 0) executeBet();
                    else startCountdown(getCountdownSec());
                } else {
                    state.countdown--;
                    document.getElementById('countdownNum').innerText = state.countdown;
                }
            }, 1000);
        }
        function clearCountdown() { if(state.countdownInterval){ clearInterval(state.countdownInterval); state.countdownInterval=null; } }
        function refreshBalance() { syncBalance(); }
        function setSpeed(speed) {
            state.speed = speed;
            document.querySelectorAll('.speed-btn').forEach(btn => {
                if(parseInt(btn.dataset.speed)===speed) btn.classList.add('active');
                else btn.classList.remove('active');
            });
            clearCountdown();
            startCountdown(getCountdownSec());
        }
        function switchUser() {
            const newId = document.getElementById('switchUserIdInput').value.trim();
            if(!newId) return;
            CURRENT_USER_ID = newId;
            document.getElementById('currentUserId').innerText = CURRENT_USER_ID;
            state.bets = { DRAGON:0, TIGER:0, TIE:0 };
            lastBet = null;
            updateUI();
            syncBalance();
            clearCountdown();
            startCountdown(getCountdownSec());
        }
        const hiddenInput = document.getElementById('hiddenFileInput');
        let pendingUploadType = null;
        hiddenInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (!file) return;
            if (pendingUploadType === 'dragon') uploadDragon(file);
            else if (pendingUploadType === 'tiger') uploadTiger(file);
            else if (pendingUploadType === 'background') uploadBackground(file);
            pendingUploadType = null;
            hiddenInput.value = '';
        });
        function triggerUpload(type) {
            pendingUploadType = type;
            hiddenInput.click();
        }
        let longPressTimer = null;
        let activeMenu = null;
        function showSecretMenu() {
            if(activeMenu) { activeMenu.remove(); activeMenu=null; return; }
            const menu = document.createElement('div');
            menu.className = 'secret-menu';
            menu.innerHTML = `
                <button id="secretDragon">🐉 上传龙图/视频</button>
                <button id="secretTiger">🐯 上传虎图/视频</button>
                <button id="secretBg">🌌 上传背景 (图/视频)</button>
                <button id="secretSettings">🔐 设置中心 (密码保护)</button>
            `;
            document.body.appendChild(menu);
            activeMenu = menu;
            const closeHandler = (e) => {
                if(!menu.contains(e.target)){
                    menu.remove(); activeMenu=null; document.removeEventListener('click', closeHandler);
                }
            };
            setTimeout(()=>document.addEventListener('click', closeHandler), 20);
            document.getElementById('secretDragon').onclick = () => {
                if(activeMenu) activeMenu.remove();
                activeMenu = null;
                triggerUpload('dragon');
            };
            document.getElementById('secretTiger').onclick = () => {
                if(activeMenu) activeMenu.remove();
                activeMenu = null;
                triggerUpload('tiger');
            };
            document.getElementById('secretBg').onclick = () => {
                if(activeMenu) activeMenu.remove();
                activeMenu = null;
                triggerUpload('background');
            };
            document.getElementById('secretSettings').onclick = () => {
                if(activeMenu) activeMenu.remove();
                activeMenu = null;
                const pwd = prompt("🔐 请输入管理密码:", "");
                if(pwd !== ADMIN_PASSWORD){ alert("密码错误！"); return; }
                const action = prompt("设置中心\n1. 修改API地址\n2. 修改管理密码\n请输入数字(1/2):", "1");
                if(action === "1"){
                    const newApi = prompt("请输入新的API地址:", API_URL);
                    if(newApi && newApi.trim()){ setApiUrl(newApi.trim()); alert("✅ API地址已更新"); setTimeout(()=>syncBalance(),200); }
                } else if(action === "2"){
                    const newPwd = prompt("请输入新的管理密码 (至少4位):", "");
                    if(newPwd && newPwd.length>=4){
                        if(changePassword(pwd, newPwd)) alert("✅ 密码修改成功！");
                        else alert("❌ 密码修改失败");
                    } else alert("密码无效");
                } else alert("无效选项");
            };
        }
        function onLongPress() {
            const pwd = prompt("🔐 管理员验证（长按续押按钮3秒）\n请输入管理密码:", "");
            if(pwd === ADMIN_PASSWORD) {
                showSecretMenu();
            } else if(pwd !== null) {
                alert("密码错误！");
            }
        }
        function bindEvents() {
            document.getElementById('refreshBtn').onclick = refreshBalance;
            const repeatBtn = document.getElementById('repeatBtn');
            repeatBtn.onclick = null;
            repeatBtn.addEventListener('click', (e) => {
                if(longPressTimer) clearTimeout(longPressTimer);
                repeatLastBet();
            });
            repeatBtn.addEventListener('touchstart', (e) => {
                longPressTimer = setTimeout(() => { onLongPress(); longPressTimer = null; }, 3000);
            });
            repeatBtn.addEventListener('touchend', () => { if(longPressTimer) clearTimeout(longPressTimer); });
            repeatBtn.addEventListener('touchcancel', () => { if(longPressTimer) clearTimeout(longPressTimer); });
            repeatBtn.addEventListener('mousedown', (e) => {
                longPressTimer = setTimeout(() => { onLongPress(); longPressTimer = null; }, 3000);
            });
            repeatBtn.addEventListener('mouseup', () => { if(longPressTimer) clearTimeout(longPressTimer); });
            document.getElementById('cancelBtn').onclick = cancelAllBets;
            document.getElementById('fightBtn').onclick = executeBet;
            document.getElementById('switchUserBtn').onclick = switchUser;
            document.querySelectorAll('.speed-btn').forEach(btn => btn.onclick = () => setSpeed(parseInt(btn.dataset.speed)));
            document.querySelectorAll('.bet-dec').forEach(btn => btn.onclick = (e) => { e.stopPropagation(); adjustBet(btn.dataset.type, -10); });
            document.querySelectorAll('.bet-inc').forEach(btn => btn.onclick = (e) => { e.stopPropagation(); adjustBet(btn.dataset.type, 10); });
        }
        async function init() {
            await openDB();
            await restoreBackground();
            bindEvents();
            await syncBalance();
            startPoolFluctuation();
            setSpeed(1);
            updateUI();
            startCountdown(getCountdownSec());
        }
        window.onload = init;
    })();
</script>
</body>
</html>
