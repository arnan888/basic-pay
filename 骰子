                <div id="fishDoubleGrid" style="display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; margin-bottom:8px;"></div>
                <button id="fishRecordBtn" class="exec-btn" style="width:100%; padding:6px;">📜 记录</button>
                <div id="fishPlayersPanel" style="margin-top:8px; background:rgba(0,0,0,0.4); border-radius:16px; padding:6px;"><strong>👥 闲家押注</strong><div id="fishPlayerBetsList"></div></div>
            </div>
        `;
        const patternNames = ["鱼","虾","蟹","葫芦","金钱","鸡"];
        const patternEmojis = ["🐟","🦐","🦀","🎃","💰","🐔"];
        const doubleCombos = [
            ["鱼","虾"],["鱼","蟹"],["鱼","葫芦"],["鱼","金钱"],["鱼","鸡"],
            ["虾","蟹"],["虾","葫芦"],["虾","金钱"],["虾","鸡"],
            ["蟹","葫芦"],["蟹","金钱"],["蟹","鸡"],
            ["葫芦","金钱"],["葫芦","鸡"],["金钱","鸡"]
        ];
        function buildFishDice(diceDiv) {
            if(!diceDiv) return;
            diceDiv.innerHTML = '';
            const faces = ['fish-front','fish-back','fish-right','fish-left','fish-top','fish-bottom'];
            faces.forEach((faceClass, idx) => {
                let fd = document.createElement('div');
                fd.className = `fish-dice-face ${faceClass}`;
                fd.style.fontSize = '1.6rem';
                fd.innerText = patternEmojis[idx % 6];
                diceDiv.appendChild(fd);
            });
            const randX = Math.floor(Math.random() * 360);
            const randY = Math.floor(Math.random() * 360);
            diceDiv.style.transform = `rotateX(${randX}deg) rotateY(${randY}deg)`;
        }
        function setFishDiceValue(diceDiv, patternName) {
            let index = patternNames.indexOf(patternName);
            let rotateX = 0, rotateY = 0;
            switch(index) {
                case 0: rotateX=0; rotateY=0; break;
                case 1: rotateX=0; rotateY=-90; break;
                case 2: rotateX=0; rotateY=180; break;
                case 3: rotateX=0; rotateY=90; break;
                case 4: rotateX=-90; rotateY=0; break;
                case 5: rotateX=90; rotateY=0; break;
            }
            const extraX = 360 * (1 + Math.floor(Math.random() * 2));
            const extraY = 360 * (1 + Math.floor(Math.random() * 2));
            diceDiv.style.transform = `rotateX(${rotateX + extraX}deg) rotateY(${rotateY + extraY}deg)`;
        }
        const fishDice = [document.getElementById('fishDice0'), document.getElementById('fishDice1'), document.getElementById('fishDice2')];
        fishDice.forEach(d => buildFishDice(d));
        let patternBets = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
        let doubleBets = {};
        doubleCombos.forEach(combo => { doubleBets[combo.join(',')] = 0; });
        let currentChip = 10;
        let hasGrabbed = false;
        let playerBankerBalance = 0;
        let gameRecords = [], isRolling = false, roundActive = true, countdownTimer = null, lastWinAmount = 0;
        let playersList = [{ name:"闲家A", bet:0 }, { name:"闲家B", bet:0 }, { name:"闲家C", bet:0 }];
        let lastBetState = null;
        let clearTimer = null;

        function updateFishUI() {
            for(let p in patternBets) { let span = document.getElementById(`fishBet_${p}`); if(span) span.innerText = patternBets[p]; }
            for(let combo of doubleCombos) { let key = combo.join(','); let span = document.getElementById(`doubleBet_${key.replace(/,/g,'_')}`); if(span) span.innerText = doubleBets[key]; }
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + Object.values(doubleBets).reduce((a,b)=>a+b,0);
            document.getElementById('fishTotalBet').innerText = total;
            document.getElementById('fishLastWin').innerText = lastWinAmount;
            // 异步获取余额并显示
            getUserBalance().then(balance => {
                document.getElementById('fishMyBalance').innerText = balance.toFixed(2);
            });
            let panelDiv = document.getElementById('fishPlayerBetsList');
            if(panelDiv) panelDiv.innerHTML = playersList.map(p => `<div style="font-size:0.7rem;">${p.name}: ${p.bet} 元</div>`).join('');
        }
        function saveLastBetState() { lastBetState = { patternBets: {...patternBets}, doubleBets: {...doubleBets} }; }
        async function repeatLastBet() {
            if(!lastBetState) { showToast("无上局押注"); return; }
            let total = Object.values(lastBetState.patternBets).reduce((a,b)=>a+b,0) + Object.values(lastBetState.doubleBets).reduce((a,b)=>a+b,0);
            let bal = await getUserBalance();
            if(total > bal) { showToast("余额不足"); return; }
            let oldTotal = Object.values(patternBets).reduce((a,b)=>a+b,0) + Object.values(doubleBets).reduce((a,b)=>a+b,0);
            if(oldTotal>0) await setUserBalance(bal + oldTotal);
            patternBets = {...lastBetState.patternBets};
            doubleBets = {...lastBetState.doubleBets};
            await setUserBalance(await getUserBalance() - total);
            updateFishUI();
            showToast("续押成功");
        }
        async function addPatternBet(pattern, val) {
            if(hasGrabbed) { showToast("庄家不能下注"); return; }
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + Object.values(doubleBets).reduce((a,b)=>a+b,0);
            if(val>500 || total+val>2000) { showToast("超上限"); return; }
            let bal = await getUserBalance();
            if(val > bal) { showToast("余额不足"); return; }
            await setUserBalance(bal - val);
            patternBets[pattern] += val;
            updateFishUI();
            saveLastBetState();
        }
        async function subPatternBet(pattern, val) { let cur=patternBets[pattern]; if(cur<val) val=cur; if(val===0) return; patternBets[pattern]-=val; let bal = await getUserBalance(); await setUserBalance(bal + val); updateFishUI(); saveLastBetState(); }
        async function addDoubleBet(comboKey) {
            if(hasGrabbed) { showToast("庄家不能下注"); return; }
            let val = currentChip;
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + Object.values(doubleBets).reduce((a,b)=>a+b,0);
            if(val>500 || total+val>2000) { showToast("超上限"); return; }
            let bal = await getUserBalance();
            if(val > bal) { showToast("余额不足"); return; }
            await setUserBalance(bal - val);
            doubleBets[comboKey] += val;
            updateFishUI();
            saveLastBetState();
        }
        async function clearFishBets() {
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + Object.values(doubleBets).reduce((a,b)=>a+b,0);
            if(total>0) {
                let bal = await getUserBalance();
                await setUserBalance(bal + total);
            }
            patternBets = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
            for(let k in doubleBets) doubleBets[k]=0;
            updateFishUI();
            saveLastBetState();
        }
        async function rollFishDiceWithAnimation(finalPatterns) {
            for(let i=0;i<3;i++) { fishDice[i].style.transition = 'none'; const randX=Math.random()*360; const randY=Math.random()*360; fishDice[i].style.transform=`rotateX(${randX}deg) rotateY(${randY}deg)`; }
            await new Promise(r=>setTimeout(r,40));
            for(let i=0;i<3;i++) fishDice[i].style.transition = 'transform 0.4s cubic-bezier(0.4,0,0.2,1)';
            for(let step=0;step<10;step++){ for(let i=0;i<3;i++){ const randX=Math.random()*360; const randY=Math.random()*360; fishDice[i].style.transform=`rotateX(${randX}deg) rotateY(${randY}deg)`; } await new Promise(r=>setTimeout(r,60)); }
            for(let i=0;i<3;i++) setFishDiceValue(fishDice[i], finalPatterns[i]);
            await new Promise(r=>setTimeout(r,300));
        }
        async function settleFish() {
            if(isRolling) return;
            let totalBet = Object.values(patternBets).reduce((a,b)=>a+b,0) + Object.values(doubleBets).reduce((a,b)=>a+b,0);
            if(totalBet===0 && !hasGrabbed) { showToast("请先下注"); return; }
            isRolling = true;
            let r1 = patternNames[Math.floor(Math.random()*6)];
            let r2 = patternNames[Math.floor(Math.random()*6)];
            let r3 = patternNames[Math.floor(Math.random()*6)];
            await rollFishDiceWithAnimation([r1,r2,r3]);
            
            let occursRaw = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
            [r1,r2,r3].forEach(p=>occursRaw[p]++);
            let occursEffective = { ...occursRaw };
            let shrimpCount = occursRaw["虾"];
            let crabCount = occursRaw["蟹"];
            occursEffective["虾"] = crabCount;
            occursEffective["蟹"] = shrimpCount;
            
            let winAmount = 0;
            for(let p in patternBets) {
                let cnt = occursEffective[p];
                if(cnt>0 && patternBets[p]>0) {
                    winAmount += patternBets[p] * (cnt+1);
                }
            }
            for(let combo of doubleCombos) {
                let key = combo.join(',');
                let betAmt = doubleBets[key];
                if(betAmt>0) {
                    let a = combo[0];
                    let b = combo[1];
                    let effA = (a === "虾") ? "蟹" : (a === "蟹") ? "虾" : a;
                    let effB = (b === "虾") ? "蟹" : (b === "蟹") ? "虾" : b;
                    if(occursEffective[effA] > 0 && occursEffective[effB] > 0) {
                        winAmount += betAmt * 4.5;
                    }
                }
            }
            winAmount = winAmount * adjustFactor;
            
            let isPlayerWin = (winAmount > totalBet);
            let serviceFee = 0;
            if (isPlayerWin) {
                serviceFee = winAmount * 0.01;
            } else {
                if (hasGrabbed) {
                    serviceFee = winAmount * 0.02;
                }
            }
            let finalWin = winAmount - serviceFee;
            let netProfit = finalWin - totalBet;
            lastWinAmount = netProfit;
            
            let pop = document.createElement('div'); 
            pop.className='result-popup'; 
            pop.innerText = finalWin>0 ? `🎉 赢 ${finalWin.toFixed(2)}` : `😭 输 ${totalBet}`;
            document.body.appendChild(pop); 
            setTimeout(()=>pop.remove(), 1800);
            
            gameRecords.unshift({ 
                time: new Date().toLocaleTimeString(), 
                dice: `${r1},${r2},${r3}`, 
                result: finalWin>0 ? `赢${finalWin.toFixed(2)}` : `输${totalBet}`,
                fee: serviceFee.toFixed(2)
            });
            updateFishUI();
            
            let wasGrabbed = hasGrabbed;
            
            if (clearTimer) clearTimeout(clearTimer);
            clearTimer = setTimeout(async () => {
                let curBal = await getUserBalance();
                await setUserBalance(curBal + finalWin);
                patternBets = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
                for(let k in doubleBets) doubleBets[k]=0;
                updateFishUI();
                saveLastBetState();
                
                if (wasGrabbed) {
                    let bankerNet = (totalBet - finalWin) * adjustFactor;
                    playerBankerBalance += bankerNet;
                    if (playerBankerBalance !== 0) {
                        let curBal2 = await getUserBalance();
                        await setUserBalance(curBal2 + playerBankerBalance);
                        showToast(`庄家结算 ${playerBankerBalance>0 ? '盈利' : '亏损'} ${Math.abs(playerBankerBalance).toFixed(2)} 元`);
                    }
                    hasGrabbed = false;
                    playerBankerBalance = 0;
                    localStorage.removeItem('neon_fish_banker');
                    updateFishUI();
                }
                await addGameRecord(currentUser.account, '金辉鱼虾蟹', 
                    `单选${Object.entries(patternBets).filter(([k,v])=>v>0).map(([k,v])=>`${k}${v}`).join(',')} 双押${Object.entries(doubleBets).filter(([k,v])=>v>0).map(([k,v])=>`${k}=${v}`).join(',')}`, 
                    `${r1},${r2},${r3}`, finalWin, totalBet);
                if(roundActive) startFishRound();
            }, 3000);
            
            isRolling = false;
            if (countdownTimer) clearInterval(countdownTimer);
        }
        function startFishRound() {
            if(countdownTimer) clearInterval(countdownTimer);
            let remaining=25;
            let hintDiv=document.getElementById('fishPhaseHint');
            if(hintDiv) hintDiv.innerText = `🎲 下注阶段 · ${remaining}秒`;
            countdownTimer = setInterval(()=>{ 
                remaining--; 
                if(hintDiv) hintDiv.innerText=`🎲 下注阶段 · ${remaining}秒`; 
                if(remaining<=0){ 
                    clearInterval(countdownTimer); 
                    if(!isRolling && roundActive) settleFish(); 
                } 
            },1000);
        }
        function resetCountdown() {
            if (countdownTimer) clearInterval(countdownTimer);
            startFishRound();
        }
        let gridDiv = document.getElementById('fishPatternGrid');
        patternNames.forEach(p => {
            let card = document.createElement('div'); card.className = 'fish-bet-card';
            card.innerHTML = `<div style="font-size:1rem;">${patternEmojis[patternNames.indexOf(p)]}</div><div style="font-size:0.65rem;">${p}</div><div><button class="quick-bet sub-pat" data-pat="${p}" style="padding:2px 6px;">-</button><span id="fishBet_${p}" style="margin:0 4px; font-size:0.8rem;">0</span><button class="quick-bet add-pat" data-pat="${p}" style="padding:2px 6px;">+</button></div>`;
            gridDiv.appendChild(card);
        });
        let doubleGrid = document.getElementById('fishDoubleGrid');
        doubleCombos.forEach(combo => {
            let key = combo.join(',');
            let btn = document.createElement('div'); btn.className='bet-card'; btn.style.padding='4px'; btn.style.fontSize='0.7rem';
            btn.innerHTML = `<div>${combo[0]}+${combo[1]}</div><div id="doubleBet_${key.replace(/,/g,'_')}" style="font-weight:bold;">0</div>`;
            btn.onclick = () => addDoubleBet(key);
            doubleGrid.appendChild(btn);
        });
        document.querySelectorAll('#fishChips .chip').forEach(chip=>{ chip.onclick=function(){ currentChip=parseInt(this.dataset.chip); document.querySelectorAll('#fishChips .chip').forEach(c=>c.classList.remove('selected')); this.classList.add('selected'); }; });
        document.getElementById('fishGrabBtn').onclick=async ()=>{ 
            if(hasGrabbed){ showToast("已是庄家"); return; } 
            let bal = await getUserBalance();
            if(bal>=2001){ 
                await setUserBalance(bal-2001); 
                playerBankerBalance=2001; 
                hasGrabbed=true; 
                localStorage.setItem('neon_fish_banker', playerBankerBalance); 
                updateFishUI(); 
                showToast("抢庄成功，不可下注"); 
                resetCountdown();
            } else showToast("余额不足2001"); 
        };
        document.getElementById('fishClearBtn').onclick=clearFishBets;
        document.getElementById('fishRepeatBtn').onclick=repeatLastBet;
        document.getElementById('fishRollBtn').onclick=()=>{ if(!isRolling && roundActive) settleFish(); };
        document.getElementById('fishRecordBtn').onclick=()=>{ 
            if(gameRecords.length===0){ showToast("暂无记录"); return; } 
            let html = '<div style="max-height:200px; overflow-y:auto;">';
            gameRecords.forEach(r => {
                html += `<div style="border-bottom:1px solid #ffaa33; padding:6px;">${r.time} 🎲 ${r.dice} ${r.result} ${r.fee>0 ? `<span style="color:#ff884d;">服务费:${r.fee}元</span>` : ''}</div>`;
            });
            html += '</div><button id="closeRec" class="auth-btn">关闭</button>';
            let m=document.createElement('div'); m.className='modal'; m.innerHTML=`<div class="modal-content">${html}</div>`; document.body.appendChild(m); m.querySelector('#closeRec').onclick=()=>m.remove(); 
        };
        gridDiv.addEventListener('click',(e)=>{ let btn=e.target.closest('.quick-bet'); if(!btn) return; let pat=btn.dataset.pat; if(btn.classList.contains('add-pat')) addPatternBet(pat, currentChip); if(btn.classList.contains('sub-pat')) subPatternBet(pat, currentChip); });
        let saved=localStorage.getItem('neon_fish_banker'); if(saved && parseInt(saved)>0){ hasGrabbed=true; playerBankerBalance=parseInt(saved); }
        updateFishUI();
        startFishRound();
        function updatePlayersBet() { if(hasGrabbed){ playersList.forEach(p=>{ p.bet=Math.floor(Math.random()*500)+50; }); updateFishUI(); } }
        setInterval(()=>{ if(hasGrabbed && roundActive && !isRolling) updatePlayersBet(); }, 10000);
        fishDestroy = () => { 
            if(clearTimer) clearTimeout(clearTimer);
            roundActive=false; 
            if(countdownTimer) clearInterval(countdownTimer); 
            container.innerHTML=''; 
        };
        window.currentFishReset = ()=>{ hasGrabbed=false; playerBankerBalance=0; localStorage.removeItem('neon_fish_banker'); updateFishUI(); };
        return fishDestroy;
    }

    // ==================== 骰宝游戏（独立3D骰子，带金额显示和盈亏） ====================
    let diceDestroy = null;
    function initDiceGame(container) {
