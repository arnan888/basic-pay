            transform-style: preserve-3d;
            transition: transform 0.5s cubic-bezier(0.2,0.8,0.3,1.1);
        }
        .dice-face {
            position: absolute;
            width: 60px;
            height: 60px;
            background: linear-gradient(145deg, #fffff0, #f5f5dc);
            border-radius: 12px;
            box-shadow: inset 0 2px 5px rgba(255,255,255,0.8), 0 5px 12px rgba(0,0,0,0.3);
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            border: 1px solid rgba(200,180,120,0.5);
        }
        .front  { transform: translateZ(30px); }
        .back   { transform: rotateY(180deg) translateZ(30px); }
        .right  { transform: rotateY(90deg) translateZ(30px); }
        .left   { transform: rotateY(-90deg) translateZ(30px); }
        .top    { transform: rotateX(90deg) translateZ(30px); }
        .bottom { transform: rotateX(-90deg) translateZ(30px); }

        .pip {
            position: absolute;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            box-shadow: inset 0 1px 2px rgba(255,255,255,0.5), 0 1px 2px rgba(0,0,0,0.2);
        }
        .face-1 .pip { background: radial-gradient(circle at 35% 35%, #e74c3c, #c0392b); }
        .face-2 .pip { background: radial-gradient(circle at 35% 35%, #3498db, #2980b9); }
        .face-3 .pip-tl, .face-3 .pip-br { background: radial-gradient(circle at 35% 35%, #2ecc71, #27ae60); }
        .face-3 .pip-center { background: radial-gradient(circle at 35% 35%, #e74c3c, #c0392b); }
        .face-3 .pip-tr, .face-3 .pip-bl { background: radial-gradient(circle at 35% 35%, #3498db, #2980b9); }
        .face-4 .pip { background: radial-gradient(circle at 35% 35%, #3498db, #2980b9); }
        .face-5 .pip-tl, .face-5 .pip-br { background: radial-gradient(circle at 35% 35%, #2ecc71, #27ae60); }
        .face-5 .pip-tr, .face-5 .pip-bl { background: radial-gradient(circle at 35% 35%, #3498db, #2980b9); }
        .face-5 .pip-mid { background: radial-gradient(circle at 35% 35%, #e74c3c, #c0392b); }
        .face-6 .pip { background: radial-gradient(circle at 35% 35%, #3498db, #2980b9); }

        .pip-center { top: 50%; left: 50%; transform: translate(-50%, -50%); }
        .pip-tl { top: 20%; left: 20%; }
        .pip-tr { top: 20%; right: 20%; }
        .pip-bl { bottom: 20%; left: 20%; }
        .pip-br { bottom: 20%; right: 20%; }
        .pip-mid { top: 50%; left: 50%; transform: translate(-50%, -50%); }
        .pip-l1 { left: 20%; top: 15%; }
        .pip-l2 { left: 20%; top: 50%; transform: translateY(-50%); }
        .pip-l3 { left: 20%; bottom: 15%; }
        .pip-r1 { right: 20%; top: 15%; }
        .pip-r2 { right: 20%; top: 50%; transform: translateY(-50%); }
        .pip-r3 { right: 20%; bottom: 15%; }

        @keyframes roll1 {
            0% { transform: rotateX(0deg) rotateY(0deg); }
            25% { transform: rotateX(180deg) rotateY(90deg); }
            50% { transform: rotateX(360deg) rotateY(180deg); }
            75% { transform: rotateX(540deg) rotateY(270deg); }
            100% { transform: rotateX(720deg) rotateY(360deg); }
        }
        @keyframes roll2 {
            0% { transform: rotateX(0deg) rotateY(0deg); }
            25% { transform: rotateX(90deg) rotateY(180deg); }
            50% { transform: rotateX(180deg) rotateY(360deg); }
            75% { transform: rotateX(270deg) rotateY(540deg); }
            100% { transform: rotateX(360deg) rotateY(720deg); }
        }
        @keyframes roll3 {
            0% { transform: rotateX(0deg) rotateY(0deg); }
            25% { transform: rotateX(120deg) rotateY(240deg); }
            50% { transform: rotateX(240deg) rotateY(480deg); }
            75% { transform: rotateX(360deg) rotateY(720deg); }
            100% { transform: rotateX(480deg) rotateY(960deg); }
        }
        .rolling1 { animation: roll1 0.9s cubic-bezier(0.2,0.9,0.4,1.1); }
        .rolling2 { animation: roll2 0.9s cubic-bezier(0.2,0.9,0.4,1.1); }
        .rolling3 { animation: roll3 0.9s cubic-bezier(0.2,0.9,0.4,1.1); }
        .land { animation: land 0.15s ease-out; }
        @keyframes land { 0% { transform: scale(1.15); } 100% { transform: scale(1); } }

        .total {
