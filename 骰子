            75% { transform: rotateX(360deg) rotateY(720deg); }
            100% { transform: rotateX(480deg) rotateY(960deg); }
        }
        .rolling1 { animation: roll1 0.9s cubic-bezier(0.2,0.9,0.4,1.1); }
