<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>金辉娱乐城 · 云端同步版</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }
        body {
            background: linear-gradient(145deg, #1a120b 0%, #2a1e12 100%);
            font-family: 'Segoe UI', 'Poppins', system-ui, sans-serif;
            padding: 12px;
            min-height: 100vh;
            color: #ffecb3;
            transition: background 0.3s, color 0.3s;
        }
        #app {
            max-width: 560px;
            margin: 0 auto;
            background: rgba(30, 20, 12, 0.75);
            backdrop-filter: blur(12px);
            border-radius: 48px;
            border: 1px solid rgba(255, 215, 0, 0.5);
            overflow: hidden;
        }
        .auth-panel {
            padding: 28px 20px;
            background: rgba(20, 12, 6, 0.8);
        }
        .auth-panel h2, .auth-panel h3 {
            text-align: center;
            margin-bottom: 16px;
            font-weight: 800;
            background: linear-gradient(135deg, #ffd966, #ffaa33);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .auth-input {
            width: 100%;
            padding: 12px 16px;
            margin: 6px 0;
            background: rgba(0,0,0,0.6);
            border: 1px solid #ffaa33;
            border-radius: 40px;
            color: #ffd966;
            font-size: 0.95rem;
            outline: none;
        }
        .flex-row {
            display: flex;
            gap: 10px;
            align-items: center;
            margin: 10px 0;
        }
        .code-btn {
            background: linear-gradient(135deg, #ffaa33, #ff884d);
            border: none;
            border-radius: 40px;
            padding: 10px 18px;
            color: #2a1a0a;
            font-weight: 700;
            cursor: pointer;
        }
        .auth-btn {
            background: linear-gradient(135deg, #ffaa33, #ff884d);
            border: none;
            border-radius: 40px;
            padding: 12px;
            font-weight: bold;
            color: #2a1a0a;
            cursor: pointer;
            width: 100%;
            margin-top: 10px;
            font-size: 0.95rem;
        }
        hr {
            margin: 20px 0;
            border-color: #ffaa33;
        }
        .auth-note {
            font-size: 0.65rem;
            text-align: center;
            margin-top: 12px;
            color: #ffaa33;
        }
        .user-section {
            background: rgba(20, 12, 6, 0.7);
            padding: 12px 16px;
            border-bottom: 1px solid #ffaa33;
        }
        .user-info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }
        #userBalanceDisplay {
            font-size: 1.6rem;
            font-weight: 800;
            background: linear-gradient(135deg, #ffd966, #ffaa33);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            cursor: pointer;
        }
        .btn-group {
            display: flex;
            gap: 6px;
        }
        .btn-sm {
            background: rgba(255,170,51,0.2);
            border: 1px solid #ffaa33;
            padding: 4px 12px;
            border-radius: 40px;
            color: #ffd966;
            cursor: pointer;
            font-size: 0.75rem;
        }
        .charge-btn, .withdraw-btn {
            background: linear-gradient(135deg, #ffaa33, #ff884d);
            border: none;
            padding: 6px 16px;
            border-radius: 40px;
            color: #2a1a0a;
            font-weight: 700;
            cursor: pointer;
            font-size: 0.85rem;
        }
        .lang-switch, .theme-switch {
            background: #ffaa33;
            border: none;
            border-radius: 30px;
            padding: 4px 10px;
            color: #2a1a0a;
            cursor: pointer;
            font-size: 0.75rem;
            font-weight: bold;
            margin-left: 4px;
        }
        .game-nav {
            display: flex;
            gap: 6px;
            background: rgba(0,0,0,0.4);
            padding: 6px 12px;
            margin: 12px 12px;
            border-radius: 60px;
        }
        .game-tab {
            flex: 1;
            background: transparent;
            border: none;
            padding: 8px 0;
            border-radius: 40px;
            font-weight: 700;
            font-size: 0.8rem;
            color: #ffaa33;
            cursor: pointer;
        }
        .game-tab.active {
            background: linear-gradient(135deg, #ffaa33, #ff884d);
            color: #2a1a0a;
            box-shadow: 0 0 8px #ffaa33;
        }
        .game-container {
            padding: 8px 12px 20px;
        }
        .game-card {
            background: rgba(20, 12, 6, 0.7);
            backdrop-filter: blur(8px);
            border-radius: 32px;
            padding: 16px;
            border: 1px solid #ffaa33;
        }
        .chip {
            background: linear-gradient(145deg, #cc8800, #aa6600);
            display: inline-block;
            padding: 6px 14px;
            border-radius: 36px;
            margin: 3px;
            cursor: pointer;
            font-weight: bold;
            color: #ffecb3;
            border: 1px solid #ffaa33;
            font-size: 0.85rem;
        }
        .chip.selected {
            background: linear-gradient(145deg, #ffaa33, #ff884d);
            color: #2a1a0a;
        }
        .quick-bet, .clear-bet {
            background: rgba(255,170,51,0.2);
            border: 1px solid #ffaa33;
            border-radius: 30px;
            padding: 4px 10px;
            margin: 3px;
            cursor: pointer;
            color: #ffd966;
            font-weight: 500;
            font-size: 0.75rem;
        }
        .exec-btn {
            background: linear-gradient(135deg, #ffaa33, #ff884d);
            border: none;
            border-radius: 36px;
            padding: 8px 14px;
            color: #2a1a0a;
            font-weight: bold;
            cursor: pointer;
            margin: 3px;
            font-size: 0.85rem;
        }
        .main-go {
            background: linear-gradient(135deg, #ffcc66, #ffaa33);
            font-weight: 800;
        }
        .countdown-area {
            text-align: center;
            margin: 6px 0 12px 0;
            background: rgba(0,0,0,0.5);
            border-radius: 40px;
            padding: 6px 12px;
            font-weight: bold;
            font-size: 0.9rem;
            color: #ffaa33;
        }
        /* 鱼虾蟹3D骰子 */
        .fish-dice-3d-area {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 20px 0;
            perspective: 1200px;
        }
        .fish-dice-cube {
            width: 70px;
            height: 70px;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
        }
        .fish-dice-face {
            position: absolute;
            width: 100%;
            height: 100%;
            background: #2a1e12;
            border: 2px solid #ffaa33;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            backface-visibility: visible;
            font-size: 2rem;
            font-weight: bold;
            color: #ffd966;
        }
        .fish-front { transform: translateZ(35px); }
        .fish-back { transform: rotateY(180deg) translateZ(35px); }
        .fish-right { transform: rotateY(90deg) translateZ(35px); }
        .fish-left { transform: rotateY(-90deg) translateZ(35px); }
        .fish-top { transform: rotateX(90deg) translateZ(35px); }
        .fish-bottom { transform: rotateX(-90deg) translateZ(35px); }
        @media (max-width:480px){ .fish-dice-cube{width:60px;height:60px;} .fish-front,.fish-back,.fish-right,.fish-left,.fish-top,.fish-bottom{transform:translateZ(30px);} .fish-dice-face{font-size:1.5rem;} }
        /* 骰宝3D骰子 */
        .dice-3d-area {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 20px 0;
            perspective: 1200px;
        }
        .dice-cube {
            width: 70px;
            height: 70px;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
        }
        .dice-face {
            position: absolute;
            width: 100%;
            height: 100%;
            background: #2a1e12;
            border: 2px solid #ffaa33;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            backface-visibility: visible;
        }
        .front { transform: translateZ(35px); }
        .back { transform: rotateY(180deg) translateZ(35px); }
        .right { transform: rotateY(90deg) translateZ(35px); }
        .left { transform: rotateY(-90deg) translateZ(35px); }
        .top { transform: rotateX(90deg) translateZ(35px); }
        .bottom { transform: rotateX(-90deg) translateZ(35px); }
        @media (max-width:480px){ .dice-cube{width:60px;height:60px;} .front,.back,.right,.left,.top,.bottom{transform:translateZ(30px);} }
        .pip {
            width: 10px;
            height: 10px;
            background: #ffaa33;
            border-radius: 50%;
            margin: 2px;
        }
        .pip-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); }
        .pip-tl { position: absolute; top: 8px; left: 8px; }
        .pip-tr { position: absolute; top: 8px; right: 8px; }
        .pip-bl { position: absolute; bottom: 8px; left: 8px; }
        .pip-br { position: absolute; bottom: 8px; right: 8px; }
        .pip-mid { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); }
        .pip-l1,.pip-l2,.pip-l3 { position: absolute; left: 8px; }
        .pip-l1 { top: 8px; }
        .pip-l2 { top: 50%; transform: translateY(-50%); }
        .pip-l3 { bottom: 8px; }
        .pip-r1,.pip-r2,.pip-r3 { position: absolute; right: 8px; }
        .pip-r1 { top: 8px; }
        .pip-r2 { top: 50%; transform: translateY(-50%); }
        .pip-r3 { bottom: 8px; }
        .fish-pattern-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 5px; margin: 10px 0; }
        .fish-bet-card { background: rgba(0,0,0,0.5); border-radius: 16px; padding: 6px 2px; text-align: center; border: 1px solid #ffaa33; }
        .bet-card { background: rgba(0,0,0,0.5); border-radius: 18px; padding: 6px; text-align: center; cursor: pointer; border: 1px solid #ffaa33; font-size: 0.8rem; }
        .points-grid, .trio-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(58px,1fr)); gap: 6px; margin: 10px 0; }
        .history-cell { width: 32px; height: 32px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background: rgba(255,170,51,0.2); font-weight: bold; }
        .modal { position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1000; }
        .modal-content { background: #2a1e12; border-radius: 36px; padding: 20px; max-width: 90%; max-height: 85%; overflow: auto; color: #ffd966; border: 1px solid #ffaa33; text-align: center; }
        .qr-img { width: 120px; height: 120px; object-fit: cover; border-radius: 16px; border: 2px solid #ffaa33; background: white; }
        .toast-message { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); background: #2a1a0a; color: #ffd966; padding: 6px 16px; border-radius: 40px; z-index: 2000; font-weight: bold; white-space: nowrap; border: 1px solid #ffaa33; font-size: 0.8rem; }
        .result-popup { position: fixed; bottom: 40%; left: 50%; transform: translateX(-50%); background: linear-gradient(135deg,#ffaa33,#ff884d); color: #2a1a0a; padding: 10px 24px; border-radius: 50px; font-weight: bold; font-size: 1rem; z-index: 1500; }
        .admin-table { width: 100%; border-collapse: collapse; font-size: 0.75rem; }
        .admin-table th, .admin-table td { padding: 6px 4px; border-bottom: 1px solid #ffaa33; text-align: left; }
        .admin-btn { background: #ffaa33; border: none; border-radius: 20px; padding: 4px 8px; margin: 2px; color: #2a1a0a; font-weight: bold; cursor: pointer; font-size: 0.7rem; }
        @keyframes dtFlash { 0%{opacity:1;text-shadow:0 0 5px gold;} 50%{opacity:0.3;text-shadow:0 0 30px orange;} 100%{opacity:1;text-shadow:0 0 5px gold;} }
        @keyframes dtShake { 0%{transform:translateX(0);} 25%{transform:translateX(-8px) scale(1.05);} 50%{transform:translateX(8px) scale(1.1);} 75%{transform:translateX(-4px) scale(1.05);} 100%{transform:translateX(0) scale(1);} }
        .dt-flash { animation: dtFlash 0.3s 3; }
        .dt-animation-box { animation: dtShake 0.5s ease-in-out; }
        .niu-card { width: 55px; height: 75px; background: white; border-radius: 8px; display: inline-flex; flex-direction: column; justify-content: center; align-items: center; font-weight: bold; font-size: 1rem; margin: 0; box-shadow: 0 2px 6px rgba(0,0,0,0.3); flex-shrink: 0; color: #2a1a0a; }
        .niu-card[data-suit="♥"], .niu-card[data-suit="♦"] { color: #c33; }
        .niu-card[data-suit="♣"], .niu-card[data-suit="♠"] { color: #333; }
        .niu-hand { display: flex; flex-direction: row; flex-wrap: nowrap; overflow-x: auto; justify-content: center; gap: 8px; min-height: 100px; padding: 8px; background: rgba(0,0,0,0.3); border-radius: 20px; margin: 8px 0; }
        @media (max-width:480px){ .niu-card{width:48px;height:65px;font-size:0.85rem;} }
        body.light-mode { background: linear-gradient(145deg,#f5f0e6 0%,#e8dfd0 100%); color: #3a2a1a; }
        body.light-mode #app { background: rgba(245,240,230,0.85); border-color: rgba(180,130,60,0.5); }
        body.light-mode .auth-panel, body.light-mode .user-section, body.light-mode .game-card, body.light-mode .modal-content { background: rgba(250,245,235,0.9); border-color: #b8860b; color: #3a2a1a; }
        body.light-mode .auth-input, body.light-mode .fish-bet-card, body.light-mode .bet-card, body.light-mode .chip, body.light-mode .quick-bet, body.light-mode .exec-btn, body.light-mode .countdown-area { background: rgba(255,250,240,0.8); border-color: #c99a3b; color: #4a3a2a; }
        body.light-mode .chip.selected { background: linear-gradient(145deg,#ffcc77,#e6a822); color: #2a1a0a; }
        body.light-mode .fish-dice-face, body.light-mode .dice-face, body.light-mode .niu-card { background: #fffaf0; border-color: #c99a3b; color: #4a3a2a; }
        body.light-mode .toast-message { background: #fff9ef; color: #b8860b; border-color: #b8860b; }
        body.light-mode .result-popup { background: linear-gradient(135deg,#ffcc77,#e6a822); color: #2a1a0a; }
        body.light-mode .admin-table th, body.light-mode .admin-table td { border-bottom-color: #dbb45c; }
        body.light-mode .admin-btn { background: #e6a822; color: #2a1a0a; }
        body.light-mode .lang-switch, body.light-mode .theme-switch { background: #e6a822; color: #2a1a0a; }
        body.light-mode .charge-btn, body.light-mode .withdraw-btn { background: linear-gradient(135deg,#e6a822,#c9881c); color: #2a1a0a; }
        body.light-mode #userBalanceDisplay { background: linear-gradient(135deg,#c9881c,#a56b0f); -webkit-background-clip: text; background-clip: text; color: transparent; }
        body.light-mode #app > div:first-child { background: linear-gradient(135deg,#f5e6d3,#e8d8c0); border-bottom-color: #b8860b; }
        body.light-mode #app > div:first-child h1 { background: linear-gradient(135deg,#c9881c,#a56b0f); -webkit-background-clip: text; background-clip: text; color: transparent; }
        body.light-mode #app > div:first-child p { color: #b8860b; }
        body.light-mode #app > div:first-child div:last-child { background: #b8860b; }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pocketbase/0.22.4/pocketbase.umd.js"></script>
</head>
<body>
<div id="app"></div>
<script>
    // ==================== 配置 ====================
    // 请修改为你的 PocketBase 服务器地址（内网IP或公网穿透地址）
    const PB_URL = 'http://127.0.0.1:8090';  // 例如 http://192.168.1.100:8090
    const pb = new PocketBase(PB_URL);

    // ==================== 双语 ====================
    const lang = {
        zh: {
            recharge: "💎 充值", withdraw: "💰 提现", service: "📞 客服", logout: "退出", balance: "余额",
            phoneOrEmail: "手机号 / 邮箱", password: "密码 (≥4位)", referralCode: "推荐码 (必填)", remember: "记住账号",
            login: "登录", register: "注册", referralNote: "推荐码: VIP666,888VIP,GOLD2025,LUCKY8,DICE100",
            getCode: "获取验证码", verifyCode: "验证码", registerNow: "注册新账户",
            gameFish: "🐟 金辉鱼虾蟹", gameDice: "🎲 金辉骰宝", gameDT: "🐉 金辉龙虎斗", game4: "🐮 金辉牛牛"
        },
        th: {
            recharge: "💎 เติมเงิน", withdraw: "💰 ถอนเงิน", service: "📞 บริการ", logout: "ออก", balance: "ยอดเงิน",
            phoneOrEmail: "เบอร์โทร / อีเมล", password: "รหัสผ่าน (≥4)", referralCode: "รหัสแนะนำ", remember: "จำฉัน",
            login: "เข้าสู่ระบบ", register: "สมัคร", referralNote: "รหัส: VIP666,888VIP,GOLD2025,LUCKY8,DICE100",
            getCode: "รับรหัส", verifyCode: "รหัสยืนยัน", registerNow: "สมัครสมาชิก",
            gameFish: "🐟 ปลาหมึกทอง", gameDice: "🎲 เซียนเต๋าทอง", gameDT: "🐉 มังกรเสือทอง", game4: "🐮 กระบือทอง"
        }
    };
    let currentLang = 'zh';
    function t(key) { return lang[currentLang][key] || lang.zh[key] || key; }

    // ==================== 全局变量 ====================
    let currentUser = null;          // 当前登录用户的对象（包含 id, account, balance 等）
    let systemBankerBalance = 50000;
    let adjustFactor = 1.0;
    let validReferralCodes = ["VIP666","888VIP","GOLD2025","LUCKY8","DICE100"];

    function showToast(msg) {
        let t = document.createElement('div');
        t.className = 'toast-message';
        t.innerText = msg;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 2000);
    }

    // ==================== 加载系统配置 ====================
    async function loadSystemConfig() {
        try {
            const records = await pb.collection('system_config').getFullList();
            for (let rec of records) {
                if (rec.key === 'systemBankerBalance') systemBankerBalance = rec.value;
                if (rec.key === 'adjustFactor') adjustFactor = rec.value;
            }
        } catch (err) {
            console.warn("加载系统配置失败", err);
        }
    }

    // ==================== 用户操作（PocketBase 版） ====================
    async function login(account, password) {
        try {
            const user = await pb.collection('users').getFirstListItem(`account="${account}"`);
            if (user && user.password === password) {
                currentUser = user;
                return true;
            }
        } catch (err) {}
        showToast("账号或密码错误");
        return false;
    }

    async function register(account, password, code) {
        if (!validReferralCodes.includes(code)) {
            showToast("推荐码无效");
            return false;
        }
        try {
            // 检查账号是否已存在
            const existing = await pb.collection('users').getFirstListItem(`account="${account}"`).catch(() => null);
            if (existing) {
                showToast("账号已存在");
                return false;
            }
            await pb.collection('users').create({
                account: account,
                password: password,
                balance: 0,
                registerTime: new Date().toLocaleString(),
                records: [],
                resultHistory: []
            });
            return true;
        } catch (err) {
            showToast(err.message);
            return false;
        }
    }

    async function getUserBalance() {
        if (!currentUser) return 0;
        // 刷新用户信息
        const fresh = await pb.collection('users').getOne(currentUser.id);
        currentUser = fresh;
        return fresh.balance;
    }

    async function setUserBalance(amount) {
        if (!currentUser) return;
        await pb.collection('users').update(currentUser.id, { balance: amount });
        currentUser.balance = amount;
        const span = document.getElementById("userBalanceDisplay");
        if (span) span.innerText = amount.toFixed(2);
    }

    async function addGameRecord(account, gameName, betInfo, result, winAmount, betAmount) {
        try {
            const user = await pb.collection('users').getFirstListItem(`account="${account}"`);
            let records = user.records || [];
            records.unshift({
                time: new Date().toLocaleString(),
                game: gameName,
                bet: betInfo,
                result: result,
                win: winAmount,
                amount: betAmount
            });
            if (records.length > 100) records.pop();
            await pb.collection('users').update(user.id, { records: records });
        } catch (err) {
            console.warn("添加记录失败", err);
        }
    }

    // ==================== 充值（提交申请） ====================
    async function recharge() {
        let modalDiv = document.createElement('div');
        modalDiv.className = 'modal';
        modalDiv.innerHTML = `
            <div class="modal-content">
                <h3 style="color:#ffaa33;">💎 金辉充值</h3>
                <div style="display:flex; justify-content:center; gap:15px; margin:12px 0;">
                    <div><img class="qr-img" alt="微信收款码" src="mmexport1776247819360.jpg" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22%3E%3Crect width=%22100%22 height=%22100%22 fill=%22%23ddd%22/%3E%3Ctext x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 dy=%22.3em%22 fill=%22%23999%22%3E%E5%BE%AE%E4%BF%A1%E6%94%B6%E6%AC%BE%E7%A0%81%3C/text%3E%3C/svg%3E'"><p>微信支付</p></div>
