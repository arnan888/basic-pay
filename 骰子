DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>龙虎斗 · 骰盅开奖版 | 气势磅礴</title>
    <style>
        /* ============================================= */
        /* 全局样式与重置 */
        /* ============================================= */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }
        body {
            background: linear-gradient(145deg, #0a0a1a, #1a1a2e);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: "PingFang SC", "Microsoft YaHei", "Helvetica Neue", sans-serif;
            padding: 12px;
        }

        /* 主容器 */
        .container-outer {
            width: 100%;
            max-width: 500px;
            margin: 0 auto;
            background: linear-gradient(145deg, #2a2a3a, #1e1e2e);
            border-radius: 32px;
            padding: 8px;
            box-shadow: 0 20px 35px rgba(0,0,0,0.6);
        }
        .container {
            background: #2d2d3d;
            border-radius: 24px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* 战斗场景 (相对定位，骰盅覆盖) */
        .battle-scene {
            position: relative;
            margin: 16px;
            border-radius: 24px;
            overflow: hidden;
            background: #0a0a0a;
            height: 44vh;
            min-height: 280px;
            flex-shrink: 0;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.8), 0 10px 20px rgba(0,0,0,0.5);
        }
        .scene-bg {
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, #2a2a2a, #050505);
            z-index: 1;
        }
        /* 龙虎大字 */
        .dragon-word, .tiger-word {
            position: absolute;
            bottom: 20px;
            font-size: 56px;
            font-weight: 900;
            text-shadow: 6px 6px 0 rgba(0,0,0,0.6), 0 0 25px currentColor;
            z-index: 10;
            transition: all 0.2s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }
        .dragon-word { left: 20px; color: #ff5555; text-shadow: 0 0 15px red, 4px 4px 0 darkred; }
        .tiger-word { right: 20px; color: #55aaff; text-shadow: 0 0 15px blue, 4px 4px 0 darkblue; }
        .highlight-win {
            transform: scale(1.35);
            text-shadow: 0 0 40px currentColor, 8px 8px 0 rgba(0,0,0,0.5);
        }
        .battle-result {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            padding: 10px 28px;
            border-radius: 60px;
            color: #ffdd88;
            font-weight: bold;
            font-size: 20px;
            z-index: 20;
            white-space: nowrap;
            border: 2px solid #ffaa44;
            box-shadow: 0 0 20px rgba(255,170,68,0.8);
            letter-spacing: 2px;
        }
        /* ========== 骰盅超大样式 ========== */
        .dice-cover {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(ellipse at 30% 30%, #4a2e1a, #1f1408);
            backdrop-filter: blur(12px);
            border-radius: 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 30;
            transition: all 0.6s cubic-bezier(0.34, 1.1, 0.55, 1);
            box-shadow: 0 0 0 4px #e5b874, inset 0 0 40px rgba(0,0,0,0.7);
            cursor: pointer;
            border: 1px solid rgba(255,215,0,0.6);
        }
        .dice-cover span:first-child {
            font-size: 5rem;
            filter: drop-shadow(4px 8px 12px black);
            animation: breathe 1.8s infinite ease;
        }
        .cover-text {
            font-size: 1.1rem;
            background: #000000aa;
            padding: 6px 18px;
            border-radius: 60px;
            color: #ffdd99;
            margin-top: 12px;
            font-weight: bold;
            letter-spacing: 2px;
            border: 1px solid #ffcc66;
        }
        @keyframes breathe {
            0% { transform: scale(1); opacity: 0.9; }
            50% { transform: scale(1.08); opacity: 1; text-shadow: 0 0 15px gold; }
            100% { transform: scale(1); opacity: 0.9; }
        }
        /* 开盅动画：向上移动并淡出 */
        .dice-cover.open-cover {
            transform: translateY(-120px) scale(0.7);
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
        /* 隐藏状态（开盅后完全不可见，但保留占位） */
        .dice-cover.hidden-cover {
            display: none;
        }

        /* 押注区样式（沿用原风格，微调） */
        .bet-section {
            background: #23222f;
            margin: 16px;
            border-radius: 24px;
            padding: 20px;
            box-shadow: inset 0 1px 2px rgba(255,255,255,0.05), 0 8px 20px rgba(0,0,0,0.4);
            max-height: calc(100vh - 300px);
            overflow-y: auto;
        }
        .account-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #1b1b26;
            border-radius: 60px;
            padding: 8px 16px;
            margin-bottom: 16px;
        }
        .account-info, .account-info span { color: #ffaa66; font-size: 14px; }
        .btn-sm {
            background: #2e2e42;
            border: none;
            border-radius: 40px;
            padding: 6px 16px;
            color: #ffcc88;
            font-size: 12px;
            cursor: pointer;
            box-shadow: 2px 2px 4px rgba(0,0,0,0.4);
        }
        .btn-sm:active { transform: translateY(2px); }
        .multi-bet-item {
            background: #1b1b26;
            border-radius: 28px;
            padding: 18px 12px;
            margin-bottom: 20px;
            text-align: center;
            box-shadow: 0 5px 0 #0f0f16;
        }
        .multi-bet-name { font-size: 28px; font-weight: bold; margin-bottom: 8px; }
        .multi-bet-name.dragon { color: #ff6666; }
        .multi-bet-name.tiger { color: #66aaff; }
        .multi-bet-name.tie { color: #aa88ff; }
        .bet-amount-wrapper { background: #00000055; border-radius: 40px; padding: 8px; margin: 10px 0; }
        .multi-bet-amount { font-size: 34px; font-weight: 900; color: #ffdd99; }
        .multi-bet-control button, .quick-bet {
            background: #2e2e42;
            border: none;
            border-radius: 40px;
            padding: 5px 14px;
            color: #ffcc88;
            font-weight: bold;
            margin: 4px;
            box-shadow: 2px 2px 3px black;
            cursor: pointer;
        }
        .multi-bet-control button:active, .quick-bet:active { transform: translateY(2px); }
        .data-stack {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin: 20px 0;
        }
        .data-item {
            background: #1b1b26;
            border-radius: 28px;
            padding: 12px;
            text-align: center;
        }
        .data-item label { font-size: 12px; color: #ffaa77; }
        .data-item value { font-size: 28px; font-weight: bold; color: #ffdd99; display: block; }
        .timer-text { text-align: center; font-size: 20px; color: #ffcc66; margin: 16px 0; font-weight: bold; }
        .speed-select { display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; }
        .speed-btn {
            background: #2e2e42;
            border-radius: 40px;
            padding: 5px 24px;
            color: #ccc;
            font-weight: bold;
            cursor: pointer;
        }
        .speed-btn.active { background: #ff8844; color: #1a1a2a; }
        .history-area {
            background: #1b1b26;
            border-radius: 28px;
            padding: 16px;
            margin: 16px 0;
        }
        .history-grid {
            display: grid;
            grid-template-columns: repeat(10, 1fr);
            gap: 6px;
            justify-items: center;
            margin: 12px 0;
        }
        .history-cell {
            width: 32px;
            height: 32px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            background: #2a2a3a;
        }
        .history-cell.dragon { background: #ff4444; color: white; box-shadow: 0 0 6px red; }
        .history-cell.tiger { background: #4488ff; color: white; box-shadow: 0 0 6px blue; }
        .history-cell.tie { background: #aa66ff; color: white; }
        .record-list { max-height: 100px; overflow-y: auto; font-size: 12px; color: #ddd; }
        .exec-row {
            display: flex;
            gap: 12px;
            margin: 20px 0;
        }
        .exec-btn {
            flex: 1;
            background: #2e2e42;
            border: none;
            border-radius: 60px;
            padding: 12px 0;
            font-weight: bold;
            color: #ffdd99;
            cursor: pointer;
            box-shadow: 0 4px 0 #0f0f16;
        }
        .exec-btn:active { transform: translateY(2px); }
        .main-go { background: linear-gradient(145deg, #d43f1f, #a1220a); color: white; box-shadow: 0 4px 0 #5a1e0a; }
        .bottom-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-top: 16px;
        }
        .stat-card {
            background: #1b1b26;
            border-radius: 28px;
            padding: 12px;
            text-align: center;
        }
        .stat-card span:first-child { font-size: 12px; color: #ffaa77; display: block; }
        .stat-card span:last-child { font-size: 28px; font-weight: bold; color: #ffdd99; }
        .modal {
            position: fixed;
            top:0;left:0;width:100%;height:100%;
            background: rgba(0,0,0,0.9);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal-content {
            background: #2a2a3a;
            border-radius: 32px;
            padding: 24px;
            max-width: 320px;
            text-align: center;
        }
        button { pointer-events: auto; }
        @media (max-width: 500px) {
            .dragon-word, .tiger-word { font-size: 42px; }
            .dice-cover span:first-child { font-size: 3.5rem; }
            .cover-text { font-size: 0.8rem; }
        }
    </style>
</head>
<body>
<div class="container-outer">
    <div class="container">
        <!-- 战斗场景 + 骰盅 -->
        <div class="battle-scene" id="battleScene">
            <div class="scene-bg"></div>
            <div class="dragon-word" id="dragonWord">龍</div>
            <div class="tiger-word" id="tigerWord">虎</div>
            <div class="battle-result" id="battleResult">⚔️ 待开奖 ⚔️</div>
            <!-- 气势骰盅 -->
            <div class="dice-cover" id="diceCover">
                <span>🏺</span>
                <div class="cover-text">龍爭虎鬥 · 骰盅未啟</div>
            </div>
        </div>

        <!-- 押注操作区 -->
        <div class="bet-section">
            <div class="account-bar">
                <div class="account-info">👤 帳戶：<span id="currentUserId">wang8888</span></div>
                <div class="btn-group">
                    <button id="myHistoryBtn" class="btn-sm">📜 我的記錄</button>
                    <button id="newUserBtn" class="btn-sm">✨ 新用戶</button>
                </div>
            </div>
            <div class="account-bar" style="margin-top: 4px;">
                <input type="text" id="switchUserIdInput" placeholder="登錄用戶ID" style="flex:2; background:#1e1e2e; border:1px solid #ffaa44; border-radius:40px; padding:8px 16px; color:white;">
                <button id="switchUserBtn" class="btn-sm">登錄</button>
            </div>
            <!-- 龍 -->
            <div class="multi-bet-item" data-type="DRAGON">
                <div class="multi-bet-name dragon">🐉 龍</div>
                <div class="bet-amount-wrapper"><div class="bet-label-text">💰 單向押注額</div><div class="multi-bet-amount" id="betDragonAmount">0</div></div>
                <div class="multi-bet-control"><button class="clear-bet" data-type="DRAGON">🧹 清空</button></div>
                <div class="quick-bet-row">
                    <button class="quick-bet" data-type="DRAGON" data-amount="10">+10</button>
                    <button class="quick-bet" data-type="DRAGON" data-amount="20">+20</button>
                    <button class="quick-bet" data-type="DRAGON" data-amount="50">+50</button>
                    <button class="quick-bet" data-type="DRAGON" data-amount="100">+100</button>
                    <button class="quick-bet" data-type="DRAGON" data-amount="500">+500</button>
                </div>
            </div>
            <!-- 和 -->
            <div class="multi-bet-item" data-type="TIE">
                <div class="multi-bet-name tie">⚖️ 和</div>
                <div class="bet-amount-wrapper"><div class="bet-label-text">💰 單向押注額</div><div class="multi-bet-amount" id="betTieAmount">0</div></div>
                <div class="multi-bet-control"><button class="clear-bet" data-type="TIE">🧹 清空</button></div>
                <div class="quick-bet-row">
                    <button class="quick-bet" data-type="TIE" data-amount="10">+10</button>
                    <button class="quick-bet" data-type="TIE" data-amount="20">+20</button>
                    <button class="quick-bet" data-type="TIE" data-amount="50">+50</button>
                    <button class="quick-bet" data-type="TIE" data-amount="100">+100</button>
                    <button class="quick-bet" data-type="TIE" data-amount="500">+500</button>
                </div>
            </div>
            <!-- 虎 -->
            <div class="multi-bet-item" data-type="TIGER">
                <div class="multi-bet-name tiger">🐯 虎</div>
                <div class="bet-amount-wrapper"><div class="bet-label-text">💰 單向押注額</div><div class="multi-bet-amount" id="betTigerAmount">0</div></div>
                <div class="multi-bet-control"><button class="clear-bet" data-type="TIGER">🧹 清空</button></div>
                <div class="quick-bet-row">
                    <button class="quick-bet" data-type="TIGER" data-amount="10">+10</button>
                    <button class="quick-bet" data-type="TIGER" data-amount="20">+20</button>
                    <button class="quick-bet" data-type="TIGER" data-amount="50">+50</button>
                    <button class="quick-bet" data-type="TIGER" data-amount="100">+100</button>
                    <button class="quick-bet" data-type="TIGER" data-amount="500">+500</button>
                </div>
            </div>

            <div class="data-stack">
                <div class="data-item"><label>📊 總押注</label><value id="totalBetAmount">0.00</value></div>
                <div class="data-item"><label>🏆 預計獎金</label><value id="valWin">0.00</value></div>
            </div>
            <div class="timer-text">⏱️ 下一局: <span id="countdownNum">30</span> 秒</div>
            <div class="speed-select">
                <span class="speed-btn active" data-speed="1">1X</span>
                <span class="speed-btn" data-speed="2">2X</span>
                <span class="speed-btn" data-speed="3">3X</span>
            </div>
            <div class="history-area">
                <div class="history-title">📈 最近20局開獎</div>
                <div class="history-grid" id="historyGrid"></div>
                <div class="history-title">📋 開獎記錄</div>
                <div class="record-list" id="recordList"></div>
            </div>
            <div class="exec-row">
                <button class="exec-btn" id="refreshBtn">🔄 刷新</button>
                <button class="exec-btn" id="repeatBtn">🔁 續押</button>
                <button class="exec-btn" id="cancelBtn">❌ 全部取消</button>
                <button class="exec-btn main-go" id="fightBtn">🎲 確認投注 · 開盅！</button>
            </div>
            <div class="bottom-stats">
                <div class="stat-card"><span>💰 餘額</span><span id="balanceDisplay">0.00</span></div>
                <div class="stat-card"><span>😁 彩金池</span><span id="poolDisplay">50000.00</span></div>
            </div>
        </div>
    </div>
</div>

<script>
    // ==================== 龍虎鬥完整邏輯 + 氣勢骰盅動畫 ====================
    (function(){
        // ----- 語音播報 -----
        let speechEnabled = false;
        function enableSpeech() { if(!speechEnabled) speechEnabled = true; }
        document.body.addEventListener('click', enableSpeech, { once: true });
        function speak(text) {
            if(speechEnabled && window.speechSynthesis){
                const ut = new SpeechSynthesisUtterance(text);
                ut.lang = 'zh-CN'; ut.rate = 1.1;
                speechSynthesis.cancel();
                speechSynthesis.speak(ut);
            }
        }
        // ----- 用戶數據 -----
        let users = JSON.parse(localStorage.getItem('dragon_tiger_users')) || {};
        let CURRENT_USER_ID = "wang8888";
        if(!users[CURRENT_USER_ID]) users[CURRENT_USER_ID] = { balance: 1000.00, records: [], resultHistory: [] };
        localStorage.setItem('dragon_tiger_users', JSON.stringify(users));
        function saveUsers(){ localStorage.setItem('dragon_tiger_users', JSON.stringify(users)); }
        function getBalance(uid){ if(!users[uid]) users[uid]={ balance:1000, records:[], resultHistory:[] }; return users[uid].balance; }
        function setBalance(uid,amt){ if(!users[uid]) users[uid]={ balance:1000, records:[], resultHistory:[] }; users[uid].balance=amt; saveUsers(); }
        function addBalance(uid,delta){ setBalance(uid, getBalance(uid)+delta); }
        function getUserList(){ return Object.keys(users); }
        function generateRandomId(){ return "user_"+Math.floor(Math.random()*1000000); }
        
        // ----- 押注數據 -----
        let betDragon = 0, betTie = 0, betTiger = 0;
        let countdown = 30;
        let timerInterval = null;
        let currentSpeed = 1;
        let isOpening = false;  // 防止開盅中重複點擊
        
        // DOM 元素
        const balanceSpan = document.getElementById('balanceDisplay');
        const totalBetSpan = document.getElementById('totalBetAmount');
        const valWinSpan = document.getElementById('valWin');
        const dragonAmountSpan = document.getElementById('betDragonAmount');
        const tieAmountSpan = document.getElementById('betTieAmount');
        const tigerAmountSpan = document.getElementById('betTigerAmount');
        const countdownNumSpan = document.getElementById('countdownNum');
        const historyGrid = document.getElementById('historyGrid');
        const recordListDiv = document.getElementById('recordList');
        const fightBtn = document.getElementById('fightBtn');
        const diceCover = document.getElementById('diceCover');
        const battleResultDiv = document.getElementById('battleResult');
        const dragonWord = document.getElementById('dragonWord');
        const tigerWord = document.getElementById('tigerWord');
        
        function updateBetUI(){
            dragonAmountSpan.innerText = betDragon;
            tieAmountSpan.innerText = betTie;
            tigerAmountSpan.innerText = betTiger;
            let total = betDragon + betTie + betTiger;
            totalBetSpan.innerText = total.toFixed(2);
            // 預期獎金 (龍虎1賠1，和1賠8)
            let expected = (betDragon * 2) + (betTiger * 2) + (betTie * 9);
            valWinSpan.innerText = expected.toFixed(2);
        }
        function updateBalanceUI(){ balanceSpan.innerText = getBalance(CURRENT_USER_ID).toFixed(2); }
        
        // 添加押注（校驗餘額）
        function addBet(type, amount){
            let totalBetNow = betDragon+betTie+betTiger;
            let newTotal = totalBetNow + amount;
            let currentBal = getBalance(CURRENT_USER_ID);
            if(newTotal > currentBal){ showModal("餘額不足，無法加注", "知道了"); return false; }
            if(type === 'DRAGON') betDragon += amount;
            else if(type === 'TIE') betTie += amount;
            else if(type === 'TIGER') betTiger += amount;
            updateBetUI();
            return true;
        }
        function clearBet(type){
            if(type === 'DRAGON') betDragon = 0;
            else if(type === 'TIE') betTie = 0;
            else if(type === 'TIGER') betTiger = 0;
            updateBetUI();
        }
        function clearAllBets(){ betDragon=0; betTie=0; betTiger=0; updateBetUI(); }
        
        // 續押（複製上一局押注，需存儲最後押注）
        let lastBets = { dragon:0, tie:0, tiger:0 };
        function saveLastBets(){ lastBets = { dragon:betDragon, tie:betTie, tiger:betTiger }; }
        function repeatLastBets(){
            if(lastBets.dragon+lastBets.tie+lastBets.tiger === 0){ showModal("沒有可續押的記錄","好的"); return; }
            let total = lastBets.dragon+lastBets.tie+lastBets.tiger;
            if(total > getBalance(CURRENT_USER_ID)){ showModal("餘額不足，無法續押","取消"); return; }
            betDragon = lastBets.dragon;
            betTie = lastBets.tie;
            betTiger = lastBets.tiger;
            updateBetUI();
        }
        
        // 開獎核心 + 骰盅動畫整合
        function performOpenAndSettle(finalResult) {
            // finalResult: 'DRAGON', 'TIE', 'TIGER'
            let totalBet = betDragon+betTie+betTiger;
            if(totalBet === 0){ showModal("請先下注再開盅！", "好的"); return false; }
            let currentBal = getBalance(CURRENT_USER_ID);
            if(totalBet > currentBal){ showModal("餘額不足，無法開獎", "知道了"); return false; }
            
            // 扣除押注
            setBalance(CURRENT_USER_ID, currentBal - totalBet);
            let winAmount = 0;
            let winText = "";
            if(finalResult === 'DRAGON'){ winAmount = betDragon * 2; winText = "龍"; }
            else if(finalResult === 'TIGER'){ winAmount = betTiger * 2; winText = "虎"; }
            else { winAmount = betTie * 9; winText = "和"; }
            // 添加獎金
            addBalance(CURRENT_USER_ID, winAmount);
            let netProfit = winAmount - totalBet;
            // 記錄
            let record = { time: new Date().toLocaleTimeString(), bet: `龍:${betDragon} 虎:${betTiger} 和:${betTie}`, result: winText, win: netProfit, amount: totalBet };
            if(!users[CURRENT_USER_ID].records) users[CURRENT_USER_ID].records=[];
            users[CURRENT_USER_ID].records.unshift(record);
            if(users[CURRENT_USER_ID].records.length>50) users[CURRENT_USER_ID].records.pop();
            // 開獎歷史
            pushResultHistory(CURRENT_USER_ID, finalResult);
            saveUsers();
            updateBalanceUI();
            // 顯示結果動畫
            battleResultDiv.innerText = `🏆 ${winText} 獲勝！ 淨利 ${netProfit>=0?'+'+netProfit:netProfit}`;
            battleResultDiv.classList.add('pop');
            setTimeout(()=>battleResultDiv.classList.remove('pop'), 500);
            // 龍虎高亮動畫
            dragonWord.classList.remove('highlight-win');
            tigerWord.classList.remove('highlight-win');
            if(finalResult === 'DRAGON') dragonWord.classList.add('highlight-win');
            else if(finalResult === 'TIGER') tigerWord.classList.add('highlight-win');
            else { dragonWord.classList.add('highlight-win'); tigerWord.classList.add('highlight-win'); }
            setTimeout(()=>{
                dragonWord.classList.remove('highlight-win');
                tigerWord.classList.remove('highlight-win');
            }, 800);
            // 語音
            speak(`${winText} 勝利！`);
            // 清空本次押注 (為下一局)
            clearAllBets();
            saveLastBets();  // 保存當前這局押注（清空前已保存）
            updateHistoryDisplay();
            updateRecordList();
            return true;
        }
        
        function pushResultHistory(uid, result){
            if(!users[uid]) users[uid]={ balance:1000, records:[], resultHistory:[] };
            let arr = users[uid].resultHistory || [];
            arr.unshift(result);
            if(arr.length>20) arr.pop();
            users[uid].resultHistory = arr;
            saveUsers();
            if(uid===CURRENT_USER_ID) updateHistoryDisplay();
        }
        function updateHistoryDisplay(){
            let arr = users[CURRENT_USER_ID]?.resultHistory || [];
            historyGrid.innerHTML = "";
            for(let i=0;i<Math.min(20, arr.length);i++){
                let cell = document.createElement('div');
                cell.className = `history-cell ${arr[i].toLowerCase()}`;
                cell.innerText = arr[i]==='DRAGON'?'龍':(arr[i]==='TIGER'?'虎':'和');
                historyGrid.appendChild(cell);
            }
            for(let i=arr.length;i<20;i++){
                let cell = document.createElement('div'); cell.className='history-cell'; cell.innerText='?';
                historyGrid.appendChild(cell);
            }
        }
        function updateRecordList(){
            let recs = users[CURRENT_USER_ID]?.records || [];
            recordListDiv.innerHTML = "";
            recs.slice(0,15).forEach(r=>{
                let div = document.createElement('div'); div.className='record-item';
                div.innerHTML = `<span>${r.time}</span><span>${r.bet}</span><span class="${r.win>=0?'record-win':'record-lose'}">${r.win>=0?`+${r.win}`:`${r.win}`}</span>`;
                recordListDiv.appendChild(div);
            });
        }
        
        // ========== 骰盅開獎主流程（緩慢開盅 -> 隨機結果 -> 結算 -> 復位骰盅） ==========
        async function openDiceAndFight(){
            if(isOpening) { showModal("骰盅正在開啟，請稍後...", "好的"); return; }
            let total = betDragon+betTie+betTiger;
            if(total === 0){ showModal("請先下注再開盅", "馬上押注"); return; }
            if(total > getBalance(CURRENT_USER_ID)){ showModal("餘額不足，請減少押注", "知道了"); return; }
            isOpening = true;
            fightBtn.disabled = true;
            // 確保骰盅可見
            if(diceCover.classList.contains('hidden-cover')) diceCover.classList.remove('hidden-cover');
            diceCover.style.display = "flex";
            diceCover.classList.remove('open-cover');
            // 強制重繪
            void diceCover.offsetWidth;
            // 添加開盅動畫
            diceCover.classList.add('open-cover');
            // 等待動畫完成 (0.6s)
            await new Promise(resolve => setTimeout(resolve, 650));
            // 隱藏骰盅
            diceCover.classList.add('hidden-cover');
            diceCover.style.display = "none";
            // 隨機開獎 (龍/虎/和) 概率 龍:0.45 虎:0.45 和:0.1
            let rand = Math.random();
            let finalRes = '';
            if(rand < 0.45) finalRes = 'DRAGON';
            else if(rand < 0.9) finalRes = 'TIGER';
            else finalRes = 'TIE';
            // 執行結算
            performOpenAndSettle(finalRes);
            // 等待 1.2 秒後復位骰盅（讓玩家看清結果）
            await new Promise(resolve => setTimeout(resolve, 1500));
            // 復位骰盅：重新顯示並蓋上，骰子/文字恢復待開狀態
            diceCover.style.display = "flex";
            diceCover.classList.remove('open-cover', 'hidden-cover');
            diceCover.style.visibility = "visible";
            diceCover.style.opacity = "1";
            diceCover.style.transform = "translateY(0) scale(1)";
            battleResultDiv.innerText = "⚔️ 待開獎 ⚔️";
            // 重置倒計時
            resetCountdown();
            isOpening = false;
            fightBtn.disabled = false;
        }
        
        // 倒計時 (自動開獎)
        function resetCountdown(){
            if(timerInterval) clearInterval(timerInterval);
            countdown = Math.floor(30 / currentSpeed);
            countdownNumSpan.innerText = countdown;
            timerInterval = setInterval(()=>{
                if(countdown <= 1){
                    clearInterval(timerInterval);
                    if(!isOpening && (betDragon+betTie+betTiger)>0){
                        openDiceAndFight();
                    } else {
                        resetCountdown();
                    }
                } else {
                    countdown--;
                    countdownNumSpan.innerText = countdown;
                }
            }, 1000);
        }
        
        function setSpeed(speed){
            currentSpeed = speed;
            resetCountdown();
        }
        
        // 事件綁定
        function bindEvents(){
            document.querySelectorAll('.quick-bet').forEach(btn=>{
                btn.addEventListener('click',(e)=>{
                    let type = btn.getAttribute('data-type');
                    let amount = parseInt(btn.getAttribute('data-amount'));
                    if(!isNaN(amount)) addBet(type, amount);
                });
            });
            document.querySelectorAll('.clear-bet').forEach(btn=>{
                btn.addEventListener('click',(e)=>{
                    let type = btn.getAttribute('data-type');
                    clearBet(type);
                });
            });
            document.getElementById('cancelBtn').addEventListener('click', clearAllBets);
            document.getElementById('refreshBtn').addEventListener('click', ()=>{ updateBalanceUI(); updateHistoryDisplay(); updateRecordList(); });
            document.getElementById('repeatBtn').addEventListener('click', repeatLastBets);
            fightBtn.addEventListener('click', openDiceAndFight);
            document.getElementById('switchUserBtn').addEventListener('click', ()=>{
                let newId = document.getElementById('switchUserIdInput').value.trim();
                if(newId && users[newId]){ CURRENT_USER_ID = newId; document.getElementById('currentUserId').innerText = CURRENT_USER_ID; updateBalanceUI(); updateHistoryDisplay(); updateRecordList(); clearAllBets(); showModal(`切換至 ${CURRENT_USER_ID}`, "好的"); }
                else if(newId && !users[newId]){ showModal("用戶不存在，請先創建新帳戶", "知道了"); }
            });
            document.getElementById('newUserBtn').onclick = ()=>{
                let newId = generateRandomId();
                document.getElementById('switchUserIdInput').value = newId;
                users[newId] = { balance: 1000, records: [], resultHistory: [] };
                saveUsers();
                CURRENT_USER_ID = newId;
                document.getElementById('currentUserId').innerText = CURRENT_USER_ID;
                updateBalanceUI(); updateHistoryDisplay(); updateRecordList(); clearAllBets();
                showModal(`新帳戶 ${newId} 創建成功，初始餘額1000`, "開始遊戲");
            };
            document.querySelectorAll('.speed-btn').forEach(btn=>{
                btn.addEventListener('click',()=>{
                    let sp = parseInt(btn.getAttribute('data-speed'));
                    if(sp){ setSpeed(sp); document.querySelectorAll('.speed-btn').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); }
                });
            });
        }
        
        function showModal(msg, btnText){
            let modal = document.createElement('div'); modal.className='modal';
            modal.innerHTML = `<div class="modal-content"><h3>📢 提示</h3><p>${msg}</p><button id="modalCloseBtn">${btnText}</button></div>`;
            document.body.appendChild(modal);
            document.getElementById('modalCloseBtn').onclick = ()=>modal.remove();
        }
        
        // 初始化
        function init(){
            updateBalanceUI();
            updateHistoryDisplay();
            updateRecordList();
            clearAllBets();
            bindEvents();
            resetCountdown();
            // 確保骰盅初始可見
            diceCover.classList.remove('open-cover','hidden-cover');
            diceCover.style.display = "flex";
            battleResultDiv.innerText = "⚔️ 待開獎 ⚔️";
        }
        init();
    })();
</script>
</body>
</html>










<!DOCTYPE html>
<html lang="zh-CN">
