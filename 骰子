        .special-odds { font-size: 9px; color: #ffdd99; margin-top: 2px; }
        .special-bet-amount {
            font-size: 11px;
            font-weight: bold;
            color: #ffaa44;
            margin-top: 3px;
            background: rgba(0,0,0,0.5);
            border-radius: 20px;
            padding: 2px;
