        /* 点数区域 — 暖金色 */
        .points-outer {
            background: rgba(0,0,0,0.5);
            border-radius: 20px;
            padding: 8px;
            margin-bottom: 14px;
            box-shadow: inset 0 2px 6px rgba(0,0,0,0.5), 0 1px 0 rgba(255,255,255,0.05);
        }
        .points-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }
        .point-card {
            background: linear-gradient(145deg, #d4a017, #b8860b);
            border-radius: 14px;
            padding: 6px 2px;
            text-align: center;
            cursor: pointer;
            border: 1px solid rgba(255,215,0,0.6);
        }
        .point-card.selected {
            background: linear-gradient(135deg, #ffcc44, #ffaa44);
            transform: scale(0.97);
        }
        .point-value { font-size: 14px; font-weight: bold; color: #fff; text-shadow: 0 1px 1px rgba(0,0,0,0.3); }
        .point-odds { font-size: 8px; color: #fff9c4; }
        .point-bet-amount {
            font-size: 11px;
            font-weight: bold;
            color: #ffdd88;
            margin-top: 3px;
            background: rgba(0,0,0,0.5);
            border-radius: 20px;
            padding: 2px;
        }

        /* 围骰 / 豹子 — 深蓝色 */
        .trio-outer {
            margin-bottom: 14px;
        }
        .trio-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }
        .trio-card {
            background: linear-gradient(145deg, #1e3a8a, #1e40af);
            border-radius: 14px;
            padding: 6px 2px;
            text-align: center;
            cursor: pointer;
            border: 1px solid rgba(96,165,250,0.6);
        }
        .trio-card.selected {
            background: linear-gradient(135deg, #ffcc44, #ffaa44);
