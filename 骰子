        .admin-btns {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: center;
            margin: 12px 0;
        }
        .admin-btn {
            padding: 8px 16px;
            border-radius: 25px;
            border: none;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>
<body>
<div class="game-container">
    <div class="inner">
        <!-- 骰子区 -->
        <div class="dice-area section">
            <div class="dice-row">
                <div class="dice" id="dice1">
                    <div class="dice-face front face-1"><div class="pip pip-center"></div></div>
                    <div class="dice-face back face-6"><div class="pip pip-l1"></div><div class="pip pip-l2"></div><div class="pip pip-l3"></div><div class="pip pip-r1"></div><div class="pip pip-r2"></div><div class="pip pip-r3"></div></div>
                    <div class="dice-face right face-4"><div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div></div>
                    <div class="dice-face left face-3"><div class="pip pip-tl"></div><div class="pip pip-center"></div><div class="pip pip-br"></div></div>
                    <div class="dice-face top face-2"><div class="pip pip-tl"></div><div class="pip pip-br"></div></div>
                    <div class="dice-face bottom face-5"><div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-mid"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div></div>
                </div>
                <div class="dice" id="dice2">
                    <div class="dice-face front face-1"><div class="pip pip-center"></div></div>
                    <div class="dice-face back face-6"><div class="pip pip-l1"></div><div class="pip pip-l2"></div><div class="pip pip-l3"></div><div class="pip pip-r1"></div><div class="pip pip-r2"></div><div class="pip pip-r3"></div></div>
                    <div class="dice-face right face-4"><div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div></div>
                    <div class="dice-face left face-3"><div class="pip pip-tl"></div><div class="pip pip-center"></div><div class="pip pip-br"></div></div>
                    <div class="dice-face top face-2"><div class="pip pip-tl"></div><div class="pip pip-br"></div></div>
                    <div class="dice-face bottom face-5"><div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-mid"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div></div>
                </div>
                <div class="dice" id="dice3">
                    <div class="dice-face front face-1"><div class="pip pip-center"></div></div>
                    <div class="dice-face back face-6"><div class="pip pip-l1"></div><div class="pip pip-l2"></div><div class="pip pip-l3"></div><div class="pip pip-r1"></div><div class="pip pip-r2"></div><div class="pip pip-r3"></div></div>
                    <div class="dice-face right face-4"><div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div></div>
                    <div class="dice-face left face-3"><div class="pip pip-tl"></div><div class="pip pip-center"></div><div class="pip pip-br"></div></div>
                    <div class="dice-face top face-2"><div class="pip pip-tl"></div><div class="pip pip-br"></div></div>
                    <div class="dice-face bottom face-5"><div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-mid"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div></div>
                </div>
            </div>
            <div class="total">
                <div class="total-label">总 点 数</div>
                <div class="total-number" id="totalPoints">3</div>
            </div>
        </div>

        <!-- 用户栏 -->
        <div class="user-row">
            <div><span style="color:#ffaa44">👤</span> <span id="currentUserId" style="color:#ffaa44; font-weight:bold">player888</span></div>
            <div>
                <button id="historyBtn" class="small-btn">📜 记录</button>
                <button id="newUserBtn" class="small-btn">✨ 新用户</button>
            </div>
        </div>

        <!-- 登录行 -->
        <div class="login-row">
            <input type="text" id="switchId" class="login-input" placeholder="输入ID登录">
            <button id="switchBtn" class="small-btn">登录</button>
        </div>

        <!-- 信息条：倒计时 + 当前筹码 -->
        <div class="info-bar">
            <div class="info-item">
                <div class="info-label">⏱️ 下注倒计时</div>
                <div class="info-value" id="countdownNum">25</div>
            </div>
            <div class="info-item">
                <div class="info-label">🎲 当前筹码</div>
                <div class="info-value" id="selectedChip">0</div>
            </div>
        </div>

        <!-- 三个主按钮 -->
        <div class="action-buttons">
            <button class="action-btn" id="clearAllBtn">全部取消</button>
            <button class="action-btn" id="refreshBtn">刷新余额</button>
            <button class="action-btn btn-primary" id="betBtn">确认投注</button>
        </div>

        <!-- 余额 & 奖池 -->
        <div class="balance-row">
            <div class="balance-card" id="adminEntry">
                <div class="balance-label">💰 账户余额</div>
                <div class="balance-value" id="balanceDisplay">1000.00</div>
            </div>
            <div class="balance-card">
                <div class="balance-label">🎰 奖池累积</div>
                <div class="balance-value" id="poolDisplay">50000.00</div>
            </div>
        </div>

        <!-- 筹码区 -->
        <div class="chips">
            <div class="chip chip-10" data-val="10">10</div>
            <div class="chip chip-20" data-val="20">20</div>
            <div class="chip chip-50" data-val="50">50</div>
            <div class="chip chip-100" data-val="100">100</div>
            <div class="chip chip-500" data-val="500">500</div>
            <div class="chip chip-1000" data-val="1000">1K</div>
        </div>

        <!-- 大小单双 -->
        <div class="special-grid">
            <div class="special-card" data-type="BIG"><div class="special-name">🎲 大</div><div class="special-odds">赔 2倍</div><div class="special-bet-amount" id="bet_BIG">0</div></div>
            <div class="special-card" data-type="SMALL"><div class="special-name">🎲 小</div><div class="special-odds">赔 2倍</div><div class="special-bet-amount" id="bet_SMALL">0</div></div>
            <div class="special-card" data-type="ODD"><div class="special-name">🎲 单</div><div class="special-odds">赔 2倍</div><div class="special-bet-amount" id="bet_ODD">0</div></div>
            <div class="special-card" data-type="EVEN"><div class="special-name">🎲 双</div><div class="special-odds">赔 2倍</div><div class="special-bet-amount" id="bet_EVEN">0</div></div>
        </div>

        <!-- 点数网格 4-17 -->
        <div class="points-grid" id="pointsGrid"></div>

        <!-- 统计 -->
        <div class="stats">
            <div class="stat-card"><div class="stat-label">总押注</div><div class="stat-value" id="totalBet">0</div></div>
            <div class="stat-card"><div class="stat-label">选中点数</div><div class="stat-value" id="selectedPoint">-</div></div>
        </div>

        <!-- 历史记录 -->
        <div class="history" id="historyList"></div>
    </div>
</div>

<script>
const oddsMap = {4:60,5:30,6:18,7:12,8:8,9:7,10:6,11:6,12:7,13:8,14:12,15:18,16:30,17:60,'BIG':2,'SMALL':2,'ODD':2,'EVEN':2};
let users = JSON.parse(localStorage.getItem('dice_users')) || {};
let currentUser = "player888";
if (!users[currentUser]) users[currentUser] = { balance: 1000, records: [] };
let adminPwd = "wang000000";
function saveUsers() { localStorage.setItem('dice_users', JSON.stringify(users)); }
function getBalance(uid) { return users[uid]?.balance || 1000; }
function setBalance(uid, amt) { if (!users[uid]) users[uid] = { balance: 1000, records: [] }; users[uid].balance = amt; saveUsers(); }

let bets = {'BIG':0,'SMALL':0,'ODD':0,'EVEN':0,4:0,5:0,6:0,7:0,8:0,9:0,10:0,11:0,12:0,13:0,14:0,15:0,16:0,17:0};
let selectedChip = 0;
let currentBalance = getBalance(currentUser);
const diceEl = [document.getElementById('dice1'), document.getElementById('dice2'), document.getElementById('dice3')];
const totalEl = document.getElementById('totalPoints');

function setDiceValue(dice, val) {
    const rot = {1:'rotateX(0deg) rotateY(0deg)',2:'rotateX(-90deg) rotateY(0deg)',3:'rotateX(0deg) rotateY(90deg)',4:'rotateX(0deg) rotateY(-90deg)',5:'rotateX(90deg) rotateY(0deg)',6:'rotateX(180deg) rotateY(0deg)'};
    dice.style.transform = rot[val];
}
function startRolling(finalVals) {
    return new Promise(resolve=>{
        diceEl[0].classList.add('rolling1'); diceEl[1].classList.add('rolling2'); diceEl[2].classList.add('rolling3');
        totalEl.classList.add('total-blink');
        let step=0, maxStep=18;
        let iv = setInterval(()=>{
            step++;
            diceEl.forEach(d=>setDiceValue(d, Math.floor(Math.random()*6)+1));
            if(step>=maxStep){
                clearInterval(iv);
                diceEl.forEach(d=>d.classList.remove('rolling1','rolling2','rolling3'));
                totalEl.classList.remove('total-blink');
                diceEl.forEach((d,i)=>{ setDiceValue(d,finalVals[i]); d.classList.add('land'); setTimeout(()=>d.classList.remove('land'),200); });
                resolve();
            }
        },55);
    });
}
function getResultType(t){
    let r=[];
    if(t>=11&&t<=17) r.push('BIG');
    if(t>=4&&t<=10) r.push('SMALL');
    if(t%2===1) r.push('ODD');
    if(t%2===0) r.push('EVEN');
    return r;
}
function updateUI(){
    document.getElementById('bet_BIG').innerText=bets['BIG'];
    document.getElementById('bet_SMALL').innerText=bets['SMALL'];
    document.getElementById('bet_ODD').innerText=bets['ODD'];
    document.getElementById('bet_EVEN').innerText=bets['EVEN'];
    for(let i=4;i<=17;i++){ let el=document.getElementById(`bet_${i}`); if(el) el.innerText=bets[i]; }
    let total=Object.values(bets).reduce((a,b)=>a+b,0);
    document.getElementById('totalBet').innerText=total;
    document.getElementById('balanceDisplay').innerText=currentBalance.toFixed(2);
    let pool=50000+(Math.random()-0.5)*3000;
    pool=Math.max(40000,Math.min(60000,pool));
    document.getElementById('poolDisplay').innerText=pool.toFixed(2);
}
function addBet(type){
    if(selectedChip<=0){ alert("请先选择筹码"); return; }
    if(selectedChip>currentBalance){ alert("余额不足"); return; }
    currentBalance-=selectedChip;
    setBalance(currentUser,currentBalance);
    bets[type]+=selectedChip;
    updateUI();
    document.querySelectorAll('.special-card, .point-card').forEach(el=>el.classList.remove('selected'));
    if(typeof type==='string') document.querySelector(`.special-card[data-type="${type}"]`)?.classList.add('selected');
    else document.querySelector(`.point-card[data-point="${type}"]`)?.classList.add('selected');
    setTimeout(()=>document.querySelectorAll('.special-card, .point-card').forEach(el=>el.classList.remove('selected')),800);
}
function clearAll(){
    let total=Object.values(bets).reduce((a,b)=>a+b,0);
    currentBalance+=total;
    setBalance(currentUser,currentBalance);
    for(let k in bets) bets[k]=0;
    updateUI();
}
let isDrawing=false, isLocked=false, countdownInterval=null;
async function draw(){
    if(isDrawing) return;
    let total=Object.values(bets).reduce((a,b)=>a+b,0);
    if(total===0){ alert("请先下注"); return; }
    isDrawing=true; isLocked=true;
    let d1=Math.floor(Math.random()*6)+1, d2=Math.floor(Math.random()*6)+1, d3=Math.floor(Math.random()*6)+1, totalNum=d1+d2+d3;
    let resultTypes=getResultType(totalNum);
    let wins=[];
    if(resultTypes.includes('BIG') && bets['BIG']>0) wins.push(bets['BIG']*2);
    if(resultTypes.includes('SMALL') && bets['SMALL']>0) wins.push(bets['SMALL']*2);
    if(resultTypes.includes('ODD') && bets['ODD']>0) wins.push(bets['ODD']*2);
    if(resultTypes.includes('EVEN') && bets['EVEN']>0) wins.push(bets['EVEN']*2);
    if(bets[totalNum]>0) wins.push(bets[totalNum]*oddsMap[totalNum]);
    let totalWin=wins.reduce((a,b)=>a+b,0);
    await startRolling([d1,d2,d3]);
    totalEl.innerText=totalNum;
    if(totalWin>0){ totalEl.style.color='#4caf50'; setTimeout(()=>totalEl.style.color='#ffcc44',2000); }
    else{ totalEl.style.color='#f44336'; setTimeout(()=>totalEl.style.color='#ffcc44',2000); }
    currentBalance+=totalWin;
    setBalance(currentUser,currentBalance);
    let betSummary=[];
    for(let k in bets) if(bets[k]>0){
        if(typeof k==='string') betSummary.push((k==='BIG'?'大':k==='SMALL'?'小':k==='ODD'?'单':'双')+bets[k]);
        else betSummary.push(k+'点'+bets[k]);
    }
    let recs=users[currentUser].records||[];
    recs.unshift({time:new Date().toLocaleTimeString(), bets:betSummary.join(' '), result:totalNum, resultType:resultTypes.map(t=>t==='BIG'?'大':t==='SMALL'?'小':t==='ODD'?'单':'双').join(','), win:totalWin, isWin:totalWin>0});
    if(recs.length>30) recs.pop();
    users[currentUser].records=recs;
    saveUsers();
    updateHistory();
    for(let k in bets) bets[k]=0;
    updateUI();
    if(navigator.vibrate) navigator.vibrate(totalWin>0?[100,50,100]:80);
    setTimeout(()=>{ isDrawing=false; isLocked=false; startCountdown(25); },3000);
}
function startCountdown(sec){
    if(countdownInterval) clearInterval(countdownInterval);
    let c=sec;
    const cdSpan=document.getElementById('countdownNum');
    cdSpan.innerText=c;
    cdSpan.classList.remove('countdown-warning');
    isLocked=false;
    countdownInterval=setInterval(()=>{
        if(c<=1){
            clearInterval(countdownInterval);
            countdownInterval=null;
            isLocked=true;
            draw();
        } else {
            c--;
            cdSpan.innerText=c;
            if(c<=5) cdSpan.classList.add('countdown-warning');
        }
    },1000);
}
function updateHistory(){
    let container=document.getElementById('historyList');
    let recs=users[currentUser]?.records||[];
    container.innerHTML='';
    if(recs.length===0){ container.innerHTML='<div style="text-align:center;color:#666">暂无记录</div>'; return; }
    recs.slice(0,10).forEach(r=>{
        let div=document.createElement('div');
        div.className='history-item';
        div.innerHTML=`<span>${r.time}</span><span>${r.bets}</span><span>开${r.result}(${r.resultType})</span><span class="${r.isWin?'win':'lose'}">${r.isWin?'+'+r.win:''}</span>`;
        container.appendChild(div);
    });
}
function refreshBalance(){ currentBalance=getBalance(currentUser); updateUI(); }
function switchUser(){
    let newId=document.getElementById('switchId').value.trim();
    if(!newId) return;
    currentUser=newId;
    if(!users[currentUser]) users[currentUser]={balance:1000,records:[]};
    document.getElementById('currentUserId').innerText=currentUser;
    currentBalance=getBalance(currentUser);
    for(let k in bets) bets[k]=0;
    updateUI();
    if(countdownInterval) clearInterval(countdownInterval);
    startCountdown(25);
    updateHistory();
}
function showHistoryModal(){
    let recs=users[currentUser]?.records||[];
    let html='<div style="max-height:300px;overflow-y:auto">';
    if(recs.length===0) html+='<p>暂无记录</p>';
    else recs.forEach(r=>{ html+=`<div style="padding:8px;border-bottom:1px solid #333;display:flex;justify-content:space-between"><span>${r.time}</span><span>${r.bets}</span><span>开${r.result}点</span><span style="color:${r.isWin?'#4caf50':'#f44336'}">${r.isWin?'+'+r.win:''}</span></div>`; });
    html+='</div><button id="closeModalBtn" style="background:#ff6600;border:none;border-radius:30px;padding:10px 24px;margin-top:16px;color:#fff">关闭</button>';
    let modal=document.createElement('div'); modal.className='modal'; modal.innerHTML=`<div class="modal-content"><h3>📜 投注记录</h3>${html}</div>`;
    document.body.appendChild(modal);
    document.getElementById('closeModalBtn').onclick=()=>modal.remove();
}
let adminPanel=null, adminSelectedUser=currentUser;
function showAdminPanel(){
    if(adminPanel){ adminPanel.remove(); adminPanel=null; return; }
    let panel=document.createElement('div'); panel.className='modal';
    panel.innerHTML=`<div class="modal-content" style="width:90%;max-width:360px"><h3>🔐 管理员</h3><div id="adminUserList" class="admin-user-list"></div><div>当前：<strong id="adminSelectedUser">${adminSelectedUser}</strong></div><input type="number" id="adminAmount" class="admin-input" placeholder="金额" value="0"><div class="admin-btns"><button id="adminAdd" class="admin-btn" style="background:#4caf50;color:#fff">上分</button><button id="adminSub" class="admin-btn" style="background:#f44336;color:#fff">下分</button><button id="adminQuery" class="admin-btn" style="background:#2196f3;color:#fff">查询</button><button id="adminReset" class="admin-btn" style="background:#ff9800;color:#fff">重置</button><button id="adminPwd" class="admin-btn" style="background:#9c27b0;color:#fff">改密</button></div><button id="adminClose" style="background:#ffaa44;color:#1a1a2a;padding:8px 24px;border-radius:25px;border:none;margin-top:12px">关闭</button></div>`;
    document.body.appendChild(panel); adminPanel=panel;
    function refreshList(){
        let listDiv=document.getElementById('adminUserList');
        let usersArr=Object.keys(users);
        listDiv.innerHTML='';
        usersArr.forEach(uid=>{
            let div=document.createElement('div'); div.className='admin-user'; if(uid===adminSelectedUser) div.classList.add('selected');
            div.textContent=`${uid} (${getBalance(uid).toFixed(2)})`;
            div.onclick=()=>{ adminSelectedUser=uid; document.getElementById('adminSelectedUser').innerText=adminSelectedUser; refreshList(); };
            listDiv.appendChild(div);
        });
    }
    refreshList();
    document.getElementById('adminAdd').onclick=()=>{ let amt=parseFloat(document.getElementById('adminAmount').value); if(isNaN(amt)||amt<=0){ alert("请输入正数"); return; } let cur=getBalance(adminSelectedUser); setBalance(adminSelectedUser,cur+amt); refreshList(); if(adminSelectedUser===currentUser){ currentBalance=getBalance(currentUser); updateUI(); } alert(`给 ${adminSelectedUser} 上分 ${amt}`); };
    document.getElementById('adminSub').onclick=()=>{ let amt=parseFloat(document.getElementById('adminAmount').value); if(isNaN(amt)||amt<=0){ alert("请输入正数"); return; } let cur=getBalance(adminSelectedUser); if(cur<amt){ alert("余额不足"); return; } setBalance(adminSelectedUser,cur-amt); refreshList(); if(adminSelectedUser===currentUser){ currentBalance=getBalance(currentUser); updateUI(); } alert(`从 ${adminSelectedUser} 下分 ${amt}`); };
    document.getElementById('adminQuery').onclick=()=>{ alert(`${adminSelectedUser} 余额: ${getBalance(adminSelectedUser).toFixed(2)}`); };
    document.getElementById('adminReset').onclick=()=>{ if(confirm(`重置 ${adminSelectedUser} 余额为1000？`)){ setBalance(adminSelectedUser,1000); refreshList(); if(adminSelectedUser===currentUser){ currentBalance=getBalance(currentUser); updateUI(); } alert("重置成功"); } };
    document.getElementById('adminPwd').onclick=()=>{ let old=prompt("当前密码:"); if(old!==adminPwd){ alert("密码错误"); return; } let newPwd=prompt("新密码(至少6位):"); if(!newPwd||newPwd.length<6){ alert("密码至少6位"); return; } adminPwd=newPwd; localStorage.setItem('dice_admin_pwd',newPwd); alert("密码修改成功"); };
    document.getElementById('adminClose').onclick=()=>{ panel.remove(); adminPanel=null; };
}
function createPointsGrid(){
    let grid=document.getElementById('pointsGrid');
    for(let i=4;i<=17;i++){
        let card=document.createElement('div'); card.className='point-card'; card.setAttribute('data-point',i);
        card.innerHTML=`<div class="point-value">${i}点</div><div class="point-odds">赔 ${oddsMap[i]}倍</div><div class="point-bet-amount" id="bet_${i}">0</div>`;
        card.onclick=()=>addBet(i);
        grid.appendChild(card);
    }
}
function init(){
    createPointsGrid();
    setDiceValue(diceEl[0],1); setDiceValue(diceEl[1],1); setDiceValue(diceEl[2],1);
    totalEl.innerText=3;
    updateUI();
    updateHistory();
    startCountdown(25);
    let saved=localStorage.getItem('dice_admin_pwd'); if(saved) adminPwd=saved;
    document.querySelectorAll('.chip').forEach(chip=>{
        chip.onclick=()=>{ selectedChip=parseInt(chip.dataset.val); document.getElementById('selectedChip').innerText=selectedChip; document.querySelectorAll('.chip').forEach(c=>c.classList.remove('selected-chip')); chip.classList.add('selected-chip'); };
    });
    document.querySelectorAll('.special-card').forEach(card=>{ card.onclick=()=>addBet(card.dataset.type); });
    document.getElementById('clearAllBtn').onclick=clearAll;
    document.getElementById('refreshBtn').onclick=refreshBalance;
    document.getElementById('betBtn').onclick=draw;
    document.getElementById('switchBtn').onclick=switchUser;
    document.getElementById('historyBtn').onclick=showHistoryModal;
    document.getElementById('adminEntry').onclick=()=>{ let pwd=prompt("管理员密码:"); if(pwd===adminPwd) showAdminPanel(); else if(pwd!==null) alert("密码错误"); };
    document.getElementById('newUserBtn').onclick=()=>{ let newId="player_"+Math.floor(Math.random()*100000); document.getElementById('switchId').value=newId; switchUser(); alert(`新账户：${newId}\n初始余额：1000`); };
}
init();
</script>
</body>
</html>






