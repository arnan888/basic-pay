        </div>`;
        let pointsHtml=''; for(let i=4;i<=17;i++) pointsHtml+=`<div class="bet-card point-card" data-point="${i}" style="padding:4px;">${i}点<br><span id="bet_${i}" style="color:#ffaa33;">0</span></div>`; document.getElementById('pointsGrid').innerHTML=pointsHtml;
        let trioHtml=''; for(let i=1;i<=6;i++) trioHtml+=`<div class="bet-card trio-card" data-type="TRIPLE_${i}" style="padding:4px;">${i}围<br><span id="bet_TRIPLE_${i}" style="color:#ffaa33;">0</span></div>`; trioHtml+=`<div class="bet-card trio-card" data-type="ALL_TRIPLE" style="padding:4px;">豹子<br><span id="bet_ALL_TRIPLE" style="color:#ffaa33;">0</span></div>`; document.getElementById('trioGrid').innerHTML=trioHtml;
        function buildDiceCube(diceDiv) {
            if(!diceDiv) return;
            diceDiv.innerHTML='';
            const faces=['front','back','right','left','top','bottom'];
            const valMap={front:1,back:6,right:4,left:3,top:2,bottom:5};
            faces.forEach(face=>{
                let num=valMap[face];
                let fd=document.createElement('div');
                fd.className=`dice-face ${face}`;
                let pipHtml='';
                if(num===1)pipHtml='<div class="pip pip-center"></div>';
                else if(num===2)pipHtml='<div class="pip pip-tl"></div><div class="pip pip-br"></div>';
                else if(num===3)pipHtml='<div class="pip pip-tl"></div><div class="pip pip-center"></div><div class="pip pip-br"></div>';
                else if(num===4)pipHtml='<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                else if(num===5)pipHtml='<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-mid"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                else pipHtml='<div class="pip pip-l1"></div><div class="pip pip-l2"></div><div class="pip pip-l3"></div><div class="pip pip-r1"></div><div class="pip pip-r2"></div><div class="pip pip-r3"></div>';
                fd.innerHTML=pipHtml;
                diceDiv.appendChild(fd);
            });
            const randX=Math.floor(Math.random()*360);
            const randY=Math.floor(Math.random()*360);
            diceDiv.style.transform=`rotateX(${randX}deg) rotateY(${randY}deg)`;
        }
        function setCubeValue(dice, val) {
            const rot={1:'rotateX(0deg) rotateY(0deg)',2:'rotateX(-90deg) rotateY(0deg)',3:'rotateY(90deg)',4:'rotateY(-90deg)',5:'rotateX(90deg)',6:'rotateX(180deg)'};
            let rotateX=0,rotateY=0;
            if(rot[val].includes('rotateX')){ let match=rot[val].match(/rotateX\(([-\d]+)deg\)/); if(match) rotateX=parseInt(match[1]); }
            if(rot[val].includes('rotateY')){ let match=rot[val].match(/rotateY\(([-\d]+)deg\)/); if(match) rotateY=parseInt(match[1]); }
            const extraX=360*(1+Math.floor(Math.random()*2));
            const extraY=360*(1+Math.floor(Math.random()*2));
            dice.style.transform=`rotateX(${rotateX+extraX}deg) rotateY(${rotateY+extraY}deg)`;
        }
