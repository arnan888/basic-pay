        }
        .bal-val { font-size: 60px; font-weight: 900; text-shadow: 0 0 15px var(--neon); color: #fff; }

        /* 2. 复刻：JILI 风格实体转盘 */
        .stage { position: relative; width: 88vw; max-width: 400px; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; }
        .needle { position: absolute; top: -10px; width: 6px; height: 60px; background: #fff; box-shadow: 0 0 20px #fff; z-index: 100; border-radius: 3px; }

        .disk-core {
            width: 100%; height: 100%; border-radius: 50%;
            background: radial-gradient(circle, #333 0%, #000 70%);
            border: 5px solid #444; position: relative; overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.9), inset 0 0 80px rgba(0,242,255,0.2);
            transition: transform 6s cubic-bezier(0.1, 0, 0, 1);
        }
        .item { position: absolute; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; transform-origin: center; }
        .item b { position: absolute; top: 10%; font-size: 85px; filter: drop-shadow(0 5px 10px #000); }

        /* 核心：JILI 风格 3D SPIN 按钮 */
        .spin-btn {
            position: absolute; width: 120px; height: 120px; border-radius: 50%;
            background: linear-gradient(180deg, #00ff88 0%, #006633 100%);
            border: 6px solid #004422; color: #fff; font-size: 24px; font-weight: 900;
            display: flex; align-items: center; justify-content: center; z-index: 200;
            box-shadow: 0 8px 0 #002211, 0 15px 30px rgba(0,0,0,0.8);
            cursor: pointer; transition: 0.1s;
        }
        .spin-btn:active { transform: translateY(6px); box-shadow: 0 2px 0 #002211, 0 5px 15px rgba(0,0,0,0.5); }

        /* 3. 复刻：重金属控制面板 */
        .control-panel {
            background: linear-gradient(180deg, #2a2a2a, #111);
            width: 100%; padding: 20px 0; border-top: 4px solid #444;
            display: flex; flex-direction: column; align-items: center;
            box-shadow: 0 -10px 30px rgba(0,0,0,0.5);
        }
        .status-msg { font-size: 28px; font-weight: 900; color: var(--gold); margin-bottom: 15px; text-shadow: 0 0 10px var(--gold); }
        
        .bet-row { display: flex; align-items: center; gap: 40px; }
        
        /* 实体加减按钮 */
        .btn-3d {
            width: 80px; height: 80px; border-radius: 12px;
            background: linear-gradient(180deg, #444, #222);
            border: 2px solid #555; color: #fff; font-size: 50px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 5px 0 #111, 0 8px 15px rgba(0,0,0,0.6);
            cursor: pointer; transition: 0.1s;
        }
        .btn-3d:active { transform: translateY(4px); box-shadow: 0 1px 0 #111; color: var(--neon); }
        .bet-display { font-size: 80px; font-weight: 900; min-width: 140px; text-align: center; color: #fff; }

        /* 震耳欲聋效果 */
        .bass-vibe { animation: shock 0.06s infinite; filter: brightness(1.3); }
        @keyframes shock { 0%{transform:translate(2px,2px)} 50%{transform:translate(-2px,-2px)} }
    </style>
</head>
<body onclick="initAudio()">

    <canvas id="fx-canvas"></canvas>

    <div class="ui-main" id="ui">
        <div class="bal-display">
            <div style="font-size:40px">💎</div>
            <div class="bal-val" id="bal">1,000</div>
        </div>

        <div class="stage">
            <div class="needle"></div>
            <div id="disk" class="disk-core">
                <div class="item" style="transform:rotate(0deg)"><b>👑</b></div>
                <div class="item" style="transform:rotate(60deg)"><b>🦁</b></div>
                <div class="item" style="transform:rotate(120deg)"><b>🐯</b></div>
                <div class="item" style="transform:rotate(180deg)"><b>🦅</b></div>
                <div class="item" style="transform:rotate(240deg)"><b>🐺</b></div>
                <div class="item" style="transform:rotate(300deg)"><b>🐕</b></div>
            </div>
            <div class="spin-btn" onclick="spin()">SPIN</div>
        </div>

        <div class="control-panel">
            <div id="status-out" class="status-msg">READY_SYSTEM</div>
            <div class="bet-row">
                <div class="btn-3d" onclick="adj(-10)">-</div>
                <div class="bet-display" id="bet">1</div>
                <div class="btn-3d" onclick="adj(10)">+</div>
            </div>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp; tg.expand();
        let balance = 1000, bet = 1, r = 0, active = false, audioCtx;

        function initAudio() {
            if(audioCtx) return;
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            const cvs = document.getElementById('fx-canvas');
            const ctx = cvs.getContext('2d');
            cvs.width = window.innerWidth; cvs.height = window.innerHeight;
            let p = [];
            for(let i=0; i<100; i++) p.push({x:Math.random()*cvs.width, y:Math.random()*cvs.height, s:Math.random()*3+1});
            function anim() {
                ctx.fillStyle = 'rgba(0,0,0,0.2)'; ctx.fillRect(0,0,cvs.width, cvs.height);
                p.forEach(a => {
                    a.y += active ? 40 : 2; if(a.y > cvs.height) a.y = -20;
                    ctx.fillStyle = active ? '#fff' : '#00f2ff';
                    ctx.beginPath(); ctx.arc(a.x, a.y, active?a.s*2:a.s, 0, Math.PI*2); ctx.fill();
                });
                requestAnimationFrame(anim);
            }
            anim();
        }

        function playDJ(d) {
            if(!audioCtx) return;
            const osc = audioCtx.createOscillator();
            const g = audioCtx.createGain();
            osc.type = 'sawtooth'; osc.frequency.setValueAtTime(50, audioCtx.currentTime);
            osc.frequency.exponentialRampToValueAtTime(20, audioCtx.currentTime + d);
            g.gain.setValueAtTime(0.4, audioCtx.currentTime);
            g.gain.linearRampToValueAtTime(0, audioCtx.currentTime + d);
            osc.connect(g); g.connect(audioCtx.destination);
            osc.start(); osc.stop(audioCtx.currentTime + d);
        }

        function adj(v) {
            if(active) return;
            bet = Math.max(1, Math.min(balance, bet + v));
            document.getElementById('bet').innerText = bet;
            tg.HapticFeedback.selectionChanged();
        }

        function spin() {
            if(active || balance < bet) return;
            active = true; balance -= bet;
            document.getElementById('bal').innerText = balance.toLocaleString();
            document.getElementById('ui').classList.add('bass-vibe');
            document.getElementById('status-out').innerText = "BASS_OVERLOAD";
            playDJ(6); tg.HapticFeedback.impactOccurred('heavy');

            let target = Math.floor(Math.random()*6);
            r += (3600 + (360 - (target * 60)));
            document.getElementById('disk').style.transform = `rotate(${r}deg)`;

            setTimeout(() => {
                document.getElementById('ui').classList.remove('bass-vibe');
                const multi = [88, 15, 10, 5, 2, 0];
                let win = Math.floor(bet * multi[target]);
                balance += win;
                document.getElementById('bal').innerText = balance.toLocaleString();
                document.getElementById('status-out').innerText = win > 0 ? "WIN: +" + win : "LOST";
                tg.HapticFeedback.notificationOccurred(win > 0 ? 'success' : 'error');
                active = false;
            }, 6500);
        }
    </script>
</body>
</html>