    <title>JILI_STYLE_V29000</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        :root { --neon: #00f2ff; --pink: #ff0055; --gold: #ffcc00; --panel: #1a1a1a; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin:0; padding:0; }
        body { background: #000; color: #fff; font-family: 'Arial Black', sans-serif; height: 100vh; overflow: hidden; }

        /* 背景：原子聚变流光 */
        #fx-canvas { position: fixed; inset: 0; z-index: 1; pointer-events: none; }

        .ui-main { position: relative; z-index: 10; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 30px 0; }

        /* 1. 复刻：3D发光余额 */
        .bal-display {
            background: linear-gradient(180deg, #333, #000); 
            border: 3px solid var(--neon); padding: 10px 60px; border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.8), 0 0 30px var(--neon);
