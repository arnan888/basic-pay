                <div class="slice" style="background:rgba(0,242,255,0.15); transform:rotate(90deg)"><b class="emoji">🦅</b></div>
                <div class="slice" style="background:rgba(147,112,219,0.2); transform:rotate(150deg)"><b class="emoji">🐺</b></div>
                <div class="slice" style="background:rgba(255,255,255,0.1); transform:rotate(210deg)"><b class="emoji">🐕</b></div>
            </div>
