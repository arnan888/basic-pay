    <script>
        const tg = window.Telegram.WebApp; tg.ready(); tg.expand();
        let balance = 1000, currentBet = 1, rotation = 0, spinning = false, audioCtx;

        // 第一次点击唤醒系统（绕过浏览器静音限制）
        function wakeUp() {
            if(!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                if(audioCtx.state === 'suspended') audioCtx.resume();
                document.getElementById('msg').innerText = "READY FOR BET";
                playTone(440, 0.1, 'sine', 0.05);
            }
        }

        function playTone(freq, dur, type='sine', vol=0.1) {
            if(!audioCtx) return;
            const osc = audioCtx.createOscillator();
            const amp = audioCtx.createGain();
            osc.type = type;
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            amp.gain.setValueAtTime(vol, audioCtx.currentTime);
            amp.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + dur);
            osc.connect(amp); amp.connect(audioCtx.destination);
            osc.start(); osc.stop(audioCtx.currentTime + dur);
        }

        function changeBet(val) {
            if(spinning) return;
            currentBet = Math.max(1, Math.min(balance, currentBet + val));
            document.getElementById('bet').innerText = currentBet;
            document.getElementById('bet').parentElement.style.transform = "scale(1.2)";
            setTimeout(() => document.getElementById('bet').parentElement.style.transform = "scale(1)", 100);
            tg.HapticFeedback.selectionChanged();
            playTone(800, 0.1, 'square', 0.02);
        }

        function spinNow() {
            if(spinning || balance < currentBet) return;
            spinning = true;
            balance -= currentBet;
            document.getElementById('bal').innerText = balance.toLocaleString();
            tg.HapticFeedback.impactOccurred('heavy');

            // 旋转音效模拟
            let sfxTimer = setInterval(() => {
                if(spinning) playTone(200 + Math.random()*600, 0.08, 'sawtooth', 0.02);
            }, 120);

            const targetIdx = Math.floor(Math.random() * 6);
            rotation += (3600 + (targetIdx * 60)); // 至少转10圈
            document.getElementById('wheel').style.transform = `rotate(-${rotation}deg)`;
            document.getElementById('msg').innerText = "LOCKING TARGET...";

            setTimeout(() => {
                clearInterval(sfxTimer);
                const odds = [88, 15, 10, 5, 2, 0];
                let winAmt = Math.floor(currentBet * odds[targetIdx]);
                balance += winAmt;
                document.getElementById('bal').innerText = balance.toLocaleString();

                if(winAmt > 0) {
                    document.getElementById('msg').innerText = "SYSTEM REWARD: +" + winAmt;
                    tg.HapticFeedback.notificationOccurred('success');
                    for(let i=0; i<12; i++) {
                        setTimeout(() => playTone(600 + (i*80), 0.4, 'sine', 0.1), i*70);
                    }
                } else {
                    document.getElementById('msg').innerText = "ACCESS DENIED";
                    playTone(110, 0.6, 'triangle', 0.1);
                }
                spinning = false;
            }, 6000);
        }
    </script>
</body>
</html>
