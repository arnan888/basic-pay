<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>龙虎斗·水墨金纹版</title>
    <style>
        :root {
            --jade: #2d5a4a;
            --jade-d: #1e3a2f;
            --stone: #4a5b55;
            --gold: #e6c87e;
            --blue: #6ba5c4;
            --tiger: #d98c5f;
            --tie: #b8868b;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: "PingFang SC", "Microsoft YaHei", "楷体", serif; -webkit-tap-highlight-color: transparent; }
        body { 
            background: #1a1a1a; 
            height: 100vh; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            overflow: hidden;
        }

        /* 中国风水墨背景 + 动态金色云纹 */
        .container-outer {
            width: 100vw; 
            height: 100vh; 
            max-width: 480px;
            display: flex; 
            justify-content: center; 
            align-items: center;
            background: 
                /* 水墨底纹 */
                radial-gradient(ellipse at 20% 40%, rgba(30,40,35,0.9) 0%, rgba(10,15,12,0.95) 100%),
                /* 金色云纹（动态） */
                repeating-linear-gradient(45deg, 
                    rgba(230,200,126,0.03) 0px, 
                    rgba(230,200,126,0.03) 40px,
                    transparent 40px,
                    transparent 80px),
                /* 墨迹斑点 */
                radial-gradient(circle at 70% 80%, rgba(0,0,0,0.3) 0%, transparent 50%),
                radial-gradient(circle at 15% 20%, rgba(0,0,0,0.2) 0%, transparent 60%);
            background-size: auto, 80px 80px, auto, auto;
            animation: cloudMove 60s linear infinite;
            padding: 6px;
            border-radius: 18px;
            box-shadow: 0 0 50px rgba(230,200,126,0.3);
            position: relative;
        }
        /* 金色光晕流动 */
        .container-outer::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 50% 50%, rgba(230,200,126,0.1) 0%, transparent 70%);
            pointer-events: none;
            animation: glowPulse 4s ease-in-out infinite;
        }
        @keyframes cloudMove {
            0% { background-position: 0% 0%, 0% 0%; }
            100% { background-position: 0% 0%, 80px 80px; }
        }
        @keyframes glowPulse {
            0% { opacity: 0.3; }
            50% { opacity: 0.8; }
            100% { opacity: 0.3; }
        }

        .container {
            width: 100%; 
            height: 100%;
            background: rgba(30,40,35,0.75);
            backdrop-filter: blur(3px);
            border-radius: 15px;
            display: flex; 
            flex-direction: column;
            box-shadow: inset 0 0 30px rgba(0,0,0,0.5), 0 0 20px rgba(230,200,126,0.2);
            border: 1px solid rgba(230,200,126,0.3);
        }

        .header { height: 8%; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 8px 12px; }
        .box { 
            background: rgba(0,0,0,0.5); 
            border: 1px solid var(--gold); 
            border-radius: 8px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            padding: 0 12px;
            backdrop-filter: blur(4px);
            box-shadow: 0 0 10px rgba(230,200,126,0.2);
        }
        .box span:first-child { font-size: 12px; color: #e6c87e; letter-spacing: 2px; font-weight: bold; text-shadow: 0 0 5px rgba(0,0,0,0.5); }
        .box span:last-child { font-size: 20px; font-weight: bold; color: var(--gold); text-shadow: 0 0 10px rgba(230,200,126,0.8); }

        .battle-scene { 
            height: 38%; 
            margin: 4px 10px;
            position: relative; 
            overflow: hidden;
            border-radius: 12px;
            border: 2px solid var(--gold);
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(2px);
        }
        .battle-scene video {
            position: absolute;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 1;
            opacity: 0.95;
        }
        .battle-scene .overlay-text {
            position: absolute;
            bottom: 10px;
            left: 0;
            right: 0;
            text-align: center;
            color: var(--gold);
            font-weight: bold;
            text-shadow: 0 0 10px black;
            z-index: 2;
            background: rgba(0,0,0,0.6);
            padding: 6px;
            font-size: 14px;
            letter-spacing: 2px;
            border-top: 1px solid rgba(230,200,126,0.5);
            border-bottom: 1px solid rgba(230,200,126,0.5);
        }

        .play-section {
            flex: 1; 
            display: flex; 
            flex-direction: column;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            border: 2px solid rgba(230,200,126,0.5);
            border-radius: 12px;
            margin: 4px 10px 8px 10px;
            padding: 12px;
        }

        .multi-bet-row { display: flex; gap: 8px; margin-bottom: 12px; justify-content: space-between; }
        .multi-bet-item {
            flex: 1; 
            background: rgba(0,0,0,0.6);
            border: 1px solid var(--gold);
            border-radius: 12px;
            padding: 8px 4px;
            text-align: center;
            transition: all 0.2s;
        }
        .multi-bet-item.selected { 
            border-color: var(--gold); 
            background: rgba(230,200,126,0.2);
            box-shadow: 0 0 15px rgba(230,200,126,0.5);
        }
        .multi-bet-name { font-size: 24px; font-weight: bold; margin-bottom: 4px; }
        .multi-bet-name.dragon { color: #6ba5c4; text-shadow: 0 0 8px rgba(107,165,196,0.5); }
        .multi-bet-name.tiger { color: #d98c5f; text-shadow: 0 0 8px rgba(217,140,95,0.5); }
        .multi-bet-name.tie { color: #b8868b; text-shadow: 0 0 8px rgba(184,134,139,0.5); }
        .multi-bet-amount { font-size: 16px; color: var(--gold); font-weight: bold; }
        .multi-bet-control { display: flex; justify-content: center; gap: 12px; margin-top: 6px; }
        .multi-bet-control button {
            background: rgba(0,0,0,0.7);
            border: 1px solid var(--gold);
            border-radius: 20px;
            width: 28px;
            height: 28px;
            color: var(--gold);
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.1s;
        }
        .multi-bet-control button:active { transform: scale(0.95); }

        .data-stack { display: grid; grid-template-rows: repeat(3, 1fr); gap: 6px; margin: 0 6px; }
        .data-item { 
            background: rgba(0,0,0,0.6); 
            border: 1px solid rgba(230,200,126,0.5); 
            border-radius: 8px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            padding: 0 12px;
        }
        .data-item label { font-size: 12px; color: #e6c87e; font-weight: bold; letter-spacing: 1px; }
        .data-item value { font-size: 18px; color: var(--gold); font-weight: 900; text-shadow: 0 0 6px var(--gold); }

        .stake-txt { text-align: center; color: #e6c87e; font-size: 16px; font-weight: bold; margin: 8px 0; text-shadow: 0 0 5px black; }
        .stake-txt span { color: var(--gold); text-shadow: 0 0 8px var(--gold); }

        .exec-row { display: flex; gap: 10px; align-items: center; margin-bottom: 10px; }
        .step-btn { 
            width: 52px; height: 52px; 
            background: rgba(0,0,0,0.6); 
            border: 1px solid var(--gold); 
            border-radius: 10px; 
            color: var(--gold); 
            font-size: 28px; 
            font-weight: bold; 
            cursor: pointer;
            transition: 0.1s;
        }
        .step-btn:active { transform: scale(0.95); }
        .main-go { 
            flex: 1; height: 52px; 
            background: linear-gradient(135deg, #b8860b, #8b5a2b); 
            border: none; 
            border-radius: 30px; 
            color: #fff; 
            font-size: 20px; 
            font-weight: bold; 
            cursor: pointer; 
            box-shadow: 0 4px 0 #5a3a1a;
            letter-spacing: 2px;
        }
        .main-go:active { transform: translateY(2px); box-shadow: 0 1px 0 #5a3a1a; }

        .mode-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .mode-btn { 
            height: 42px; 
            background: rgba(0,0,0,0.5); 
            border: 1px solid var(--gold); 
            border-radius: 8px; 
            color: #e6c87e; 
            font-size: 14px; 
            font-weight: bold; 
            cursor: pointer; 
            display: flex; 
            align-items: center; 
            justify-content: center;
            transition: 0.1s;
        }
        .mode-btn.active { 
            border-color: var(--gold); 
            color: #000; 
            background: var(--gold); 
            box-shadow: 0 0 15px var(--gold);
        }
        .speed-btn { display: flex; gap: 8px; }
        .speed-btn span { 
            width: 33%; 
            height: 100%; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            border-radius: 6px;
            transition: 0.1s;
        }
        .speed-btn span.active { 
            background: var(--gold); 
            color: #000; 
            font-weight: bold; 
            box-shadow: 0 0 10px var(--gold);
        }
    </style>
</head>
<body>
<div class="container-outer">
    <div class="container">
        <div class="header">
            <div class="box"><span>余额</span><span id="balanceDisplay">857.80</span></div>
            <div class="box"><span>奖池</span><span id="poolDisplay">84291.50</span></div>
        </div>
        <div class="battle-scene">
            <video id="fightVideo" autoplay loop muted playsinline>
                <source src="fight.mp4" type="video/mp4">
                您的浏览器不支持视频
            </video>
            <div class="overlay-text" id="battle-result">⚔️ 龙虎激战 ⚔️</div>
        </div>
        <div class="play-section">
            <div class="multi-bet-row">
                <div class="multi-bet-item" id="multiDragon" data-type="DRAGON">
                    <div class="multi-bet-name dragon">🐉 龙</div>
                    <div class="multi-bet-amount" id="betDragonAmount">0</div>
                    <div class="multi-bet-control">
                        <button class="bet-dec" data-type="DRAGON">-</button>
                        <button class="bet-inc" data-type="DRAGON">+</button>
                    </div>
                </div>
                <div class="multi-bet-item" id="multiTie" data-type="TIE">
                    <div class="multi-bet-name tie">⚖️ 和</div>
                    <div class="multi-bet-amount" id="betTieAmount">0</div>
                    <div class="multi-bet-control">
                        <button class="bet-dec" data-type="TIE">-</button>
                        <button class="bet-inc" data-type="TIE">+</button>
                    </div>
                </div>
                <div class="multi-bet-item" id="multiTiger" data-type="TIGER">
                    <div class="multi-bet-name tiger">🐯 虎</div>
                    <div class="multi-bet-amount" id="betTigerAmount">0</div>
                    <div class="multi-bet-control">
                        <button class="bet-dec" data-type="TIGER">-</button>
                        <button class="bet-inc" data-type="TIGER">+</button>
                    </div>
                </div>
            </div>
            <div class="data-stack">
                <div class="data-item"><label>总押注</label><value id="totalBetAmount">0.00</value></div>
                <div class="data-item"><label>预计奖金</label><value id="val-win">0.00</value></div>
                <div class="data-item"><label>模式</label><value>多选押注</value></div>
            </div>
            <div class="stake-txt">单注步长：<span id="stepValue">10</span> USDT</div>
            <div class="exec-row">
                <button class="step-btn" id="stepMinus">-</button>
                <button class="main-go" id="fightBtn">确认投注</button>
                <button class="step-btn" id="stepPlus">+</button>
            </div>
            <div class="mode-row">
                <div id="btn-auto" class="mode-btn">自动投注</div>
                <div class="mode-btn speed-btn" id="speedSelector">
                    <span id="speed-1" class="active">1X</span>
                    <span id="speed-2">2X</span>
                    <span id="speed-3">3X</span>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
let state = { balance: 857.8, betStep: 10, bets: { DRAGON: 0, TIGER: 0, TIE: 0 }, betRolling: false, autoMode: false, speed: 1, pool: 84291.5 };
const ODDS = { DRAGON: 2, TIGER: 2, TIE: 8 };
function updateUI() {
    document.getElementById('balanceDisplay').innerText = state.balance.toFixed(2);
    document.getElementById('poolDisplay').innerText = state.pool.toFixed(2);
    document.getElementById('betDragonAmount').innerText = state.bets.DRAGON;
    document.getElementById('betTigerAmount').innerText = state.bets.TIGER;
    document.getElementById('betTieAmount').innerText = state.bets.TIE;
    let total = state.bets.DRAGON + state.bets.TIGER + state.bets.TIE;
    document.getElementById('totalBetAmount').innerText = total.toFixed(2);
    let maxWin = 0;
    if(state.bets.DRAGON>0) maxWin = Math.max(maxWin, state.bets.DRAGON*2);
    if(state.bets.TIGER>0) maxWin = Math.max(maxWin, state.bets.TIGER*2);
    if(state.bets.TIE>0) maxWin = Math.max(maxWin, state.bets.TIE*8);
    document.getElementById('val-win').innerText = maxWin.toFixed(2);
    document.getElementById('multiDragon').classList.toggle('selected', state.bets.DRAGON>0);
    document.getElementById('multiTiger').classList.toggle('selected', state.bets.TIGER>0);
    document.getElementById('multiTie').classList.toggle('selected', state.bets.TIE>0);
}
function adjustBet(type, delta) { if(state.betRolling) return; let newVal = state.bets[type] + delta; if(newVal<0) newVal=0; state.bets[type]=newVal; updateUI(); }
function adjustStep(dir) { let newStep = state.betStep + dir*10; if(newStep<10) newStep=10; if(newStep>500) newStep=500; state.betStep=newStep; document.getElementById('stepValue').innerText=state.betStep; }
function executeBet() {
    if(state.betRolling) { alert('请稍后'); return; }
    let total = state.bets.DRAGON + state.bets.TIGER + state.bets.TIE;
    if(total<=0) { alert('请押注'); return; }
    if(state.balance<total) { alert('余额不足'); return; }
    state.betRolling = true;
    state.balance -= total;
    updateUI();
    document.getElementById('battle-result').innerText = '💥 龙虎碰撞！ 💥';
    let delay = state.speed===3 ? 1200 : (state.speed===2 ? 2000 : 2800);
    setTimeout(() => {
        let rand = Math.random();
        let winType = rand<0.45 ? 'DRAGON' : (rand<0.9 ? 'TIGER' : 'TIE');
        let winAmount = 0;
        let txt = '';
        if(winType==='DRAGON') { txt='🐉 龙胜'; if(state.bets.DRAGON>0) winAmount=state.bets.DRAGON*2; }
        else if(winType==='TIGER') { txt='🐯 虎胜'; if(state.bets.TIGER>0) winAmount=state.bets.TIGER*2; }
        else { txt='⚖️ 和局'; if(state.bets.TIE>0) winAmount=state.bets.TIE*8; }
        if(winAmount>0) { state.balance += winAmount; txt += ` +${winAmount.toFixed(2)}`; updateUI(); }
        document.getElementById('battle-result').innerHTML = txt;
        state.betRolling = false;
        if(state.autoMode) setTimeout(() => { if(state.autoMode && !state.betRolling) executeBet(); }, state.speed===3?1500:(state.speed===2?2200:3000));
    }, delay);
}
function toggleAuto() { state.autoMode = !state.autoMode; let btn = document.getElementById('btn-auto'); btn.classList.toggle('active'); btn.innerText = state.autoMode ? '关闭自动' : '自动投注'; }
function setSpeed(s) { state.speed = s; document.querySelectorAll('.speed-btn span').forEach(sp=>sp.classList.remove('active')); document.getElementById(`speed-${s}`).classList.add('active'); }
function toggleSpeed() { setSpeed(state.speed%3+1); }
document.getElementById('stepMinus').onclick = () => adjustStep(-1);
document.getElementById('stepPlus').onclick = () => adjustStep(1);
document.getElementById('fightBtn').onclick = executeBet;
document.getElementById('btn-auto').onclick = toggleAuto;
document.getElementById('speedSelector').onclick = toggleSpeed;
document.querySelectorAll('.bet-dec').forEach(btn => btn.onclick = (e) => { e.stopPropagation(); adjustBet(btn.dataset.type, -state.betStep); });
document.querySelectorAll('.bet-inc').forEach(btn => btn.onclick = (e) => { e.stopPropagation(); adjustBet(btn.dataset.type, state.betStep); });
updateUI();
</script>
</body>
</html>