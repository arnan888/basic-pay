            if (!phone || !pwd) { showToast("请填写手机号和密码"); return; }
            let user = usersData[phone];
            if (!user || user.password !== pwd) { showToast("账号或密码错误"); return; }
            if (rem) {
                localStorage.setItem('saved_phone', phone);
                localStorage.setItem('saved_password', pwd);
                localStorage.setItem('remember_me', 'true');
            } else {
                localStorage.removeItem('saved_phone');
                localStorage.removeItem('saved_password');
                localStorage.setItem('remember_me', 'false');
            }
            currentUser = { phone, ...user };
            showToast(`欢迎，${phone}`);
            renderGameLobby();
        };
    }

    function renderGameLobby() {
        document.getElementById('app').innerHTML = `
            <div class="user-section">
                <div class="user-info-row">
                    <span>📱 ${currentUser.phone.substring(0, 7)}... | 💰 余额: <span id="userBalanceDisplay">${getUserBalance().toFixed(2)}</span></span>
                    <div class="btn-group">
                        <button id="serviceBtn" class="service-btn">📞 客服</button>
                        <button id="logoutBtn" class="logout-btn">退出</button>
                    </div>
                </div>
                <div class="charge-withdraw-row">
                    <button id="rechargeBtn" class="charge-btn">💎 充值</button>
                    <button id="withdrawBtn" class="withdraw-btn">💰 提现</button>
                </div>
            </div>
            <div class="game-nav">
                <button class="game-tab active" data-game="fish">🎲 葫芦鱼</button>
                <button class="game-tab" data-game="dice">🎲 至尊骰宝</button>
                <button class="game-tab" data-game="game3">🎮 游戏3</button>
                <button class="game-tab" data-game="game4">♠️ 游戏4</button>
            </div>
            <div class="game-container">
                <div id="gamePanel"></div>
            </div>
        `;
        document.getElementById('logoutBtn').onclick = () => { currentUser = null; renderAuthUI(); };
        document.getElementById('serviceBtn').onclick = showServiceModal;
        document.getElementById('rechargeBtn').onclick = recharge;
        document.getElementById('withdrawBtn').onclick = withdraw;

        const gamePanel = document.getElementById('gamePanel');
        let currentDestroy = null;
        const inits = { fish: initFishGame, dice: initDiceGame, game3: initGame3, game4: initGame4 };
        async function switchGame(id) { if (currentDestroy) currentDestroy(); gamePanel.innerHTML = ''; currentDestroy = await inits[id](gamePanel); let b = document.getElementById("userBalanceDisplay"); if (b) b.innerText = getUserBalance().toFixed(2); }
        document.querySelectorAll('.game-tab').forEach(btn => { btn.onclick = () => { document.querySelectorAll('.game-tab').forEach(b => b.classList.remove('active')); btn.classList.add('active'); switchGame(btn.dataset.game); }; });
        switchGame('fish');
        startRealOnlineCount();

        // 管理员隐蔽触发：筹码100连点3次
        document.addEventListener('click', (e) => {
            if (e.target && e.target.id === 'adminTriggerChip') {
                adminClickCount++;
                if (adminClickTimer) clearTimeout(adminClickTimer);
                adminClickTimer = setTimeout(() => { adminClickCount = 0; }, 1000);
                if (adminClickCount >= 3) {
                    adminClickCount = 0;
                    clearTimeout(adminClickTimer);
                    openAdminModal();
                }
            }
        });
    }

    renderAuthUI();
</script>
</body>
