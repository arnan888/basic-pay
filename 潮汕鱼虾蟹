        document.getElementById('rechargeBtn').onclick = recharge;
        document.getElementById('withdrawBtn').onclick = withdraw;
        
        buildGameUI();
        renderSeats();
        updateStatsUI();
        resetDiceCover();
        
        const userBalanceSpan = document.getElementById("userBalanceDisplay");
        if(userBalanceSpan) userBalanceSpan.innerText = getUserBalance().toFixed(2);
        
        if(players.length === 0) {
            for(let i=1; i<=6; i++) {
                let name = namePool[(i-1)%namePool.length] + Math.floor(Math.random()*100);
                players.push({ id: nextPlayerId++, name: name, seatIndex: i });
            }
            renderSeats();
        }
