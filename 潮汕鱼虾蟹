            border-bottom: 4px solid #f7bc6c;
        }

        .game-header h1 {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 2px;
            color: #ffefcf;
            text-shadow: 3px 3px 0 #56200c;
