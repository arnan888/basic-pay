    function escapeHtml(str) { return str.replace(/[&<>]/g, function(m){if(m==='&') return '&amp;'; if(m==='<') return '&lt;'; if(m==='>') return '&gt;'; return m;}); }
    
    function addRandomPlayerToSeat() {
        if(players.length >= 20) return;
        let emptySeats = [];
        for(let i=1;i<=20;i++) if(!players.find(p=>p.seatIndex===i)) emptySeats.push(i);
        if(emptySeats.length===0) return;
        let randomSeat = emptySeats[Math.floor(Math.random()*emptySeats.length)];
        let randomName = namePool[Math.floor(Math.random() * namePool.length)] + (Math.floor(Math.random()*90)+10);
        players.push({ id: nextPlayerId++, name: randomName, seatIndex: randomSeat });
        renderSeats();
    }
    
