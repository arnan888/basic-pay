    ];
    const patternIdToName = { fish:"鱼", shrimp:"虾", crab:"蟹", calabash:"葫芦", coin:"金钱", chicken:"鸡" };
    const SPECIALS = [
        { id: "big", name: "大", icon: "🔴", odds: 1 },
        { id: "small", name: "小", icon: "🔵", odds: 1 },
        { id: "odd", name: "单", icon: "⚪", odds: 1 },
        { id: "even", name: "双", icon: "⚫", odds: 1 },
        { id: "allTriplets", name: "全围", icon: "🌀", odds: 24 }
    ];

    let balance = 10000;
    let patternBets = { fish:0, shrimp:0, crab:0, calabash:0, coin:0, chicken:0 };
