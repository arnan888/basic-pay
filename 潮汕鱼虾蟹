        .action-btn {
            background: #734c2e;
            border: none;
            padding: 7px 20px;
            font-weight: bold;
            border-radius: 50px;
            color: #ffe3b3;
            box-shadow: 0 4px 0 #3f2a1a;
            cursor: pointer;
        }
        .action-btn.primary { background: #c47c3a; color: #2f1b0a; box-shadow: 0 4px 0 #764e26; }
        .action-btn:active { transform: translateY(2px); box-shadow: none; }

        .message-area {
            background: #1c140e;
            margin: 0 20px 20px;
            border-radius: 40px;
