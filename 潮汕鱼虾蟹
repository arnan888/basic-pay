<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>双游戏大厅 | 葫芦鱼抢庄 + 骰宝系统坐庄 | 真实在线人数</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: #1a1a1a;
            background-image: radial-gradient(circle at 20% 30%, rgba(200, 140, 70, 0.2) 2%, transparent 3%);
            background-size: 40px 40px;
            font-family: 'Segoe UI', 'PingFang SC', Roboto, sans-serif;
            padding: 12px;
        }

        .app {
            max-width: 550px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* 导航栏 */
        .game-nav {
            background: linear-gradient(135deg, #1a4a1a, #0a2a0a);
            border-radius: 60px;
            padding: 6px;
            display: flex;
            gap: 8px;
            border: 1px solid #ffaa44;
            flex-wrap: wrap;
        }

        .game-tab {
            flex: 1;
            background: transparent;
            border: none;
            padding: 10px 0;
            border-radius: 50px;
            font-weight: bold;
            font-size: 0.9rem;
            color: #ccaa77;
            cursor: pointer;
            transition: 0.2s;
            text-align: center;
        }

        .game-tab.active {
            background: #c47c3a;
            color: #2f1b0a;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.9);
        }

        /* 用户区 */
        .user-section {
            background: #1f1711;
            border-radius: 40px;
            padding: 12px 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .user-info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }

        .user-info-row span {
            color: #ffdd99;
            font-size: 0.9rem;
            font-weight: bold;
        }

        #userBalanceDisplay {
            font-size: 1.8rem;
            font-weight: 900;
            color: #ffcc44;
            background: #0a0705;
            padding: 2px 16px;
            border-radius: 50px;
            letter-spacing: 2px;
            text-shadow: 0 0 4px rgba(255, 200, 0, 0.95);
        }

        .btn-group {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .logout-btn,
        .service-btn {
            background: #734c2e;
            border: none;
            padding: 6px 14px;
            border-radius: 30px;
            color: #ffe3b3;
            font-size: 0.8rem;
            cursor: pointer;
            font-weight: bold;
        }

        .service-btn {
            background: #2e7d32;
        }

        .charge-withdraw-row {
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .charge-btn,
        .withdraw-btn {
            background: #c47c3a;
            border: none;
            padding: 8px 20px;
            border-radius: 40px;
            color: #2f1b0a;
            font-weight: bold;
            font-size: 0.9rem;
            cursor: pointer;
            flex: 1;
            text-align: center;
            box-shadow: 0 2px 0 #764e26;
        }

        .withdraw-btn {
            background: #734c2e;
            color: #ffe3b3;
            box-shadow: 0 2px 0 #3f2a1a;
        }

        /* 游戏容器 */
        .game-container {
            background: linear-gradient(145deg, #362a1f 0%, #251e16 100%);
            border-radius: 48px;
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            min-height: 580px;
        }

        /* 登录界面 */
        .auth-panel {
            background: linear-gradient(145deg, #362a1f 0%, #251e16 100%);
            border-radius: 48px;
            padding: 30px 20px;
            text-align: center;
            border: 2px solid #ffaa44;
        }

        .auth-panel h2 {
            color: #ffdd99;
            font-size: 1.8rem;
            margin-bottom: 20px;
        }

        .auth-input {
            width: 100%;
            padding: 14px;
            margin: 10px 0;
            background: #2a241e;
            border: 1px solid #ffaa44;
            border-radius: 60px;
            color: white;
            font-size: 1rem;
            text-align: center;
        }

        .auth-buttons {
            display: flex;
            gap: 12px;
            margin: 20px 0;
        }

        .auth-btn {
            flex: 1;
            background: #c47c3a;
            border: none;
            padding: 12px;
            border-radius: 60px;
            color: #2f1b0a;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
        }

        .auth-note {
            color: #aa8855;
            font-size: 0.75rem;
        }

        /* 筹码 */
        .chip {
            background: #ebbc7e;
            color: #3a240f;
            font-weight: bold;
            font-size: 1rem;
            padding: 6px 16px;
            border-radius: 40px;
            cursor: pointer;
            box-shadow: 0 2px 0 #8b5a2e;
            display: inline-block;
            transition: 0.05s linear;
            text-align: center;
        }

        .chip.selected {
            background: #f7c56e;
            box-shadow: 0 0 0 2px #ffefb0, 0 2px 0 #7a4b22;
            transform: scale(1.02);
        }

        /* 投注卡片通用 */
        .bet-card {
            background: #1f1712;
            border-radius: 28px;
            padding: 8px 4px;
            text-align: center;
            box-shadow: 0 6px 0 #0a0705;
            border: 1px solid #6f4f34;
            cursor: pointer;
            transition: 0.05s linear;
        }

        .bet-card:active {
            transform: translateY(3px);
            box-shadow: 0 3px 0 #0a0705;
        }

        .bet-name {
            font-size: 0.9rem;
            font-weight: bold;
            color: #ffddb0;
        }

        .bet-odds {
            font-size: 0.7rem;
            color: #dba959;
        }

        .bet-amount {
            background: #0c0907;
            border-radius: 40px;
            padding: 4px 6px;
            margin-top: 6px;
            font-size: 1.2rem;
            font-weight: bold;
            color: #ffcc66;
            text-align: center;
            text-shadow: 0 0 2px #ffaa44;
        }

        .btn-chip {
            background: #523b26;
            border: none;
            color: #fce2b4;
            width: 32px;
            height: 32px;
            border-radius: 30px;
            font-size: 1.2rem;
            cursor: pointer;
            font-weight: bold;
        }

        /* 在线人数 */
        .online-count-box {
            background: #2a1f16;
            margin: 12px;
            padding: 10px 16px;
            border-radius: 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.9rem;
            color: #ffdd99;
            border: 1px solid #ffaa44;
        }

        .online-number {
            font-size: 1.5rem;
            font-weight: 900;
            color: #ffaa44;
            margin-left: 8px;
            text-shadow: 0 0 3px #ff8800;
        }

        /* 骰子3D */
        .dice {
            width: 60px;
            height: 60px;
            position: relative;
            transform-style: preserve-3d;
        }

        .dice-face {
            position: absolute;
            width: 60px;
            height: 60px;
            background: linear-gradient(145deg, #fffff0, #f5f5dc);
            border-radius: 12px;
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            border: 1px solid rgba(200, 180, 120, 0.5);
        }

        .front {
            transform: translateZ(30px);
        }

        .back {
            transform: rotateY(180deg) translateZ(30px);
        }

        .right {
            transform: rotateY(90deg) translateZ(30px);
        }

        .left {
            transform: rotateY(-90deg) translateZ(30px);
        }

        .top {
            transform: rotateX(90deg) translateZ(30px);
        }

        .bottom {
            transform: rotateX(-90deg) translateZ(30px);
        }

        .pip {
            position: absolute;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            background: radial-gradient(circle at 35% 35%, #e74c3c, #c0392b);
        }

        /* 骰子点数定位 */
        .face-1 .pip-center {
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .face-2 .pip-tl {
            top: 20%;
            left: 20%;
        }

        .face-2 .pip-br {
            bottom: 20%;
            right: 20%;
        }

        .face-3 .pip-tl {
            top: 20%;
            left: 20%;
        }

        .face-3 .pip-center {
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .face-3 .pip-br {
            bottom: 20%;
            right: 20%;
        }

        .face-4 .pip-tl {
            top: 20%;
            left: 20%;
        }

        .face-4 .pip-tr {
            top: 20%;
            right: 20%;
        }

        .face-4 .pip-bl {
            bottom: 20%;
            left: 20%;
        }

        .face-4 .pip-br {
            bottom: 20%;
            right: 20%;
        }

        .face-5 .pip-tl {
            top: 20%;
            left: 20%;
        }

        .face-5 .pip-tr {
            top: 20%;
            right: 20%;
        }

        .face-5 .pip-mid {
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .face-5 .pip-bl {
            bottom: 20%;
            left: 20%;
        }

        .face-5 .pip-br {
            bottom: 20%;
            right: 20%;
        }

        .face-6 .pip-l1 {
            left: 20%;
            top: 15%;
        }

        .face-6 .pip-l2 {
            left: 20%;
            top: 50%;
            transform: translateY(-50%);
        }

        .face-6 .pip-l3 {
            left: 20%;
            bottom: 15%;
        }

        .face-6 .pip-r1 {
            right: 20%;
            top: 15%;
        }

        .face-6 .pip-r2 {
            right: 20%;
            top: 50%;
            transform: translateY(-50%);
        }

        .face-6 .pip-r3 {
            right: 20%;
            bottom: 15%;
        }

        /* 弹窗 */
        .result-popup {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.6);
            background: linear-gradient(145deg, #ffcc44, #ff9933);
            color: #1a1a2a;
            padding: 24px 40px;
            border-radius: 80px;
            font-size: 2.5rem;
            font-weight: 900;
            z-index: 2000;
            opacity: 0;
            transition: 0.25s;
            pointer-events: none;
            white-space: nowrap;
            text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.2);
        }

        .result-popup.show {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }

        .result-popup.win {
            background: linear-gradient(145deg, #ffcc44, #ffaa22);
        }

        .result-popup.lose {
            background: linear-gradient(145deg, #555, #333);
            color: #ffaa66;
        }

        .toast-message {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #000000cc;
            color: #ffcc44;
            padding: 8px 16px;
            border-radius: 40px;
            z-index: 2001;
            animation: fadeInOut 2s forwards;
            font-size: 0.9rem;
            font-weight: bold;
            white-space: nowrap;
        }

        @keyframes fadeInOut {
            0% {
                opacity: 0;
                transform: translateX(-50%) translateY(20px);
            }

            15% {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }

            85% {
                opacity: 1;
            }

            100% {
                opacity: 0;
                transform: translateX(-50%) translateY(-20px);
            }
        }

        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 3000;
        }

        .modal-content {
            background: #1a2a1a;
            border-radius: 48px;
            padding: 24px;
            border: 2px solid #ffaa44;
            width: 85%;
            max-width: 500px;
            text-align: center;
            color: #ffdd99;
            max-height: 80vh;
            overflow-y: auto;
        }

        .qr-img {
            width: 160px;
            height: 160px;
            margin: 10px auto;
            display: block;
            background: white;
            border-radius: 20px;
            padding: 8px;
            object-fit: contain;
        }

        /* 骰宝网格 */
        .points-grid,
        .trio-grid,
        .special-grid {
            display: grid;
            gap: 8px;
            margin-bottom: 12px;
        }

        .points-grid {
            grid-template-columns: repeat(4, 1fr);
        }

        .trio-grid {
            grid-template-columns: repeat(4, 1fr);
        }

        .special-grid {
            grid-template-columns: repeat(4, 1fr);
        }

        .countdown-warning {
            animation: warning 0.5s infinite;
            color: #ff3300 !important;
            text-shadow: 0 0 3px red;
        }

        @keyframes warning {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.6;
            }
        }

        /* 葫芦鱼图片 */
        .fish-pattern-img {
            width: 48px;
            height: 48px;
            object-fit: contain;
            margin: 4px auto;
            display: block;
            background: #2a1f16;
            border-radius: 12px;
            padding: 4px;
        }

        /* 六门卡片 */
        .fish-wrapper .bet-card {
            background: #660099;
            border-radius: 16px;
            padding: 8px 4px;
            text-align: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.65);
            border: 1px solid #005a32;
            transition: all 0.1s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100px;
            width: 100%;
            box-sizing: border-box;
        }

        .fish-wrapper .bet-name {
            font-size: 0.85rem;
            font-weight: bold;
            color: #bb77ff;
            margin: 4px 0 2px;
        }

        .fish-wrapper .bet-amount {
            background: #0c0907;
            border-radius: 40px;
            padding: 4px 8px;
            margin: 6px 8px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 6px;
            font-size: 1.2rem;
            font-weight: bold;
            color: #ffcc66;
            width: calc(100% - 16px);
            box-sizing: border-box;
        }

        .fish-wrapper .bet-amount span {
            font-size: 1.2rem;
            font-weight: bold;
            color: #ffdd88;
            min-width: 32px;
            text-align: center;
            text-shadow: 0 0 2px #ffaa44;
        }

        #patternGrid {
            display: grid !important;
            grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
            gap: 10px !important;
            margin: 12px 0 !important;
            width: 100%;
            overflow: visible;
        }

        .fish-wrapper .bet-sections {
            padding: 0 8px;
            overflow: visible;
        }

        /* 庄家余额等数字 */
        #fishBankerDisplay,
        #diceBankerDisplay,
        #totalBetValue,
        #lastWinValue,
        #totalBet,
        #rollingWinNumber,
        #countdownNum,
        #selectedChip {
            font-size: 1.4rem;
            font-weight: 900;
            color: #ffcc44;
            text-shadow: 0 0 3px #ff8800;
            background: rgba(0, 0, 0, 0.95);
            padding: 0 8px;
            border-radius: 30px;
            display: inline-block;
        }

        #rollingWinNumber {
            font-size: 1.3rem;
        }

        #countdownNum {
            font-size: 1.6rem;
        }

        .dice-wrapper #totalBet,
        .dice-wrapper #rollingWinNumber {
            font-size: 1.2rem;
        }

        /* 抢庄按钮 */
        .grab-btn {
            background: linear-gradient(135deg, #ffaa44, #ff7700);
            border: none;
            padding: 12px 28px;
            border-radius: 60px;
            font-weight: 900;
            font-size: 1.2rem;
            color: #2f1b0a;
            cursor: pointer;
            box-shadow: 0 6px 0 #aa4a00, 0 4px 12px rgba(0, 0, 0, 0.4);
            transition: all 0.1s ease;
            text-shadow: 0 1px 0 rgba(255, 255, 200, 0.8);
            letter-spacing: 2px;
            width: 80%;
            margin: 0 auto;
            display: block;
        }

        .grab-btn:active {
            transform: translateY(3px);
            box-shadow: 0 3px 0 #aa4a00;
        }

        .grab-btn:disabled {
            background: #888;
            box-shadow: 0 4px 0 #555;
            transform: none;
            cursor: not-allowed;
            text-shadow: none;
        }

        /* 双押按钮 */
        .double-bet-btn {
            background: linear-gradient(135deg, #ffaa44, #ff7700);
            border: none;
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: bold;
            font-size: 1rem;
            color: #2f1b0a;
            box-shadow: 0 4px 0 #aa4a00;
            width: 80%;
            margin: 0 auto;
            display: block;
            text-align: center;
            cursor: pointer;
        }

        .double-bet-btn:active {
            transform: translateY(2px);
            box-shadow: 0 2px 0 #aa4a00;
        }

        @media (max-width: 480px) {
            .dice {
                width: 50px;
                height: 50px;
            }

            .dice-face {
                width: 50px;
                height: 50px;
            }

            .front {
                transform: translateZ(25px);
            }

            .back {
                transform: rotateY(180deg) translateZ(25px);
            }

            .right {
                transform: rotateY(90deg) translateZ(25px);
            }

            .left {
                transform: rotateY(-90deg) translateZ(25px);
            }

            .top {
                transform: rotateX(90deg) translateZ(25px);
            }

            .bottom {
                transform: rotateX(-90deg) translateZ(25px);
            }

            .fish-pattern-img {
                width: 36px;
                height: 36px;
            }

            #userBalanceDisplay {
                font-size: 1.4rem;
            }

            #fishBankerDisplay,
            #diceBankerDisplay,
            #totalBetValue,
            #lastWinValue {
                font-size: 1.1rem;
            }

            #patternGrid {
                gap: 6px !important;
            }

            .fish-wrapper .bet-amount {
                padding: 4px 4px;
            }

            .fish-wrapper .bet-amount span {
                font-size: 1rem;
                min-width: 24px;
            }

            .btn-chip {
                width: 26px;
                height: 26px;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
<div class="app" id="app"></div>
<script>
    // ==================== 全局系统 ====================
    const USERS_KEY = 'double_games_final_v22';
    let usersData = JSON.parse(localStorage.getItem(USERS_KEY)) || {};
