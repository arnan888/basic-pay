            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            padding: 14px 22px;
            background: #1f1711;
            border-bottom: 1px solid #644a33;
        }

        .stat-card {
            background: #1a130d;
            border-radius: 48px;
            padding: 6px 18px;
            box-shadow: inset 0 1px 2px #00000033, 0 4px 8px #0000001f;
            flex: 1;
            min-width: 100px;
            text-align: center;
        }

        .stat-label {
            font-size: 0.7rem;
            color: #e2bc89;
            letter-spacing: 1px;
        }

        .stat-value {
            font-size: 1.7rem;
            font-weight: 800;
            color: #f9d792;
            line-height: 1;
            font-family: monospace;
        }

        /* 骰子区 */
        .dice-area {
            background: #2a211a;
            margin: 18px 22px;
            border-radius: 60px;
            padding: 18px 12px;
            text-align: center;
            box-shadow: inset 0 0 0 2px #5e4230, 0 8px 18px black;
        }

        .dice-title {
            font-size: 0.9rem;
            color: #f5c28e;
            margin-bottom: 12px;
            font-weight: bold;
        }

        .dice-box {
            display: flex;
            justify-content: center;
            gap: 18px;
            flex-wrap: wrap;
        }

        .dice {
            background: #fef0cf;
            width: 80px;
            height: 80px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            box-shadow: 0 8px 0 #926b42;
            background: #fff2df;
            border: 2px solid #e5b874;
        }

        /* 投注区 */
        .bet-sections {
            padding: 8px 20px 0 20px;
        }

        .section-title {
            color: #ffd49f;
            font-size: 0.9rem;
            margin: 8px 0 10px 8px;
            border-left: 5px solid #f7b05e;
            padding-left: 12px;
            font-weight: bold;
        }

        .bet-grid, .special-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
            gap: 14px;
            margin-bottom: 20px;
        }

        .bet-card {
            background: #1f1712;
            border-radius: 32px;
            text-align: center;
            padding: 10px 5px 8px;
            box-shadow: 0 5px 0 #0a0705;
            border: 1px solid #6f4f34;
        }

        .bet-icon {
            font-size: 2.2rem;
            background: #2f231c;
            width: 55px;
            height: 55px;
            line-height: 55px;
            margin: 0 auto 5px;
            border-radius: 50%;
        }

        .bet-name {
            font-size: 0.9rem;
            font-weight: bold;
            color: #ffddb0;
        }

        .bet-odds {
            font-size: 0.6rem;
            color: #dba959;
        }

        .bet-amount {
            background: #0c0907;
            border-radius: 60px;
            padding: 3px 6px;
            margin: 8px 5px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 4px;
        }

        .bet-amount span {
            color: #ffbc6e;
            font-weight: bold;
            font-size: 0.9rem;
            background: #2a1c12;
            padding: 2px 6px;
            border-radius: 30px;
            min-width: 45px;
        }

        .btn-chip {
            background: #523b26;
            border: none;
            color: #fce2b4;
            font-weight: bold;
            width: 32px;
            height: 32px;
            border-radius: 40px;
            cursor: pointer;
            box-shadow: 0 2px 3px black;
            transition: 0.05s linear;
        }
        .btn-chip:active { transform: scale(0.92); }

        .chip-bar {
            background: #2a1f16;
            margin: 8px 20px 16px;
            padding: 10px 12px;
            border-radius: 60px;
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .chip {
            background: #ebbc7e;
            color: #3a240f;
            font-weight: bold;
            padding: 5px 16px;
            border-radius: 40px;
            cursor: pointer;
            box-shadow: 0 3px 0 #8b5a2e;
            transition: 0.05s linear;
        }
        .chip:active { transform: translateY(2px); box-shadow: none; }
        .chip.selected { background: #f7c56e; box-shadow: 0 0 0 2px #ffefb0, 0 3px 0 #7a4b22; }

        .action-bar {
            display: flex;
            justify-content: center;
            gap: 12px;
            padding: 8px 20px 24px;
