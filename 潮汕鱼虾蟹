    async function animateRolling(finalPatterns) {
        const diceEls = document.querySelectorAll(".dice");
        const iconMap = { "鱼":"🐟","虾":"🦐","蟹":"🦀","葫芦":"🏺","金钱":"💰","鸡":"🐔" };
        for(let step=0; step<8; step++) {
            await new Promise(r=>setTimeout(r, 70));
            for(let i=0;i<3;i++) {
                let rand = PATTERNS[Math.floor(Math.random()*6)];
                diceEls[i].innerHTML = rand.icon;
            }
        }
        for(let i=0;i<3;i++) {
            diceEls[i].innerHTML = iconMap[finalPatterns[i]] || "🎲";
        }
    }

    function getPointValue(pname) { const m={"鱼":1,"虾":2,"蟹":3,"葫芦":4,"金钱":5,"鸡":6}; return m[pname]||0; }
    
    function settleGame(diceNames) {
        let points = diceNames.map(n=>getPointValue(n));
        let sum = points.reduce((a,b)=>a+b,0);
        let isTriplet = diceNames[0]===diceNames[1] && diceNames[1]===diceNames[2];
        let totalBet = getTotalBet();
        if(totalBet===0) { showMsg("没有下注，无法结算"); return false; }
        if(totalBet > balance) { showMsg("下注超额，请检查余额"); return false; }
        balance -= totalBet;
        let winAmount = 0;
        let winDetails = [];
        for(let [pid, betVal] of Object.entries(patternBets)) {
            if(betVal===0) continue;
            let occur = diceNames.filter(n=> n === patternIdToName[pid]).length;
            if(occur>0) {
                let prize = betVal * (occur+1);
                winAmount += prize;
                winDetails.push(`${patternIdToName[pid]} x${occur}`);
            }
        }
        let bigWin=false, smallWin=false, oddWin=false, evenWin=false, allTripletWin=false;
        if(!isTriplet) {
            if(sum>=11 && sum<=17) bigWin=true;
            if(sum>=4 && sum<=10) smallWin=true;
            if(sum%2===1) oddWin=true;
            if(sum%2===0) evenWin=true;
        }
        if(isTriplet) allTripletWin=true;
        if(specialBets.big>0 && bigWin) { winAmount += specialBets.big*2; winDetails.push("大"); }
        if(specialBets.small>0 && smallWin) { winAmount += specialBets.small*2; winDetails.push("小"); }
        if(specialBets.odd>0 && oddWin) { winAmount += specialBets.odd*2; winDetails.push("单"); }
        if(specialBets.even>0 && evenWin) { winAmount += specialBets.even*2; winDetails.push("双"); }
        if(specialBets.allTriplets>0 && allTripletWin) { winAmount += specialBets.allTriplets*25; winDetails.push("全围"); }

        let net = winAmount - totalBet;
        balance += winAmount;
        lastWinAmount = net;
        updateStatsUI();
        let diceShow = diceNames.join("、");
        if(winAmount>0) showMsg(`🎲 ${diceShow} 净赢+${net}  [${winDetails.join(',')}]`, 4500);
        else showMsg(`😢 ${diceShow} 亏损 ${totalBet}`, 3000);
        clearAllBets();
        return true;
    }

    async function onRollWithCover() {
        if(isRolling || isCoverAnimating) return;
        let total = getTotalBet();
        if(total === 0) { showMsg("请先下注再开骰！"); return; }
        if(total > balance) { showMsg("下注总额超过庄家余额，请减少下注"); return; }
        
        const diceCover = document.getElementById("diceCover");
        if(!diceCover) return;
        if(diceCover.classList.contains("hidden-cover") || diceCover.style.display === "none") { resetDiceCover(); }
        
        isRolling = true;
        isCoverAnimating = true;
        const rollBtn = document.getElementById("rollBtn");
        if(rollBtn) rollBtn.disabled = true;
        
        diceCover.classList.add("open-cover");
        await new Promise(resolve => setTimeout(resolve, 550));
        diceCover.classList.add("hidden-cover");
        diceCover.style.display = "none";
        
        const patternList = ["鱼","虾","蟹","葫芦","金钱","鸡"];
        let finalResult = [
            patternList[Math.floor(Math.random()*6)],
            patternList[Math.floor(Math.random()*6)],
            patternList[Math.floor(Math.random()*6)]
        ];
        await animateRolling(finalResult);
        settleGame(finalResult);
        
        await new Promise(r => setTimeout(r, 1500));
        const diceEls = document.querySelectorAll(".dice");
        diceEls.forEach(d => d.innerHTML = "🎲");
        diceCover.style.display = "flex";
        diceCover.classList.remove("open-cover", "hidden-cover");
        diceCover.style.visibility = "visible";
        diceCover.style.opacity = "1";
        diceCover.style.transform = "translateY(0) scale(1)";
        
        isCoverAnimating = false;
        isRolling = false;
        if(rollBtn) rollBtn.disabled = false;
        showMsg("骰盅已复位，可继续下注", 1500);
    }
    
