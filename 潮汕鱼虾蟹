            .dice { width: 55px; height: 55px; font-size: 2rem; }
            .bet-icon { width: 38px; height: 38px; line-height: 38px; font-size: 1.5rem; }
            .btn-chip { width: 26px; height: 26px; font-size: 0.8rem; }
            .seats-grid { grid-template-columns: repeat(4, 1fr); }
        }
    </style>
</head>
<body>
<div class="app" id="app"></div>

<script>
    // ==================== 用户数据存储 (手机号注册登录) ====================
    const USERS_KEY = 'chaoshan_users_full_v2';
    let usersData = JSON.parse(localStorage.getItem(USERS_KEY)) || {};
    let currentUser = null;

    // 庄家数据
    let bankerBalance = parseInt(localStorage.getItem('chaoshan_banker_balance_full')) || 10000;
    let currentBanker = localStorage.getItem('chaoshan_banker_name_full') || "系统庄家";

    function saveUsers() { localStorage.setItem(USERS_KEY, JSON.stringify(usersData)); }
    function saveBanker() {
        localStorage.setItem('chaoshan_banker_balance_full', bankerBalance);
        localStorage.setItem('chaoshan_banker_name_full', currentBanker);
    }
    function getUserBalance() { return currentUser ? (usersData[currentUser.phone]?.balance || 1000) : 0; }
    function setUserBalance(amt) { if(currentUser) { usersData[currentUser.phone].balance = Math.max(0, amt); saveUsers(); } }
    function addUserBalance(delta) { setUserBalance(getUserBalance() + delta); }

    function showToast(msg) {
        let toast = document.createElement('div');
        toast.textContent = msg;
        toast.style.cssText = 'position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#000000cc;backdrop-filter:blur(10px);color:#ffaa44;padding:10px 20px;border-radius:50px;font-size:0.8rem;z-index:2000;border:1px solid #ffaa44;';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
    }

    // ==================== 游戏核心 ====================
    const STORAGE_KEY = 'chaoshan_balance';
    let balance = parseInt(localStorage.getItem(STORAGE_KEY)) || 10000;
    
    const PATTERNS = [
        { id: "fish", name: "鱼", icon: "🐟", value: 1 },
        { id: "shrimp", name: "虾", icon: "🦐", value: 2 },
        { id: "crab", name: "蟹", icon: "🦀", value: 3 },
        { id: "calabash", name: "葫芦", icon: "🏺", value: 4 },
        { id: "coin", name: "金钱", icon: "💰", value: 5 },
        { id: "chicken", name: "鸡", icon: "🐔", value: 6 }
    ];
    const patternIdToName = { fish:"鱼", shrimp:"虾", crab:"蟹", calabash:"葫芦", coin:"金钱", chicken:"鸡" };
    const SPECIALS = [
        { id: "big", name: "大", icon: "🔴", odds: 1 },
        { id: "small", name: "小", icon: "🔵", odds: 1 },
        { id: "odd", name: "单", icon: "⚪", odds: 1 },
        { id: "even", name: "双", icon: "⚫", odds: 1 },
        { id: "allTriplets", name: "全围", icon: "🌀", odds: 24 }
    ];

    let patternBets = { fish:0, shrimp:0, crab:0, calabash:0, coin:0, chicken:0 };
    let specialBets = { big:0, small:0, odd:0, even:0, allTriplets:0 };
    let currentChip = 100;
    let lastWinAmount = 0;
    let isRolling = false;
    let isCoverAnimating = false;

    function persistBalance() {
        localStorage.setItem(STORAGE_KEY, balance);
    }

    function getTotalBet() {
        let p = Object.values(patternBets).reduce((a,b)=>a+b,0);
        let s = Object.values(specialBets).reduce((a,b)=>a+b,0);
        return p+s;
    }
    
    function updateStatsUI() {
        const balanceSpan = document.getElementById("balanceValue");
        if(balanceSpan) balanceSpan.innerText = Math.floor(balance);
        const totalSpan = document.getElementById("totalBetValue");
        if(totalSpan) totalSpan.innerText = getTotalBet();
        const lastSpan = document.getElementById("lastWin");
        if(lastSpan) lastSpan.innerText = lastWinAmount;
        persistBalance();
    }
    
    function updateAllBetUI() {
        for(let id of Object.keys(patternBets)) {
            let span = document.getElementById(`bet_${id}`);
            if(span) span.innerText = patternBets[id];
        }
        for(let id of Object.keys(specialBets)) {
            let span = document.getElementById(`bet_special_${id}`);
            if(span) span.innerText = specialBets[id];
        }
        updateStatsUI();
    }
    
    let msgTimeout = null;
    function showMsg(msg, duration=2000) {
        const msgDiv = document.getElementById("msgArea");
        if(!msgDiv) return;
        if(msgTimeout) clearTimeout(msgTimeout);
        msgDiv.innerText = msg;
        msgTimeout = setTimeout(() => {
            if(msgDiv.innerText === msg) msgDiv.innerText = "🎲 点击开骰 | 骰盅缓慢开启开奖";
        }, duration);
    }

    function addBet(type, id, val) {
        let target = (type === 'pattern') ? patternBets : specialBets;
        if(target[id] === undefined) return;
        let totalNow = getTotalBet();
        if(totalNow + val > balance) { showMsg(`余额不足，无法加注 ${val}`); return; }
        target[id] += val;
        updateAllBetUI();
        let name = (type === 'pattern') ? patternIdToName[id] : SPECIALS.find(s=>s.id===id)?.name || id;
        showMsg(`➕ ${name} +${val}`, 800);
    }
    
    function subBet(type, id, val) {
        let target = (type === 'pattern') ? patternBets : specialBets;
        if(target[id] === undefined) return;
        let old = target[id];
        let newVal = Math.max(0, old - val);
        if(old !== newVal) {
            target[id] = newVal;
            updateAllBetUI();
            let name = (type === 'pattern') ? patternIdToName[id] : SPECIALS.find(s=>s.id===id)?.name || id;
            showMsg(`➖ ${name} -${val}`, 800);
        }
    }
    
    function clearAllBets() {
        for(let k of Object.keys(patternBets)) patternBets[k]=0;
        for(let k of Object.keys(specialBets)) specialBets[k]=0;
        updateAllBetUI();
        showMsg("清空所有下注");
    }
    
    function resetDiceCover() {
        const diceCover = document.getElementById("diceCover");
        if(diceCover) {
            diceCover.classList.remove("open-cover", "hidden-cover");
            diceCover.style.display = "flex";
            diceCover.style.visibility = "visible";
            diceCover.style.opacity = "1";
            diceCover.style.transform = "translateY(0) scale(1)";
        }
    }
    
    function resetGame() {
        balance = 10000;
        persistBalance();
        clearAllBets();
        lastWinAmount = 0;
        updateStatsUI();
        document.querySelectorAll(".dice").forEach(d => d.innerHTML = "🎲");
        resetDiceCover();
        showMsg("庄家重置，本金 10000 文，骰盅已复位");
    }

    function chargeBalance() {
        let amount = prompt("请输入充值金额 (正整数)", "1000");
        if(amount === null) return;
        let val = parseInt(amount);
        if(isNaN(val) || val <= 0) {
            showMsg("充值金额必须是正整数", 1500);
            return;
        }
        balance += val;
        updateStatsUI();
        showMsg(`💎 充值成功！ +${val} 文，当前余额 ${balance}`, 2000);
    }

    async function animateRolling(finalPatterns) {
        const diceEls = document.querySelectorAll(".dice");
        const iconMap = { "鱼":"🐟","虾":"🦐","蟹":"🦀","葫芦":"🏺","金钱":"💰","鸡":"🐔" };
        for(let step=0; step<8; step++) {
            await new Promise(r=>setTimeout(r, 70));
            for(let i=0;i<3;i++) {
                let rand = PATTERNS[Math.floor(Math.random()*6)];
                diceEls[i].innerHTML = rand.icon;
            }
        }
        for(let i=0;i<3;i++) {
            diceEls[i].innerHTML = iconMap[finalPatterns[i]] || "🎲";
        }
    }

    function getPointValue(pname) { const m={"鱼":1,"虾":2,"蟹":3,"葫芦":4,"金钱":5,"鸡":6}; return m[pname]||0; }
    
    function settleGame(diceNames) {
        let points = diceNames.map(n=>getPointValue(n));
        let sum = points.reduce((a,b)=>a+b,0);
        let isTriplet = diceNames[0]===diceNames[1] && diceNames[1]===diceNames[2];
        let totalBet = getTotalBet();
        if(totalBet===0) { showMsg("没有下注，无法结算"); return false; }
        if(totalBet > balance) { showMsg("下注超额，请检查余额"); return false; }
        balance -= totalBet;
        let winAmount = 0;
        let winDetails = [];
        for(let [pid, betVal] of Object.entries(patternBets)) {
            if(betVal===0) continue;
            let occur = diceNames.filter(n=> n === patternIdToName[pid]).length;
            if(occur>0) {
                let prize = betVal * (occur+1);
                winAmount += prize;
                winDetails.push(`${patternIdToName[pid]} x${occur}`);
            }
        }
        let bigWin=false, smallWin=false, oddWin=false, evenWin=false, allTripletWin=false;
        if(!isTriplet) {
            if(sum>=11 && sum<=17) bigWin=true;
            if(sum>=4 && sum<=10) smallWin=true;
            if(sum%2===1) oddWin=true;
            if(sum%2===0) evenWin=true;
        }
        if(isTriplet) allTripletWin=true;
        if(specialBets.big>0 && bigWin) { winAmount += specialBets.big*2; winDetails.push("大"); }
        if(specialBets.small>0 && smallWin) { winAmount += specialBets.small*2; winDetails.push("小"); }
        if(specialBets.odd>0 && oddWin) { winAmount += specialBets.odd*2; winDetails.push("单"); }
        if(specialBets.even>0 && evenWin) { winAmount += specialBets.even*2; winDetails.push("双"); }
        if(specialBets.allTriplets>0 && allTripletWin) { winAmount += specialBets.allTriplets*25; winDetails.push("全围"); }

        let net = winAmount - totalBet;
        balance += winAmount;
        lastWinAmount = net;
        updateStatsUI();
        let diceShow = diceNames.join("、");
        if(winAmount>0) showMsg(`🎲 ${diceShow} 净赢+${net}  [${winDetails.join(',')}]`, 4500);
        else showMsg(`😢 ${diceShow} 亏损 ${totalBet}`, 3000);
        clearAllBets();
        return true;
    }

    async function onRollWithCover() {
        if(isRolling || isCoverAnimating) return;
        let total = getTotalBet();
        if(total === 0) { showMsg("请先下注再开骰！"); return; }
        if(total > balance) { showMsg("下注总额超过庄家余额，请减少下注"); return; }
        
        const diceCover = document.getElementById("diceCover");
        if(!diceCover) return;
        if(diceCover.classList.contains("hidden-cover") || diceCover.style.display === "none") {
            resetDiceCover();
        }
        
        isRolling = true;
        isCoverAnimating = true;
        const rollBtn = document.getElementById("rollBtn");
        if(rollBtn) rollBtn.disabled = true;
        
        diceCover.classList.add("open-cover");
        await new Promise(resolve => setTimeout(resolve, 550));
        diceCover.classList.add("hidden-cover");
        diceCover.style.display = "none";
        
        const patternList = ["鱼","虾","蟹","葫芦","金钱","鸡"];
        let finalResult = [
            patternList[Math.floor(Math.random()*6)],
            patternList[Math.floor(Math.random()*6)],
            patternList[Math.floor(Math.random()*6)]
        ];
        await animateRolling(finalResult);
        settleGame(finalResult);
        
        await new Promise(r => setTimeout(r, 1500));
        const diceEls = document.querySelectorAll(".dice");
        diceEls.forEach(d => d.innerHTML = "🎲");
        diceCover.style.display = "flex";
        diceCover.classList.remove("open-cover", "hidden-cover");
        diceCover.style.visibility = "visible";
        diceCover.style.opacity = "1";
        diceCover.style.transform = "translateY(0) scale(1)";
        
        isCoverAnimating = false;
        isRolling = false;
        if(rollBtn) rollBtn.disabled = false;
        showMsg("骰盅已复位，可继续下注", 1500);
    }
    
    function buildGameUI() {
        const patternContainer = document.getElementById("patternGrid");
        if(patternContainer) {
            patternContainer.innerHTML="";
            PATTERNS.forEach(p=>{
                let card = document.createElement("div"); card.className="bet-card";
                card.innerHTML = `<div class="bet-icon">${p.icon}</div><div class="bet-name">${p.name}</div><div class="bet-odds">1~3倍</div>
                <div class="bet-amount"><button class="btn-chip sub-pattern" data-id="${p.id}">-</button><span id="bet_${p.id}">0</span><button class="btn-chip add-pattern" data-id="${p.id}">+</button></div>`;
                patternContainer.appendChild(card);
            });
        }
        const specialContainer = document.getElementById("specialGrid");
        if(specialContainer) {
            specialContainer.innerHTML="";
            SPECIALS.forEach(s=>{
                let card = document.createElement("div"); card.className="bet-card";
                card.innerHTML = `<div class="bet-icon">${s.icon}</div><div class="bet-name">${s.name}</div><div class="bet-odds">${s.odds===1?"1:1":"1:24"}</div>
                <div class="bet-amount"><button class="btn-chip sub-special" data-id="${s.id}">-</button><span id="bet_special_${s.id}">0</span><button class="btn-chip add-special" data-id="${s.id}">+</button></div>`;
                specialContainer.appendChild(card);
            });
        }
        
        // 事件绑定
        document.querySelector(".bet-grid")?.addEventListener("click", (e) => {
            let btn = e.target.closest(".btn-chip");
            if(!btn) return;
            let id = btn.dataset.id;
            if(btn.classList.contains("add-pattern")) addBet('pattern', id, currentChip);
            if(btn.classList.contains("sub-pattern")) subBet('pattern', id, currentChip);
        });
        document.querySelector(".special-grid")?.addEventListener("click", (e) => {
            let btn = e.target.closest(".btn-chip");
            if(!btn) return;
            let id = btn.dataset.id;
            if(btn.classList.contains("add-special")) addBet('special', id, currentChip);
            if(btn.classList.contains("sub-special")) subBet('special', id, currentChip);
        });
        
        document.querySelectorAll(".chip").forEach(chip => {
            chip.onclick = () => {
                let val = parseInt(chip.dataset.chip);
                if(!isNaN(val)) { currentChip=val; document.querySelectorAll(".chip").forEach(c=>c.classList.remove("selected")); chip.classList.add("selected"); showMsg(`筹码 ${val}`,500); }
            };
        });
        const rollBtn = document.getElementById("rollBtn");
        if(rollBtn) rollBtn.onclick = onRollWithCover;
        const resetBtn = document.getElementById("resetBetBtn");
        if(resetBtn) resetBtn.onclick = clearAllBets;
        const resetGameBtn = document.getElementById("resetGameBtn");
        if(resetGameBtn) resetGameBtn.onclick = resetGame;
        
        let defaultChip = document.querySelector('.chip[data-chip="100"]');
        if(defaultChip) defaultChip.classList.add("selected");
        currentChip = 100;
        updateAllBetUI();
        resetDiceCover();
    }

    // ==================== 二十人房间管理 ====================
    let maxSeats = 20;
    let players = [];
    let nextPlayerId = 100;
    const namePool = ["阿强","老李","虾妹","蟹叔","金钱哥","鸡姐","小陈","骰子手","好运","锦鲤","鱼神","虾兵","蟹将","葫芦仙","铜钱","凤姐","阿珍","闲人","福仔","潮汕仔"];
    
    function renderSeats() {
        const container = document.getElementById("seatsGrid");
        if(!container) return;
        container.innerHTML = "";
        for(let i=1; i<=maxSeats; i++) {
            const player = players.find(p => p.seatIndex === i);
            const isOccupied = !!player;
            const seatDiv = document.createElement("div");
            seatDiv.className = `seat-card ${isOccupied ? "occupied" : "empty-seat"}`;
            seatDiv.innerHTML = `
                <div class="seat-number">#${i}</div>
                ${isOccupied ? `<div class="player-name" title="${escapeHtml(player.name)}">${escapeHtml(player.name.length>6?player.name.slice(0,5)+"..":player.name)}</div><button class="seat-action remove-player" data-seat="${i}">移除</button>` 
                              : `<div class="player-name">🔲 空闲</div><button class="seat-action add-to-seat" data-seat="${i}">邀请</button>`}
            `;
            container.appendChild(seatDiv);
        }
        const roomStats = document.getElementById("roomStats");
        if(roomStats) roomStats.innerHTML = `👥 ${players.length} / ${maxSeats}`;
        
        document.querySelectorAll(".remove-player").forEach(btn => {
            btn.addEventListener("click", (e) => { let seat = parseInt(btn.dataset.seat); removePlayerBySeat(seat); });
        });
        document.querySelectorAll(".add-to-seat").forEach(btn => {
            btn.addEventListener("click", (e) => { let seat = parseInt(btn.dataset.seat); addPlayerToSeat(seat); });
        });
    }
    
    function escapeHtml(str) { return str.replace(/[&<>]/g, function(m){if(m==='&') return '&amp;'; if(m==='<') return '&lt;'; if(m==='>') return '&gt;'; return m;}); }
    
    function addPlayerToSeat(seatIndex) {
        if(players.find(p=>p.seatIndex===seatIndex)) { showMsg(`座位 ${seatIndex} 已占用`, 1000); return; }
        if(players.length >= maxSeats) { showMsg(`房间已满 (最大${maxSeats}人)`, 1000); return; }
        let randomName = namePool[Math.floor(Math.random() * namePool.length)] + (Math.floor(Math.random()*90)+10);
        let newPlayer = { id: nextPlayerId++, name: randomName, seatIndex: seatIndex };
        players.push(newPlayer);
        renderSeats();
        showMsg(`✨ ${randomName} 入座 ${seatIndex} 号`, 1200);
    }
    
    function removePlayerBySeat(seatIndex) {
        let idx = players.findIndex(p=>p.seatIndex===seatIndex);
        if(idx !== -1) {
            let removed = players[idx];
            players.splice(idx,1);
            renderSeats();
            showMsg(`🚪 ${removed.name} 离开 ${seatIndex} 号`, 1200);
        }
    }
    
    function addRandomPlayer() {
        if(players.length >= maxSeats) { showMsg(`房间已满`, 1000); return; }
        let emptySeats = [];
        for(let i=1;i<=maxSeats;i++) if(!players.find(p=>p.seatIndex===i)) emptySeats.push(i);
        if(emptySeats.length===0) return;
        let randomSeat = emptySeats[Math.floor(Math.random()*emptySeats.length)];
        addPlayerToSeat(randomSeat);
    }
    
    function clearAllPlayers() { players = []; renderSeats(); showMsg(`清空所有玩家`, 1000); }
    
    function fillExamplePlayers() {
        clearAllPlayers();
        let count = Math.min(8, maxSeats);
        let usedSeats = new Set();
        for(let i=0;i<count;i++) {
            let seat = 1;
            while(usedSeats.has(seat)) seat = (seat % maxSeats) + 1;
            usedSeats.add(seat);
            let name = namePool[i % namePool.length] + (Math.floor(Math.random()*100));
            players.push({ id: nextPlayerId++, name: name, seatIndex: seat });
        }
        renderSeats();
        showMsg(`示例填充 ${players.length} 位玩家`, 1200);
    }
    
    function applyMaxCapacity() {
        let newMax = parseInt(document.getElementById("maxSeatsInput").value);
        if(isNaN(newMax)) newMax=20;
        newMax = Math.min(20, Math.max(1, newMax));
        maxSeats = newMax;
        players = players.filter(p => p.seatIndex <= maxSeats);
        renderSeats();
        showMsg(`最大座位调整为 ${maxSeats}`, 1000);
    }

    // ==================== 渲染游戏主界面 (登录后) ====================
    function renderGameUI() {
        const app = document.getElementById('app');
        app.innerHTML = `
            <div class="user-bar">
                <span>📱 ${currentUser.phone.substring(0,7)}... | 💰 余额: <span id="userBalanceDisplay">${getUserBalance().toFixed(2)}</span></span>
                <button id="logoutBtn" class="logout-btn">退出登录</button>
            </div>
            <div class="game-card">
                <div class="game-header"><h1><span>🎲</span> 潮汕葫芦鱼 · 二十人房 <span>🦐</span></h1><div class="sub">六门 | 大小单双 | 全围24倍 | 骰盅慢启</div></div>
                <div class="stats-panel">
                    <div class="stat-card"><div class="stat-label">💰 庄家余额</div><div class="stat-value" id="balanceValue">${Math.floor(balance)}</div></div>
                    <div class="stat-card"><div class="stat-label">🎲 总押注</div><div class="stat-value" id="totalBetValue">0</div></div>
                    <div class="stat-card"><div class="stat-label">🏆 上局净利</div><div class="stat-value" id="lastWin">0</div></div>
                </div>
                <div class="dice-area" id="diceArea">
                    <div class="dice-title">⚡ 三骰开彩 · 鱼虾蟹葫芦金钱鸡 ⚡</div>
                    <div class="dice-box" id="diceContainer">
                        <div class="dice">🎲</div><div class="dice">🎲</div><div class="dice">🎲</div>
                    </div>
                    <div class="dice-cover" id="diceCover"><span>🏺</span><div class="cover-text">骰盅未开</div></div>
                </div>
                <div class="bet-sections">
                    <div class="section-title">🐟 六门押注 (按次数赔)</div>
                    <div class="bet-grid" id="patternGrid"></div>
                    <div class="section-title">🎯 特殊投注</div>
                    <div class="special-grid" id="specialGrid"></div>
                </div>
                <div class="chip-bar" id="chipBar">
                    <div class="chip" data-chip="20">20</div><div class="chip" data-chip="50">50</div><div class="chip" data-chip="100">100</div>
                    <div class="chip" data-chip="500">500</div><div class="chip" data-chip="1000">1k</div>
                </div>
                <div class="action-bar">
                    <button class="action-btn primary" id="rollBtn">🎲 开骰！</button>
                    <button class="action-btn" id="resetBetBtn">🧹 清空下注</button>
                    <button class="action-btn" id="resetGameBtn">💺 重置庄家</button>
                </div>
                <div class="message-area" id="msgArea">庄家坐镇 | 骰盅缓慢开启 → 骰子摇动</div>
            </div>
            <div class="admin-card">
                <div class="admin-header" id="adminHeader"><h3>🎛️ 二十人座席管理 · 充值口</h3><button class="toggle-btn" id="toggleAdminBtn">▼ 收起</button></div>
                <div class="admin-content" id="adminContent">
                    <div class="capacity-row">
                        <div class="capacity-control"><label>🏠 最大座位</label><input type="number" id="maxSeatsInput" min="1" max="20" value="20" step="1"><button class="admin-btn" id="applyCapacityBtn" style="padding: 3px 10px;">设置</button></div>
                        <div class="stat-badge" id="roomStats">👥 0 / 20</div>
                    </div>
                    <div class="seats-grid" id="seatsGrid"></div>
                    <div class="admin-buttons">
                        <button class="admin-btn" id="addRandomPlayerBtn">➕ 随机加入</button>
                        <button class="admin-btn" id="clearAllPlayersBtn">🗑️ 清空</button>
                        <button class="admin-btn" id="fillExampleBtn">🎲 示例8人</button>
                        <button class="admin-btn charge" id="chargeBtn">💎 庄家充值</button>
                    </div>
