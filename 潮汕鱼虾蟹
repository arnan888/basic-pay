    // ==================== 登录/注册界面 ====================
    function renderAuthUI() {
        const savedPhone = localStorage.getItem('saved_phone') || '';
        const savedPwd = localStorage.getItem('saved_password') || '';
        const rememberChecked = localStorage.getItem('remember_me') === 'true';
        
        const app = document.getElementById('app');
        app.innerHTML = `
            <div class="auth-panel">
                <h2>🎲 潮汕葫芦鱼</h2>
                <input type="tel" id="regPhone" class="auth-input" placeholder="手机号" maxlength="11" value="${savedPhone}">
                <input type="password" id="regPassword" class="auth-input" placeholder="密码 (至少4位)" value="${savedPwd}">
                <div style="display: flex; align-items: center; justify-content: flex-start; gap: 8px; margin: 8px 0;">
                    <input type="checkbox" id="rememberCheckbox" style="width: 18px; height: 18px; cursor: pointer;" ${rememberChecked ? 'checked' : ''}>
                    <label for="rememberCheckbox" style="color: #ffdd99; font-size: 0.7rem; cursor: pointer;">记住账号密码</label>
                </div>
                <div class="auth-buttons">
                    <button id="loginBtn" class="auth-btn">登录</button>
                    <button id="registerBtn" class="auth-btn">注册</button>
                </div>
