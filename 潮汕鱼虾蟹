        if(user.password !== pwd) { showToast("密码错误"); return; }
        
        // 记住密码逻辑
        if(remember) {
            localStorage.setItem('saved_phone', phone);
            localStorage.setItem('saved_password', pwd);
            localStorage.setItem('remember_me', 'true');
        } else {
            localStorage.removeItem('saved_phone');
