            document.getElementById("userBalanceDisplay").innerText = currentBalance.toFixed(2);
            let multText = selectedMultiplier === 1 ? "平倍 (1x)" : (selectedMultiplier === 2 ? "翻倍 (2x)" : "超级牛牛 (3x)");
            document.getElementById('nnCurrentMultiplier').innerText = multText;
        }
        function placeBet() {
            if (currentBet > 0) { showToast("已有下注，请先清空或开奖"); return; }
            let chip = betChip;
            if (chip > currentBalance) { showToast("余额不足"); return; }
            currentBet = chip;
            currentBalance -= chip;
            updateBalanceDisplay();
            updateUI();
            showToast(`下注 ${chip} 元，倍率 ${selectedMultiplier}x`);
        }
        function clearBet() {
            if (currentBet > 0) {
                currentBalance += currentBet;
                updateBalanceDisplay();
                currentBet = 0;
                updateUI();
                showToast("已清空下注");
            } else showToast("无下注");
        }
        async function dealAndSettle() {
            if (currentBet === 0) { showToast("请先下注"); return; }
            document.getElementById('nnBankerCards').innerHTML = '';
            document.getElementById('nnPlayerCards').innerHTML = '';
            document.getElementById('nnResult').innerHTML = '';
            document.getElementById('bankerNiuType').innerHTML = '';
            const msgDiv = document.getElementById('nnDealingMsg');
            msgDiv.innerText = "🎲 发牌中...";
            
            let bankerCards = [], playerCards = [];
            for (let i=0;i<5;i++) {
                bankerCards.push(getRandomCard());
                playerCards.push(getRandomCard());
            }
            for (let i=0;i<5;i++) {
                await new Promise(r => setTimeout(r, 200));
                const current = bankerCards.slice(0, i+1);
                document.getElementById('nnBankerCards').innerHTML = getCardsHTML(current);
            }
            let bankerPoints = bankerCards.map(c=>c.value);
            let bankerNiu = calcNiu(bankerPoints);
            let bankerType = bankerNiu.type;
            let bankerMulti = bankerNiu.baseMulti;
            let maxCard = bankerCards.reduce((max, c) => {
                let rankVal = (c.rank === 'A' ? 1 : (c.rank === 'J' || c.rank === 'Q' || c.rank === 'K' ? 10 : parseInt(c.rank)));
                let maxVal = (max.rank === 'A' ? 1 : (max.rank === 'J' || max.rank === 'Q' || max.rank === 'K' ? 10 : parseInt(max.rank)));
                return rankVal > maxVal ? c : max;
            }, bankerCards[0]);
            document.getElementById('bankerNiuType').innerHTML = `庄家牌型：${bankerType}，最大牌：${maxCard.rank}${maxCard.suit}`;
            await new Promise(r => setTimeout(r, 300));
            for (let i=0;i<5;i++) {
                await new Promise(r => setTimeout(r, 200));
                const current = playerCards.slice(0, i+1);
                document.getElementById('nnPlayerCards').innerHTML = getCardsHTML(current);
            }
            await new Promise(r => setTimeout(r, 300));
            msgDiv.innerText = "";
            
            let playerPoints = playerCards.map(c=>c.value);
            let playerNiu = calcNiu(playerPoints);
            let playerType = playerNiu.type;
            let playerMulti = playerNiu.baseMulti;
            let winAmount = 0;
            let resultText = "";
            if (playerMulti > bankerMulti) {
                let totalMulti = playerMulti * selectedMultiplier;
                winAmount = currentBet * totalMulti;
                resultText = `闲家${playerType} 胜 庄家${bankerType}，您赢了 ${winAmount.toFixed(2)} 元 (${playerMulti}倍 × ${selectedMultiplier}倍)`;
                const settleRes = await apiSettle(currentBet, winAmount, `牛牛下注${currentBet}`, `${playerType} vs ${bankerType}`, '至尊牛牛');
                if (settleRes.success) {
                    currentBalance = settleRes.newBalance;
                    updateBalanceDisplay();
                } else { showToast(settleRes.message || "结算失败"); await refreshBalance(); }
                nnBankerBal -= winAmount;
            } else if (bankerMulti > playerMulti) {
                winAmount = -currentBet;
                resultText = `庄家${bankerType} 胜 闲家${playerType}，您输了 ${currentBet} 元`;
                const settleRes = await apiSettle(currentBet, 0, `牛牛下注${currentBet}`, `${playerType} vs ${bankerType}`, '至尊牛牛');
                if (settleRes.success) {
                    currentBalance = settleRes.newBalance;
                    updateBalanceDisplay();
                } else { showToast(settleRes.message || "结算失败"); await refreshBalance(); }
                nnBankerBal += currentBet;
            } else {
                let bankerNiuVal = bankerType === '牛牛' ? 10 : (bankerType === '无牛' ? 0 : parseInt(bankerType.replace('牛','')));
                let playerNiuVal = playerType === '牛牛' ? 10 : (playerType === '无牛' ? 0 : parseInt(playerType.replace('牛','')));
                if (playerNiuVal > bankerNiuVal) {
                    let totalMulti = (playerMulti === 0 ? 1 : playerMulti) * selectedMultiplier;
                    winAmount = currentBet * totalMulti;
                    resultText = `闲家${playerType} 胜 庄家${bankerType}，您赢了 ${winAmount.toFixed(2)} 元 (${playerMulti}倍 × ${selectedMultiplier}倍)`;
                    const settleRes = await apiSettle(currentBet, winAmount, `牛牛下注${currentBet}`, `${playerType} vs ${bankerType}`, '至尊牛牛');
                    if (settleRes.success) { currentBalance = settleRes.newBalance; updateBalanceDisplay(); }
                    nnBankerBal -= winAmount;
                } else if (bankerNiuVal > playerNiuVal) {
                    winAmount = -currentBet;
                    resultText = `庄家${bankerType} 胜 闲家${playerType}，您输了 ${currentBet} 元`;
                    const settleRes = await apiSettle(currentBet, 0, `牛牛下注${currentBet}`, `${playerType} vs ${bankerType}`, '至尊牛牛');
                    if (settleRes.success) { currentBalance = settleRes.newBalance; updateBalanceDisplay(); }
