                } else {
                    winAmount = 0;
                    resultText = `平局！庄家${bankerType}，闲家${playerType}，退还本金 ${currentBet} 元`;
                    const settleRes = await apiSettle(currentBet, currentBet, `牛牛下注${currentBet}`, `${playerType} vs ${bankerType}`, '至尊牛牛');
                    if (settleRes.success) { currentBalance = settleRes.newBalance; updateBalanceDisplay(); }
                }
            }
            lastWin = winAmount;
            document.getElementById('nnResult').innerHTML = resultText;
            gameRecords.unshift({ time:new Date().toLocaleTimeString(), bankerType, playerType, bet: currentBet, win: winAmount, multiplier: selectedMultiplier });
            if (gameRecords.length > 50) gameRecords.pop();
            currentBet = 0;
            updateUI();
            let pop = document.createElement('div'); pop.className='result-popup'; pop.innerText = winAmount>0?`🎉 赢 ${winAmount.toFixed(2)} 🎉`:(winAmount<0?`😭 输 ${-winAmount} 😭`:`⚖️ 平局`); document.body.appendChild(pop); setTimeout(()=>pop.remove(),2000);
        }
        function showHistory() {
