<div id="app"></div>
<script>
    // ==================== Supabase 配置 ====================
    const SUPABASE_URL = 'https://spjmfifgzzqjritklgxm.supabase.co';
    const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNwam1maWZnenpxanJpdGtsZ3htIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY5NDQ5MjIsImV4cCI6MjA5MjUyMDkyMn0.lzqdVmNEGHjkdr_Pbj23J_PrSEKnEmVkTAWEZ1Qa6QQ';
    // 修复：改用 supabaseClient，避免与全局 supabase 冲突
    const supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    // ==================== 双语 ====================
    const lang = {
        zh: {
            recharge: "💎 充值", withdraw: "💰 提现", service: "📞 客服", logout: "退出", balance: "余额",
            phoneOrEmail: "手机号 / 邮箱", password: "密码 (≥4位)", referralCode: "推荐码 (必填)", remember: "记住账号",
            login: "登录", register: "注册", referralNote: "推荐码: VIP666,888VIP,GOLD2025,LUCKY8,DICE100",
            getCode: "获取验证码", verifyCode: "验证码", registerNow: "注册新账户",
            gameFish: "🐟 金辉鱼虾蟹", gameDice: "🎲 金辉骰宝", gameDT: "🐉 金辉龙虎斗", game4: "🐮 金辉牛牛"
        },
        th: {
            recharge: "💎 เติมเงิน", withdraw: "💰 ถอนเงิน", service: "📞 บริการ", logout: "ออก", balance: "ยอดเงิน",
            phoneOrEmail: "เบอร์โทร / อีเมล", password: "รหัสผ่าน (≥4)", referralCode: "รหัสแนะนำ", remember: "จำฉัน",
            login: "เข้าสู่ระบบ", register: "สมัคร", referralNote: "รหัส: VIP666,888VIP,GOLD2025,LUCKY8,DICE100",
            getCode: "รับรหัส", verifyCode: "รหัสยืนยัน", registerNow: "สมัครสมาชิก",
            gameFish: "🐟 ปลาหมึกทอง", gameDice: "🎲 เซียนเต๋าทอง", gameDT: "🐉 มังกรเสือทอง", game4: "🐮 กระบือทอง"
        }
    };
    let currentLang = 'zh';
    function t(key) { return lang[currentLang][key] || lang.zh[key] || key; }

    // ==================== 全局变量 ====================
    let currentUser = null;
    let systemBankerBalance = 50000;
    let adjustFactor = 1.0;
    let validReferralCodes = ["VIP666","888VIP","GOLD2025","LUCKY8","DICE100"];

    function showToast(msg) {
        let t = document.createElement('div');
        t.className = 'toast-message';
        t.innerText = msg;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 2000);
    }

    // ==================== 加载系统配置 ====================
    async function loadSystemConfig() {
        try {
            const { data, error } = await supabaseClient
                .from('system_config')
                .select('*');
            if (error) throw error;
            for (let cfg of data) {
                if (cfg.key === 'systemBankerBalance') systemBankerBalance = cfg.value;
                if (cfg.key === 'adjustFactor') adjustFactor = cfg.value;
            }
        } catch (err) {
            console.warn("加载配置失败", err);
        }
    }

    // ==================== 用户操作（Supabase 版） ====================
    async function login(account, password) {
        try {
            const { data, error } = await supabaseClient
                .from('users')
                .select('*')
                .eq('account', account)
                .maybeSingle();
            if (error || !data) return false;
            if (data.password === password) {
                currentUser = data;
                return true;
            }
            return false;
        } catch (err) {
            return false;
        }
    }

    async function register(account, password, code) {
        if (!validReferralCodes.includes(code)) {
            showToast("推荐码无效");
            return false;
        }
        try {
            const { data, error } = await supabaseClient
                .from('users')
                .select('account')
                .eq('account', account)
                .maybeSingle();
            if (data) {
                showToast("账号已存在");
                return false;
            }
            const { error: insertError } = await supabaseClient
                .from('users')
                .insert({
                    account: account,
                    password: password,
                    balance: 0,
                    register_time: new Date().toLocaleString(),
                    records: [],
                    result_history: []
                });
            if (insertError) throw insertError;
            return true;
        } catch (err) {
            showToast(err.message);
            return false;
        }
    }

    async function getUserBalance() {
        if (!currentUser) return 0;
        const { data, error } = await supabaseClient
            .from('users')
            .select('balance')
            .eq('id', currentUser.id)
            .single();
        if (!error && data) {
            currentUser.balance = data.balance;
            return data.balance;
        }
        return currentUser.balance;
    }

    async function setUserBalance(amount) {
        if (!currentUser) return;
        const { error } = await supabaseClient
            .from('users')
            .update({ balance: amount })
            .eq('id', currentUser.id);
        if (!error) {
            currentUser.balance = amount;
            const span = document.getElementById("userBalanceDisplay");
            if (span) span.innerText = amount.toFixed(2);
        } else {
            showToast("更新余额失败");
        }
    }

    async function addGameRecord(account, gameName, betInfo, result, winAmount, betAmount) {
        try {
            const { data: user, error: fetchError } = await supabaseClient
                .from('users')
                .select('records')
                .eq('account', account)
                .single();
            if (fetchError) throw fetchError;
            let records = user.records || [];
            records.unshift({
                time: new Date().toLocaleString(),
                game: gameName,
                bet: betInfo,
                result: result,
                win: winAmount,
                amount: betAmount
            });
            if (records.length > 100) records.pop();
            const { error: updateError } = await supabaseClient
                .from('users')
                .update({ records: records })
                .eq('account', account);
            if (updateError) throw updateError;
        } catch (err) {
            console.warn("添加记录失败", err);
        }
    }

    // ==================== 充值申请 ====================
    async function recharge() {
        let modalDiv = document.createElement('div');
        modalDiv.className = 'modal';
