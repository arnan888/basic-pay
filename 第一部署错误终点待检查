    async function withdraw() {
        let bal = await getUserBalance();
        if (bal <= 0) { showToast("余额不足"); return; }
        let amount = parseFloat(prompt("提现金额 (元)", "10"));
        if (isNaN(amount) || amount <= 0 || amount > bal) { showToast("金额无效"); return; }
        let type = confirm("提现方式：确定=微信，取消=支付宝") ? "微信" : "支付宝";
        let account = prompt("请输入收款账号:");
        if (!account) return;
        try {
            const { error } = await supabaseClient
                .from('withdraws')
                .insert({
                    account: currentUser.account,
                    amount: amount,
                    type: type,
                    account_no: account,
                    time: new Date().toLocaleString()
                });
            if (error) throw error;
            await setUserBalance(bal - amount);
            showToast(`提现申请已提交！${amount}元将处理到${type}账号 ${account}`);
        } catch (err) {
            showToast("提现申请失败: " + err.message);
        }
    }

