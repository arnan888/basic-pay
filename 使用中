        .history-title { font-size: 12px; color: #ffaa44; text-align: center; margin-bottom: 10px; }
        .history-grid { display: grid; grid-template-columns: repeat(10, 30px); gap: 5px; justify-content: center; margin-bottom: 12px; }
        .history-cell { width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; background: #1e1e2e; }
        .history-cell.dragon { background: #ff3300; }
        .history-cell.tiger { background: #005a32; }
        .history-cell.tie { background: #aa66ff; }
        .record-list { max-height: 100px; overflow-y: auto; font-size: 11px; }
        .record-item { display: flex; justify-content: space-between; padding: 4px 10px; border-bottom: 1px solid rgba(255,255,255,0.1); color: #ddd; }
