        let account = prompt("请输入收款账号:");
        if (!account) return;
        setUserBalance(bal - wenNum);
        let record = { phone: currentUser.phone, amount: wenNum, yuan: yuan.toFixed(2), type, account, time: new Date().toLocaleString(), status: "待处理" };
        withdrawRecords.push(record);
        localStorage.setItem('withdraw_records', JSON.stringify(withdrawRecords));
        showToast(`提现申请已提交！${wenNum}文 (${yuan}元) 将处理到${type}账号 ${account}`);
