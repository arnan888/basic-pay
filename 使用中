                let p=Math.min(1,(now-start)/5000), ease=1-Math.pow(1-p,2), cur=startVal+(finalAmount-startVal)*ease;
                rollingWinEl.innerText=cur.toFixed(2);
                if(p<1) window.rollingAnimation=requestAnimationFrame(update);
