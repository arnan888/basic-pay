        document.getElementById('serviceBtn').onclick = showServiceModal;
        document.getElementById('rechargeBtn').onclick = recharge;
        document.getElementById('withdrawBtn').onclick = withdraw;
        document.getElementById('langSwitchBtn').onclick = () => {
            currentLang = currentLang === 'zh' ? 'th' : 'zh';
            document.getElementById('langSwitchBtn').innerText = currentLang === 'zh' ? 'ภาษาไทย' : '中文';
            renderGameLobby();
        };
        const gamePanel = document.getElementById('gamePanel');
        let currentDestroy = null;
        const inits = { fish: initFishGame, dice: initDiceGame, dragonTiger: initDragonTigerGame, game4: initGame4 };
        async function switchGame(id) { if (currentDestroy) currentDestroy(); gamePanel.innerHTML = ''; currentDestroy = await inits[id](gamePanel); }
        document.querySelectorAll('.game-tab').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('.game-tab').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                switchGame(btn.dataset.game);
            };
        });
        switchGame('fish');
        let adminClickCount = 0;
        document.getElementById('userBalanceDisplay').addEventListener('click', () => {
            adminClickCount++;
            setTimeout(() => { adminClickCount = 0; }, 1000);
            if (adminClickCount >= 3) { adminClickCount = 0; openAdminModal(); }
        });
    }

    renderAuthUI();
</script>
</body>
</html>








