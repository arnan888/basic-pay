        if(savedBankerFish && parseInt(savedBankerFish)>0){ hasGrabbed=true; playerBankerBalance=parseInt(savedBankerFish); }
        updateFishUI();
        startFishRound();
        fishDestroy = () => { roundActive=false; if(countdownTimer) clearInterval(countdownTimer); if(autoRollTimer) clearTimeout(autoRollTimer); container.innerHTML=''; };
        return fishDestroy;
    }

    // ==================== 至尊骰宝（系统坐庄，完整版） ====================
    let diceDestroy = null;
    function initDiceGame(container) {
        if (diceDestroy) { diceDestroy(); diceDestroy = null; }
        container.innerHTML = '';
        const oddsMap = { 4:60,5:30,6:18,7:12,8:8,9:7,10:6,11:6,12:7,13:8,14:12,15:18,16:30,17:60 };
        let pointsHtml = '';
        for (let i=4;i<=17;i++) pointsHtml += `<div class="bet-card point-card" data-point="${i}"><div class="bet-name">${i}点</div><div class="bet-odds">${oddsMap[i]}倍</div><div id="bet_${i}" class="bet-amount">0</div></div>`;
        let trioHtml = '';
        for (let i=1;i<=6;i++) trioHtml += `<div class="bet-card trio-card" data-type="TRIPLE_${i}"><div class="bet-name">${i}围</div><div class="bet-odds">150倍</div><div id="bet_TRIPLE_${i}" class="bet-amount">0</div></div>`;
        trioHtml += `<div class="bet-card trio-card" data-type="ALL_TRIPLE"><div class="bet-name">🐆 豹子</div><div class="bet-odds">30倍</div><div id="bet_ALL_TRIPLE" class="bet-amount">0</div></div>`;
        container.innerHTML = `
            <div class="dice-wrapper" style="padding:12px;">
                <div style="background:linear-gradient(145deg,#1f482f,#0b2a18); border-radius:48px; padding:14px;">
                    <div style="display:flex; gap:12px; margin-bottom:12px;">
                        <div style="flex:1; background:#0c0b09; border-radius:44px; padding:6px; text-align:center;"><div>🏦 庄家资金</div><div id="diceBankerDisplay">${systemBankerBalance.toFixed(2)}</div></div>
                        <div style="flex:1; background:#0c0b09; border-radius:44px; padding:6px; text-align:center;"><div>🎲 总押注</div><div id="totalBet">0</div></div>
                    </div>
                    <div class="dice-3d-area"><div class="dice-cube" id="dice1"></div><div class="dice-cube" id="dice2"></div><div class="dice-cube" id="dice3"></div></div>
                    <div style="text-align:center;"><span id="totalPoints" style="font-size:26px; font-weight:800;">3</span></div>
                    <div style="display:flex; justify-content:space-between; background:#00000066; border-radius:40px; padding:6px 12px; margin:8px 0;"><span>🎲 本局中奖:</span><span id="rollingWinNumber">0.00</span></div>
                    <div style="display:flex; justify-content:space-between; background:#19140ed9; border-radius:40px; padding:6px 12px;"><div>⏱️ 下注 <span id="countdownNum">25</span> s</div><div>🎲 筹码 <span id="selectedChip">0</span></div></div>
                    <div style="display:flex; gap:8px; margin:12px 0;"><button id="clearAllBtn" style="flex:1; background:#c23b22; border-radius:60px; padding:8px;">❌ 清空</button><button id="repeatBtn" style="flex:1; background:#e09d32; border-radius:60px; padding:8px;">🔄 续押</button><button id="refreshBtn" style="flex:1; background:#2c7a4d; border-radius:60px; padding:8px;">💹 刷新</button></div>
                    <div class="chips"><div class="chip" data-val="10">10</div><div class="chip" data-val="20">20</div><div class="chip" data-val="50">50</div><div class="chip" data-val="100">100</div><div class="chip" data-val="500">500</div><div class="chip" data-val="1000" id="adminTriggerChip">1K</div></div>
                    <div style="font-size:0.7rem;">🎲 大小单双 · 赔率2倍</div>
                    <div class="special-grid"><div class="bet-card special-card" data-type="BIG">大<div id="bet_BIG">0</div></div><div class="bet-card special-card" data-type="SMALL">小<div id="bet_SMALL">0</div></div><div class="bet-card special-card" data-type="ODD">单<div id="bet_ODD">0</div></div><div class="bet-card special-card" data-type="EVEN">双<div id="bet_EVEN">0</div></div></div>
                    <div style="font-size:0.7rem;">🎲 点数投注 · 4-17点</div><div class="points-grid">${pointsHtml}</div>
                    <div style="font-size:0.7rem;">🎲 围骰 · 豹子专区</div><div class="trio-grid">${trioHtml}</div>
                    <button id="showDiceHistoryBtn" style="width:100%; background:#3a2a1c; border-radius:60px; padding:10px; margin-top:14px;">📜 开奖记录查询</button>
                </div>
            </div>
        `;
        function buildDiceCube(diceDiv) {
            if (!diceDiv) return;
            diceDiv.innerHTML = '';
            const faces = ['front','back','right','left','top','bottom'];
            const valMap = { front:1, back:6, right:4, left:3, top:2, bottom:5 };
            faces.forEach(face => {
                let num = valMap[face];
                let fd = document.createElement('div');
                fd.className = `dice-face ${face}`;
                let pipHtml = '';
                if (num===1) pipHtml = '<div class="pip pip-center"></div>';
                else if (num===2) pipHtml = '<div class="pip pip-tl"></div><div class="pip pip-br"></div>';
                else if (num===3) pipHtml = '<div class="pip pip-tl"></div><div class="pip pip-center"></div><div class="pip pip-br"></div>';
                else if (num===4) pipHtml = '<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                else if (num===5) pipHtml = '<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-mid"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>';
                else pipHtml = '<div class="pip pip-l1"></div><div class="pip pip-l2"></div><div class="pip pip-l3"></div><div class="pip pip-r1"></div><div class="pip pip-r2"></div><div class="pip pip-r3"></div>';
                fd.innerHTML = pipHtml;
                diceDiv.appendChild(fd);
            });
        }
        const diceEls = [document.getElementById('dice1'), document.getElementById('dice2'), document.getElementById('dice3')];
        diceEls.forEach(d=>buildDiceCube(d));
        function setCubeValue(dice, val) {
            const rot = { 1:'rotateX(0deg)',2:'rotateX(-90deg)',3:'rotateY(90deg)',4:'rotateY(-90deg)',5:'rotateX(90deg)',6:'rotateX(180deg)' };
            dice.style.transform = rot[val];
        }
        let bets = { BIG:0,SMALL:0,ODD:0,EVEN:0,4:0,5:0,6:0,7:0,8:0,9:0,10:0,11:0,12:0,13:0,14:0,15:0,16:0,17:0,TRIPLE_1:0,TRIPLE_2:0,TRIPLE_3:0,TRIPLE_4:0,TRIPLE_5:0,TRIPLE_6:0,ALL_TRIPLE:0 };
        let selectedChip = 0, currentBalance = getUserBalance(), isDrawing = false, isBetLocked = false, countdownInterval = null, rollingAnimation = null, lastBet = null;
        const totalEl = document.getElementById('totalPoints');
        const rollingWinEl = document.getElementById('rollingWinNumber');
        function updateUI() {
            for(let k in bets) { let el = document.getElementById(`bet_${k}`); if(el) el.innerText = bets[k]; }
            document.getElementById('totalBet').innerText = Object.values(bets).reduce((a,b)=>a+b,0);
            document.getElementById('diceBankerDisplay').innerText = systemBankerBalance.toFixed(2);
            document.getElementById("userBalanceDisplay").innerText = getUserBalance().toFixed(2);
        }
        async function startRollingLong(finalVals, duration=5000) {
            return new Promise(resolve => {
                let steps=30, step=0, interval=duration/steps;
                let iv = setInterval(()=>{ diceEls.forEach(d=>setCubeValue(d, Math.floor(Math.random()*6)+1)); step++; if(step>=steps){ clearInterval(iv); diceEls.forEach((d,i)=>setCubeValue(d, finalVals[i])); resolve(); } }, interval);
            });
        }
        function startRollingNumber(finalAmount) {
            if(rollingAnimation) cancelAnimationFrame(rollingAnimation);
            let start=performance.now(), startVal=parseFloat(rollingWinEl.innerText)||0;
            function update(now){ let p=Math.min(1,(now-start)/5000), ease=1-Math.pow(1-p,2), cur=startVal+(finalAmount-startVal)*ease; rollingWinEl.innerText=cur.toFixed(2); if(p<1) rollingAnimation=requestAnimationFrame(update); else { rollingWinEl.innerText=finalAmount.toFixed(2); rollingAnimation=null; } }
            rollingAnimation=requestAnimationFrame(update);
        }
        function getResultInfo(d1,d2,d3){
            let total=d1+d2+d3, types=[];
            if(total>=11 && total<=17) types.push('BIG'); else types.push('SMALL');
            if(total%2===1) types.push('ODD'); else types.push('EVEN');
            if(d1===d2 && d2===d3) { types.push(`TRIPLE_${d1}`); types.push('ALL_TRIPLE'); }
            return {total, types};
        }
        async function addBet(type){
            if(isBetLocked) { showToast("开奖中请等待"); return; }
            if(selectedChip<=0){ showToast("请选择筹码"); return; }
            if(selectedChip > currentBalance){ showToast("余额不足"); return; }
            currentBalance -= selectedChip;
            setUserBalance(currentBalance);
            bets[type] += selectedChip;
            updateUI();
        }
        async function clearAllBets(){
            let total = Object.values(bets).reduce((a,b)=>a+b,0);
            currentBalance += total;
            setUserBalance(currentBalance);
            for(let k in bets) bets[k]=0;
            updateUI();
            showToast("已清空");
        }
        async function repeatLastBet(){
            if(!lastBet || Object.values(lastBet).every(v=>v===0)){ showToast("无续押记录"); return; }
            let need = Object.values(lastBet).reduce((a,b)=>a+b,0);
            if(need > currentBalance){ showToast("余额不足"); return; }
            for(let k in bets) bets[k]=0;
            for(let k in lastBet) bets[k]=lastBet[k];
            currentBalance -= need;
            setUserBalance(currentBalance);
            updateUI();
            if(!isDrawing && !isBetLocked) startAutoDraw();
        }
        let gameRecords = [];
        function addRecord(d1,d2,d3,winAmount,totalBetVal){ gameRecords.unshift({ time:new Date().toLocaleTimeString(), dice:`${d1},${d2},${d3}`, result:winAmount>0?`赢${winAmount}`:`输${totalBetVal}`, win:winAmount }); if(gameRecords.length>50) gameRecords.pop(); }
        async function startAutoDraw(){
            if(isDrawing) return;
            let totalBetVal = Object.values(bets).reduce((a,b)=>a+b,0);
            isDrawing=true; isBetLocked=true;
            let d1=Math.floor(Math.random()*6)+1, d2=Math.floor(Math.random()*6)+1, d3=Math.floor(Math.random()*6)+1;
            let {total, types} = getResultInfo(d1,d2,d3);
            let winAmount=0;
            if(totalBetVal>0){
                if(types.includes('BIG') && bets.BIG) winAmount += bets.BIG*2;
                if(types.includes('SMALL') && bets.SMALL) winAmount += bets.SMALL*2;
                if(types.includes('ODD') && bets.ODD) winAmount += bets.ODD*2;
                if(types.includes('EVEN') && bets.EVEN) winAmount += bets.EVEN*2;
                if(bets[total]) winAmount += bets[total] * oddsMap[total];
                for(let t of types) { if(t.startsWith('TRIPLE_') && bets[t]) winAmount += bets[t]*150; if(t==='ALL_TRIPLE' && bets.ALL_TRIPLE) winAmount += bets.ALL_TRIPLE*30; }
                winAmount = winAmount * adjustFactor;
            }
            startRollingNumber(winAmount);
            await startRollingLong([d1,d2,d3], 5000);
            totalEl.innerText = total;
            if(totalBetVal>0){
                if(winAmount>0) currentBalance += winAmount;
                setUserBalance(currentBalance);
                let netToBanker = (totalBetVal - winAmount) * adjustFactor;
                modifyBanker(netToBanker);
            }
            addRecord(d1,d2,d3,winAmount,totalBetVal);
            for(let k in bets) bets[k]=0;
            lastBet = JSON.parse(JSON.stringify(bets));
            updateUI();
            let pop = document.createElement('div'); pop.className='result-popup '+(winAmount>0?'win':'lose'); pop.textContent=winAmount>0?`🎉 赢 ${winAmount.toFixed(2)} 🎉`:(totalBetVal>0?`😭 输 ${totalBetVal} 😭`:`🎲 点数 ${total} 无人下注`); document.body.appendChild(pop); setTimeout(()=>pop.classList.add('show'),10); setTimeout(()=>{ pop.classList.remove('show'); setTimeout(()=>pop.remove(),300); },2000);
            isDrawing=false; isBetLocked=false;
            startCountdown(25);
        }
        function startCountdown(sec){
            if(countdownInterval) clearInterval(countdownInterval);
            let c=sec, cdSpan=document.getElementById('countdownNum');
            cdSpan.innerText=c; isBetLocked=false;
            countdownInterval = setInterval(()=>{
                if(c<=1){ clearInterval(countdownInterval); countdownInterval=null; isBetLocked=true; startAutoDraw(); }
                else { c--; cdSpan.innerText=c; if(c<=5) cdSpan.classList.add('countdown-warning'); else cdSpan.classList.remove('countdown-warning'); }
            },1000);
        }
        async function refreshBalance(){ currentBalance=getUserBalance(); updateUI(); showToast("余额已刷新"); }
        document.querySelectorAll('.dice-wrapper .chip').forEach(chip=>{ chip.onclick=function(){ selectedChip=parseInt(this.dataset.val); document.getElementById('selectedChip').innerText=selectedChip; document.querySelectorAll('.dice-wrapper .chip').forEach(c=>c.classList.remove('selected')); this.classList.add('selected'); }; });
        document.querySelectorAll('.special-card').forEach(c=>{ c.onclick=()=>addBet(c.dataset.type); });
        document.querySelectorAll('.point-card').forEach(c=>{ c.onclick=()=>addBet(parseInt(c.dataset.point)); });
        document.querySelectorAll('.trio-card').forEach(c=>{ c.onclick=()=>addBet(c.dataset.type); });
        document.getElementById('clearAllBtn').onclick=clearAllBets;
        document.getElementById('repeatBtn').onclick=repeatLastBet;
        document.getElementById('refreshBtn').onclick=refreshBalance;
        document.getElementById('showDiceHistoryBtn').onclick=()=>{
            if(gameRecords.length===0){ showToast("暂无记录"); return; }
            let html='<div style="max-height:350px; overflow-y:auto;">';
            gameRecords.forEach(r=>{ html+=`<div style="margin:6px; padding:6px;">${r.time} 🎲 ${r.dice} ${r.result}</div>`; });
            html+='</div><button id="closeRec" style="background:#d49c3f; margin-top:12px; padding:8px; border-radius:60px;">关闭</button>';
            let m=document.createElement('div'); m.className='modal'; m.innerHTML=`<div class="modal-content">${html}</div>`; document.body.appendChild(m); m.querySelector('#closeRec').onclick=()=>m.remove();
        };
        diceEls.forEach((d,i)=>setCubeValue(d,1));
        totalEl.innerText=3;
        updateUI();
        startCountdown(25);
        diceDestroy = () => { if(countdownInterval) clearInterval(countdownInterval); if(rollingAnimation) cancelAnimationFrame(rollingAnimation); container.innerHTML=''; };
        return diceDestroy;
    }

