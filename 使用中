    function recharge() { showRechargeModal(); }
    function withdraw() { showToast("提现请联系客服微信: game_kf_888"); }

    // ==================== 真实在线人数 ====================
    let onlineInterval = null;
    function startRealOnlineCount() {
        if (onlineInterval) clearInterval(onlineInterval);
        function fetchOnline() {
            const span = document.getElementById('onlineCount');
            if (!span) return;
            fetch('http://127.0.0.1:8090/getOnlineCount')
                .then(res => res.json())
                .then(data => { let count = data?.count ?? data?.online; if (typeof count === 'number' && !isNaN(count)) span.innerText = count; else span.innerText = '--'; })
                .catch(() => { span.innerText = '--'; });
