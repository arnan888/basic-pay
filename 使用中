            if (!isNaN(newAmt) && newAmt >= 0) {
                systemBankerBalance = newAmt;
                localStorage.setItem('neon_system_banker', systemBankerBalance);
                showToast(`骰宝庄家余额已设为 ${newAmt.toFixed(2)} 元`);
                let bankerEl = document.getElementById('diceBankerDisplay');
                if (bankerEl) bankerEl.innerText = systemBankerBalance.toFixed(2);
            } else showToast("无效");
