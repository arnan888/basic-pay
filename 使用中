                localStorage.setItem('fish_player_banker', playerBankerBalance);
                updateFishUI();
                showToast("抢庄成功，不可下注");
            } else showToast("余额不足2001");
        };
        document.getElementById('fishClearBtn').onclick=clearFishBets;
        document.getElementById('fishDoubleBtn').onclick=addDoubleBet;
        document.getElementById('fishRollBtn').onclick=()=>{ if(!isRolling && roundActive) settleFish(); };
        document.getElementById('fishRecordBtn').onclick=()=>{
            if(gameRecords.length===0){ showToast("暂无记录"); return; }
            let html='<div>'; gameRecords.forEach(r=>{ html+=`<div style="margin:6px;">${r.time} 🎲 ${r.dice} ${r.result}</div>`; }); html+='</div><button id="closeRec">关闭</button>';
            let m=document.createElement('div'); m.className='modal'; m.innerHTML=`<div class="modal-content">${html}</div>`; document.body.appendChild(m); m.querySelector('#closeRec').onclick=()=>m.remove();
        };
        document.getElementById('fishRulesBtn').onclick=()=>{ showToast("六门:出现次数赔(次数+1)倍，双押鱼+虾4.5倍，全局系数"+adjustFactor); };
        gridDiv.addEventListener('click',(e)=>{
            let btn=e.target.closest('.btn-chip');
            if(!btn) return;
            let pat=btn.dataset.pat;
            if(btn.classList.contains('add-pat')) addFishBet(pat, currentChip);
            if(btn.classList.contains('sub-pat')) subFishBet(pat, currentChip);
        });
