        setTimeout(() => t.remove(), 2000);
    }
    function updateAllBalance() {
        let balSpan = document.getElementById("userBalanceDisplay");
        if (balSpan) balSpan.innerText = getUserBalance().toFixed(2);
    }
    // 充值：1元 = 1000文
    function recharge() {
        let yuan = prompt("💎 充值金额 (元)\n1元 = 1000文", "10");
        if (!yuan) return;
        let yuanNum = parseFloat(yuan);
        if (isNaN(yuanNum) || yuanNum <= 0) { showToast("请输入正数"); return; }
        let addAmount = yuanNum * 1000;
        setUserBalance(getUserBalance() + addAmount);
        showToast(`充值成功 +${addAmount.toFixed(0)}文`);
        updateAllBalance();
    }
    // 提现：1元 = 1rmb
    function withdraw() {
        let bal = getUserBalance();
        if (bal <= 0) { showToast("余额不足"); return; }
        let wen = prompt("提现金额 \n1rmb = 1元", "1");
        if (!wen) return;
        let wenNum = parseFloat(wen);
        if (isNaN(wenNum) || wenNum <= 0 || wenNum > bal) { showToast("金额无效"); return; }
