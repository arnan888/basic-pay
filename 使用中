        modalDiv.querySelector('#adminChangePwd').onclick = () => {
            let old = prompt("当前管理员密码:");
            if (old !== adminPassword) { showToast("密码错误"); return; }
            let newPwd = prompt("新密码(≥4位):");
            if (newPwd && newPwd.length >= 4) {
                adminPassword = newPwd;
                localStorage.setItem('neon_admin_pwd', newPwd);
                showToast("管理员密码修改成功");
            } else showToast("密码至少4位");
        };
        modalDiv.querySelector('#adminSaveFactor').onclick = () => {
            let newFac = parseFloat(modalDiv.querySelector('#adminAdjustFactor').value);
            if (!isNaN(newFac) && newFac >= 0.2 && newFac <= 3.0) {
                adjustFactor = newFac;
                localStorage.setItem('neon_adjustFactor', adjustFactor);
                showToast(`全局赔付系数已设为 ${adjustFactor}`);
            } else showToast("系数范围 0.2 ~ 3.0");
        };
        modalDiv.querySelector('#adminViewWithdraw').onclick = () => {
            let records = JSON.parse(localStorage.getItem('neon_withdraw')) || [];
            if (records.length === 0) { alert("暂无提现记录"); return; }
            let txt = records.map(r => `${r.phone}  ${r.amount}元 ${r.type} ${r.account} ${r.time}`).join('\n');
            alert("提现记录：\n" + txt);
        };
        modalDiv.querySelector('#adminCloseBtn').onclick = () => modalDiv.remove();
    }

    function addGameRecord(account, gameName, betInfo, result, winAmount, betAmount) {
        if (!usersData[account]) return;
        let rec = usersData[account].records || [];
        rec.unshift({ time: new Date().toLocaleString(), game: gameName, bet: betInfo, result, win: winAmount, amount: betAmount });
        if (rec.length > 100) rec.pop();
        usersData[account].records = rec;
        saveUsers();
    }

    // ==================== 葫芦鱼（鱼虾蟹3D骰子） ====================
    let fishDestroy = null;
    function initFishGame(container) {
        if (fishDestroy) fishDestroy();
        container.innerHTML = `
            <div class="game-card">
                <div style="display:flex; gap:12px; margin-bottom:16px;">
                    <div style="flex:1; background:rgba(0,0,0,0.5); border-radius:24px; padding:8px; text-align:center;"><div>🏦 庄家余额</div><div id="fishBankerDisplay">∞</div></div>
                    <div style="flex:1; background:rgba(0,0,0,0.5); border-radius:24px; padding:8px; text-align:center;"><div>🎲 总押注</div><div id="fishTotalBet">0</div></div>
                    <div style="flex:1; background:rgba(0,0,0,0.5); border-radius:24px; padding:8px; text-align:center;"><div>🏆 上局净利</div><div id="fishLastWin">0</div></div>
                </div>
                <div id="fishChips" style="margin:8px 0;"><span class="chip" data-chip="2">2</span><span class="chip" data-chip="5">5</span><span class="chip selected" data-chip="10">10</span><span class="chip" data-chip="50">50</span><span class="chip" data-chip="100">100</span></div>
                <div style="display:flex; gap:8px; margin:12px 0;">
                    <button id="fishRollBtn" class="exec-btn">${t('fishRoll')}</button>
                    <button id="fishClearBtn" class="exec-btn" style="background:#c23b22;">${t('fishClear')}</button>
                    <button id="fishGrabBtn" class="exec-btn" style="background:#f59e0b;">${t('fishGrab')}</button>
                    <button id="fishDoubleBtn" class="exec-btn" style="background:#f97316;">${t('fishDouble')}</button>
                </div>
                <div class="dice-3d-area"><div class="dice-cube" id="fishDice0"></div><div class="dice-cube" id="fishDice1"></div><div class="dice-cube" id="fishDice2"></div></div>
                <div id="fishPatternGrid" class="fish-pattern-grid"></div>
                <button id="fishRecordBtn" class="exec-btn" style="width:100%; margin-top:8px;">📜 记录</button>
                <div id="fishPhaseHint" style="text-align:center; margin-top:12px; background:rgba(0,0,0,0.5); border-radius:30px; padding:8px;">🎲 下注阶段 · 25秒</div>
            </div>
        `;
        const patternNames = ["鱼","虾","蟹","葫芦","金钱","鸡"];
        const patternEmojis = ["🐟", "🦐", "🦀", "🎃", "💰", "🐔"];
        function buildFishDice(diceDiv) {
            if (!diceDiv) return;
            diceDiv.innerHTML = '';
            const faces = ['front', 'back', 'right', 'left', 'top', 'bottom'];
            const facePatterns = patternEmojis;
            faces.forEach((face, idx) => {
                let fd = document.createElement('div');
                fd.className = `dice-face ${face}`;
                fd.style.background = "#1e1e2a";
                fd.style.display = "flex";
                fd.style.alignItems = "center";
                fd.style.justifyContent = "center";
                fd.style.fontSize = "2.5rem";
                fd.style.fontWeight = "bold";
                fd.style.color = "#00ffff";
                fd.style.textShadow = "0 0 5px cyan";
                fd.innerText = facePatterns[idx];
                diceDiv.appendChild(fd);
            });
            const randX = Math.floor(Math.random() * 360);
            const randY = Math.floor(Math.random() * 360);
            diceDiv.style.transform = `rotateX(${randX}deg) rotateY(${randY}deg)`;
        }
        function setFishDiceValue(diceDiv, patternName) {
            const index = patternNames.indexOf(patternName);
            let rotateX = 0, rotateY = 0;
            switch(index) {
                case 0: rotateX = 0; rotateY = 0; break;
                case 1: rotateX = 0; rotateY = -90; break;
                case 2: rotateX = 0; rotateY = 180; break;
                case 3: rotateX = 0; rotateY = 90; break;
                case 4: rotateX = -90; rotateY = 0; break;
                case 5: rotateX = 90; rotateY = 0; break;
            }
            const extraX = 360 * (1 + Math.floor(Math.random() * 2));
            const extraY = 360 * (1 + Math.floor(Math.random() * 2));
            diceDiv.style.transform = `rotateX(${rotateX + extraX}deg) rotateY(${rotateY + extraY}deg)`;
        }
        const fishDice = [document.getElementById('fishDice0'), document.getElementById('fishDice1'), document.getElementById('fishDice2')];
        fishDice.forEach(d => buildFishDice(d));
        let patternBets = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
        let specialDouble = 0;
        let currentChip = 10;
        let hasGrabbed = false;
        let playerBankerBalance = 0;
        let gameRecords = [];
        let isRolling = false, roundActive = true, countdownTimer = null;
        let lastWinAmount = 0;

        function updateFishUI() {
            for (let p in patternBets) { let span = document.getElementById(`fishBet_${p}`); if(span) span.innerText = patternBets[p]; }
            document.getElementById('fishTotalBet').innerText = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            document.getElementById('fishLastWin').innerText = lastWinAmount;
            let bankerSpan = document.getElementById('fishBankerDisplay');
            if (bankerSpan) bankerSpan.innerText = hasGrabbed ? playerBankerBalance.toFixed(2) : "∞";
        }
        function addFishBet(pattern, val) {
            if (hasGrabbed) { showToast("庄家不能下注"); return; }
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            if (val > 500) { showToast("单注上限500"); return; }
            if (total+val > 2000) { showToast("总注上限2000"); return; }
            if (val > getUserBalance()) { showToast("余额不足"); return; }
            setUserBalance(getUserBalance() - val);
            patternBets[pattern] += val;
            updateFishUI();
        }
        function subFishBet(pattern, val) {
            let cur = patternBets[pattern];
            if (cur < val) val = cur;
            if (val===0) return;
            patternBets[pattern] -= val;
            setUserBalance(getUserBalance() + val);
            updateFishUI();
        }
        function addDoubleBet() {
            if (hasGrabbed) { showToast("庄家不能下注"); return; }
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            if (currentChip > 500) { showToast("双押上限500"); return; }
            if (total+currentChip > 2000) { showToast("总注上限2000"); return; }
            if (currentChip > getUserBalance()) { showToast("余额不足"); return; }
            setUserBalance(getUserBalance() - currentChip);
            specialDouble += currentChip;
            updateFishUI();
        }
        function clearFishBets() {
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            if (total>0) setUserBalance(getUserBalance() + total);
            patternBets = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
            specialDouble = 0;
            updateFishUI();
        }
        async function rollFishDiceWithAnimation(finalPatterns) {
            for (let i=0;i<3;i++) {
                fishDice[i].style.transition = 'none';
                const randX = Math.floor(Math.random() * 360);
                const randY = Math.floor(Math.random() * 360);
                fishDice[i].style.transform = `rotateX(${randX}deg) rotateY(${randY}deg)`;
            }
            await new Promise(r => setTimeout(r, 50));
            for (let i=0;i<3;i++) fishDice[i].style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
            for (let step=0; step<12; step++) {
                for (let i=0;i<3;i++) {
                    const randX = Math.random() * 360;
                    const randY = Math.random() * 360;
                    fishDice[i].style.transform = `rotateX(${randX}deg) rotateY(${randY}deg)`;
                }
                await new Promise(r => setTimeout(r, 80));
            }
            for (let i=0;i<3;i++) setFishDiceValue(fishDice[i], finalPatterns[i]);
            await new Promise(r => setTimeout(r, 400));
        }
        async function settleFish() {
            if (isRolling) return;
            let totalBet = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            if (totalBet === 0) { showToast("请先下注"); return; }
            isRolling = true;
            let r1 = patternNames[Math.floor(Math.random()*6)];
            let r2 = patternNames[Math.floor(Math.random()*6)];
            let r3 = patternNames[Math.floor(Math.random()*6)];
            await rollFishDiceWithAnimation([r1,r2,r3]);
            let winAmount = 0;
            let occurs = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
            [r1,r2,r3].forEach(p=>occurs[p]++);
            for (let p in patternBets) {
                let cnt = occurs[p];
                if (cnt>0 && patternBets[p]>0) winAmount += patternBets[p] * (cnt+1);
            }
            if (specialDouble>0 && occurs["鱼"]>0 && occurs["虾"]>0) winAmount += specialDouble * 4.5;
            winAmount = winAmount * adjustFactor;
            if (totalBet>0) {
                setUserBalance(getUserBalance() + winAmount);
                if (hasGrabbed) {
                    let net = (totalBet - winAmount) * adjustFactor;
                    playerBankerBalance += net;
                    if (playerBankerBalance < 0) { hasGrabbed=false; playerBankerBalance=0; localStorage.removeItem('neon_fish_banker'); showToast("庄家破产"); }
                    else localStorage.setItem('neon_fish_banker', playerBankerBalance);
                    updateFishUI();
                }
                lastWinAmount = winAmount - totalBet;
                addGameRecord(currentUser.account, '葫芦鱼', `押${Object.entries(patternBets).filter(([k,v])=>v>0).map(([k,v])=>`${k}${v}`).join(',')}`, `${r1},${r2},${r3}`, winAmount, totalBet);
            } else lastWinAmount = 0;
            gameRecords.unshift({ time:new Date().toLocaleTimeString(), dice:`${r1},${r2},${r3}`, result:winAmount>0?`赢${winAmount}`:`输${totalBet}` });
            clearFishBets();
            let pop = document.createElement('div'); pop.className='result-popup'; pop.innerText = winAmount>0?`🎉 赢 ${winAmount.toFixed(2)} 🎉`:`😭 输 ${totalBet} 😭`; document.body.appendChild(pop); setTimeout(()=>pop.remove(), 2000);
            isRolling=false;
            if(roundActive) startFishRound();
        }
        function startFishRound() {
            if (countdownTimer) clearInterval(countdownTimer);
            let remaining=25;
            let hintDiv = document.getElementById('fishPhaseHint');
            if(hintDiv) hintDiv.innerText = `🎲 下注阶段 · ${remaining}秒`;
            countdownTimer = setInterval(()=>{
                remaining--;
                if(hintDiv) hintDiv.innerText = `🎲 下注阶段 · ${remaining}秒`;
                if(remaining<=0){
                    clearInterval(countdownTimer);
                    if(!isRolling && roundActive) settleFish();
                }
            },1000);
        }
        let gridDiv = document.getElementById('fishPatternGrid');
        patternNames.forEach(p => {
            let card = document.createElement('div'); card.className = 'fish-bet-card';
            let emoji = patternEmojis[patternNames.indexOf(p)];
            card.innerHTML = `<div style="font-size:1.6rem; margin-bottom:4px;">${emoji}</div><div>${p}</div><div><button class="quick-bet sub-pat" data-pat="${p}">-</button><span id="fishBet_${p}" style="margin:0 12px; font-weight:bold;">0</span><button class="quick-bet add-pat" data-pat="${p}">+</button></div>`;
            gridDiv.appendChild(card);
        });
        document.querySelectorAll('#fishChips .chip').forEach(chip=>{
            chip.onclick=function(){ currentChip=parseInt(this.dataset.chip); document.querySelectorAll('#fishChips .chip').forEach(c=>c.classList.remove('selected')); this.classList.add('selected'); };
        });
        document.getElementById('fishGrabBtn').onclick=()=>{
            if(hasGrabbed){ showToast("已是庄家"); return; }
            if(getUserBalance()>=2001){
                setUserBalance(getUserBalance()-2001);
                playerBankerBalance=2001;
                hasGrabbed=true;
                localStorage.setItem('neon_fish_banker', playerBankerBalance);
                updateFishUI();
                showToast("抢庄成功，不可下注");
            } else showToast("余额不足2001");
        };
        document.getElementById('fishClearBtn').onclick=clearFishBets;
        document.getElementById('fishDoubleBtn').onclick=addDoubleBet;
        document.getElementById('fishRollBtn').onclick=()=>{ if(!isRolling && roundActive) settleFish(); };
        document.getElementById('fishRecordBtn').onclick=()=>{
            if(gameRecords.length===0){ showToast("暂无记录"); return; }
            let html = '<div>' + gameRecords.map(r=>`<div>${r.time} 🎲 ${r.dice} ${r.result}</div>`).join('') + '</div><button id="closeRec" class="auth-btn">关闭</button>';
            let m = document.createElement('div'); m.className='modal'; m.innerHTML = `<div class="modal-content">${html}</div>`;
            document.body.appendChild(m); m.querySelector('#closeRec').onclick=()=>m.remove();
        };
        gridDiv.addEventListener('click',(e)=>{
            let btn = e.target.closest('.quick-bet');
            if(!btn) return;
            let pat = btn.dataset.pat;
            if(btn.classList.contains('add-pat')) addFishBet(pat, currentChip);
            if(btn.classList.contains('sub-pat')) subFishBet(pat, currentChip);
        });
        let saved = localStorage.getItem('neon_fish_banker');
        if(saved && parseInt(saved)>0){ hasGrabbed=true; playerBankerBalance=parseInt(saved); }
        updateFishUI();
        startFishRound();
        fishDestroy = () => { roundActive=false; if(countdownTimer) clearInterval(countdownTimer); container.innerHTML=''; };
        return fishDestroy;
    }

