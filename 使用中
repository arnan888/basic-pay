        modalDiv.querySelector('#adminResetSearch').onclick = () => {
            modalDiv.querySelector('#adminSearchInput').value = '';
            renderUserTable('');
        };
        
        const getTarget = () => modalDiv.querySelector('#adminTargetUser').value;
        const getAmt = () => parseInt(modalDiv.querySelector('#adminAmount').value) || 0;
        
        modalDiv.querySelector('#adminAddBalance').onclick = () => {
            let t = getTarget(), a = getAmt();
            if (a <= 0) { showToast("金额>0"); return; }
            usersData[t].balance += a;
            saveUsers();
            showToast(`${t} +${a}`);
            if (currentUser?.phone === t) setUserBalance(usersData[t].balance);
            modalDiv.remove(); openAdminModal();
        };
        modalDiv.querySelector('#adminSubBalance').onclick = () => {
            let t = getTarget(), a = getAmt();
            if (a <= 0 || usersData[t].balance < a) { showToast("金额无效或余额不足"); return; }
            usersData[t].balance -= a;
            saveUsers();
            showToast(`${t} -${a}`);
            if (currentUser?.phone === t) setUserBalance(usersData[t].balance);
            modalDiv.remove(); openAdminModal();
        };
        modalDiv.querySelector('#adminResetBalance').onclick = () => {
            let t = getTarget();
            if (confirm(`重置 ${t} 余额为1000？`)) {
                usersData[t].balance = 1000;
                saveUsers();
                showToast(`${t} 已重置为1000`);
                if (currentUser?.phone === t) setUserBalance(1000);
                modalDiv.remove(); openAdminModal();
            }
        };
        modalDiv.querySelector('#adminViewWithdraw').onclick = () => {
            let records = JSON.parse(localStorage.getItem('withdraw_records')) || [];
            if (records.length === 0) { alert("暂无提现记录"); return; }
            let txt = records.map(r => `${r.phone}  ${r.amount}文 (${r.yuan}元) ${r.type} ${r.account} ${r.time} ${r.status}`).join('\n');
            alert(txt);
        };
        modalDiv.querySelector('#adminSetBanker').onclick = () => {
            let newAmt = parseFloat(prompt("骰宝庄家新余额:", systemBankerBalance));
            if (!isNaN(newAmt) && newAmt >= 0) {
                systemBankerBalance = newAmt;
                localStorage.setItem('system_banker_balance', systemBankerBalance);
                showToast(`庄家余额已设为 ${newAmt}`);
                updateAllBalance();
            } else showToast("无效");
        };
        modalDiv.querySelector('#adminChangePwd').onclick = () => {
            let old = prompt("当前密码:");
            if (old !== adminPassword) { showToast("密码错误"); return; }
            let newPwd = prompt("新密码(≥4位):");
            if (newPwd && newPwd.length >= 4) { adminPassword = newPwd; localStorage.setItem('admin_pwd', newPwd); showToast("修改成功"); }
            else if (newPwd) showToast("至少4位");
        };
        modalDiv.querySelector('#adminSaveFactor').onclick = () => {
            let newFac = parseFloat(modalDiv.querySelector('#adminAdjustFactor').value);
            if (!isNaN(newFac) && newFac >= 0.2 && newFac <= 3.0) {
                adjustFactor = newFac;
                localStorage.setItem('adjustFactor', adjustFactor);
                showToast(`全局赔付系数已设为 ${adjustFactor}`);
            } else showToast("系数范围0.2~3.0");
        };
        modalDiv.querySelector('#adminCloseBtn').onclick = () => modalDiv.remove();
    }

    // ==================== 辅助：添加游戏记录 ====================
    function addGameRecord(phone, gameName, betInfo, result, winAmount, betAmount) {
        if (!usersData[phone]) usersData[phone] = { balance: 1000, records: [], resultHistory: [] };
        let rec = usersData[phone].records || [];
        rec.unshift({
            time: new Date().toLocaleString(),
            game: gameName,
            bet: betInfo,
            result: result,
            win: winAmount,
            amount: betAmount
        });
        if (rec.length > 100) rec.pop();
        usersData[phone].records = rec;
        saveUsers();
    }

    // ==================== 葫芦鱼（完整版） ====================
    let fishDestroy = null;
    function initFishGame(container) {
        if (fishDestroy) fishDestroy();
        container.innerHTML = `
            <div class="fish-wrapper" style="padding:12px;">
                <div style="background:#1a3a2a; border-radius:32px; padding:12px;">
                    <div style="display:flex; gap:8px; margin-bottom:12px;">
                        <div style="flex:1; background:#0a0a08; border-radius:30px; text-align:center;"><div>🏦 庄家余额</div><div id="fishBankerDisplay">∞</div></div>
                        <div style="flex:1; background:#0a0a08; border-radius:30px; text-align:center;"><div>🎲 总押注</div><div id="fishTotalBet">0</div></div>
                        <div style="flex:1; background:#0a0a08; border-radius:30px; text-align:center;"><div>🏆 上局净利</div><div id="fishLastWin">0</div></div>
                    </div>
                    <div class="fish-chips">
                        <div class="chip" data-chip="2">2</div><div class="chip" data-chip="5">5</div><div class="chip selected" data-chip="10">10</div><div class="chip" data-chip="50">50</div><div class="chip" data-chip="100" id="fishAdminTrigger">100</div>
                    </div>
                    <div style="display:flex; gap:8px; margin-bottom:12px;">
                        <button id="fishRollBtn" style="background:#c47c3a; border-radius:40px; padding:8px;">🎲 开骰</button>
                        <button id="fishClearBtn" style="background:#c23b22; border-radius:40px; padding:8px;">清空</button>
                        <button id="fishGrabBtn" style="background:#e09d32; border-radius:40px; padding:8px;">🎲 抢庄</button>
                        <button id="fishDoubleBtn" style="background:#f39c12; border-radius:40px; padding:8px;">🎯 双押</button>
                    </div>
                    <div class="dice-3d-area">
                        <div class="dice-cube" id="fishDice0"></div>
                        <div class="dice-cube" id="fishDice1"></div>
                        <div class="dice-cube" id="fishDice2"></div>
                    </div>
                    <div id="fishPatternGrid" class="fish-pattern-grid"></div>
                    <button id="fishRecordBtn" style="width:100%; background:#3a2a1c; border-radius:40px; padding:8px; margin-top:8px;">📜 开奖记录查询</button>
                    <div id="fishPhaseHint" style="text-align:center; margin-top:8px; background:#00000066; border-radius:30px; padding:4px;">🎲 下注阶段 · 25秒</div>
                </div>
            </div>
        `;
        const patternNames = ["鱼","虾","蟹","葫芦","金钱","鸡"];
        function buildFishDice(diceDiv, initPattern) {
            if (!diceDiv) return;
            diceDiv.innerHTML = '';
            const faces = ['front','back','right','left','top','bottom'];
            const facePatterns = ["鱼","虾","蟹","葫芦","金钱","鸡"];
            faces.forEach((face, idx) => {
                let fd = document.createElement('div');
                fd.className = `dice-face ${face}`;
                fd.style.background = "#faf0cf";
                fd.style.display = "flex";
                fd.style.alignItems = "center";
                fd.style.justifyContent = "center";
                fd.style.fontSize = "1.8rem";
                fd.style.fontWeight = "bold";
                fd.style.color = "#b97f2e";
                fd.innerText = facePatterns[idx];
                diceDiv.appendChild(fd);
            });
            setFishDiceValue(diceDiv, initPattern);
        }
        function setFishDiceValue(diceDiv, patternName) {
            const rotMap = {
                "鱼": "rotateX(0deg) rotateY(0deg)",
                "虾": "rotateX(0deg) rotateY(-90deg)",
                "蟹": "rotateX(0deg) rotateY(180deg)",
                "葫芦": "rotateX(0deg) rotateY(90deg)",
                "金钱": "rotateX(-90deg) rotateY(0deg)",
                "鸡": "rotateX(90deg) rotateY(0deg)"
            };
            diceDiv.style.transform = rotMap[patternName] || "rotateX(0deg)";
        }
        const fishDice = [document.getElementById('fishDice0'), document.getElementById('fishDice1'), document.getElementById('fishDice2')];
        fishDice.forEach(d => buildFishDice(d, "鱼"));

        let patternBets = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
        let specialDouble = 0;
        let currentChip = 10;
        let hasGrabbed = false;
        let playerBankerBalance = 0;
        let gameRecords = [];
        let isRolling = false, roundActive = true, countdownTimer = null, autoRollTimer = null;
        let lastWinAmount = 0;

        function updateFishUI() {
            for (let p in patternBets) { let span = document.getElementById(`fishBet_${p}`); if(span) span.innerText = patternBets[p]; }
            document.getElementById('fishTotalBet').innerText = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            document.getElementById('fishLastWin').innerText = lastWinAmount;
            let bankerSpan = document.getElementById('fishBankerDisplay');
            if (bankerSpan) bankerSpan.innerText = hasGrabbed ? playerBankerBalance.toFixed(2) : "∞";
        }
        function addFishBet(pattern, val) {
            if (hasGrabbed) { showToast("庄家不能下注"); return; }
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            if (val > 500) { showToast("单注上限500"); return; }
            if (total+val > 2000) { showToast("总注上限2000"); return; }
            if (val > getUserBalance()) { showToast("余额不足"); return; }
            setUserBalance(getUserBalance() - val);
            patternBets[pattern] += val;
            updateFishUI();
        }
        function subFishBet(pattern, val) {
            let cur = patternBets[pattern];
            if (cur < val) val = cur;
            if (val===0) return;
            patternBets[pattern] -= val;
            setUserBalance(getUserBalance() + val);
            updateFishUI();
        }
        function addDoubleBet() {
            if (hasGrabbed) { showToast("庄家不能下注"); return; }
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            if (currentChip > 500) { showToast("双押上限500"); return; }
            if (total+currentChip > 2000) { showToast("总注上限2000"); return; }
            if (currentChip > getUserBalance()) { showToast("余额不足"); return; }
            setUserBalance(getUserBalance() - currentChip);
            specialDouble += currentChip;
            updateFishUI();
        }
        function clearFishBets() {
            let total = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            if (total>0) setUserBalance(getUserBalance() + total);
            patternBets = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
            specialDouble = 0;
            updateFishUI();
        }
        async function rollFishDiceWithAnimation(finalPatterns) {
            for (let i=0;i<3;i++) {
                fishDice[i].style.transition = 'none';
                fishDice[i].style.transform = `rotateX(${Math.random()*360}deg) rotateY(${Math.random()*360}deg)`;
            }
            await new Promise(r=>setTimeout(r, 50));
            for (let i=0;i<3;i++) fishDice[i].style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
            for (let step=0; step<12; step++) {
                for (let i=0;i<3;i++) {
                    let randX = Math.random()*360, randY = Math.random()*360;
                    fishDice[i].style.transform = `rotateX(${randX}deg) rotateY(${randY}deg)`;
                }
                await new Promise(r=>setTimeout(r, 80));
            }
            for (let i=0;i<3;i++) setFishDiceValue(fishDice[i], finalPatterns[i]);
            await new Promise(r=>setTimeout(r, 400));
        }
        async function settleFish() {
            if (isRolling) return;
            let totalBet = Object.values(patternBets).reduce((a,b)=>a+b,0) + specialDouble;
            if (totalBet === 0) { showToast("请先下注"); return; }
            isRolling = true;
            let r1 = patternNames[Math.floor(Math.random()*6)];
            let r2 = patternNames[Math.floor(Math.random()*6)];
            let r3 = patternNames[Math.floor(Math.random()*6)];
            await rollFishDiceWithAnimation([r1,r2,r3]);
            let winAmount = 0;
            let occurs = { 鱼:0,虾:0,蟹:0,葫芦:0,金钱:0,鸡:0 };
            [r1,r2,r3].forEach(p=>occurs[p]++);
            for (let p in patternBets) {
                let cnt = occurs[p];
                if (cnt>0 && patternBets[p]>0) winAmount += patternBets[p] * (cnt+1);
            }
            if (specialDouble>0 && occurs["鱼"]>0 && occurs["虾"]>0) winAmount += specialDouble * 4.5;
            winAmount = winAmount * adjustFactor;
            if (totalBet>0) {
                setUserBalance(getUserBalance() + winAmount);
                if (hasGrabbed) {
                    let net = (totalBet - winAmount) * adjustFactor;
                    playerBankerBalance += net;
                    if (playerBankerBalance < 0) { hasGrabbed=false; playerBankerBalance=0; localStorage.removeItem('fish_player_banker'); showToast("庄家破产"); }
                    else localStorage.setItem('fish_player_banker', playerBankerBalance);
                    updateFishUI();
                }
                lastWinAmount = winAmount - totalBet;
                let betInfo = `押${Object.entries(patternBets).filter(([k,v])=>v>0).map(([k,v])=>`${k}${v}`).join(',')}${specialDouble>0?` 双押${specialDouble}`:''}`;
                addGameRecord(currentUser.phone, '葫芦鱼', betInfo, `${r1},${r2},${r3}`, winAmount, totalBet);
            } else lastWinAmount = 0;
            gameRecords.unshift({ time:new Date().toLocaleTimeString(), dice:`${r1},${r2},${r3}`, result:winAmount>0?`赢${winAmount}`:`输${totalBet}` });
            if (gameRecords.length>50) gameRecords.pop();
            clearFishBets();
            let pop = document.createElement('div'); pop.className='result-popup '+(winAmount>0?'win':'lose'); pop.textContent=winAmount>0?`🎉 赢 ${winAmount.toFixed(2)} 🎉`:`😭 输 ${totalBet} 😭`; document.body.appendChild(pop); setTimeout(()=>pop.classList.add('show'),10); setTimeout(()=>{pop.classList.remove('show'); setTimeout(()=>pop.remove(),300);},2000);
            isRolling=false;
            if(roundActive) startFishRound();
        }
        function startFishRound() {
            if (countdownTimer) clearInterval(countdownTimer);
            let remaining=25;
            let hintDiv = document.getElementById('fishPhaseHint');
            if(hintDiv) hintDiv.innerText = `🎲 下注阶段 · ${remaining}秒`;
            countdownTimer = setInterval(()=>{
                remaining--;
                if(hintDiv) hintDiv.innerText = `🎲 下注阶段 · ${remaining}秒`;
                if(remaining<=0){
                    clearInterval(countdownTimer);
                    if(!isRolling && roundActive) settleFish();
                }
            },1000);
            if(autoRollTimer) clearTimeout(autoRollTimer);
            autoRollTimer = setTimeout(()=>{
                if(countdownTimer) clearInterval(countdownTimer);
                if(!isRolling && roundActive) settleFish();
            },25000);
        }
        let gridDiv = document.getElementById('fishPatternGrid');
        patternNames.forEach(p => {
            let card = document.createElement('div'); card.className = 'fish-bet-card';
            card.innerHTML = `<div class="fish-bet-name">${p}</div><div class="fish-bet-amount"><button class="btn-chip sub-pat" data-pat="${p}">-</button><span id="fishBet_${p}">0</span><button class="btn-chip add-pat" data-pat="${p}">+</button></div>`;
            gridDiv.appendChild(card);
        });
        document.querySelectorAll('.fish-wrapper .chip').forEach(chip=>{
            chip.onclick=function(){ currentChip=parseInt(this.dataset.chip); document.querySelectorAll('.fish-wrapper .chip').forEach(c=>c.classList.remove('selected')); this.classList.add('selected'); };
        });
        document.getElementById('fishGrabBtn').onclick=()=>{
            if(hasGrabbed){ showToast("已是庄家"); return; }
            if(getUserBalance()>=2001){
                setUserBalance(getUserBalance()-2001);
                playerBankerBalance=2001;
                hasGrabbed=true;
                localStorage.setItem('fish_player_banker', playerBankerBalance);
                updateFishUI();
                showToast("抢庄成功，不可下注");
            } else showToast("余额不足2001");
        };
        document.getElementById('fishClearBtn').onclick=clearFishBets;
        document.getElementById('fishDoubleBtn').onclick=addDoubleBet;
        document.getElementById('fishRollBtn').onclick=()=>{ if(!isRolling && roundActive) settleFish(); };
        document.getElementById('fishRecordBtn').onclick=()=>{
            if(gameRecords.length===0){ showToast("暂无记录"); return; }
            let html='<div style="max-height:300px; overflow-y:auto;">'+gameRecords.map(r=>`<div>${r.time} 🎲 ${r.dice} ${r.result}</div>`).join('')+'</div><button id="closeRec">关闭</button>';
            let m=document.createElement('div'); m.className='modal'; m.innerHTML=`<div class="modal-content">${html}</div>`; document.body.appendChild(m); m.querySelector('#closeRec').onclick=()=>m.remove();
        };
        gridDiv.addEventListener('click',(e)=>{
            let btn=e.target.closest('.btn-chip');
            if(!btn) return;
            let pat=btn.dataset.pat;
            if(btn.classList.contains('add-pat')) addFishBet(pat, currentChip);
            if(btn.classList.contains('sub-pat')) subFishBet(pat, currentChip);
        });
        let savedBankerFish = localStorage.getItem('fish_player_banker');
        if(savedBankerFish && parseInt(savedBankerFish)>0){ hasGrabbed=true; playerBankerBalance=parseInt(savedBankerFish); }
        updateFishUI();
        startFishRound();
        fishDestroy = () => { roundActive=false; if(countdownTimer) clearInterval(countdownTimer); if(autoRollTimer) clearTimeout(autoRollTimer); container.innerHTML=''; };
        return fishDestroy;
    }

    // ==================== 至尊骰宝（完整版） ====================
    let diceDestroy = null;
    function initDiceGame(container) {
        if (diceDestroy) diceDestroy();
        container.innerHTML = '';
