            left: -8px;
            font-size: 22px;
            color: #fff;
            text-shadow: 0 0 5px #ff3300;
        }
        .wheel-center {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 48px;
            height: 48px;
            background: radial-gradient(circle, #ffdd88, #cc9900);
            border-radius: 50%;
            z-index: 18;
            box-shadow: 0 0 15px rgba(255,200,0,0.8), inset 0 2px 5px rgba(255,255,255,0.5);
