    // ==================== 葫芦鱼（完整版，带3D骰子动画） ====================
    let fishDestroy = null;
    function initFishGame(container) {
        if (fishDestroy) fishDestroy();
        container.innerHTML = `
            <div class="fish-wrapper" style="padding:12px;">
                <div style="background:#1a3a2a; border-radius:32px; padding:12px;">
