            function saveLastBetState() { lastBetState = { patternBets: { ...patternBets }, doubleBets: { ...doubleBets } }; }
            async function repeatLastBet() {
                if (!lastBetState) return;
                let total = 0;
                for (let p in lastBetState.patternBets) total += lastBetState.patternBets[p];
                for (let k in lastBetState.doubleBets) total += lastBetState.doubleBets[k];
                if (total > currentUser.balance) return;
                let oldTotal = 0;
