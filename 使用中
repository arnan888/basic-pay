            async function settleFish() {
                if (isRolling) return;
                let totalBet = Object.values(patternBets).reduce((a, b) => a + b, 0) + Object.values(doubleBets).reduce(
                    (a, b) => a + b, 0);
                isRolling = true;
                let r1 = patternNames[Math.floor(Math.random() * 6)],
                    r2 = patternNames[Math.floor(Math.random() * 6)],
