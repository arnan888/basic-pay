    function executeDraw() {
        if (state.isDrawing) return;
        state.isDrawing = true;
        isBetLocked = true;
        enableBetButtons(false);
        
        const outcomes = ['龙', '虎', '和'];
        const result = outcomes[Math.floor(Math.random() * 3)];
        
        let totalWin = 0;
        if (result === '龙' && state.bets.DRAGON > 0) totalWin = state.bets.DRAGON * 2;
        if (result === '虎' && state.bets.TIGER > 0) totalWin = state.bets.TIGER * 2;
        if (result === '和' && state.bets.TIE > 0) totalWin = state.bets.TIE * 8;
        
        startRollingNumber(totalWin);
        
        if (wheelSpinCallback) wheelSpinCallback(result);
        
        const newBalance = state.balance + totalWin;
        setBalance(CURRENT_USER_ID, newBalance);
        state.balance = newBalance;
        
        let betTypes = [];
        if (state.bets.DRAGON > 0) betTypes.push(`龙${state.bets.DRAGON}`);
        if (state.bets.TIGER > 0) betTypes.push(`虎${state.bets.TIGER}`);
        if (state.bets.TIE > 0) betTypes.push(`和${state.bets.TIE}`);
        addRecord(CURRENT_USER_ID, betTypes.join(' '), result, totalWin, state.bets.DRAGON + state.bets.TIGER + state.bets.TIE);
        pushResult(CURRENT_USER_ID, result);
        
        highlightWord(result);
        
        const resultMsg = totalWin > 0 ? `${result} +${totalWin}` : result;
        document.getElementById('battleResult').innerHTML = `🎲 ${resultMsg}`;
        
        speak(result);
        if (window.navigator && window.navigator.vibrate) window.navigator.vibrate(100);
        
        setTimeout(() => {
            state.bets = { DRAGON: 0, TIGER: 0, TIE: 0 };
            updateUI();
            state.isDrawing = false;
            startCountdown(25);
        }, 5000);
    }

    function startCountdown(sec) {
        if(state.countdownInterval) clearInterval(state.countdownInterval);
        state.countdown = sec;
        const countdownSpan = document.getElementById('countdownNum');
        countdownSpan.innerText = state.countdown;
        
        isBetLocked = false;
        enableBetButtons(true);
        
        state.countdownInterval = setInterval(() => {
            if(state.countdown <= 1){
                clearInterval(state.countdownInterval);
                state.countdownInterval = null;
                isBetLocked = true;
                enableBetButtons(false);
                executeDraw();
            } else {
                state.countdown--;
