            document.querySelectorAll('.bet-card[data-bet]').forEach(c => { c.onclick = () => addBet(c.dataset.bet); });
            document.getElementById('niuClearBtn').onclick = clearAllBets;
            document.getElementById('niuRepeatBtn').onclick = repeatLastBet;
            document.getElementById('niuRefreshBtn').onclick = refreshBalance;
            document.getElementById('niuRecordBtn').onclick = showRecordModal;
            updateUI();
            startCountdown(25);
            saveLastBet();
            niuNiuDestroy = () => { if (countdownTimer) clearInterval(countdownTimer);
                container.innerHTML = ''; };
            return niuNiuDestroy;
        }

