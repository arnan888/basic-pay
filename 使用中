            let rem = document.getElementById('rememberCheckbox').checked;
            if (!acc || !pwd) { showToast("请填写账号和密码"); return; }
            let user = usersData[acc];
            if (!user || user.password !== pwd) { showToast("账号或密码错误"); return; }
            if (rem) { localStorage.setItem('neon_saved_account', acc); localStorage.setItem('neon_saved_password', pwd); localStorage.setItem('neon_remember_me', 'true'); }
            else { localStorage.removeItem('neon_saved_account'); localStorage.removeItem('neon_saved_password'); localStorage.setItem('neon_remember_me', 'false'); }
