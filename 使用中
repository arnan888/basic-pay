                    <tbody id="adminUserTableBody"></tbody>
                </table>
            </div>
            <div style="display:flex; gap:8px; margin:12px 0;">
                <select id="adminTargetUser" style="background:#1a1a1a; color:#ffdd99; border-radius:20px; padding:4px; flex:1;">
                    ${allUsers.map(u => `<option value="${u.phone}">${u.phone} (${u.balance.toFixed(2)})</option>`).join('')}
                </select>
            </div>
            <div style="display:flex; gap:8px; flex-wrap:wrap; margin:12px 0;">
                <input type="number" id="adminAmount" class="auth-input" placeholder="金额" value="0" style="flex:1;">
                <button id="adminAdd" style="background:#2e7d32; padding:4px 10px; border-radius:30px;">➕ 上分</button>
                <button id="adminSub" style="background:#c0392b; padding:4px 10px; border-radius:30px;">➖ 下分</button>
