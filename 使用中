            transition: all 0.1s;
        }
        .wheel-spin-btn:active {
            transform: translateX(-50%) scale(0.96);
            box-shadow: 0 2px 8px rgba(255,51,0,0.4);
        }
        .wheel-toast {
            position: absolute;
            bottom: -85px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(15px);
            padding: 6px 20px;
            border-radius: 30px;
            color: #ffaa44;
            font-weight: bold;
            font-size: 13px;
            white-space: nowrap;
            z-index: 20;
            opacity: 0;
            transition: 0.2s;
            border: 1px solid rgba(255,170,68,0.5);
            box-shadow: 0 0 15px rgba(255,170,68,0.3);
        }
        .wheel-glow {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,51,0,0.15), transparent 70%);
            pointer-events: none;
            z-index: 12;
            animation: glowPulse 2s ease-in-out infinite;
        }
        @keyframes glowPulse {
            0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
            50% { opacity: 1; transform: translate(-50%, -50%) scale(1.05); }
        }
        
        .dragon-word, .tiger-word {
            position: absolute;
            bottom: 15px;
            font-size: 38px;
            font-weight: 900;
            text-shadow: 0 0 20px currentColor, 2px 2px 0 rgba(0,0,0,0.5);
