        const accountInput = modalDiv.querySelector('#withdrawAccount');
        const confirmBtn = modalDiv.querySelector('#confirmWithdraw');
        const cancelBtn = modalDiv.querySelector('#cancelWithdraw');
        confirmBtn.onclick = () => {
            let amount = parseFloat(amountInput.value);
            let account = accountInput.value.trim();
            let payType = typeSelect.value;
            if (isNaN(amount) || amount <= 0) {
                showToast("请输入有效的提现金额");
                return;
            }
            if (amount > currentBalance) {
                showToast("提现金额不能超过余额");
                return;
