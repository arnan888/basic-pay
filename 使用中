            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
            color: #8b4513;
        }
        .wheel-spin-btn {
            position: absolute;
            bottom: -50px;
            left: 50%;
            transform: translateX(-50%);
