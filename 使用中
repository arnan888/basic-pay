            // 扣减余额
            setUserBalance(currentBalance - amount);
            // 记录提现申请
            let record = {
                phone: currentUser.phone,
                amount: amount,
                type: payType,
                account: account,
                time: new Date().toLocaleString(),
                status: "待处理"
            };
            withdrawRecords.push(record);
