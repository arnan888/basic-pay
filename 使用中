            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: #1a1a1a;
            background-image: radial-gradient(circle at 20% 30%, rgba(200, 140, 70, 0.2) 2%, transparent 3%);
            background-size: 40px 40px;
            font-family: 'Segoe UI', 'PingFang SC', Roboto, sans-serif;
            padding: 12px;
        }

        .app {
            max-width: 550px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* 导航栏 */
        .game-nav {
            background: linear-gradient(135deg, #1a4a1a, #0a2a0a);
            border-radius: 60px;
            padding: 6px;
            display: flex;
            gap: 8px;
            border: 1px solid #ffaa44;
            flex-wrap: wrap;
        }

        .game-tab {
            flex: 1;
            background: transparent;
            border: none;
            padding: 8px 0;
            border-radius: 50px;
            font-weight: bold;
            font-size: 0.85rem;
            color: #ccaa77;
            cursor: pointer;
            transition: 0.2s;
            text-align: center;
        }

        .game-tab.active {
            background: #c47c3a;
            color: #2f1b0a;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.9);
        }

        /* 用户区 */
        .user-section {
            background: #1f1711;
            border-radius: 40px;
            padding: 10px 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .user-info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 6px;
        }

        .user-info-row span {
            color: #ffdd99;
            font-size: 0.85rem;
            font-weight: bold;
        }

        #userBalanceDisplay {
            font-size: 1.5rem;
            font-weight: 900;
            color: #ffcc44;
            background: #0a0705;
            padding: 0 12px;
            border-radius: 50px;
            letter-spacing: 1px;
        }

        .btn-group {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .logout-btn,
        .service-btn {
            background: #734c2e;
            border: none;
            padding: 4px 12px;
            border-radius: 30px;
            color: #ffe3b3;
            font-size: 0.75rem;
            cursor: pointer;
            font-weight: bold;
        }

        .service-btn {
            background: #2e7d32;
        }

        .charge-withdraw-row {
            display: flex;
            gap: 8px;
            justify-content: center;
        }

        .charge-btn,
        .withdraw-btn {
            background: #c47c3a;
            border: none;
            padding: 6px 16px;
            border-radius: 40px;
            color: #2f1b0a;
            font-weight: bold;
            font-size: 0.85rem;
            cursor: pointer;
            flex: 1;
            text-align: center;
            box-shadow: 0 2px 0 #764e26;
        }

        .withdraw-btn {
            background: #734c2e;
            color: #ffe3b3;
            box-shadow: 0 2px 0 #3f2a1a;
        }

        .game-container {
            background: linear-gradient(145deg, #362a1f 0%, #251e16 100%);
            border-radius: 48px;
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.3);
            overflow: hidden;
        }

        /* 登录界面 */
        .auth-panel {
            background: linear-gradient(145deg, #362a1f 0%, #251e16 100%);
            border-radius: 48px;
            padding: 30px 20px;
            text-align: center;
            border: 2px solid #ffaa44;
        }

        .auth-panel h2 {
            color: #ffdd99;
            font-size: 1.6rem;
            margin-bottom: 20px;
        }

        .auth-input {
            width: 100%;
            padding: 12px;
            margin: 8px 0;
            background: #2a241e;
            border: 1px solid #ffaa44;
            border-radius: 60px;
            color: white;
            font-size: 0.9rem;
            text-align: center;
        }

        .auth-buttons {
            display: flex;
            gap: 12px;
            margin: 15px 0;
        }

        .auth-btn {
            flex: 1;
            background: #c47c3a;
            border: none;
            padding: 10px;
            border-radius: 60px;
            color: #2f1b0a;
            font-weight: bold;
            font-size: 0.9rem;
            cursor: pointer;
        }

        .auth-note {
            color: #aa8855;
            font-size: 0.7rem;
        }

        /* 所有功能按键：圆角2px，紧凑 */
        .chip,
        .action-btn,
        .grab-btn,
        .double-bet-btn,
        .record-btn,
        .rules-btn,
        .bg-upload label {
            border-radius: 2px !important;
            border: 1px solid #aa6f30;
            background: #ebbc7e;
            color: #3a240f;
            font-weight: bold;
            font-size: 0.8rem;
            padding: 6px 8px;
            cursor: pointer;
            text-align: center;
            transition: 0.05s linear;
            display: block;
            width: 100%;
            box-shadow: none;
            margin: 0;
        }

        .chip.selected {
            background: #f7c56e;
            border-color: #ffaa44;
            transform: scale(0.98);
        }

        .action-btn {
            background: #c47c3a;
            color: #2f1b0a;
        }

        .grab-btn {
            background: linear-gradient(135deg, #ffaa44, #ff7700);
            color: #2f1b0a;
            font-weight: 900;
        }

        .double-bet-btn {
            background: linear-gradient(135deg, #ffaa44, #ff7700);
            color: #2f1b0a;
        }

        .record-btn,
        .rules-btn,
        .bg-upload label {
            background: #2a1f16;
            color: #ffdd99;
            border-color: #ffaa44;
            text-align: center;
        }

        .bg-upload {
            margin-top: 8px;
