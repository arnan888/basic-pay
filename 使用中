    // 5秒滚动数字动画
    let rollingAnimationId = null;
    function startRollingNumber(finalAmount) {
        const rollingDiv = document.getElementById('rollingWinNumber');
        if (!rollingDiv) return;
        if (rollingAnimationId) cancelAnimationFrame(rollingAnimationId);
        
        const duration = 5000;
        const startTime = performance.now();
        const startValue = 0.01;
        
        rollingDiv.classList.add('rolling-animation');
        
        function updateRolling(now) {
            const elapsed = now - startTime;
            const progress = Math.min(1, elapsed / duration);
            const easeOut = 1 - Math.pow(1 - progress, 2);
            let currentValue = startValue + (finalAmount - startValue) * easeOut;
            
            if (progress >= 1) {
                rollingDiv.classList.remove('rolling-animation');
                rollingDiv.innerText = finalAmount.toFixed(2);
                rollingAnimationId = null;
            } else {
                rollingDiv.innerText = currentValue.toFixed(2);
                rollingAnimationId = requestAnimationFrame(updateRolling);
            }
        }
        
        rollingAnimationId = requestAnimationFrame(updateRolling);
    }

    function syncBalance() { state.balance = getBalance(CURRENT_USER_ID); updateUI(); }
    
