        function renderUserTable(searchKeyword = '') {
            let filtered = searchKeyword ? allUsers.filter(u => u.phone.includes(searchKeyword)) : allUsers;
            let tbody = modalDiv.querySelector('#adminUserTableBody');
            if (!tbody) return;
            tbody.innerHTML = filtered.map(u => `
                <tr>
                    <td>${u.phone}</td>
                    <td>💰 ${u.balance.toFixed(2)}</td>
                    <td>${u.regTime}</td>
                    <td><button class="viewUserRecordBtn" data-phone="${u.phone}" style="background:#d49c3f; border:none; border-radius:30px; padding:4px 8px;">📜 记录</button></td>
