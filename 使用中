        .stat-card span:last-child { font-size: 22px; font-weight: bold; color: #ffaa44; }
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); display: flex; align-items: center; justify-content: center; z-index: 1000; }
        .modal-content { background: #1e1e2e; width: 85%; max-width: 340px; border-radius: 20px; padding: 20px; text-align: center; color: white; }
        .modal-content button { background: #ffaa44; border: none; border-radius: 8px; padding: 8px 20px; margin-top: 12px; cursor: pointer; }
        .btn-highlight { animation: btnFlash 0.1s ease-out; }
        @keyframes btnFlash { 0% { transform: scale(1); } 50% { transform: scale(0.92); } 100% { transform: scale(1); } }
    </style>
</head>
<body>
<div class="container-outer">
    <div class="container">
        <!-- 战斗场景 -->
        <div class="battle-scene" id="battleScene">
