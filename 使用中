    function addBetAmount(type, amount) {
        if(state.isDrawing || isBetLocked) {
            showModal("开奖中，请等待...", "知道了");
            return;
        }
        let newVal = state.bets[type] + amount;
        if (newVal > state.balance) {
            showModal("余额不足！", "知道了");
            return;
        }
        state.bets[type] = newVal;
        updateUI();
        flashButton(document.querySelector(`.quick-bet[data-type="${type}"][data-amount="${amount}"]`));
    }

    function clearBet(type) {
        if(state.isDrawing || isBetLocked) return;
        let amount = state.bets[type];
        if (amount > 0) {
            state.balance += amount;
            setBalance(CURRENT_USER_ID, state.balance);
        }
        state.bets[type] = 0;
        updateUI();
        flashButton(document.querySelector(`.clear-bet[data-type="${type}"]`));
    }

    function executeBet() {
        if(state.isDrawing || isBetLocked) {
            showModal("开奖中，请等待...", "知道了");
            return;
        }
        let totalBet = state.bets.DRAGON + state.bets.TIGER + state.bets.TIE;
        if (totalBet === 0) {
            showModal("请先下注", "知道了");
            return;
        }
        if (totalBet > state.balance) {
            showModal("余额不足", "知道了");
            return;
        }
        lastBet = { ...state.bets };
        state.balance -= totalBet;
        setBalance(CURRENT_USER_ID, state.balance);
        updateUI();
        clearCountdown();
        executeDraw();
    }

    function repeatLastBet() {
        if(state.isDrawing || isBetLocked) {
            showModal("开奖中，请等待...", "知道了");
            return;
        }
        if(lastBet) {
            let total = (lastBet.DRAGON||0) + (lastBet.TIGER||0) + (lastBet.TIE||0);
            if (total > state.balance) {
                showModal("余额不足", "知道了");
                return;
            }
            state.bets = { ...lastBet };
            state.balance -= total;
            setBalance(CURRENT_USER_ID, state.balance);
            updateUI();
            flashButton(document.getElementById('repeatBtn'));
        }
    }
    
    function cancelAllBets() {
        if(state.isDrawing || isBetLocked) return;
