        // ----- C11：初始化入口（恢复背景、绑定事件、启动倒计时等）-----
        async function init() {
            await restoreBackground();
            bindEvents();
            syncBalance();
            startPoolFluctuation();
            setSpeed(1);
            updateUI();
            startCountdown(getCountdownSec());

// ========== 转盘代码开始 ==========
            const wheelCanvas = document.getElementById('wheelCanvas');
            if (wheelCanvas) {
                const ctx = wheelCanvas.getContext('2d');
                const spinBtn = document.getElementById('spinWheelBtn');
                const wheelToast = document.getElementById('wheelToast');
                const SEGMENTS = 15;
                const SEG_ANGLE = (Math.PI * 2) / SEGMENTS;
                let currentRotation = 0;
                let isSpinning = false;
                const prizes = Array.from({length: SEGMENTS}, (_, i) => (i+1).toString());
                
                function drawWheel(rotation) {
                    const size = 400;
                    wheelCanvas.width = size;
                    wheelCanvas.height = size;
                    const centerX = size/2, centerY = size/2;
                    const radius = size/2 - 2;
                    
                    const colorList = [
                        '#ff3333', '#ff3333', '#3333ff', '#3333ff',
                        '#ffff33', '#ffff33', '#33ff33', '#33ff33',
                        '#33ffff', '#33ffff', '#ff9933', '#ff9933',
                        '#cc33ff', '#cc33ff'
                    ];
                    const textList = [
                        '龍', '虎', '龍', '虎', '龍', '虎',
                        '龍', '虎', '龍', '虎', '龍', '虎',
                        '龍', '虎', '王'
                    ];
                    
                    for (let i = 0; i < SEGMENTS; i++) {
                        const start = i * SEG_ANGLE + rotation;
                        const end = (i+1) * SEG_ANGLE + rotation;
                        ctx.beginPath();
                        ctx.moveTo(centerX, centerY);
                        ctx.arc(centerX, centerY, radius, start, end);
                        
                        if (i === 14) {
                            const grad = ctx.createLinearGradient(centerX - radius, centerY - radius, centerX + radius, centerY + radius);
                            grad.addColorStop(0, '#ff0000');
                            grad.addColorStop(0.16, '#ff6600');
                            grad.addColorStop(0.33, '#ffff00');
                            grad.addColorStop(0.5, '#00ff00');
                            grad.addColorStop(0.66, '#00ffff');
                            grad.addColorStop(0.83, '#0000ff');
                            grad.addColorStop(1, '#ff00ff');
                            ctx.fillStyle = grad;
                        } else {
                            ctx.fillStyle = colorList[i];
                        }
                        ctx.fill();
                        
                        ctx.shadowBlur = 12;
                        ctx.shadowColor = ctx.fillStyle;
// --- 替换原有的 ctx.save() 到 ctx.restore() 之间的文字绘制部分 ---
ctx.save();
ctx.translate(centerX, centerY);
ctx.rotate(start + SEG_ANGLE / 2);
ctx.textAlign = "center";
ctx.textBaseline = "middle";

// 1. 设置基础属性
let targetColor, shadowIntensity, fontSize;
if (textList[i] === '龍') {
    targetColor = '#ff3300';
    shadowIntensity = 12; // 增加发光强度
    fontSize = "bold 32px";
} else if (textList[i] === '虎') {
    targetColor = '#005a32';
    shadowIntensity = 12;
    fontSize = "bold 32px";
} else {
    targetColor = '#ffcc44';
    shadowIntensity = 15;
    fontSize = "bold 28px";
}

ctx.font = `${fontSize} 'PingFang SC'`;
ctx.fillStyle = targetColor;

// 2. 核心优化：多重阴影叠加强化发光度（不改变颜色，只调发光）
// 第一层：环境光渲染
ctx.shadowColor = targetColor;
ctx.shadowBlur = shadowIntensity;
ctx.fillText(textList[i], radius * 0.65, 0); // 纵坐标微调为0更居中

// 第二层：核心高亮渲染 (再次叠加让字体中心更实，更明亮)
ctx.shadowBlur = 4; 
ctx.globalAlpha = 0.8; // 调节透明度，让光晕更有层次
ctx.fillText(textList[i], radius * 0.65, 0);

// 3. 恢复状态
ctx.restore();
                    }                                        ctx.beginPath();                    ctx.arc(centerX, centerY, 22, 0, 2*Math.PI);                    ctx.fillStyle = "#ffaa44";                    ctx.shadowBlur = 15;                    ctx.shadowColor = "#ffaa44";
                    ctx.fill();                    ctx.shadowBlur = 0;
                    ctx.font = "bold 22px 'PingFang SC'";                    ctx.fillStyle = "#1a1a2a";                    ctx.textAlign = "center";                    ctx.textBaseline = "middle";                    ctx.fillText("转", centerX, centerY);
                }
                
                function spinWheel() {
                    if (isSpinning) return;
                    isSpinning = true;
                    const spinAngle = Math.random() * 2 * Math.PI + 10 * Math.PI;
                    const duration = 2000;
                    const startTime = performance.now();
                    const startRotation = currentRotation;
                    function animateSpin(now) {
                        const elapsed = now - startTime;
                        let t = Math.min(1, elapsed / duration);
                        const easeOut = 1 - Math.pow(1 - t, 3);                        currentRotation = startRotation + spinAngle * easeOut;                        drawWheel(currentRotation);
                        if (t < 1) {
                            requestAnimationFrame(animateSpin);
                        } else {
                            const finalRotation = currentRotation % (Math.PI * 2);
                            let pointerAngle = -Math.PI / 2;
                            let angleDiff = (pointerAngle - finalRotation + 2 * Math.PI) % (2 * Math.PI);
                            let idx = Math.floor(angleDiff / SEG_ANGLE) % SEGMENTS;                            const prize = prizes[idx];                            wheelToast.innerText = `🎉 转盘结果：${prize} 区 🎉`;                            wheelToast.style.opacity = '1';                            setTimeout(() => { wheelToast.style.opacity = '0'; }, 2000);
                            isSpinning = false;
                        }
                    }
                    requestAnimationFrame(animateSpin);
                }
                
                if (spinBtn) spinBtn.addEventListener('click', spinWheel);
                drawWheel(currentRotation);
            }
            // ========== 转盘代码结束 ==========                        refreshRecordDisplay();            updateHistoryGrid();
            if (!localStorage.getItem('visited_before')) {
                localStorage.setItem('visited_before', 'true');
                setTimeout(() => {
