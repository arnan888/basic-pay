            height: 280px;
            z-index: 15;
        }
        .wheel-outer-ring {
            position: absolute;
            top: -8px;
            left: -8px;
            right: -8px;
            bottom: -8px;
            border-radius: 50%;
            background: linear-gradient(145deg, #c9a03d, #8b6914);
            z-index: 14;
            box-shadow: 0 0 0 2px rgba(255,215,0,0.3), 0 10px 25px rgba(0,0,0,0.5);
        }
        .wheel-outer-ring::before {
            content: '';
            position: absolute;
            top: 2px;
            left: 2px;
            right: 2px;
            bottom: 2px;
            border-radius: 50%;
            background: linear-gradient(145deg, #ffdd77, #b8860b);
        }
        .wheel-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border-radius: 50%;
            z-index: 15;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.3);
        }
        .wheel-pointer {
            position: absolute;
            top: -32px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 20px solid transparent;
            border-right: 20px solid transparent;
            border-top: 48px solid #ffcc44;
            filter: drop-shadow(0 6px 10px rgba(0,0,0,0.4));
            z-index: 20;
        }
        .wheel-pointer::before {
            content: '';
