        }
        .dragon-word { left: 15px; color: #ff4444; text-shadow: 0 0 20px #ff0000; }
        .tiger-word { right: 15px; color: #4488ff; text-shadow: 0 0 20px #0088ff; }
        .highlight-win {
            transform: scale(1.2);
            text-shadow: 0 0 35px currentColor, 0 0 15px white;
        }
        .battle-result {
            position: absolute;
            top: 15px;
            left: 50%;
            transform: translateX(-50%);
