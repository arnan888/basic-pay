
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>龙虎斗 · 稳定版</title>
    <style>
        /* ============================================= */
        /* 板块1：全局样式与重置 */
        /* 功能：清除默认边距、盒模型、禁用选中、全局背景和字体 */
        /* ============================================= */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }
        body {
            background: #ff3300,005a32,ff3300.,005a32,ff3300,005a32,ff3300,005a32,ff3300;
            min-height: 80vh;
vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: "PingFang SC", "Microsoft YaHei", "Helvetica Neue", sans-serif;
            padding: 12px;
        }

        /* ============================================= */
        /* 板块2：主容器大边框板块 */
        /* 功能：最外层大边框（container-outer）和内层主容器（container）的样式 */
        /* ============================================= */
        .container-outer {
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
            background: linear-gradient(145deg, #2a2a3a, #1e1e2e);
            border-radius: 16px;
            padding: 8px;
            box-shadow: 8px 8px 16px rgba(0,0,0,0.5), -4px -4px 8px rgba(255,255,255,0.1);
        }
        .container {
            background: #2d2d3d;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: inset 2px 2px 4px rgba(0,0,0,0.5), inset -2px -2px 4px rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
        }

        /* ============================================= */
        /* 板块3：战斗场景/显示屏板块 */
        /* 功能：顶部对战场地，包含背景、龙虎文字、结果弹窗和动画 */
        /* ============================================= */
        .battle-scene {
            position: relative;
            margin: 16px;
            border-radius: 12px;
            overflow: hidden;
            background: #0a0a0a;
            height: 40vh;
            flex-shrink: 0;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.6), 10px 10px 20px rgba(0,0,0,0.4), -4px -4px 8px rgba(255,255,255,0.05);
        }
        .scene-bg {
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, #2a2a2a, #111);
            background-size: cover;
            background-position: center;
            z-index: 1;
        }
        .scene-bg video {
            width: 80%;
            height: 80%;
            object-fit: cover;
        }
        .dragon-word, .tiger-word {
            position: absolute;
            bottom: 20px;
            font-size: 56px;
            font-weight: 900;
            text-shadow: 6px 6px 0 rgba(0,0,0,0.6), 0 0 25px currentColor;
            z-index: 10;
            transition: all 0.15s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            opacity: 0.95;
        }
        .dragon-word { left: 20px; color: #ff5555; text-shadow: 0 0 15px red, 4px 4px 0 darkred; }
        .tiger-word { right: 20px; color: #55aaff; text-shadow: 0 0 15px blue, 4px 4px 0 darkblue; }
        .highlight-win {
            transform: scale(1.3);
            text-shadow: 0 0 40px currentColor, 8px 8px 0 rgba(0,0,0,0.5);
            opacity: 1;
        }
        .battle-result {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(8px);
            padding: 8px 24px;
            border-radius: 30px;
            color: #9900ff;
            font-weight: bold;
            font-size: 18px;
            z-index: 20;
            white-space: nowrap;
            border: 1px solid #ff3300;
            box-shadow: 0 0 20px rgba(255,170,68,0.8);
            transition: all 0.1s ease;
            pointer-events: none;
        }
        .battle-result.pop {
            transform: translateX(-50%) scale(1.1);
            background: rgba(255,170,68,0.9);
            color: #1a1a2a;
        }
        .flash-gold {
            animation: goldFlash 0.3s ease-out;
        }
        @keyframes goldFlash {
            0% { box-shadow: 0 0 0 0 rgba(255,215,0,0); background-color: transparent; }
            30% { box-shadow: 0 0 0 8px rgba(255,215,0,0.6); background-color: rgba(255,215,0,0.2); }
            100% { box-shadow: 0 0 0 0 rgba(255,215,0,0); background-color: transparent; }
        }

        /* ============================================= */
        /* 板块4：押注操作区（整体） */
        /* 功能：包含账户栏、三个押注项、数据显示、计时器、历史记录和操作按钮等 */
        /* ============================================= */
        .bet-section {
            background: #005a32;
            margin: 16px;
            border-radius: 12px;
            padding: 20px;
            box-shadow: inset 4px 4px 8px rgba(0,0,0,0.5), inset -2px -2px 4px rgba(255,255,255,0.05), 8px 8px 16px rgba(0,0,0,0.3);
            max-height: calc(100vh - 280px);
            overflow-y: auto;
            flex-shrink: 1;
        }

        /* 板块4.1：账户栏和按钮 */
        .account-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #005a32;
            border-radius: 12px;
            padding: 8px 16px;
            margin-bottom: 20px;
            box-shadow: inset 2px 2px 5px rgba(0,0,0,0.5), inset -2px -2px 5px rgba(255,255,255,0.05), 4px 4px 8px rgba(0,0,0,0.3);
        }
        .account-info {
            font-size: 14px;
            color: #ff3300;
        }
        .account-info span {
            color: #ff3300;
            font-weight: bold;
        }
        .btn-group {
            display: flex;
            gap: 8px;
        }
        .btn-sm {
            background: #005a32;
            border: none;
            border-radius: 8px;
            padding: 6px 16px;
            color: ff3300;
            font-size: 12px;
            cursor: pointer;
            box-shadow: 3px 3px 6px rgba(0,0,0,0.4), -1px -1px 2px rgba(255,255,255,0.1);
            transition: 0.05s linear;
        }
        .btn-sm:active {
            transform: translateY(2px);
            box-shadow: inset 2px 2px 4px rgba(0,0,0,0.5);
        }

        /* 板块4.2：三个押注卡片（龙、和、虎）共用样式 */
        .multi-bet-row {
            display: flex;
            gap: 48px;
            margin-bottom: 60px;
            flex-wrap: wrap;
        }
        .multi-bet-item {
            flex: 1;
            min-width: 120px;
            background: #005a32;
            border-radius: 12px;
            padding: 24px 16px;
            text-align: center;
            box-shadow: 8px 8px 16px rgba(0,0,0,0.4), -4px -4px 8px rgba(255,255,255,0.05), inset 0 1px 0 rgba(255,255,255,0.1);
            transition: all 0.05s;
        }
        .multi-bet-item.selected {
            background: #ff3300;
            color: #005a32;
            transform: scale(0.98);
        }
        .multi-bet-name {
            font-size: 26px;
            font-weight: bold;
            margin-bottom: 8px;
        }
        .multi-bet-name.dragon { color: #ff3300; }
        .multi-bet-name.tiger { color: #005a32; }
        .multi-bet-name.tie { color: #0000ff; }
        .multi-bet-item.selected .multi-bet-name { color: #1a1a2a; }

        .bet-amount-wrapper {
            background: rgba(0,0,0,0.5);
            margin: 8px 0;
            padding: 10px 4px;
            border-radius: 8px;
            border: 1px solid rgba(255,170,68,0.3);
        }
        .bet-label-text {
            font-size: 11px;
            color: #ff3300;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }
        .multi-bet-amount {
            font-size: 32px;
            font-weight: 900;
            color: #ff3300;
            line-height: 1.2;
            text-shadow: 0 0 5px rgba(0,0,0,0.5);
        }
        .multi-bet-item.selected .multi-bet-amount {
            color: #1a1a2a;
            text-shadow: none;
        }

        .multi-bet-control {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin: 10px 0 8px;
        }
        .multi-bet-control button {
            background: #1e1e2e;
            border: none;
            border-radius: 8px;
            padding: 6px 12px;
            color: #ffaa44;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 3px 3px 6px rgba(0,0,0,0.5), -1px -1px 2px rgba(255,255,255,0.05);
            transition: 0.05s;
        }
        .multi-bet-control button:active {
            transform: translateY(2px);
            box-shadow: inset 2px 2px 4px rgba(0,0,0,0.5);
        }
        .quick-bet-row {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 8px;
            flex-wrap: wrap;
        }
        .quick-bet {
            background: #1e1e2e;
            border: none;
            border-radius: 8px;
            padding: 4px 12px;
            color: #ffaa44;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 2px 2px 4px rgba(0,0,0,0.5);
            transition: 0.05s linear;
        }
        .quick-bet:active {
            transform: translateY(2px);
            box-shadow: inset 1px 1px 2px rgba(0,0,0,0.5);
        }

        /* 板块4.3：数据展示区（总押注、预计奖金） */
        .data-stack {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin: 16px 0;
        }
        .data-item {
            background: #005a32;
            border-radius: 12px;
            padding: 12px;
            text-align: center;
            box-shadow: inset 2px 2px 5px rgba(0,0,0,0.5), inset -2px -2px 5px rgba(255,255,255,0.05), 6px 6px 12px rgba(0,0,0,0.3);
        }
        .data-item label {
            font-size: 13px;
            color: #ff3300;
        }
        .data-item value {
            font-size: 28px;
            font-weight: bold;
            color: #ff3300;
            display: block;
        }
        .stake-txt {
            text-align: center;
            font-size: 13px;
            background: #005a32;
            display: inline-block;
            width: auto;
            margin: 0 auto 10px;
            padding: 5px 12px;
            border-radius: 20px;
            color: #ffaa88;
        }

        /* 板块4.4：计时器与速度选择 */
        .timer-text {
            text-align: center;
            font-size: 18px;
            color: #ffaa44;
            margin: 12px 0;
            font-weight: bold;
        }
        .speed-select {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin: 12px 0;
        }
        .speed-btn {
            background: #ff3300;
            border: none;
            border-radius: 20px;
            padding: 6px 24px;
            color: #aaa;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 3px 3px 6px rgba(0,0,0,0.4), -1px -1px 2px rgba(255,255,255,0.05);
        }
        .speed-btn.active {
            background: #ff3300;
            color: #005a32;
        }

        /* 板块4.5：历史记录区域 */
        .history-area {
            background: #005a32;
            border-radius: 12px;
            padding: 16px;
            margin: 16px 0;
            box-shadow: inset 2px 2px 5px rgba(0,0,0,0.5), inset -2px -2px 5px rgba(255,255,255,0.05);
        }
        .history-title {
            font-size: 13px;
            color: #ff3300;
            text-align: center;
            margin-bottom: 12px;
        }
        .history-grid {
            display: grid;
            grid-template-columns: repeat(10, 32px);
            gap: 6px;
            justify-content: center;
            margin-bottom: 16px;
        }
        .history-cell {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: bold;
            background: #005a32;
            box-shadow: inset 1px 1px 2px rgba(0,0,0,0.5), inset -1px -1px 2px rgba(255,255,255,0.05);
        }
        .history-cell.dragon { background: #ff3300; color: white; box-shadow: 0 0 8px red; }
        .history-cell.tiger { background: #005a32; color: white; box-shadow: 0 0 8px blue; }
        .history-cell.tie { background: #00aaff,#007bff,add8e6; color: white; box-shadow: 0 0 8px purple; }
        .record-list {
            max-height: 120px;
            overflow-y: auto;
            font-size: 12px;
        }
        .record-item {
            display: flex;
            justify-content: space-between;
            padding: 6px 12px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            color: #ddd;
        }
        .record-win { color: #4caf50; font-weight: bold; }
        .record-lose { color: #f44336; font-weight: bold; }

        /* 板块4.6：底部操作按钮组（刷新、续押、取消、投注） */
        .exec-row {
            display: flex;
            gap: 16px;
            margin-top: 16px;
            margin-bottom: 16px;
        }
        .exec-btn {
            flex: 1;
            padding: 14px;
            border-radius: 12px;
            font-weight: bold;
            text-align: center;
            cursor: pointer;
            background: #005a32;
            color: #ffffff;
            border: none;
            box-shadow: 6px 6px 12px rgba(0,0,0,0.4), -2px -2px 4px rgba(255,255,255,0.05);
            transition: 0.05s;
        }
        .exec-btn:active {
            transform: translateY(3px);
            box-shadow: inset 2px 2px 4px rgba(0,0,0,0.5);
        }
        .main-go {
            background: linear-gradient(145deg, #e53935, #b71c1c);
            color: white;
        }
        .my-history-btn {
            background: #005a32;
        }

        /* 板块4.7：余额与彩金池显示 */
        .bottom-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-top: 16px;
            margin-bottom: 8px;
        }
        .stat-card {
            background: #005a32;
            border-radius: 12px;
            padding: 12px 8px;
            text-align: center;
            box-shadow: 6px 6px 12px rgba(0,0,0,0.4), -4px -4px 8px rgba(255,255,255,0.05), inset 0 1px 0 rgba(255,255,255,0.1);
        }
        .stat-card span:first-child {
            display: block;
            font-size: 12px;
            color: #ff3300;
            letter-spacing: 1px;
        }
        .stat-card span:last-child {
            font-size: 26px;
            font-weight: bold;
            color: #ff3300;
            text-shadow: 0 0 8px rgba(255,200,0,0.6);
        }

        /* ============================================= */
        /* 板块5：通用组件与弹窗样式 */
        /* 功能：隐藏文件输入框、模态框、动画等全局辅助样式 */
        /* ============================================= */
        #hiddenFileInput {
            position: absolute;
            opacity: 0;
            pointer-events: none;
            width: 0;
            height: 0;
        }
        .modal {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal-content {
            background: #2a2a3a;
            width: 85%;
            max-width: 360px;
            border-radius: 16px;
            padding: 24px;
            text-align: center;
            color: white;
            box-shadow: 12px 12px 24px rgba(0,0,0,0.6), -6px -6px 12px rgba(255,255,255,0.05);
        }
        .modal-content button {
            background: #ffaa44;
            border: none;
            border-radius: 8px;
            padding: 10px 24px;
            margin-top: 16px;
            font-weight: bold;
            cursor: pointer;
        }
        button, .btn-sm, .exec-btn, .speed-btn, .multi-bet-control button, .quick-bet {
            pointer-events: auto !important;
        }
/* 转盘样式 */
.wheel-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 300px;
    border-radius: 50%;
    z-index: 15;
    cursor: pointer;
    box-shadow: 0 0 0 3px #ffaa44, 0 0 0 6px rgba(0,0,0,0.5);
}
.wheel-canvas {
    width: 100%;
    height: 100%;
    border-radius: 50%;
}
.wheel-pointer {
    position: absolute;
    top: -18px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-top: 26px solid #ffcc44;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
    z-index: 16;
}
.spin-btn {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    background: #ffaa44;
    border: none;
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: bold;
    color: #1a1a2a;
    cursor: pointer;
    z-index: 17;
    box-shadow: 0 2px 6px black;
}
.spin-btn:active {
    transform: translateX(-50%) scale(0.96);
}
.wheel-result-toast {
    position: absolute;
    bottom: 45px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(8px);
    padding: 4px 12px;
    border-radius: 20px;
    color: #ffaa44;
    font-weight: bold;
    font-size: 12px;
    white-space: nowrap;
    z-index: 18;
    pointer-events: none;
    opacity: 0;
    transition: 0.2s;
}  
    </style>
</head>
<body>
<div class="container-outer">
    <div class="container">
        <!-- ============================================= -->
        <!-- 板块A：战斗场景/显示屏 HTML结构 -->
        <!-- ============================================= -->
        <div
<div class="battle-scene" id="battleScene">
    <div class="scene-bg" id="sceneBg"></div>
    <div class="dragon-word" id="dragonWord">龍</div>
    <div class="tiger-word" id="tigerWord">虎</div>
    <div class="battle-result" id="battleResult"></div>
    
    <!-- 转盘模块 -->
    <div class="wheel-container" id="wheelContainer">
        <canvas id="wheelCanvas" class="wheel-canvas" width="400" height="400"></canvas>
        <div class="wheel-pointer"></div>
        <button class="spin-btn" id="spinWheelBtn">🎡 转盘开奖</button>
        <div class="wheel-result-toast" id="wheelToast">✨</div>
    </div>
</div>
        <!-- =  <=============== -->
        <!-- 板块B：押注操作区 HTML结构 -->
        <!-- ============================================= -->
        <div class="bet-section">
            <!-- 子板块B1：账户栏 -->
            <div class="account-bar">
                <div class="account-info">👤 账户：<span id="currentUserId">登录Log in </span></div>
                <div class="btn-group">
                    <button id="myHistoryBtn" class="btn-sm my-history-btn">📜 我的记录</button>
                    <button id="newUserBtn" class="btn-sm">✨ 新用户</button>
                </div>
            </div>
            <!-- 子板块B2：用户切换栏 -->
            <div class="account-bar" style="margin-top: 8px;">
                <div class="account-switch" style="display: flex; gap: 8px; width:100%;">
                    <input type="text" id="switchUserIdInput" placeholder="登录用户ID" style="flex:2; background:#1e1e2e; border:1px solid #ffaa44; border-radius:8px; padding:8px 16px; color:white;">
                    <button id="switchUserBtn" class="btn-sm">登录</button>
                </div>
            </div>
            
            <!-- 子板块B3：龙押注卡片 -->
            <div class="multi-bet-item" data-type="DRAGON">
                <div class="multi-bet-name dragon">🐉 龙</div>
                <div class="bet-amount-wrapper">
                    <div class="bet-label-text">💰 单向押注额</div>
                    <div class="multi-bet-amount" id="betDragonAmount">0 TRX</div>
                </div>
                <div class="multi-bet-control">
                    <button class="clear-bet" data-type="DRAGON">🧹 清空</button>
                </div>
                <div class="quick-bet-row">
                    <button class="quick-bet" data-type="DRAGON" data-amount="10">+10</button>
                    <button class="quick-bet" data-type="DRAGON" data-amount="20">+20</button>
                    <button class="quick-bet" data-type="DRAGON" data-amount="50">+50</button>
                    <button class="quick-bet" data-type="DRAGON" data-amount="100">+100</button>
                     <button class="quick-bet" data-type="DRAGON" data-amount="500">+500</button>
                     <button class="quick-bet" data-type="DRAGON" data-amount="1000">+1000</button>
                </div>
            </div>
            
            <!-- 子板块B4：和押注卡片 -->
            <div class="multi-bet-item" data-type="TIE">
                <div class="multi-bet-name tie">⚖️ 和</div>
                <div class="bet-amount-wrapper">
                    <div class="bet-label-text">💰 单向押注额</div>
                    <div class="multi-bet-amount" id="betTieAmount">0 rmb</div>
                </div>
                <div class="multi-bet-control">
                    <button class="clear-bet" data-type="TIE">🧹 清空</button>
                </div>
                <div class="quick-bet-row">
                    <button class="quick-bet" data-type="TIE" data-amount="10">+10</button>
                    <button class="quick-bet" data-type="TIE" data-amount="20">+20</button>
                    <button class="quick-bet" data-type="TIE" data-amount="50">+50</button>
                    <button class="quick-bet" data-type="TIE" data-amount="100">+100</button>
                     <button class="quick-bet" data-type="TIE" data-amount="500">+500</button>
                     <button class="quick-bet" data-type="TIE" data-amount="1000">+1000</button>
              </div>
            </div>
            
            <!-- 子板块B5：虎押注卡片 -->
            <div class="multi-bet-item" data-type="TIGER">
                <div class="multi-bet-name tiger">🐯 虎</div>
                <div class="bet-amount-wrapper">
                    <div class="bet-label-text">💰 单向押注额</div>
                    <div class="multi-bet-amount" id="betTigerAmount">0 TRX</div>
                </div>
                <div class="multi-bet-control">
                    <button class="clear-bet" data-type="TIGER">🧹 清空</button>
                </div>
                <div class="quick-bet-row">
                    <button class="quick-bet" data-type="TIGER" data-amount="10">+10</button>
                    <button class="quick-bet" data-type="TIGER" data-amount="20">+20</button>
                    <button class="quick-bet" data-type="TIGER" data-amount="50">+50</button>
                    <button class="quick-bet" data-type="TIGER" data-amount="100">+100</button>
                     <button class="quick-bet" data-type="TIGER" data-amount="500">+500</button>
                     <button class="quick-bet" data-type="TIGER" data-amount="1000">+1000</button>
                </div>
            </div>
            
            <!-- 子板块B6：数据展示（总押注/预计奖金） -->
            <div class="data-stack">
                <div class="data-item"><label>📊 总押注</label><value id="totalBetAmount">0.00</value></div>
                <div class="data-item"><label>🏆 预计奖金</label><value id="valWin">0.00</value></div>
            </div>
            <div class="stake-txt">⚡ 单注步长：<span id="stepValue">10</span> rmb</div>
            
            <!-- 子板块B7：计时器与速度选择 -->
            <div class="timer-text">⏱️ 下一局: <span id="countdownNum">30</span> 秒</div>
            <div class="speed-select">
                <span class="speed-btn active" data-speed="1">1X</span>
                <span class="speed-btn" data-speed="2">2X</span>
                <span class="speed-btn" data-speed="3">3X</span>
            </div>
            
            <!-- 子板块B8：历史记录（开奖格子+详细列表） -->
            <div class="history-area">
                <div class="history-title">📈 最近20局开奖</div>
                <div class="history-grid" id="historyGrid"></div>
                <div class="history-title">📋 开奖记录</div>
                <div class="record-list" id="recordList"></div>
            </div>
            
            <!-- 子板块B9：底部操作按钮组 -->
            <div class="exec-row">
                <button class="exec-btn" id="refreshBtn">🔄 刷新</button>
                <button class="exec-btn" id="repeatBtn">🔁 续押</button>
                <button class="exec-btn" id="cancelBtn">❌ 全部取消</button>
                <button class="exec-btn main-go" id="fightBtn">🎲 确认投注</button>
            </div>
            
            <!-- 子板块B10：余额与彩金池 -->
            <div class="bottom-stats">
                <div class="stat-card"><span>💰 余额</span><span id="balanceDisplay">0.00</span></div>
                <div class="stat-card"><span>😁彩金池</span><span id="poolDisplay">50000.00</span></div>
            </div>
        </div>
    </div>
</div>

<script>
    // =============================================
    // 板块C：JavaScript 核心逻辑
    // 包含：数据存储、用户管理、押注逻辑、动画、后台管理、事件绑定等
    // =============================================
    (function(){
        // ----- C1：语音播报功能 -----
        let speechEnabled = false;
        function enableSpeech() {
            if (!speechEnabled) {
                speechEnabled = true;
            }
        }
        document.body.addEventListener('click', enableSpeech, { once: true });
        function speak(text) {
            if (speechEnabled && window.speechSynthesis) {
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'zh-CN';
                utterance.rate = 1.2;
                speechSynthesis.cancel();
                speechSynthesis.speak(utterance);
            }
        }

        // ----- C2：用户数据存储与全局变量 -----
        let users = JSON.parse(localStorage.getItem('dragon_tiger_users')) || {};
        let CURRENT_USER_ID = "wang8888";
        if (!users[CURRENT_USER_ID]) {
            users[CURRENT_USER_ID] = { balance: 0.00, records: [], resultHistory: [] };
            localStorage.setItem('dragon_tiger_users', JSON.stringify(users));
        }
        let ADMIN_PASSWORD = localStorage.getItem('dragon_tiger_password') || "wang000000";
        
        function saveUsers() { localStorage.setItem('dragon_tiger_users', JSON.stringify(users)); }
        function getBalance(uid) { if (!users[uid]) users[uid] = { balance: 0.00, records: [], resultHistory: [] }; return users[uid].balance; }
        function setBalance(uid, amt) { if (!users[uid]) users[uid] = { balance: 0.00, records: [], resultHistory: [] }; users[uid].balance = amt; saveUsers(); }
        function addBalance(uid, delta) { setBalance(uid, getBalance(uid) + delta); }
        function getUserList() { return Object.keys(users); }
        function generateRandomId() { return "user_" + Math.floor(Math.random() * 1000000); }

        // ----- C3：弹窗与记录显示 -----
        function showModal(msg, btnText) {
            const modal = document.createElement('div');
            modal.className = 'modal';
            modal.innerHTML = `<div class="modal-content"><h3>📢 提示</h3><p>${msg}</p><button id="modalCloseBtn">${btnText}</button></div>`;
            document.body.appendChild(modal);
            document.getElementById('modalCloseBtn').onclick = () => modal.remove();
        }

        function showMyHistory() {
            const recs = users[CURRENT_USER_ID]?.records || [];
            let html = `<div style="max-height:300px; overflow-y:auto; text-align:left;">`;
            if (recs.length === 0) html += "<p>暂无记录</p>";
            else {
                recs.slice(0, 30).forEach(r => {
                    const isWin = r.win > 0;
                    html += `<div style="padding:6px; border-bottom:1px solid #555; display:flex; justify-content:space-between;">
                                <span>${r.time}</span>
                                <span>押 ${r.bet} → ${r.result}</span>
                                <span style="color:${isWin?'#4caf50':'#f44336'}">${isWin ? `+${r.win}` : `-${r.amount}`}</span>
                             </div>`;
                });
            }
            html += `</div><button id="closeHistoryBtn" style="margin-top:12px;">关闭</button>`;
            const modal = document.createElement('div');
            modal.className = 'modal';
            modal.innerHTML = `<div class="modal-content"><h3>📜 我的历史记录</h3>${html}</div>`;
            document.body.appendChild(modal);
            document.getElementById('closeHistoryBtn').onclick = () => modal.remove();
        }
        document.getElementById('myHistoryBtn').onclick = showMyHistory;
        document.getElementById('newUserBtn').onclick = () => {
            const newId = generateRandomId();
            document.getElementById('switchUserIdInput').value = newId;
            switchUser();
            showModal(`✅ 新账户：${newId}\n初始余额：0.00 rmb`, "开始游戏");
        };

        // ----- C4：开奖结果历史（前10局格子）-----
        function getResultHistory(uid) { return users[uid]?.resultHistory || []; }
        function pushResult(uid, res) {
            if (!users[uid]) users[uid] = { balance: 0.00, records: [], resultHistory: [] };
            let arr = users[uid].resultHistory || [];
            arr.unshift(res);
            if (arr.length > 10) arr.pop();
            users[uid].resultHistory = arr;
            saveUsers();
            if (uid === CURRENT_USER_ID) updateHistoryGrid();
        }
        
        function updateHistoryGrid() {
            const grid = document.getElementById('historyGrid');
            if (!grid) return;
            const hist = getResultHistory(CURRENT_USER_ID);
            grid.innerHTML = '';
            for (let i = 0; i < 10; i++) {
                const cell = document.createElement('div');
                cell.className = 'history-cell';
                if (i < hist.length) {
                    const r = hist[i];
                    cell.classList.add(r === '龙' ? 'dragon' : (r === '虎' ? 'tiger' : 'tie'));
                    cell.textContent = r === '龙' ? '🐉' : (r === '虎' ? '🐯' : '⚖️');
                } else {
                    cell.textContent = '?';
                }
                grid.appendChild(cell);
            }
        }
        // ----- C5：个人投注记录（详细列表）-----
        function addRecord(uid, betType, result, win, betAmt) {
            if (!users[uid]) users[uid] = { balance: 0.00, records: [], resultHistory: [] };
            let recs = users[uid].records || [];
            recs.unshift({ time: new Date().toLocaleTimeString(), bet: betType, result: result, win: win, amount: betAmt });
            if (recs.length > 50) recs.pop();
            users[uid].records = recs;
            saveUsers();
            if (uid === CURRENT_USER_ID) refreshRecordDisplay();
        }

        function refreshRecordDisplay() {
            const container = document.getElementById('recordList');
            if (!container) return;
            const recs = users[CURRENT_USER_ID]?.records || [];
            container.innerHTML = '';
            if (recs.length === 0) { container.innerHTML = '<div style="text-align:center; color:#aaa;">暂无记录</div>'; return; }
            recs.slice(0, 10).forEach(r => {
                const div = document.createElement('div');
                div.className = 'record-item';
                const isWin = r.win > 0;
                div.innerHTML = `<span>${r.time}</span><span>押 ${r.bet} → ${r.result}</span><span class="${isWin ? 'record-win' : 'record-lose'}">${isWin ? `+${r.win}` : `-${r.amount}`}</span>`;
                container.appendChild(div);
            });
        }

        // ----- C6：开奖动画与特效（大弹窗、闪光、语音）-----
        let isAnimating = false;
        function showResultAnimation(result, winAmount, betAmount, callback) {
            if (isAnimating) return;
            isAnimating = true;
            const btns = document.querySelectorAll('.quick-bet, .clear-bet, #fightBtn, #repeatBtn, #cancelBtn, .speed-btn, #switchUserBtn, #newUserBtn, #refreshBtn');
            btns.forEach(btn => btn.disabled = true);

            const overlay = document.createElement('div');
            overlay.style.position = 'fixed';
            overlay.style.left = '0';
            overlay.style.width = '100%';
            overlay.style.height = '100%';
            overlay.style.backgroundColor = 'rgba(0,0,0,0.85)';
            overlay.style.backdropFilter = 'blur(8px)';
            overlay.style.display = 'flex';
            overlay.style.alignItems = 'center';
            overlay.style.justifyContent = 'center';
            overlay.style.zIndex = '10000';
            overlay.style.flexDirection = 'column';

            const box = document.createElement('div');
            box.style.background = '#2a2a3a';
            box.style.padding = '40px 60px';
            box.style.textAlign = 'center';
            box.style.boxShadow = '0 0 50px rgba(255,215,0,0.8)';
            box.style.borderRadius = '20px';

            const icon = document.createElement('div');
            icon.style.fontSize = '100px';
            icon.style.marginBottom = '20px';
            icon.style.animation = 'roll 0.6s ease-out';
            if (result === '龙') icon.textContent = '🐉';
            else if (result === '虎') icon.textContent = '🐯';
            else icon.textContent = '⚖️';
            icon.style.color = result === '龙' ? '#ff5555' : (result === '虎' ? '#55aaff' : '#bb77ff');

            const resultText = document.createElement('div');
            resultText.style.fontSize = '48px';
            resultText.style.fontWeight = 'bold';
            resultText.style.color = '#ffaa44';
            resultText.style.marginTop = '20px';
            resultText.textContent = result;

            const info = document.createElement('div');
            info.style.marginTop = '16px';
            info.style.fontSize = '28px';
            info.style.fontWeight = 'bold';
            info.style.color = winAmount > 0 ? '#ffaa44' : '#ff8888';
            info.textContent = winAmount > 0 ? `🎉 恭喜中奖 +${winAmount} rmb` : '😞 未中奖';
            box.appendChild(icon);
            box.appendChild(resultText);
            box.appendChild(info);
            overlay.appendChild(box);

            const style = document.createElement('style');
            style.textContent = `@keyframes roll { 0% { transform: rotate(0deg); } 50% { transform: rotate(360deg); } 100% { transform: rotate(720deg); } }`;
            document.head.appendChild(style);

            document.body.appendChild(overlay);
            speak(result);

            setTimeout(() => {
                overlay.remove();
                style.remove();
                isAnimating = false;
                btns.forEach(btn => btn.disabled = false);
                if (callback) callback();
            }, 2000);
        }

        function flashAndPop(result) {
            const scene = document.getElementById('battleScene');
            const resultDiv = document.getElementById('battleResult');
            scene.classList.add('flash-gold');
            setTimeout(() => scene.classList.remove('flash-gold'), 300);
            resultDiv.classList.add('pop');
            setTimeout(() => resultDiv.classList.remove('pop'), 200);
            const dragon = document.getElementById('dragonWord');
            const tiger = document.getElementById('tigerWord');
            dragon.style.transform = 'scale(1.1)';
            tiger.style.transform = 'scale(1.1)';
            setTimeout(() => { dragon.style.transform = ''; tiger.style.transform = ''; }, 200);
        }

        function highlightWord(result) {
            const dragon = document.getElementById('dragonWord');
            const tiger = document.getElementById('tigerWord');
            dragon.classList.remove('highlight-win');
            tiger.classList.remove('highlight-win');
            if (result === '龙') {
                dragon.classList.add('highlight-win');
                setTimeout(() => dragon.classList.remove('highlight-win'), 800);
            } else if (result === '虎') {
                tiger.classList.add('highlight-win');
                setTimeout(() => tiger.classList.remove('highlight-win'), 800);
            } else if (result === '和') {
                dragon.classList.add('highlight-win');
                tiger.classList.add('highlight-win');
                setTimeout(() => {
                    dragon.classList.remove('highlight-win');
                    tiger.classList.remove('highlight-win');
                }, 800);
            }
        }

        // ----- C7：背景媒体上传与 IndexedDB 存储（支持图片/视频）-----
        const DB_NAME = "DragonTigerMedia";
        const STORE_NAME = "media";
        let db = null;
        function openDB() {
            return new Promise((resolve, reject) => {
                const req = indexedDB.open(DB_NAME, 1);
                req.onupgradeneeded = (e) => { const dbRef = e.target.result; if (!dbRef.objectStoreNames.contains(STORE_NAME)) dbRef.createObjectStore(STORE_NAME); };
                req.onsuccess = (e) => { db = e.target.result; resolve(db); };
                req.onerror = (e) => reject(e);
            });
        }
        async function saveMedia(key, blob, mimeType) {
            if (!db) await openDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(STORE_NAME, "readwrite");
                const store = tx.objectStore(STORE_NAME);
                store.put({ blob, mimeType }, key);
                tx.oncomplete = () => resolve();
                tx.onerror = (e) => reject(e);
            });
        }
        async function loadMedia(key) {
            if (!db) await openDB();
            return new Promise((resolve) => {
                const tx = db.transaction(STORE_NAME, "readonly");
                const store = tx.objectStore(STORE_NAME);
                const req = store.get(key);
                req.onsuccess = () => resolve(req.result || null);
                req.onerror = () => resolve(null);
            });
        }
        function applyBackground(blob, mimeType) {
            const bgDiv = document.getElementById('sceneBg');
            bgDiv.innerHTML = '';
            bgDiv.style.backgroundImage = 'none';
            if (!blob) return;
            const url = URL.createObjectURL(blob);
            if (mimeType.startsWith('video/')) {
                const video = document.createElement('video');
                video.src = url;
                video.autoplay = true;
                video.loop = true;
                video.muted = true;
                video.playsInline = true;
                video.style.width = '100%';
                video.style.height = '100%';
                video.style.objectFit = 'cover';
                bgDiv.appendChild(video);
                video.play().catch(e=>console.log);
            } else {
                bgDiv.style.backgroundImage = `url(${url})`;
                bgDiv.style.backgroundSize = 'cover';
                bgDiv.style.backgroundPosition = 'center';
                const reader = new FileReader();
                reader.onload = e => { try { localStorage.setItem('savedBgImage', e.target.result); } catch(err) {} };
                reader.readAsDataURL(blob);
            }
        }
        async function restoreBackground() {
            const savedImg = localStorage.getItem('savedBgImage');
            if (savedImg && savedImg.startsWith('data:image')) {
                const bgDiv = document.getElementById('sceneBg');
                bgDiv.innerHTML = '';
                bgDiv.style.backgroundImage = `url(${savedImg})`;
                bgDiv.style.backgroundSize = 'cover';
                bgDiv.style.backgroundPosition = 'center';
            }
            try { const bg = await loadMedia('background'); if (bg && bg.blob) applyBackground(bg.blob, bg.mimeType); } catch(e) { console.log(e); }
        }
        async function uploadBackground(file) { if (!file) return; await saveMedia('background', file, file.type); applyBackground(file, file.type); }

        // ----- C8：游戏状态、押注核心逻辑与倒计时 -----
        let state = {
            balance: getBalance(CURRENT_USER_ID),
            bets: { DRAGON: 0, TIGER: 0, TIE: 0 },
            betRolling: false,
            autoMode: true,
            speed: 1,
            pool: 50000,
            countdown: 30,
            countdownInterval: null
        };
        let lastBet = null;

        function getCountdownSec() { return state.speed===1?30:(state.speed===2?20:10); }
        function syncBalance() { state.balance = getBalance(CURRENT_USER_ID); updateUI(); }

        function placeBet(type, amount) {
            if (state.betRolling || isAnimating || amount<=0 || amount>state.balance) return false;
            state.betRolling = true;
            const outcomes = ['龙', '虎', '和'];
            const result = outcomes[Math.floor(Math.random() * 3)];
            let win = 0;
            if (type === result) win = amount * (result === '和' ? 8 : 2);
            const newBalance = state.balance - amount + win;
            setBalance(CURRENT_USER_ID, newBalance);
            state.balance = newBalance;
            updateUI();
            addRecord(CURRENT_USER_ID, type, result, win, amount);
            pushResult(CURRENT_USER_ID, result);
            flashAndPop(result);
            highlightWord(result);
            const resultMsg = win > 0 ? '🎲 开奖: ' + result + '  ✅ 中奖 +' + win + ' rmb' : '🎲 开奖: ' + result + '  ❌ 未中奖';
            document.getElementById('battleResult').innerText = resultMsg;
            showResultAnimation(result, win, amount, () => {
                if (state.autoMode) {
                    clearCountdown();
                    startCountdown(getCountdownSec());
                }
            });
            state.betRolling = false;
            return true;
        }

        function executeBet() {
            if (state.betRolling || isAnimating) return;
            let selectedType = null, selectedAmount = 0;
            if (state.bets.DRAGON > selectedAmount) { selectedType = "DRAGON"; selectedAmount = state.bets.DRAGON; }
            if (state.bets.TIGER > selectedAmount) { selectedType = "TIGER"; selectedAmount = state.bets.TIGER; }
            if (state.bets.TIE > selectedAmount) { selectedType = "TIE"; selectedAmount = state.bets.TIE; }
            if (!selectedType) return;
            const betType = { DRAGON:"龙", TIGER:"虎", TIE:"和" }[selectedType];
            lastBet = { type: betType, amount: selectedAmount };
            clearCountdown();
            placeBet(betType, selectedAmount);
            state.bets = { DRAGON: 0, TIGER: 0, TIE: 0 };
            updateUI();
        }

        function repeatLastBet() { if(lastBet && !state.betRolling && !isAnimating) placeBet(lastBet.type, lastBet.amount); }
        function cancelAllBets() { if(!state.betRolling && !isAnimating){ state.bets = { DRAGON:0, TIGER:0, TIE:0 }; updateUI(); } }

        function updateUI() {
            document.getElementById('balanceDisplay').innerText = state.balance.toFixed(2);
            document.getElementById('poolDisplay').innerText = state.pool.toFixed(2);
            document.getElementById('betDragonAmount').innerHTML = state.bets.DRAGON + " rmb";
            document.getElementById('betTigerAmount').innerHTML = state.bets.TIGER + " rmb";
            document.getElementById('betTieAmount').innerHTML = state.bets.TIE + " rmb";
            const total = state.bets.DRAGON + state.bets.TIGER + state.bets.TIE;
            document.getElementById('totalBetAmount').innerText = total.toFixed(2);
            let maxWin = 0;
            if (state.bets.DRAGON > 0) maxWin = Math.max(maxWin, state.bets.DRAGON * 1.95);
            if (state.bets.TIGER > 0) maxWin = Math.max(maxWin, state.bets.TIGER * 1.95);
            if (state.bets.TIE > 0) maxWin = Math.max(maxWin, state.bets.TIE * 8);
            document.getElementById('valWin').innerText = maxWin.toFixed(2);
            document.querySelectorAll('.multi-bet-item').forEach(el => { const type = el.dataset.type; if (state.bets[type] > 0) el.classList.add('selected'); else el.classList.remove('selected'); });
        }

        function addBetAmount(type, amount) {
            if(state.betRolling || isAnimating) return;
            let newVal = state.bets[type] + amount;
            if (newVal > state.balance) {
                if (window.navigator && window.navigator.vibrate) window.navigator.vibrate(200);
                showModal("❌ 余额不足！当前余额：" + state.balance.toFixed(2) + " rmb", "知道了");
                return;
            }
            if(newVal < 0) newVal = 0;
            state.bets[type] = newVal;
            updateUI();
        }

        function clearBet(type) {
            if(state.betRolling || isAnimating) return;
            state.bets[type] = 0;
            updateUI();
            if (window.navigator && window.navigator.vibrate) window.navigator.vibrate(50);
        }

        function startPoolFluctuation() { 
            setInterval(() => { 
                let change = Math.floor(Math.random()*61)-30; 
                let newPool = state.pool+change; 
                if(newPool<10000) newPool=10000; 
                if(newPool>100000) newPool=100000; 
                state.pool=newPool; 
                document.getElementById('poolDisplay').innerText=state.pool.toFixed(2); 
            }, 1000); 
        }

        function startCountdown(sec) {
            if(state.countdownInterval) clearInterval(state.countdownInterval);
            state.countdown = sec;
            document.getElementById('countdownNum').innerText = state.countdown;
            state.countdownInterval = setInterval(() => {
                if(state.countdown <= 1){
                    clearInterval(state.countdownInterval);
                    state.countdownInterval = null;
                    if(state.bets.DRAGON+state.bets.TIGER+state.bets.TIE > 0) executeBet();
                    else startCountdown(getCountdownSec());
                } else {
                    state.countdown--;
                    document.getElementById('countdownNum').innerText = state.countdown;
                }
            }, 1000);
        }

        function clearCountdown() { if(state.countdownInterval){ clearInterval(state.countdownInterval); state.countdownInterval=null; } }
        function refreshBalance() { syncBalance(); }

        function setSpeed(speed) {
            if(isAnimating) return;
            state.speed = speed;
            document.querySelectorAll('.speed-btn').forEach(btn => { if(parseInt(btn.dataset.speed)===speed) btn.classList.add('active'); else btn.classList.remove('active'); });
            clearCountdown(); startCountdown(getCountdownSec());
        }

        function switchUser() {
            if(isAnimating) return;
            const newId = document.getElementById('switchUserIdInput').value.trim();
            if(!newId) return;
            CURRENT_USER_ID = newId;
            if (!users[CURRENT_USER_ID]) { users[CURRENT_USER_ID] = { balance: 0.00, records: [], resultHistory: [] }; saveUsers(); }
            document.getElementById('currentUserId').innerText = CURRENT_USER_ID;
            state.bets = { DRAGON:0, TIGER:0, TIE:0 };
            lastBet = null;
            syncBalance(); updateUI(); clearCountdown(); startCountdown(getCountdownSec());
            refreshRecordDisplay();
            updateHistoryGrid();
        }

        // ----- C9：管理员面板（上分/下分/重置/改密）与长按菜单-----
        let adminPanel = null;
        let selectedAdminUserId = CURRENT_USER_ID;
        function showAdminPanel() {
            if (adminPanel) { adminPanel.remove(); adminPanel = null; return; }
            const panel = document.createElement('div');
            panel.className = 'modal';
            panel.innerHTML = '<div class="modal-content" style="width:90%; max-width:360px;">' +
                '<h3>🔐 管理员面板</h3>' +
