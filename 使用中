                btn.onclick = () => {
                    let phone = btn.dataset.phone;
                    showUserGameRecords(phone);
                };
            });
        }
        renderUserTable();
        
        function showUserGameRecords(phone) {
            let user = usersData[phone];
            if (!user) { showToast("用户不存在"); return; }
            let records = user.records || [];
            if (records.length === 0) {
                showToast(`${phone} 暂无游戏记录`);
                return;
            }
            let html = `<div style="max-height:400px; overflow-y:auto;"><h3>📜 ${phone} 的游戏记录</h3>`;
            records.slice(0, 100).forEach(rec => {
                let gameName = rec.game || (rec.bet ? (rec.bet.includes('鱼') || rec.bet.includes('虾') ? '葫芦鱼' : '龙虎斗') : '骰宝');
                let winColor = rec.win > 0 ? '#4caf50' : '#f44336';
                html += `<div class="record-item-detail">
                            <div>🕒 ${rec.time}</div>
                            <div>🎮 ${gameName}</div>
                            <div>📌 下注: ${rec.bet || rec.betType || '未知'} | 开奖: ${rec.result || '?'}</div>
                            <div>💰 下注金额: ${rec.amount || 0} | <span style="color:${winColor}">输赢: ${rec.win > 0 ? `+${rec.win}` : `-${rec.amount || 0}`}</span></div>
                         </div>`;
            });
            html += `<button id="closeRecordModal" style="margin-top:12px; background:#d49c3f; border-radius:40px; padding:6px; width:100%;">关闭</button></div>`;
            let recModal = document.createElement('div'); recModal.className = 'modal';
            recModal.innerHTML = `<div class="modal-content">${html}</div>`;
            document.body.appendChild(recModal);
            recModal.querySelector('#closeRecordModal').onclick = () => recModal.remove();
