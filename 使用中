            usersData[newId] = { balance: 0, password: "123456", records: [], resultHistory: [], registerTime: new Date().toLocaleString() };
            saveUsers();
            showToast(`新账号 ${newId} 创建成功，密码123456`);
            document.getElementById('switchUserIdInputDT').value = newId;
            switchUserDT();
        }
        function switchUserDT() {
            let newId = document.getElementById('switchUserIdInputDT').value.trim();
            if (!newId) return;
            if (!usersData[newId]) { showToast("账号不存在"); return; }
            currentUser = { account: newId, ...usersData[newId] };
            document.getElementById('currentUserId').innerText = newId;
            document.getElementById("userBalanceDisplay").innerText = getUserBalance().toFixed(2);
            updateUIDT(); updateHistoryDisplayDT(); updateRecordDisplayDT();
            clearCountdownDT(); startCountdownDT(getCountdownSec());
            showToast(`已切换到 ${newId}`);
