                    </div>
                    <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px;">
                        <div class="fish-chips" style="display:flex; gap:8px; flex-wrap:wrap;">
                            <div class="chip" data-chip="2">2</div><div class="chip" data-chip="5">5</div><div class="chip selected" data-chip="10">10</div><div class="chip" data-chip="50">50</div><div class="chip" data-chip="100" id="fishAdminTrigger">100</div>
                        </div>
