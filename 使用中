    // ========== 高端转盘绘制 ==========
    const wheelCanvas = document.getElementById('wheelCanvas');
    if (wheelCanvas) {
        const size = 500;
        wheelCanvas.width = size;
        wheelCanvas.height = size;
        wheelCanvas.style.width = '100%';
        wheelCanvas.style.height = '100%';
        
        const ctx = wheelCanvas.getContext('2d');
        const centerX = size / 2;
        const centerY = size / 2;
        const radius = size / 2 - 15;
        const PI = Math.PI;
        const TAU = PI * 2;
        
        const SEGMENTS = [
            { name: '龙', color: '#dc2626', color2: '#991b1b', chn: '龙' },
            { name: '和', color: '#8b5cf6', color2: '#6d28d9', chn: '和' },
            { name: '虎', color: '#3b82f6', color2: '#1d4ed8', chn: '虎' }
        ];
        
        let currentRotation = 0;
        let isSpinning = false;
        
        function drawSegment(start, end, color, color2, label) {
            const grad = ctx.createLinearGradient(
                centerX + Math.cos(start) * radius * 0.3,
                centerY + Math.sin(start) * radius * 0.3,
                centerX + Math.cos(end) * radius * 0.8,
                centerY + Math.sin(end) * radius * 0.8
            );
            grad.addColorStop(0, color);
            grad.addColorStop(1, color2);
            
            ctx.beginPath();
            ctx.moveTo(centerX, centerY);
            ctx.arc(centerX, centerY, radius, start, end);
            ctx.closePath();
            ctx.fillStyle = grad;
            ctx.fill();
            
            ctx.strokeStyle = 'rgba(255,215,0,0.4)';
            ctx.lineWidth = 2;
            ctx.stroke();
            
            const mid = start + (end - start) / 2;
            const textR = radius * 0.7;
            const x = centerX + Math.cos(mid) * textR;
            const y = centerY + Math.sin(mid) * textR;
            
            ctx.font = `bold ${Math.floor(radius * 0.18)}px "PingFang SC"`;
            ctx.fillStyle = '#ffffff';
            ctx.shadowBlur = 5;
            ctx.shadowColor = 'rgba(0,0,0,0.5)';
            ctx.fillText(label, x, y);
        }
        
        function drawWheel(rot = 0) {
            ctx.clearRect(0, 0, size, size);
            const anglePer = TAU / SEGMENTS.length;
            for (let i = 0; i < SEGMENTS.length; i++) {
                const s = i * anglePer + rot;
                const e = (i + 1) * anglePer + rot;
                drawSegment(s, e, SEGMENTS[i].color, SEGMENTS[i].color2, SEGMENTS[i].name);
            }
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius * 0.2, 0, TAU);
            ctx.fillStyle = '#1a1a2e';
            ctx.fill();
            ctx.strokeStyle = '#ffcc44';
            ctx.lineWidth = 3;
            ctx.stroke();
        }
        
        function spinToResult(targetChn, callback) {
            if (isSpinning) return;
            isSpinning = true;
            
            const spinBtn = document.getElementById('wheelSpinBtn');
            if (spinBtn) spinBtn.disabled = true;
            
            const targetIndex = targetChn === '龙' ? 0 : (targetChn === '和' ? 1 : 2);
            const anglePer = TAU / SEGMENTS.length;
            const pointerAngle = -PI / 2;
            
            let currentHit = (pointerAngle - currentRotation + TAU * 4) % TAU;
            let currentIdx = Math.floor(currentHit / anglePer) % SEGMENTS.length;
            let delta = (targetIndex - currentIdx + SEGMENTS.length) % SEGMENTS.length;
            let targetRot = currentRotation + delta * anglePer;
            
            if (Math.abs(targetRot - currentRotation) > PI) {
                targetRot = currentRotation - (SEGMENTS.length - delta) * anglePer;
            }
            
            const spins = 5 + Math.random() * 6;
            const finalRot = currentRotation + (spins * TAU) + (targetRot - currentRotation) % TAU;
            const startRot = currentRotation;
            const duration = 1500;
            const startTime = performance.now();
            
            function animate(now) {
                const elapsed = now - startTime;
                const progress = Math.min(1, elapsed / duration);
                const ease = 1 - Math.pow(1 - progress, 3);
                currentRotation = startRot + (finalRot - startRot) * ease;
                drawWheel(currentRotation);
                
                if (progress < 1) {
                    requestAnimationFrame(animate);
                } else {
                    currentRotation = finalRot % TAU;
                    drawWheel(currentRotation);
                    isSpinning = false;
                    if (spinBtn) spinBtn.disabled = false;
                    if (callback) callback();
                }
            }
            requestAnimationFrame(animate);
        }
        
        function randomSpin() {
            if (isSpinning) return;
            isSpinning = true;
            
            const spinBtn = document.getElementById('wheelSpinBtn');
            if (spinBtn) spinBtn.disabled = true;
            if (window.navigator && window.navigator.vibrate) window.navigator.vibrate(50);
            
            const spins = 8 + Math.random() * 10;
            const randomAngle = Math.random() * TAU;
            const finalRot = currentRotation + (spins * TAU) + randomAngle;
            const startRot = currentRotation;
            const duration = 1500;
            const startTime = performance.now();
            
            function animate(now) {
                const elapsed = now - startTime;
                const progress = Math.min(1, elapsed / duration);
                const ease = 1 - Math.pow(1 - progress, 3);
                currentRotation = startRot + (finalRot - startRot) * ease;
                drawWheel(currentRotation);
                
                if (progress < 1) {
                    requestAnimationFrame(animate);
                } else {
                    currentRotation = finalRot % TAU;
                    drawWheel(currentRotation);
                    
                    const pointerAngle = -PI / 2;
                    const anglePer = TAU / SEGMENTS.length;
                    let hit = (pointerAngle - currentRotation + TAU * 4) % TAU;
                    let idx = Math.floor(hit / anglePer) % SEGMENTS.length;
                    const result = SEGMENTS[idx].chn;
                    
                    const toast = document.getElementById('wheelToast');
                    if (toast) {
                        toast.textContent = `✨ ${result} ✨`;
                        toast.style.opacity = '1';
                        setTimeout(() => toast.style.opacity = '0', 1500);
                    }
                    document.getElementById('battleResult').innerHTML = `🎡 ${result}`;
                    highlightWord(result);
                    speak(result);
                    
                    isSpinning = false;
                    if (spinBtn) spinBtn.disabled = false;
                }
            }
            requestAnimationFrame(animate);
        }
        
        drawWheel(0);
        setWheelCallback((result) => { spinToResult(result, () => {}); });
        
        document.getElementById('wheelSpinBtn').onclick = (e) => {
            e.stopPropagation();
            randomSpin();
        };
        document.getElementById('wheelWrapper').onclick = (e) => {
            if (e.target === document.getElementById('wheelSpinBtn')) return;
            if (!isSpinning) randomSpin();
        };
    }

    // ========== 事件绑定 ==========
    function bindEvents() {
        document.getElementById('refreshBtn').onclick = refreshBalance;
        const repeatBtn = document.getElementById('repeatBtn');
        repeatBtn.onclick = null;
        repeatBtn.addEventListener('click', (e) => { if(longPressTimer) clearTimeout(longPressTimer); repeatLastBet(); });
        repeatBtn.addEventListener('touchstart', (e) => { longPressTimer = setTimeout(() => { onLongPress(); longPressTimer = null; }, 3000); });
        repeatBtn.addEventListener('touchend', () => { if(longPressTimer) clearTimeout(longPressTimer); });
        repeatBtn.addEventListener('touchcancel', () => { if(longPressTimer) clearTimeout(longPressTimer); });
        repeatBtn.addEventListener('mousedown', (e) => { longPressTimer = setTimeout(() => { onLongPress(); longPressTimer = null; }, 3000); });
        repeatBtn.addEventListener('mouseup', () => { if(longPressTimer) clearTimeout(longPressTimer); });
        document.getElementById('cancelBtn').onclick = cancelAllBets;
        document.getElementById('fightBtn').onclick = executeBet;
        document.getElementById('switchUserBtn').onclick = switchUser;
        
        document.querySelectorAll('.quick-bet').forEach(btn => {
            btn.onclick = (e) => {
                e.stopPropagation();
                const type = btn.dataset.type;
                const amount = parseInt(btn.dataset.amount);
                addBetAmount(type, amount);
            };
        });
        
        document.querySelectorAll('.clear-bet').forEach(btn => {
            btn.onclick = (e) => {
                e.stopPropagation();
                const type = btn.dataset.type;
                clearBet(type);
            };
        });
    }

    // ========== 初始化 ==========
    function init() {
        bindEvents();
        syncBalance();
        startPoolFluctuation();
        updateUI();
        startCountdown(25);
        refreshRecordDisplay();
        updateHistoryGrid();
        if (!localStorage.getItem('visited_before')) {
            localStorage.setItem('visited_before', 'true');
            setTimeout(() => {
                showModal("龙虎斗尊享版\n• 初始余额：0 rmb\n• 25秒下注时间\n• 5秒开奖滚动\n• 长按「续押」3秒进入后台", "开始");
            }, 500);
        }
    }
    
    init();
})();
</script>
</body>
</html>
 
