<body>
    <div id="app"></div>
    <script>
        // ==================== API配置（阿里云服务器部署时修改此地址） ====================
        const API_BASE = window.location.origin + '/api';
        // 如果后端不可用，自动回退到localStorage模式
        let apiAvailable = false;

        async function checkApi() {
            try {
                const resp = await fetch(API_BASE + '/ping', { method: 'GET', signal: AbortSignal.timeout(3000) });
                if (resp.ok) {
                    apiAvailable = true;
                    console.log('✅ 后端API已连接，使用服务器存储');
                }
            } catch (e) {
                apiAvailable = false;
                console.log('⚠️ 后端API不可用，回退到localStorage本地存储');
            }
        }

        async function apiCall(method, path, body = null) {
            if (!apiAvailable) throw new Error('API不可用');
            const opts = {
                method,
                headers: { 'Content-Type': 'application/json' },
            };
            if (body) opts.body = JSON.stringify(body);
            const resp = await fetch(API_BASE + path, opts);
            if (!resp.ok) {
                const err = await resp.json().catch(() => ({ msg: '请求失败' }));
                throw new Error(err.msg || '请求失败');
            }
            return resp.json();
        }

        // ==================== 全局存储（localStorage回退层） ====================
        const STORAGE = { users: 'jh_final', recharge: 'jh_recharge', withdraw: 'jh_withdraw', config: 'jh_config' };
        let systemConfig = { bankerBalance: 200000, adjustFactor: 0.98 };

        async function loadConfig() {
            if (apiAvailable) {
                try {
                    const data = await apiCall('GET', '/config');
                    systemConfig = data;
                    return;
                } catch (e) { /* 回退 */ }
            }
            let s = localStorage.getItem(STORAGE.config);
            if (s) systemConfig = JSON.parse(s);
            else localStorage.setItem(STORAGE.config, JSON.stringify(systemConfig));
        }

        async function saveConfig() {
            if (apiAvailable) {
                try { await apiCall('PUT', '/config', systemConfig); return; } catch (e) { /* 回退 */ }
            }
            localStorage.setItem(STORAGE.config, JSON.stringify(systemConfig));
        }

        async function loadUsers() {
            if (apiAvailable) {
                try {
                    const data = await apiCall('GET', '/users');
                    return data;
                } catch (e) { /* 回退 */ }
            }
            let u = localStorage.getItem(STORAGE.users);
            if (!u) {
                let init = [{ account: "admin", password: "admin888", balance: 5000, records: [] }];
                localStorage.setItem(STORAGE.users, JSON.stringify(init));
                return init;
            }
            return JSON.parse(u);
        }

        async function saveUsers(users) {
            if (apiAvailable) {
                try { await apiCall('PUT', '/users/batch', { users }); return; } catch (e) { /* 回退 */ }
            }
            localStorage.setItem(STORAGE.users, JSON.stringify(users));
        }

        let currentUser = null;

        async function updateBalance(acc, newBal) {
            if (apiAvailable) {
                try {
                    await apiCall('PUT', '/user/' + encodeURIComponent(acc) + '/balance', { balance: newBal });
                    if (currentUser && currentUser.account === acc) currentUser.balance = newBal;
                    let span = document.getElementById("userBalanceDisplay");
                    if (span) span.innerText = newBal.toFixed(2);
                    return;
                } catch (e) { /* 回退 */ }
            }
            let users = await loadUsers();
            let idx = users.findIndex(u => u.account === acc);
            if (idx !== -1) {
                users[idx].balance = newBal;
                await saveUsers(users);
                if (currentUser && currentUser.account === acc) currentUser.balance = newBal;
                let span = document.getElementById("userBalanceDisplay");
                if (span) span.innerText = newBal.toFixed(2);
            }
        }

        function showToast(msg, isErr = false) {
            // 静默处理，不弹窗干扰游戏
            console.log(isErr ? '❌' : '✅', msg);
        }

        async function gameSettle(totalBet, winAmount) {
            if (!currentUser) return false;
            if (currentUser.balance < totalBet) return false;
            let bankerDelta = totalBet - winAmount;
            let newBanker = systemConfig.bankerBalance + bankerDelta;
            if (newBanker < 0) return false;
            systemConfig.bankerBalance = newBanker;
            await saveConfig();
            let newBal = currentUser.balance - totalBet + winAmount;
            await updateBalance(currentUser.account, newBal);
            return true;
        }

        async function applyRecharge() {
            let amt = parseFloat(prompt("充值金额（USDT）:", "100"));
            if (isNaN(amt) || amt <= 0) return;
            if (apiAvailable) {
                try {
                    await apiCall('POST', '/recharge', { account: currentUser.account, amount: amt });
                    return;
                } catch (e) { /* 回退 */ }
            }
            let orders = JSON.parse(localStorage.getItem(STORAGE.recharge) || '[]');
            orders.push({ id: Date.now(), account: currentUser.account, amount: amt, status: 'pending',
                time: new Date().toLocaleString() });
            localStorage.setItem(STORAGE.recharge, JSON.stringify(orders));
        }

        async function applyWithdraw() {
            let amt = parseFloat(prompt("提现金额（USDT）:", "10"));
            if (isNaN(amt) || amt <= 0) return;
            if (currentUser.balance < amt) return;
            let addr = prompt("USDT收款地址");
            if (!addr) return;
            if (apiAvailable) {
                try {
                    await apiCall('POST', '/withdraw', { account: currentUser.account, amount: amt, address: addr });
                    return;
                } catch (e) { /* 回退 */ }
            }
            let orders = JSON.parse(localStorage.getItem(STORAGE.withdraw) || '[]');
            orders.push({ id: Date.now(), account: currentUser.account, amount: amt, address: addr, status: 'pending',
                time: new Date().toLocaleString() });
            localStorage.setItem(STORAGE.withdraw, JSON.stringify(orders));
        }

