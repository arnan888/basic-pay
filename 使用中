        async function openAdminModal() {
            let pwd = prompt("管理员密码:");
            if (pwd !== "admin888") { return; }
            let users = await loadUsers();
            let rechargeOrders, withdrawOrders;
            if (apiAvailable) {
                try {
                    const rResp = await apiCall('GET', '/recharges/pending');
                    rechargeOrders = rResp;
                    const wResp = await apiCall('GET', '/withdraws/pending');
                    withdrawOrders = wResp;
                } catch (e) {
                    rechargeOrders = JSON.parse(localStorage.getItem(STORAGE.recharge) || '[]');
                    withdrawOrders = JSON.parse(localStorage.getItem(STORAGE.withdraw) || '[]');
