    </div>`;
    for(let i=4;i<=17;i++) document.getElementById('pointsGrid').innerHTML += `<div class="bet-card point-card" data-point="${i}">${i}点<br><span id="bet_${i}">0</span></div>`;
    for(let i=1;i<=6;i++) document.getElementById('trioGrid').innerHTML += `<div class="bet-card trio-card" data-type="TRIPLE_${i}">${i}围<br><span id="bet_TRIPLE_${i}">0</span></div>`;
    document.getElementById('trioGrid').innerHTML += `<div class="bet-card trio-card" data-type="ALL_TRIPLE">豹子<br><span id="bet_ALL_TRIPLE">0</span></div>`;

    const diceEls = [document.getElementById('dice1'), document.getElementById('dice2'), document.getElementById('dice3')];
    function buildDice(d) {
        d.innerHTML = '';
        const tz = window.innerWidth<=480?27.5:35;
        const faces = ['front','back','right','left','top','bottom'];
        const nums = { front:1, back:6, right:4, left:3, top:2, bottom:5 };
        const transforms = [`translateZ(${tz}px)`,`rotateY(180deg) translateZ(${tz}px)`,`rotateY(90deg) translateZ(${tz}px)`,`rotateY(-90deg) translateZ(${tz}px)`,`rotateX(90deg) translateZ(${tz}px)`,`rotateX(-90deg) translateZ(${tz}px)`];
        const pipHtml = {
            1:'<div class="pip pip-center"></div>',
            2:'<div class="pip pip-tl"></div><div class="pip pip-br"></div>',
            3:'<div class="pip pip-tl"></div><div class="pip pip-center"></div><div class="pip pip-br"></div>',
            4:'<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>',
            5:'<div class="pip pip-tl"></div><div class="pip pip-tr"></div><div class="pip pip-mid"></div><div class="pip pip-bl"></div><div class="pip pip-br"></div>',
            6:'<div class="pip pip-l1"></div><div class="pip pip-l2"></div><div class="pip pip-l3"></div><div class="pip pip-r1"></div><div class="pip pip-r2"></div><div class="pip pip-r3"></div>'
        };
        for(let i=0;i<6;i++){
            let face = document.createElement('div');
            face.className = `dice-face ${faces[i]}`;
            face.style.transform = transforms[i];
            face.innerHTML = pipHtml[nums[faces[i]]];
            d.appendChild(face);
        }
        d.style.transform = `rotateX(${Math.random()*360}deg) rotateY(${Math.random()*360}deg)`;
    }
    diceEls.forEach(buildDice);
    let bets = { BIG:0, SMALL:0, ODD:0, EVEN:0 };
    for(let i=4;i<=17;i++) bets[i]=0;
    for(let i=1;i<=6;i++) bets['TRIPLE_'+i]=0;
    bets['ALL_TRIPLE']=0;
    let selectedChip=100, isRolling=false, countdownTimer=null, lastBet=null, flashes=[], records=[];

    function clearFlashes(){ flashes.forEach(t=>clearTimeout(t)); flashes=[]; }
    function ui(skipFlash=false){
        if(!skipFlash){
            for(let k in bets){ let el=document.getElementById('bet_'+k); if(el) el.innerText=bets[k]; }
        }
        document.getElementById('totalBetDice').innerText = Object.values(bets).reduce((a,b)=>a+b,0);
        document.getElementById('diceBankerDisplay').innerText = systemConfig.bankerBalance.toFixed(2);
        document.getElementById('repeatBtnDice').disabled = isRolling || !lastBet;
    }
    function saveLast(){ lastBet = JSON.parse(JSON.stringify(bets)); }
    function getResult(d1,d2,d3){
        let total=d1+d2+d3, types=[];
        if(total>=11&&total<=17) types.push('BIG'); else types.push('SMALL');
        if(total%2===1) types.push('ODD'); else types.push('EVEN');
        if(d1===d2&&d2===d3){ types.push('TRIPLE_'+d1); types.push('ALL_TRIPLE'); }
        return {total, types};
    }
    async function addBet(type){
        if(isRolling||selectedChip>currentUser.balance) return;
        await gameSettle(selectedChip,0);
        bets[type] += selectedChip;
        ui(); saveLast();
    }
    async function clearBets(){
        if(isRolling) return;
        let total = Object.values(bets).reduce((a,b)=>a+b,0);
        if(total>0) await gameSettle(-total,0);
        for(let k in bets) bets[k]=0;
        ui(); saveLast();
    }
    async function repeatBet(){
        if(isRolling||!lastBet) return;
        let need = Object.values(lastBet).reduce((a,b)=>a+b,0);
        if(need>currentUser.balance) return;
        let old = Object.values(bets).reduce((a,b)=>a+b,0);
        if(old>0) await gameSettle(-old,0);
        for(let k in bets) bets[k]=0;
        for(let k in lastBet) bets[k]=lastBet[k];
        await gameSettle(need,0);
        ui();
    }
    async function rollDice(d1,d2,d3){
        const steps=20;
        for(let i=0;i<steps;i++){
            setTimeout(()=>{ diceEls.forEach(d=>{ d.style.transition='transform 0.08s linear'; d.style.transform=`rotateX(${Math.random()*360}deg) rotateY(${Math.random()*360}deg)`; }); }, i*100);
        }
        await new Promise(r=>setTimeout(r,2100));
        let finalVals = [d1,d2,d3];
        diceEls.forEach((d,i)=>{ d.style.transition='transform 0.5s cubic-bezier(0.2,0.9,0.4,1.1)';
            let rx=0, ry=0;
            switch(finalVals[i]){ case 1: rx=0;ry=0;break; case 2: rx=-90;ry=0;break; case 3: rx=0;ry=90;break; case 4: rx=0;ry=-90;break; case 5: rx=90;ry=0;break; case 6: rx=180;ry=0;break; }
            d.style.transform = `rotateX(${rx+360*2}deg) rotateY(${ry+360*2}deg)`;
        });
        await new Promise(r=>setTimeout(r,600));
    }
    async function settle(){
        if(isRolling) return;
        isRolling = true; clearFlashes(); if(countdownTimer) clearInterval(countdownTimer);
        let d1=Math.floor(Math.random()*6)+1, d2=Math.floor(Math.random()*6)+1, d3=Math.floor(Math.random()*6)+1;
        let {total, types} = getResult(d1,d2,d3);
        let winAmount=0, winDetails={}, adj=systemConfig.adjustFactor||0.98;
        let totalBet = Object.values(bets).reduce((a,b)=>a+b,0);
        const odds = {4:60,5:30,6:18,7:12,8:8,9:7,10:6,11:6,12:7,13:8,14:12,15:18,16:30,17:60};
        if(totalBet>0){
            if(types.includes('BIG')&&bets.BIG){ let w=bets.BIG*2*adj; winAmount+=w; winDetails.BIG=bets.BIG+w; }
            if(types.includes('SMALL')&&bets.SMALL){ let w=bets.SMALL*2*adj; winAmount+=w; winDetails.SMALL=bets.SMALL+w; }
            if(types.includes('ODD')&&bets.ODD){ let w=bets.ODD*2*adj; winAmount+=w; winDetails.ODD=bets.ODD+w; }
            if(types.includes('EVEN')&&bets.EVEN){ let w=bets.EVEN*2*adj; winAmount+=w; winDetails.EVEN=bets.EVEN+w; }
            if(bets[total]){ let w=bets[total]*odds[total]*adj; winAmount+=w; winDetails[total]=bets[total]+w; }
            for(let t of types){
                if(t.startsWith('TRIPLE_')&&bets[t]){ let w=bets[t]*150*adj; winAmount+=w; winDetails[t]=bets[t]+w; }
                if(t==='ALL_TRIPLE'&&bets.ALL_TRIPLE){ let w=bets.ALL_TRIPLE*30*adj; winAmount+=w; winDetails.ALL_TRIPLE=bets.ALL_TRIPLE+w; }
            }
        }
        await rollDice(d1,d2,d3);
        document.getElementById('totalPoints').innerText = total;
        document.getElementById('rollingWinNumber').innerText = winAmount.toFixed(2);
        document.getElementById('diceProfitLoss').innerText = (winAmount-totalBet).toFixed(2);
        await gameSettle(totalBet, winAmount);
        for(let k in bets) bets[k]=0; saveLast();
        clearFlashes();
        for(let k in winDetails){
            let el=document.getElementById('bet_'+k);
            if(el){ el.innerText = winDetails[k].toFixed(2); let card=el.closest('.bet-card'); if(card) card.classList.add('win-flash'); let tid=setTimeout(()=>{if(card)card.classList.remove('win-flash');el.innerText='0';},4000); flashes.push(tid); }
        }
        ui();
        setTimeout(()=>{ isRolling=false; ui(); startCountdown(25); }, 4000);
    }
    function startCountdown(sec){
        if(countdownTimer) clearInterval(countdownTimer);
        let remaining = sec;
        document.getElementById('countdownNumDice').innerText = remaining;
        countdownTimer = setInterval(()=>{
            remaining--;
            document.getElementById('countdownNumDice').innerText = remaining;
            if(remaining<=0){ clearInterval(countdownTimer); if(!isRolling) settle(); }
        },1000);
    }
    document.querySelectorAll('#diceChips .chip').forEach(c=>{ c.onclick=()=>{ selectedChip=parseInt(c.dataset.val); document.querySelectorAll('#diceChips .chip').forEach(cc=>cc.classList.remove('selected')); c.classList.add('selected'); }; });
    document.querySelectorAll('.bet-card[data-type],.point-card[data-point],.trio-card[data-type]').forEach(c=>{ c.onclick=()=>addBet(c.dataset.type||c.dataset.point); });
    document.getElementById('clearAllBtnDice').onclick = clearBets;
    document.getElementById('repeatBtnDice').onclick = repeatBet;
    document.getElementById('refreshBtnDice').onclick = ()=>ui();
    document.getElementById('diceHistoryBtn').onclick = ()=>{
        let m=document.createElement('div'); m.className='modal'; m.innerHTML=`<div class="modal-content"><div style="max-height:300px;overflow:auto;">暂无记录</div><button id="cls" class="auth-btn">关闭</button></div>`; document.body.appendChild(m); m.querySelector('#cls').onclick=()=>m.remove();
    };
    document.getElementById('diceBackLobbyBtn').onclick = ()=>{ if(diceDestroy) diceDestroy(); renderGameLobby(); };
    ui(); saveLast(); startCountdown(25);
    diceDestroy = () => { clearInterval(countdownTimer); clearFlashes(); container.innerHTML=''; };
    return diceDestroy;
}

