<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>金葫娱乐城</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; user-select:none; }
        body {
            background: radial-gradient(circle at 30% 10%, #0a0c1a, #020308);
            font-family: 'Segoe UI', 'Poppins', system-ui;
            padding: 12px; min-height:100vh; color:#ffecb3;
            transition: background 0.2s;
        }
        #app { max-width:560px; margin:0 auto; background:rgba(15,20,35,0.65); backdrop-filter:blur(16px); border-radius:48px; border:1px solid rgba(255,200,80,0.4); overflow:hidden; }
        .auth-panel { padding:28px 20px; background:rgba(0,0,0,0.6); border-radius:40px; margin:20px; }
        .auth-panel h2,.auth-panel h3 { text-align:center; margin-bottom:16px; background:linear-gradient(135deg,#ffd966,#ffaa33); -webkit-background-clip:text; background-clip:text; color:transparent; }
        .auth-input { width:100%; padding:12px; margin:6px 0; background:rgba(0,0,0,0.6); border:1px solid #ffaa33; border-radius:40px; color:#ffd966; outline:none; }
        .flex-row { display:flex; gap:10px; align-items:center; margin:10px 0; }
        .code-btn,.auth-btn { background:linear-gradient(135deg,#ffaa33,#ff884d); border:none; border-radius:40px; padding:12px; font-weight:bold; color:#2a1a0a; cursor:pointer; width:100%; }
        .code-btn { width:auto; padding:10px 18px; }
        hr { margin:20px 0; border-color:#ffaa33; }
        .auth-note { font-size:0.65rem; text-align:center; margin-top:12px; color:#ffaa33; }
        .user-section { background:rgba(0,0,0,0.5); padding:12px 16px; border-bottom:1px solid #ffaa33; }
        .user-info-row { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; }
        #userBalanceDisplay { font-size:1.6rem; font-weight:800; background:linear-gradient(135deg,#ffd966,#ffaa33); -webkit-background-clip:text; background-clip:text; color:transparent; cursor:pointer; }
        .btn-group { display:flex; gap:6px; }
        .btn-sm { background:rgba(255,170,51,0.2); border:1px solid #ffaa33; padding:4px 12px; border-radius:40px; cursor:pointer; }
        .charge-btn,.withdraw-btn { background:linear-gradient(135deg,#ffaa33,#ff884d); padding:6px 16px; border-radius:40px; color:#2a1a0a; font-weight:700; cursor:pointer; border:none; }
        .lang-switch,.theme-switch { background:#ffaa33; border:none; border-radius:30px; padding:4px 10px; cursor:pointer; font-weight:bold; margin-left:4px; }
        .game-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; padding:20px; }
        .game-card-item { background:rgba(0,0,0,0.5); border-radius:32px; padding:16px; text-align:center; cursor:pointer; border:1px solid #ffaa33; }
        .game-card-item:hover { transform:scale(1.02); background:rgba(255,170,51,0.2); }
        .game-name { font-weight:bold; } .game-desc { font-size:0.7rem; color:#ffd966; }
        .game-card { background:rgba(0,0,0,0.4); border-radius:32px; padding:16px; border:1px solid rgba(255,200,80,0.4); }
        .chip { background:linear-gradient(145deg,#cc8800,#aa6600); display:inline-block; padding:6px 12px; border-radius:36px; margin:3px; cursor:pointer; font-weight:bold; border:1px solid #ffaa33; }
        .chip.selected { background:#ffaa33; color:#2a1a0a; box-shadow:0 0 8px #ffaa33; }
        .exec-btn { background:linear-gradient(135deg,#ffaa33,#ff884d); border:none; border-radius:36px; padding:8px 14px; color:#2a1a0a; font-weight:bold; cursor:pointer; margin:3px; }
        .exec-btn:disabled { opacity:0.45; cursor:not-allowed; }
        .countdown-area { text-align:center; margin:6px 0 12px; background:rgba(0,0,0,0.6); border-radius:40px; padding:6px 12px; font-weight:bold; border:1px solid #ffaa33; }
        .fish-dice-cube,.dice-cube { width:80px; height:80px; position:relative; transform-style:preserve-3d; transition:transform 0.4s; }
        .fish-dice-face,.dice-face { position:absolute; width:100%; height:100%; background:#2a1e12; border:2px solid #ffaa33; border-radius:16px; display:flex; align-items:center; justify-content:center; backface-visibility:visible; font-size:2rem; }
        .fish-dice-3d-area { display:flex; justify-content:center; gap:48px; margin:24px 0; perspective:900px; }
        .fish-pattern-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin:10px 0; }
        .fish-bet-card,.bet-card { background:rgba(0,0,0,0.5); border-radius:20px; padding:8px 4px; text-align:center; border:1px solid #ffaa33; cursor:pointer; }
        .points-grid,.trio-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(58px,1fr)); gap:6px; margin:10px 0; }
        .history-cell { width:32px; height:32px; border-radius:10px; display:inline-flex; align-items:center; justify-content:center; background:rgba(255,170,51,0.2); margin:2px; }
        .modal { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); backdrop-filter:blur(8px); display:flex; align-items:center; justify-content:center; z-index:1000; }
        .modal-content { background:#2a1e12; border-radius:36px; padding:20px; color:#ffd966; border:1px solid #ffaa33; max-width:90vw; max-height:85vh; overflow-y:auto; }
        .win-flash { animation:redFlash 0.4s 10!important; background-color:#ff3300!important; box-shadow:0 0 25px #ffaa33!important; color:#ffffff!important; font-weight:bold!important; border:2px solid #ffffff!important; }
        @keyframes redFlash { 0%{background-color:rgba(255,50,50,0);color:#ffffff;} 50%{background-color:#ff3300;transform:scale(1.04);color:#ffffff;} 100%{background-color:rgba(255,50,50,0);color:#ffffff;} }
        .dt-card { background:linear-gradient(145deg,#fff8f0,#f0e6d8); width:75px; height:100px; border-radius:12px; display:inline-flex; align-items:center; justify-content:center; font-size:2.4rem; font-weight:bold; box-shadow:0 8px 20px rgba(0,0,0,0.3),inset 0 1px 0 rgba(255,255,255,0.6); border:1px solid rgba(0,0,0,0.2); transition:transform 0.4s; }
        .dt-card.flipped { transform:rotateY(180deg); }
        .simple-card { background:linear-gradient(145deg,#fff8f0,#f0e6d8); width:60px; height:85px; border-radius:10px; display:inline-flex; flex-direction:column; align-items:center; justify-content:center; font-weight:bold; font-size:1.2rem; color:#333; box-shadow:0 6px 12px rgba(0,0,0,0.2),inset 0 1px 0 rgba(255,255,255,0.6); margin:2px; }
        .niu-hand { display:flex; flex-wrap:wrap; justify-content:center; gap:8px; min-height:95px; padding:8px; background:rgba(0,0,0,0.3); border-radius:20px; margin:8px 0; }
        .game-top-bar { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; gap:6px; }
        .user-vip-card { flex:2; background:rgba(0,0,0,0.7); border:1px solid #ffaa33; border-radius:32px; padding:6px 12px; display:flex; align-items:center; gap:8px; cursor:pointer; }
        .vip-badge { background:linear-gradient(135deg,#ffd700,#ffaa00); color:#1a1a0a; padding:2px 8px; border-radius:20px; font-weight:bold; font-size:0.75rem; margin-left:auto; }
        .back-lobby-btn { flex:1; background:rgba(255,170,51,0.25); border:1px solid #ffaa33; padding:8px 6px; border-radius:32px; text-align:center; font-weight:bold; cursor:pointer; font-size:0.8rem; }
        .online-count { display:inline-block; background:rgba(0,255,100,0.2); border:1px solid #00ff64; border-radius:20px; padding:2px 10px; font-size:0.75rem; color:#00ff64; margin-left:6px; }
        body.light-mode { background:radial-gradient(circle at 30% 10%, #f5f0e6, #e8dfd0); color:#3a2a1a; }
        body.light-mode #app { background:rgba(245,240,230,0.85); border-color:rgba(180,130,60,0.5); }
        body.light-mode .auth-panel,body.light-mode .user-section,body.light-mode .game-card,body.light-mode .modal-content { background:rgba(250,245,235,0.9); border-color:#b8860b; color:#3a2a1a; }
        body.light-mode .auth-input,body.light-mode .fish-bet-card,body.light-mode .bet-card,body.light-mode .chip,body.light-mode .exec-btn,body.light-mode .countdown-area { background:rgba(255,250,240,0.8); border-color:#c99a3b; color:#4a3a2a; }
        body.light-mode .chip.selected { background:linear-gradient(145deg,#ffcc77,#e6a822); color:#2a1a0a; }
        body.light-mode .fish-dice-face,body.light-mode .dice-face,body.light-mode .simple-card,body.light-mode .dt-card { background:#fffaf0; border-color:#c99a3b; color:#4a3a2a; }
        /* 骰子点数定位 */
       .pip { width:10px; height:10px; background:#ffaa33; border-radius:50%; margin:2px; position:absolute; }
       .pip-center, .pip-mid { top:50%; left:50%; transform:translate(-50%,-50%); }
       .pip-tl { top:8px; left:8px; }
       .pip-tr { top:8px; right:8px; }
       .pip-bl { bottom:8px; left:8px; }
       .pip-br { bottom:8px; right:8px; }
       .pip-l1,.pip-l2,.pip-l3 { left:12px; }
       .pip-r1,.pip-r2,.pip-r3 { right:12px; }
       .pip-l1,.pip-r1 { top:12px; }
       .pip-l2,.pip-r2 { top:50%; transform:translateY(-50%); }
       .pip-l3,.pip-r3 { bottom:12px; }   
     </style>
  </head>
 <body>
<div id="app"></div>
<script>
// ==================== 后端通信 ====================
const API_BASE = '/api';
let apiAvailable = false;
async function checkApi(){ try{ await fetch(API_BASE+'/ping',{signal:AbortSignal.timeout(2000)}); apiAvailable=true; }catch(e){ apiAvailable=false; } }
async function apiCall(method, path, body=null){
    if(!apiAvailable) throw new Error('API离线');
    const opts = { method, headers:{ 'Content-Type':'application/json' } };
    if(body) opts.body = JSON.stringify(body);
    const r = await fetch(API_BASE+path, opts);
    if(!r.ok){ const e = await r.json().catch(()=>({msg:'请求失败'})); throw new Error(e.msg||'请求失败'); }
    return r.json();
}

// ==================== 全局状态 ====================
let currentUser = null;
let systemConfig = { bankerBalance:200000, adjustFactor:0.98, probWeight:50 };
const STORAGE = { users:'jh_final_v2', config:'jh_config_v2' };

async function loadConfig(){
    try{ systemConfig = await apiCall('GET','/config'); }catch(e){
        let s = localStorage.getItem(STORAGE.config);
        if(s) systemConfig = JSON.parse(s);
        else localStorage.setItem(STORAGE.config, JSON.stringify(systemConfig));
    }
}
async function saveConfig(){
    try{ await apiCall('PUT','/config', systemConfig); }catch(e){}
    localStorage.setItem(STORAGE.config, JSON.stringify(systemConfig));
}
async function loadUsers(){
    try{ return await apiCall('GET','/users'); }catch(e){
        let u = localStorage.getItem(STORAGE.users);
        return u ? JSON.parse(u) : [];
    }
}
async function updateBalance(acc, newBal, admin=false){
    try{ await apiCall('PUT','/user/'+encodeURIComponent(acc)+'/balance', {balance:newBal, admin}); }catch(e){}
    if(currentUser && currentUser.account===acc) currentUser.balance = newBal;
    let span = document.getElementById('userBalanceDisplay');
    if(span) span.innerText = newBal.toFixed(2);
}

// ==================== VIP系统 ====================
const VIP_CONFIG = [
    { lv:0, w:0, upg:0, week:0 },{ lv:1, w:30000, upg:15, week:0 },{ lv:2, w:100000, upg:30, week:3 },
    { lv:3, w:250000, upg:55, week:5 },{ lv:4, w:500000, upg:100, week:8 },{ lv:5, w:1000000, upg:200, week:15 },
    { lv:6, w:2000000, upg:400, week:30 },{ lv:7, w:3000000, upg:550, week:55 },{ lv:8, w:4000000, upg:700, week:85 },
    { lv:9, w:5000000, upg:800, week:110 },{ lv:10, w:6000000, upg:800, week:130 }
];
function getVipInfo(totalWager){
    let lvl=0; for(let i=VIP_CONFIG.length-1;i>=0;i--) if(totalWager>=VIP_CONFIG[i].w){ lvl=VIP_CONFIG[i].lv; break; }
    return VIP_CONFIG.find(v=>v.lv===lvl)||VIP_CONFIG[0];
}
function getNextVip(lvl){ return lvl>=10?null:VIP_CONFIG.find(v=>v.lv===lvl+1); }

// ==================== 结算核心 ====================
async function gameSettle(totalBet, winAmount){
    if(!currentUser) return false;
    if(totalBet>currentUser.balance) return false;
    systemConfig.bankerBalance += (totalBet - winAmount);
    if(systemConfig.bankerBalance<0) return false;
    await saveConfig();
    let newBal = currentUser.balance - totalBet + winAmount;
    await updateBalance(currentUser.account, newBal);
    if(totalBet>0 && currentUser.vip){
        currentUser.vip.totalWager = (currentUser.vip.totalWager||0) + totalBet;
        await checkVipUpgrade(currentUser);
    }
    return true;
}
async function checkVipUpgrade(userObj){
    let total = userObj.vip.totalWager||0;
    let oldLv = userObj.vip.level||0;
    let newInfo = getVipInfo(total);
    if(newInfo.lv > oldLv){
        let upgraded = userObj.vip.upgradeRewards||[];
        for(let l=oldLv+1; l<=newInfo.lv; l++){
            let cfg = VIP_CONFIG.find(v=>v.lv===l);
            if(cfg && cfg.upg>0 && !upgraded.includes(l)){
                userObj.balance += cfg.upg;
                await updateBalance(userObj.account, userObj.balance);
                upgraded.push(l);
                showToast(`🎉 晋升VIP${l}! 奖励${cfg.upg}USDT`);
            }
        }
        userObj.vip.level = newInfo.lv;
        userObj.vip.upgradeRewards = upgraded;
    }
}
// ==================== 工具函数 ====================
function showToast(msg, isErr=false){ console.log(isErr?'❌':'✅', msg); }
function refreshVipDisplay(){
    let badge = document.getElementById('vipBadgeDisplay');
    if(badge && currentUser && currentUser.vip) badge.innerText = 'VIP'+(currentUser.vip.level||0);
}

// ==================== 潮汕葫芦鱼 ====================
const pn = ["鱼","虾","蟹","葫芦","金钱","鸡"];
const dc = [["鱼","虾"],["鱼","蟹"],["鱼","葫芦"],["鱼","金钱"],["鱼","鸡"],["虾","蟹"],["虾","葫芦"],["虾","金钱"],["虾","鸡"],["蟹","葫芦"],["蟹","金钱"],["蟹","鸡"],["葫芦","金钱"],["葫芦","鸡"],["金钱","鸡"]];

let fishDestroy = null;

function initFishGame(container) {
    if(fishDestroy) fishDestroy();
    container.innerHTML = `<div class="game-card">
      <div class="game-top-bar">
        <div class="user-vip-card" id="fishVipCard"><span>👤 ${currentUser?currentUser.account:'用户'}</span><span class="vip-badge" id="vipBadgeDisplay">VIP${(currentUser&&currentUser.vip)?currentUser.vip.level:0}</span></div>
        <div class="back-lobby-btn" id="fishBackLobbyBtn">🏠返回</div>
      </div>
      <div style="display:flex;gap:8px;"><div style="flex:1;text-align:center;">💰余额<div id="fishMyBalance">0</div></div><div style="flex:1;text-align:center;">🎲总押注<div id="fishTotalBet">0</div></div><div style="flex:1;text-align:center;">🏆上局净利<div id="fishLastWin">0</div></div></div>
      <div class="countdown-area" id="fishPhaseHint">🎲 下注阶段 · 25秒</div>
      <div id="dealerBoard" style="display:none;text-align:center;margin:4px 0;padding:6px;background:linear-gradient(145deg,#cc8800,#aa6600);border-radius:20px;color:#2a1a0a;font-weight:bold;">🐉 本局庄家：<span id="dealerName"></span></div>
      <div id="fishChips"><span class="chip" data-chip="10">10</span><span class="chip" data-chip="50">50</span><span class="chip selected" data-chip="100">100</span><span class="chip" data-chip="500">500</span><span class="chip" data-chip="1000">1000</span></div>
      <div style="display:flex;gap:6px;"><button id="fishClearBtn" class="exec-btn">清空</button><button id="fishRepeatBtn" class="exec-btn" disabled>续押</button><button id="fishGrabBtn" class="exec-btn">抢庄</button></div>
      <div class="fish-dice-3d-area">
        <div class="fish-dice-cube" id="fishDice0"></div><div class="fish-dice-cube" id="fishDice1"></div><div class="fish-dice-cube" id="fishDice2"></div>
      </div>
      <div><strong>单选押注</strong></div><div id="fishPatternGrid" class="fish-pattern-grid"></div>
      <div><strong>双押组合</strong></div><div id="fishDoubleGrid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;"></div>
      <div class="dealer-panel" id="dealerPanel" style="display:none;">
        <h4>🐉 庄家全局 <span id="closeDealerBtn" style="float:right;cursor:pointer;color:#ffaa33;">✕</span></h4>
        <div id="dealerSingleSummary"></div><div id="dealerDoubleSummary"></div>
        <div>玩家: <span id="dealerTotalPlayers">0</span> | 总注: <span id="dealerTotalBets">0</span></div>
        <div>预估盈亏: <span id="dealerEstimatedPL">--</span></div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:6px;">
        <button id="fishRecordBtn" class="exec-btn">📜记录</button>
        <button id="fishHistoryBtn" class="exec-btn">📊开奖记录</button>
        <button id="fishRulesBtn" class="exec-btn">📘规则</button>
        <span class="online-count" id="fishOnlineNum">🟢 1人</span>
      </div>
    </div>`;

    const diceEls = [document.getElementById('fishDice0'), document.getElementById('fishDice1'), document.getElementById('fishDice2')];
    function buildDice(d) {
        d.innerHTML = '';
        const tz = window.innerWidth<=480?27.5:35;
        const trs = [`translateZ(${tz}px)`,`rotateY(180deg) translateZ(${tz}px)`,`rotateY(90deg) translateZ(${tz}px)`,`rotateY(-90deg) translateZ(${tz}px)`,`rotateX(-90deg) translateZ(${tz}px)`,`rotateX(90deg) translateZ(${tz}px)`];
        const emojis = ["🐟","🦐","🦀","🎃","💰","🐔"];
        for(let i=0;i<6;i++){
            let face = document.createElement('div'); face.className='fish-dice-face';
            face.style.transform = trs[i]; face.innerText = emojis[i];
            d.appendChild(face);
        }
        d.style.transform = `rotateX(${Math.random()*360}deg) rotateY(${Math.random()*360}deg)`;
    }
    diceEls.forEach(buildDice);

    let bets = { single:{}, double:{} };
    pn.forEach(p=>bets.single[p]=0);
    dc.forEach(c=>bets.double[c.join(',')]=0);
    let chip=100, isGrabbed=false, isRolling=false, lastWin=0, timer=null, flashes=[], prevBet=null;
    const audioCtx = new(window.AudioContext||window.webkitAudioContext)();
    function beep(f=800,d=100,type='sine'){ try{ const o=audioCtx.createOscillator(),g=audioCtx.createGain(); o.type=type; o.frequency.value=f; g.gain.setValueAtTime(0.3,audioCtx.currentTime); g.gain.exponentialRampToValueAtTime(0.001,audioCtx.currentTime+d/1000); o.connect(g); g.connect(audioCtx.destination); o.start(); o.stop(audioCtx.currentTime+d/1000); }catch(e){} }

    function ui(winDetails=null) {
        let total = Object.values(bets.single).reduce((a,b)=>a+b,0) + Object.values(bets.double).reduce((a,b)=>a+b,0);
        document.getElementById('fishTotalBet').innerText = total;
        document.getElementById('fishLastWin').innerText = lastWin;
        document.getElementById('fishMyBalance').innerText = currentUser ? currentUser.balance.toFixed(2) : '0';
        for(let p of pn){
            let sp = document.getElementById(`fishBet_${p}`);
            if(sp) sp.innerText = winDetails?.[p]?.toFixed(2) ?? bets.single[p];
        }
        for(let c of dc){
            let key = c.join(','), id = 'doubleBet_'+key.replace(/,/g,'_');
            let sp = document.getElementById(id);
            if(sp) sp.innerText = winDetails?.[key]?.toFixed(2) ?? bets.double[key];
        }
        document.getElementById('fishRepeatBtn').disabled = isRolling || !prevBet;
        let grabBtn = document.getElementById('fishGrabBtn');
        if(grabBtn) grabBtn.disabled = isGrabbed || isRolling || (currentUser && currentUser.balance < 2000);
        refreshVipDisplay();
    }

    function saveLast(){ prevBet = { single:{...bets.single}, double:{...bets.double} }; }
    function clearFlashes(){ flashes.forEach(t=>clearTimeout(t)); flashes=[]; }

    async function flashWin(wd){
        clearFlashes();
        document.querySelectorAll('.fish-bet-card,.bet-card').forEach(c=>c.classList.remove('win-flash'));
        for(let p of pn){
            let sp = document.getElementById(`fishBet_${p}`);
            if(sp && wd[p]!==undefined){
                sp.innerText = wd[p].toFixed(2);
                let card = sp.closest('.fish-bet-card');
                if(card){ card.classList.add('win-flash'); let tid=setTimeout(()=>{card.classList.remove('win-flash'); sp.innerText='0';},4000); flashes.push(tid); }
            }
        }
        for(let c of dc){
            let key=c.join(','), id='doubleBet_'+key.replace(/,/g,'_'), sp=document.getElementById(id);
            if(sp && wd[key]!==undefined){
                sp.innerText = wd[key].toFixed(2);
                let card = sp.closest('.bet-card');
                if(card){ card.classList.add('win-flash'); let tid=setTimeout(()=>{card.classList.remove('win-flash'); sp.innerText='0';},4000); flashes.push(tid); }
            }
        }
    }

    async function place(s,d){
        try{
            const r = await apiCall('POST','/game/bet',{account:currentUser.account, single:s, double:d});
            currentUser.balance = r.balance; ui(); beep(600,80,'sine'); return true;
        }catch(e){ showToast(e.message,true); return false; }
    }

    async function doClear(){
        if(isRolling) return;
        try{
            const r = await apiCall('POST','/game/clearbet',{account:currentUser.account});
            currentUser.balance = r.balance;
            for(let p in bets.single) bets.single[p]=0;
            for(let k in bets.double) bets.double[k]=0;
            saveLast(); ui(); beep(300,80,'sine');
        }catch(e){ showToast(e.message,true); }
    }

    async function repeatLast(){
        if(!prevBet||isRolling) return;
        let s={}, d={}, tot=0;
        for(let p in prevBet.single) if(prevBet.single[p]>0){ s[p]=prevBet.single[p]; tot+=prevBet.single[p]; }
        for(let k in prevBet.double) if(prevBet.double[k]>0){ d[k]=prevBet.double[k]; tot+=prevBet.double[k]; }
        if(tot<=0||tot>currentUser.balance) return;
        if(await place(s,d)){ bets.single={...prevBet.single}; bets.double={...prevBet.double}; ui(); }
    }

