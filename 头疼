    if (localStorage.getItem('neon_theme') === 'light') { document.body.classList.add('light-mode'); themeBtn.innerHTML = '☀️日间'; }
    themeBtn.onclick = () => {
        document.body.classList.toggle('light-mode');
        let light = document.body.classList.contains('light-mode');
        localStorage.setItem('neon_theme', light ? 'light' : 'dark');
        themeBtn.innerHTML = light ? '☀️日间' : '🌙夜间';
    };
    document.querySelectorAll('.game-card-item').forEach(el => { el.onclick = () => switchToGame(el.dataset.game); });
    let titleClicks = 0, titleTimer;
    document.getElementById('lobbyTitle').onclick = () => {
        titleClicks++;
        if (titleTimer) clearTimeout(titleTimer);
        titleTimer = setTimeout(() => titleClicks = 0, 2000);
        if (titleClicks >= 5) { titleClicks = 0; showProbabilityPanel(); }
    };
    document.getElementById('userBalanceDisplay').onclick = () => {
        // 快速点击3次打开管理员面板
        if (!window._adminClick) window._adminClick = 0;
        window._adminClick++;
        setTimeout(() => window._adminClick = 0, 1500);
        if (window._adminClick >= 3) { window._adminClick = 0; openAdminModal(); }
    };
    refreshVipDisplay();
}

async function switchToGame(gid) {
    if (currentGameDestroy) { currentGameDestroy(); currentGameDestroy = null; }
    document.getElementById('app').innerHTML = '<div style="padding:12px;"><div id="singleGameContainer"></div></div>';
    const gc = document.getElementById('singleGameContainer');
    const inits = { fish: initFishGame, dice: initDiceGame, dragonTiger: initDragonTigerGame, game4: initGame4 };
    if (inits[gid]) currentGameDestroy = await inits[gid](gc);
}

// ==================== 登录注册 ====================
async function login(acc, pwd) {
    try {
        const res = await apiCall('POST', '/login', { account: acc, password: pwd });
        currentUser = res.user;
        localStorage.setItem('curr_acc', acc);
        return { success: true };
    } catch (e) {
        // 离线模式
        let users = await loadUsers();
        let u = users.find(u => u.account === acc);
        if (!u) return { success: false, msg: '账号不存在' };
        if (u.password !== pwd) return { success: false, msg: '密码错误' };
        if (!u.vip) u.vip = { level: 1, totalWager: 0 };
        currentUser = u;
        localStorage.setItem('curr_acc', acc);
        return { success: true };
    }
}
async function register(acc, pwd, ref) {
    try {
        const res = await apiCall('POST', '/register', { account: acc, password: pwd, referralCode: ref });
        currentUser = res.user;
        localStorage.setItem('curr_acc', acc);
        return { success: true };
    } catch (e) {
        let valid = ["VIP666","888VIP","GOLD2025","LUCKY8","DICE100"];
        if (!valid.includes(ref)) return { success: false, msg: '推荐码无效' };
        let users = await loadUsers();
        if (users.find(u => u.account === acc)) return { success: false, msg: '账号已存在' };
        let nu = { account: acc, password: pwd, balance: 0, vip: { level: 1, totalWager: 0 }, records: [] };
        users.push(nu);
        localStorage.setItem(STORAGE.users, JSON.stringify(users));
        currentUser = nu;
        localStorage.setItem('curr_acc', acc);
        return { success: true };
    }
}

function renderAuthUI() {
    document.getElementById('app').innerHTML = `<div class="auth-panel">
      <h2>金辉娱乐城</h2>
      <input id="loginAccount" class="auth-input" placeholder="账号">
      <input id="loginPassword" type="password" class="auth-input" placeholder="密码">
      <button id="loginBtn" class="auth-btn">登录</button>
      <hr><h3>注册</h3>
      <input id="regAccount" class="auth-input" placeholder="设置账号">
      <input id="regPassword" type="password" class="auth-input" placeholder="设置密码">
      <input id="regReferral" class="auth-input" placeholder="推荐码 (VIP666等)">
      <button id="registerBtn" class="auth-btn">注册</button>
      <div class="auth-note">推荐码: VIP666,888VIP,GOLD2025,LUCKY8,DICE100</div>
    </div>`;
    document.getElementById('loginBtn').onclick = async () => {
        let a = document.getElementById('loginAccount').value.trim();
        let p = document.getElementById('loginPassword').value;
        let res = await login(a, p);
        if (res.success) { renderGameLobby(); } else { alert(res.msg); }
    };
    document.getElementById('registerBtn').onclick = async () => {
        let a = document.getElementById('regAccount').value.trim();
        let p = document.getElementById('regPassword').value;
        let ref = document.getElementById('regReferral').value.trim();
        if (!a || !p || !ref) return;
        let res = await register(a, p, ref);
        if (res.success) { alert('注册成功'); renderGameLobby(); } else { alert(res.msg); }
    };
}

// ==================== 入口 ====================
async function init() {
    await checkApi();
    await loadConfig();
    let saved = localStorage.getItem('curr_acc');
    if (saved) {
        try {
            const data = await apiCall('GET', '/user/' + encodeURIComponent(saved) + '/profile');
            currentUser = data.user;
            renderGameLobby();
        } catch (e) {
            // 尝试本地加载
            let users = await loadUsers();
            let u = users.find(u => u.account === saved);
            if (u) { currentUser = u; renderGameLobby(); } else { renderAuthUI(); }
        }
    } else {
        renderAuthUI();
    }
}
init();
</script>
