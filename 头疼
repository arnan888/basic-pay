        <div class="bet-card" id="betTieCard" style="cursor:pointer;">⚖️和<br><span id="betTieAmount">0</span></div>
        <div class="bet-card" id="betTigerCard" style="cursor:pointer;">🐯虎<br><span id="betTigerAmount">0</span></div>
      </div>
      <div style="display:flex;gap:6px;justify-content:center;"><button id="dtClearBtn" class="exec-btn">清空</button><button id="dtRepeatBtn" class="exec-btn" disabled>续押</button></div>
    </div>`;
    let bets = {DRAGON:0, TIGER:0, TIE:0}, isRolling=false, countdownTimer=null, lastBet=null, selectedChip=100;
    function ui(){ document.getElementById('betDragonAmount').innerText=bets.DRAGON; document.getElementById('betTigerAmount').innerText=bets.TIGER; document.getElementById('betTieAmount').innerText=bets.TIE; document.getElementById('dtRepeatBtn').disabled=isRolling||!lastBet; }
    function saveLast(){ lastBet={...bets}; }
    async function addBet(type){
        if(isRolling||selectedChip>currentUser.balance) return;
        await gameSettle(selectedChip,0);
        bets[type]+=selectedChip;
        ui(); saveLast();
    }
    async function clearBets(){
        if(isRolling) return;
        let total=bets.DRAGON+bets.TIGER+bets.TIE;
        if(total>0) await gameSettle(-total,0);
        bets={DRAGON:0,TIGER:0,TIE:0}; ui(); saveLast();
    }
    async function repeatBet(){
        if(isRolling||!lastBet) return;
        let need=Object.values(lastBet).reduce((a,b)=>a+b,0);
        if(need>currentUser.balance) return;
        let old=Object.values(bets).reduce((a,b)=>a+b,0);
        if(old>0) await gameSettle(-old,0);
        bets={...lastBet};
        await gameSettle(need,0);
        ui();
    }
    async function settle(){
        if(isRolling) return;
        isRolling=true; if(countdownTimer) clearInterval(countdownTimer);
        let d=getCard(), t=getCard(), res='';
        if(d.points>t.points) res='D';
        else if(t.points>d.points) res='T';
        else res='E';
        let winAmount=0, adj=systemConfig.adjustFactor||0.98;
        if(res==='D'&&bets.DRAGON>0) winAmount+=bets.DRAGON*2*adj;
        if(res==='T'&&bets.TIGER>0) winAmount+=bets.TIGER*2*adj;
        if(res==='E'&&bets.TIE>0) winAmount+=bets.TIE*8*adj;
        await gameSettle(bets.DRAGON+bets.TIGER+bets.TIE, winAmount);
        document.getElementById('dragonCardDiv').innerText = d.display;
        document.getElementById('tigerCardDiv').innerText = t.display;
        document.getElementById('dtBattleResult').innerHTML = `🐉${d.display} vs ${t.display}🐯<br>${res==='D'?'龙胜':(res==='T'?'虎胜':'和')}`;
        bets={DRAGON:0,TIGER:0,TIE:0}; saveLast(); ui();
        setTimeout(()=>{ isRolling=false; startCountdown(30); },4000);
    }
    function startCountdown(sec){
        if(countdownTimer) clearInterval(countdownTimer);
        let remaining=sec;
        document.getElementById('countdownNumDT').innerText=remaining;
        countdownTimer=setInterval(()=>{
            remaining--;
            document.getElementById('countdownNumDT').innerText=remaining;
            if(remaining<=0){ clearInterval(countdownTimer); if(!isRolling) settle(); }
        },1000);
    }
    // 绑定筹码
    document.querySelectorAll('#dtChips .chip').forEach(ch => {
        ch.onclick = () => { selectedChip=parseInt(ch.dataset.chip); document.querySelectorAll('#dtChips .chip').forEach(cc=>cc.classList.remove('selected')); ch.classList.add('selected'); };
    });
    // 绑定下注区域
    document.getElementById('betDragonCard').onclick = () => addBet('DRAGON');
    document.getElementById('betTigerCard').onclick = () => addBet('TIGER');
    document.getElementById('betTieCard').onclick = () => addBet('TIE');
    // 清空/续押
    document.getElementById('dtClearBtn').onclick = clearBets;
    document.getElementById('dtRepeatBtn').onclick = repeatBet;
    document.getElementById('dtBackLobbyBtn').onclick = ()=>{ if(dragonTigerDestroy) dragonTigerDestroy(); renderGameLobby(); };
    ui(); saveLast(); startCountdown(30);
    dragonTigerDestroy = () => { clearInterval(countdownTimer); c.innerHTML=''; };
    return dragonTigerDestroy;
}

