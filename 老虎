<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8" />
<title>龙虎开奖验证版</title>
<style>
html,body{
  margin:0;
  padding:0;
  background:#000;
  overflow:hidden;
  font-family:"Microsoft YaHei",sans-serif;
}

.arena{
  position:relative;
  width:100vw;
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
}

/* VS 背景 */
.vs{
  position:absolute;
  font-size:120px;
  font-weight:900;
  color:#fff;
  opacity:.1;
}

/* 龙虎主体 */
.dragon,.tiger{
  position:absolute;
  width:260px;
  height:260px;
  border-radius:50%;
  filter:drop-shadow(0 0 35px currentColor);
}

.dragon{
  left:-40%;
  color:#00ffff;
  background:radial-gradient(circle,#00ffff,#003344);
  animation:dragonIn 2s ease-out forwards;
}

.tiger{
  right:-40%;
  color:#ffcc00;
  background:radial-gradient(circle,#ffcc00,#442200);
  animation:tigerIn 2s ease-out forwards;
}

@keyframes dragonIn{
  to{left:25%;transform:scale(1.15)}
}
@keyframes tigerIn{
  to{right:25%;transform:scale(1.15)}
}

/* 中央冲击 */
.impact{
  position:absolute;
  width:20px;
  height:20px;
  border-radius:50%;
  background:#fff;
  opacity:0;
  box-shadow:0 0 50px 20px rgba(255,255,255,.6);
  animation:impact 1.2s 2s forwards;
}

@keyframes impact{
  30%{opacity:1;transform:scale(20)}
  100%{opacity:0;transform:scale(40)}
}

/* 结果文字 */
.result{
  position:absolute;
  bottom:18%;
  font-size:96px;
  font-weight:900;
  letter-spacing:8px;
  opacity:0;
  animation:showResult 1s 3s forwards;
}

.dragonWin{
  color:#00ffff;
  text-shadow:0 0 30px #00ffff;
}
.tigerWin{
  color:#ffcc00;
  text-shadow:0 0 30px #ffcc00;
}

@keyframes showResult{
  to{opacity:1;transform:scale(1.1)}
}

/* 轻震动（降噪版） */
.shake{
  animation:shake .3s 4;
}

@keyframes shake{
  0%{transform:translate(0,0)}
  25%{transform:translate(6px,-6px)}
  50%{transform:translate(-6px,6px)}
  75%{transform:translate(4px,4px)}
}
</style>
</head>

<body>
<div class="arena shake">
  <div class="vs">VS</div>
  <div class="dragon"></div>
  <div class="tiger"></div>
  <div class="impact"></div>

  <!-- 验证用：二选一，注释另一个 -->
  <div class="result dragonWin">龙 胜</div>
  <!-- <div class="result tigerWin">虎 胜</div> -->
</div>
</body>
</html>