/* --- 游戏背景：深灰底色 + 黑色细网格 --- */
#p-game {
  /* 1. 设置主体背景色为深灰 */
  background-color: #1a1a1a; 
  
  /* 2. 用 CSS 画网格 (原理是叠加两个方向的黑色线条) */
  background-image: 
    linear-gradient(#000000 1.2px, transparent 1.2px), /* 黑色横线，1.2像素宽 */
    linear-gradient(90deg, #000000 1.2px, transparent 1.2px); /* 黑色竖线，1.2像素宽 */
    
  /* 3. 设置网格格子的大小 */
  background-size: 20px 20px; /* 每个格子是 20px x 20px 的正方形 */
  
  /* 4. 确保网格从左上角对齐，不乱跳 */
  background-position: center;
}
