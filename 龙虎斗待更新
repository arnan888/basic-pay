            padding: 16px;
        }
        .container-outer {
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
            background: #1e1e2e;
            border-radius: 0;
            padding: 12px;
            box-shadow: 12px 12px 24px rgba(0,0,0,0.6), -8px -8px 16px rgba(255,255,255,0.08);
        }
        .container {
            background: #2a2a3a;
            border-radius: 0;
            overflow: hidden;
            box-shadow: inset 6px 6px 12px rgba(0,0,0,0.6), inset -6px -6px 12px rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
        }
        .battle-scene {
            position: relative;
            margin: 16px;
            border-radius: 0;
            overflow: hidden;
            background: #0a0a0a;
            height: 180px;
            flex-shrink: 0;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.8), 10px 10px 20px rgba(0,0,0,0.5), -5px -5px 10px rgba(255,255,255,0.05);
        }
        .scene-bg {
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, #2a2a2a, #000);
            background-size: cover;
            background-position: center;
            z-index: 1;
        }
        .scene-bg video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .dragon-word, .tiger-word {
            position: absolute;
            bottom: 20px;
            font-size: 56px;
            font-weight: 900;
            text-shadow: 6px 6px 0 rgba(0,0,0,0.6), 0 0 25px currentColor;
            z-index: 10;
            transition: all 0.15s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            opacity: 0.95;
        }
        .dragon-word { left: 20px; color: #e74c3c; text-shadow: 0 0 20px red, 6px 6px 0 darkred; }
        .tiger-word { right: 20px; color: #3498db; text-shadow: 0 0 20px blue, 6px 6px 0 darkblue; }
        .highlight-win {
            transform: scale(1.3);
            text-shadow: 0 0 40px currentColor, 8px 8px 0 rgba(0,0,0,0.5);
            opacity: 1;
        }
        .battle-result {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(8px);
            padding: 8px 24px;
            border-radius: 0;
            color: #ffecb3;
            font-weight: bold;
            font-size: 18px;
            z-index: 20;
            white-space: nowrap;
            border: 1px solid #ffaa44;
            box-shadow: 0 0 20px rgba(255,170,68,0.8);
            transition: all 0.1s ease;
            pointer-events: none;
        }
        .battle-result.pop {
            transform: translateX(-50%) scale(1.1);
            background: rgba(255,170,68,0.9);
            color: #1a1a2a;
        }
        .flash-gold {
            animation: goldFlash 0.3s ease-out;
        }
        @keyframes goldFlash {
            0% { box-shadow: 0 0 0 0 rgba(255,215,0,0); background-color: transparent; }
            30% { box-shadow: 0 0 0 8px rgba(255,215,0,0.6); background-color: rgba(255,215,0,0.3); }
            100% { box-shadow: 0 0 0 0 rgba(255,215,0,0); background-color: transparent; }
        }
        /* 开奖动画层 */
        .animation-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(8px);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.2s;
            pointer-events: none;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .dice-container {
            background: #2a2a3a;
            border-radius: 0;
            padding: 40px 60px;
            text-align: center;
            box-shadow: 0 0 50px rgba(255,215,0,0.8);
            transform: scale(0.8);
            animation: popIn 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
            pointer-events: none;
        }
