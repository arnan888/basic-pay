        const lang = { zh: { phoneOrEmail: "账号", password: "密码", referralCode: "推荐码", remember: "记住", login: "登录", register: "注册", getCode: "获取验证码", verifyCode: "验证码", registerNow: "注册", referralNote: "推荐码: VIP666,888VIP,GOLD2025,LUCKY8,DICE100" }, th: { phoneOrEmail: "บัญชี", password: "รหัส", referralCode: "รหัสแนะนำ", remember: "จำ", login: "เข้าสู่", register: "สมัคร", getCode: "รับรหัส", verifyCode: "รหัส", registerNow: "สมัคร", referralNote: "VIP666,888VIP,GOLD2025,LUCKY8,DICE100" } };
        let currentLang = 'zh';
