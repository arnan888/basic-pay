            async function startAutoDrawDice() { if (isBetLocked) return; let totalBetVal = Object.values(bets).reduce((a, b) => a + b, 0); isBetLocked = true; if (countdownInterval) clearInterval(countdownInterval); let d1 = Math.floor(Math.random() * 6) + 1, d2 = Math.floor(Math.random() * 6) + 1, d3 = Math.floor(Math.random() * 6) + 1; let { total, types } = getResultInfo(d1, d2, d3); let winAmount = 0; let winDetails = {}; if (totalBetVal > 0) { const oddsMap = { 4: 60, 5: 30, 6: 18, 7: 12, 8: 8, 9: 7, 10: 6, 11: 6, 12: 7, 13: 8, 14: 12, 15: 18, 16: 30, 17: 60 }; if (types.includes('BIG') && bets.BIG) { winAmount += bets.BIG * 2; winDetails['BIG'] = bets.BIG * 3; } if (types.includes('SMALL') && bets.SMALL) { winAmount += bets.SMALL * 2; winDetails['SMALL'] = bets.SMALL * 3; } if (types.includes('ODD') && bets.ODD) { winAmount += bets.ODD * 2; winDetails['ODD'] = bets.ODD * 3; } if (types.includes('EVEN') && bets.EVEN) { winAmount += bets.EVEN * 2; winDetails['EVEN'] = bets.EVEN * 3; } if (bets[total]) { winAmount += bets[total] * oddsMap[total]; winDetails[total] = bets[total] + bets[total] * oddsMap[total]; } for (let t of types) { if (t.startsWith('TRIPLE_') && bets[t]) { winAmount += bets[t] * 150; winDetails[t] = bets[t] + bets[t] * 150; } if (t === 'ALL_TRIPLE' && bets.ALL_TRIPLE) { winAmount += bets.ALL_TRIPLE * 30; winDetails['ALL_TRIPLE'] = bets.ALL_TRIPLE + bets.ALL_TRIPLE * 30; } } winAmount *= systemConfig.adjustFactor; for (let k in winDetails) winDetails[k] *= systemConfig.adjustFactor; } let profit = winAmount - totalBetVal; for (let i = 0; i < 15; i++) { setTimeout(() => { dice.forEach(d => setCubeValue(d, Math.floor(Math.random() * 6) + 1)); }, i * 80); } setTimeout(async () => { for (let i = 0; i < 3; i++) setCubeValue(dice[i], [d1, d2, d3][i]); totalPointsSpan.innerText = total; addRecord(d1, d2, d3, winAmount, totalBetVal, profit); if (document.getElementById('diceProfitLoss')) document.getElementById('diceProfitLoss').innerText = profit.toFixed(2); await gameSettle(totalBetVal, winAmount); for (let k in bets) { let el = document.getElementById(`bet_${k}`); if (el) { if (winDetails[k] !== undefined) { el.innerText = winDetails[k]; let card = el.closest('.bet-card'); if (card) card.classList.add('win-flash'); setTimeout(() => { if (card) card.classList.remove('win-flash'); el.innerText = "0"; }, 3000); } else el.innerText = "0"; } } for (let k in bets) bets[k] = 0; updateUIDice(); startCountdownDice(25); }, 15 * 80 + 100); }
            function startCountdownDice(sec) { if (countdownInterval) clearInterval(countdownInterval); let c = sec, cd = document.getElementById('countdownNumDice'); cd.innerText = c; isBetLocked = false; countdownInterval = setInterval(() => { if (c <= 1) { clearInterval(countdownInterval); countdownInterval = null; startAutoDrawDice(); } else { c--; cd.innerText = c; } }, 1000); }
            document.querySelectorAll('#diceChips .chip').forEach(c => { c.onclick = function() { selectedChip = parseInt(this.dataset.val); document.querySelectorAll('#diceChips .chip').forEach(cc => cc.classList.remove('selected')); this.classList.add('selected'); }; });
            document.querySelectorAll('.bet-card').forEach(c => { c.onclick = () => addBetDice(c.dataset.type || c.dataset.point); });
            document.getElementById('clearAllBtnDice').onclick = clearAllBetsDice; document.getElementById('repeatBtnDice').onclick = repeatLastBetDice; document.getElementById('refreshBtnDice').onclick = () => updateUIDice();
            document.getElementById('diceHistoryBtn').onclick = () => { if (!gameRecordsDice.length) return; let html = '<div style="max-height:200px;overflow:auto;">' + gameRecordsDice.map(r => `<div>${r.time} 🎲 ${r.dice} ${r.result} (盈亏:${r.profit})</div>`).join('') + '</div><button id="closeRec" class="auth-btn">关闭</button>'; let m = document.createElement('div'); m.className = 'modal'; m.innerHTML = `<div class="modal-content">${html}</div>`; document.body.appendChild(m); m.querySelector('#closeRec').onclick = () => m.remove(); };
            dice.forEach(d => setCubeValue(d, 1)); totalPointsSpan.innerText = 3; updateUIDice(); startCountdownDice(25);
            diceDestroy = () => { if (countdownInterval) clearInterval(countdownInterval); container.innerHTML = ''; };
            return diceDestroy;
        }

