            height: 10px;
            background: #ffaa33;
            border-radius: 50%;
            margin: 2px;
            position: absolute;
        }
        .pip-l1,
        .pip-l2,
        .pip-l3 {
            left: 12px;
        }
        .pip-r1,
        .pip-r2,
        .pip-r3 {
            right: 12px;
        }
        .pip-l1,
        .pip-r1 {
            top: 12px;
        }
        .pip-l2,
        .pip-r2 {
            top: 50%;
            transform: translateY(-50%);
        }
        .pip-l3,
        .pip-r3 {
            bottom: 12px;
        }
        .pip-center {
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        .pip-tl {
            top: 8px;
            left: 8px;
        }
        .pip-tr {
            top: 8px;
            right: 8px;
        }
        .pip-bl {
            bottom: 8px;
            left: 8px;
        }
        .pip-br {
            bottom: 8px;
            right: 8px;
        }
        .pip-mid {
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        .fish-pattern-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            margin: 10px 0;
        }
        .fish-bet-card,
        .bet-card {
            background: rgba(0, 0, 0, 0.5);
            border-radius: 20px;
            padding: 8px 4px;
            text-align: center;
            border: 1px solid #ffaa33;
            cursor: pointer;
        }
        .points-grid,
        .trio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(58px, 1fr));
            gap: 6px;
            margin: 10px 0;
        }
        .history-cell {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 170, 51, 0.2);
            margin: 2px;
        }
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal-content {
            background: #2a1e12;
            border-radius: 36px;
            padding: 20px;
            color: #ffd966;
            border: 1px solid #ffaa33;
        }
        .toast-message,
        .floating-number,
        .result-popup {
            display: none !important;
        }
        .win-flash {
            animation: redFlash 1s 3 !important;
            background-color: #ff3300 !important;
            box-shadow: 0 0 20px #ffaa33 !important;
        }
        @keyframes redFlash {
            0% {
                background-color: rgba(255, 50, 50, 0);
            }
            50% {
                background-color: #ff3300;
                transform: scale(1.02);
            }
            100% {
                background-color: rgba(255, 50, 50, 0);
            }
        }
        .number-flash {
            animation: numberBlink 0.4s 3;
            display: inline-block;
        }
        @keyframes numberBlink {
            0% {
                color: #ffd966;
                transform: scale(1);
            }
            50% {
                color: #ff3300;
                transform: scale(1.3);
            }
            100% {
                color: #ffd966;
                transform: scale(1);
            }
        }
        .balance-bling {
            animation: balanceGlow 0.4s 3;
        }
        @keyframes balanceGlow {
            0% {
                text-shadow: 0 0 0;
            }
            50% {
                text-shadow: 0 0 12px #ff5500;
            }
        }
        .dt-card {
            background: linear-gradient(145deg, #fff8f0, #f0e6d8);
