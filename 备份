        function renderAuthUI() { const sa = localStorage.getItem('neon_saved_account') || '', sp = localStorage.getItem('neon_saved_password') || '', rc = localStorage.getItem('neon_remember_me') === 'true'; document.getElementById('app').innerHTML = `<div class="auth-panel"><h2>🏆金辉娱乐城</h2><div><input type="text" id="loginAccount" class="auth-input" placeholder="${t('phoneOrEmail')}" value="${sa}"><input type="password" id="loginPassword" class="auth-input" placeholder="${t('password')}" value="${sp}"><div class="flex-row"><input type="checkbox" id="rememberCheckbox" ${rc?'checked':''}><label>${t('remember')}</label></div><button id="loginBtn" class="auth-btn">${t('login')}</button></div><hr><h3>${t('registerNow')}</h3><input type="text" id="regAccount" class="auth-input" placeholder="${t('phoneOrEmail')}"><div class="flex-row"><input type="text" id="regCode" class="auth-input" placeholder="${t('verifyCode')}"><button id="getCodeBtn" class="code-btn">${t('getCode')}</button></div><input type="password" id="regPassword" class="auth-input" placeholder="${t('password')}"><input type="text" id="regReferral" class="auth-input" placeholder="${t('referralCode')}"><button id="registerBtn" class="auth-btn">${t('register')}</button><div class="auth-note">${t('referralNote')}</div></div>`; document.getElementById('loginBtn').onclick = async () => { let a = document.getElementById('loginAccount').value.trim(), p = document.getElementById('loginPassword').value, rem = document.getElementById('rememberCheckbox').checked; let res = await login(a, p); if (res.success) { if (rem) { localStorage.setItem('neon_saved_account', a); localStorage.setItem('neon_saved_password', p); localStorage.setItem('neon_remember_me', 'true'); } else { localStorage.removeItem('neon_saved_account'); localStorage.removeItem('neon_saved_password'); localStorage.setItem('neon_remember_me', 'false'); } renderGameLobby(); } }; document.getElementById('getCodeBtn').onclick = () => { let a = document.getElementById('regAccount').value.trim(); if (!a) return; let code = Math.floor(100000 + Math.random() * 900000); window.tempCode = { acc: a, code: code, expire: Date.now() + 5 * 60 * 1000 }; alert(`【验证码】您的验证码是：${code}，5分钟内有效。`); }; document.getElementById('registerBtn').onclick = async () => { let a = document.getElementById('regAccount').value.trim(), c = document.getElementById('regCode').value.trim(), p = document.getElementById('regPassword').value, ref = document.getElementById('regReferral').value.trim().toUpperCase(); if (!a || !c || !p || !ref) return; if (!['VIP666', '888VIP', 'GOLD2025', 'LUCKY8', 'DICE100'].includes(ref)) return; if (!window.tempCode || window.tempCode.acc !== a || window.tempCode.code != c || Date.now() > window.tempCode.expire) return; if (p.length < 4) return; let res = await register(a, p, ref); if (res.success) { document.getElementById('regAccount').value = ''; document.getElementById('regCode').value = ''; document.getElementById('regPassword').value = ''; document.getElementById('regReferral').value = ''; } }; }
        
