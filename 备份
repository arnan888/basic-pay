        .fish-dice-cube,
        .dice-cube {
            width: 70px;
            height: 70px;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.4s;
        }
        .fish-dice-face,
        .dice-face {
            position: absolute;
            width: 100%;
            height: 100%;
            background: #2a1e12;
            border: 2px solid #ffaa33;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            backface-visibility: visible;
            font-size: 2rem;
            transform: translateZ(35px);
        }
        .fish-dice-3d-area {
            display: flex;
            justify-content: center;
            gap: 48px;
            margin: 24px 0;
            perspective: 900px;
            flex-wrap: nowrap;
        }
        .fish-dice-cube {
            margin: 0 8px;
            flex-shrink: 0;
        }
        @media (max-width:520px) {
            .fish-dice-3d-area {
                gap: 34px;
                perspective: 750px;
            }
            .fish-dice-cube {
                margin: 0 5px;
            }
        }
        .dice-3d-area {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 20px 0;
            perspective: 700px;
        }
