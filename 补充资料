    color: #ccffaa;
    font-weight: bold;
    cursor: pointer;
}
</style>
</head>
<body>
<div class="container-outer">
    <div class="container">
        <div class="battle-scene">
            <div class="scene-bg" id="sceneBg">
                <div style="width:100%;height:100%;background:radial-gradient(circle at 30% 40%, #1a1218, #050508);"></div>
            </div>
            <div class="dragon-word" id="dragonWord">龍</div>
            <div class="tiger-word" id="tigerWord">虎</div>
            <div class="battle-result" id="battleResult">⚔️ 霓虹战域 ⚔️</div>
        </div>

        <div class="bet-section">
            <div class="account-bar" id="adminLongPressTarget">
                <div class="account-info">💰 灵蕴 <span id="balanceAmount">10000</span></div>
                <div class="btn-group">
                    <button class="btn-sm" id="resetGameBtn">重燃</button>
                </div>
            </div>

            <!-- 续押按钮 -->
            <div class="repeat-row">
                <div class="repeat-bet-btn" id="repeatBetBtn">🔄 续押 · 复制上局注码</div>
            </div>

            <div style="display: flex; gap: 14px; flex-wrap: wrap; justify-content: space-between;">
                <div class="multi-bet-item" data-bet="dragon" id="betDragonItem">
                    <div class="multi-bet-name dragon">🐉 龙</div>
                    <div class="bet-amount-wrapper">
                        <div class="bet-label-text">注码</div>
                        <div class="multi-bet-amount" id="dragonAmount">0</div>
                    </div>
                    <div class="multi-bet-control">
                        <button class="decBet" data-type="dragon">-</button>
                        <button class="incBet" data-type="dragon">+</button>
                    </div>
                    <div class="quick-bet-row">
                        <button class="quick-bet" data-type="dragon" data-val="100">+100</button>
                        <button class="quick-bet" data-type="dragon" data-val="500">+500</button>
                        <button class="quick-bet" data-type="dragon" data-val="1000">+1k</button>
                    </div>
                </div>
                <div class="multi-bet-item" data-bet="tiger" id="betTigerItem">
                    <div class="multi-bet-name tiger">🐅 虎</div>
                    <div class="bet-amount-wrapper">
                        <div class="bet-label-text">注码</div>
                        <div class="multi-bet-amount" id="tigerAmount">0</div>
                    </div>
                    <div class="multi-bet-control">
                        <button class="decBet" data-type="tiger">-</button>
                        <button class="incBet" data-type="tiger">+</button>
                    </div>
                    <div class="quick-bet-row">
                        <button class="quick-bet" data-type="tiger" data-val="100">+100</button>
                        <button class="quick-bet" data-type="tiger" data-val="500">+500</button>
                        <button class="quick-bet" data-type="tiger" data-val="1000">+1k</button>
                    </div>
                </div>
                <div class="multi-bet-item" data-bet="tie" id="betTieItem">
                    <div class="multi-bet-name tie">⚖️ 和</div>
                    <div class="bet-amount-wrapper">
                        <div class="bet-label-text">注码</div>
                        <div class="multi-bet-amount" id="tieAmount">0</div>
                    </div>
                    <div class="multi-bet-control">
                        <button class="decBet" data-type="tie">-</button>
                        <button class="incBet" data-type="tie">+</button>
                    </div>
                    <div class="quick-bet-row">
                        <button class="quick-bet" data-type="tie" data-val="100">+100</button>
                        <button class="quick-bet" data-type="tie" data-val="500">+500</button>
                        <button class="quick-bet" data-type="tie" data-val="1000">+1k</button>
                    </div>
                </div>
            </div>

            <div class="data-stack">
                <div class="data-item"><label>🌀 总下注</label><value id="totalBetAmount">0</value></div>
                <div class="data-item"><label>⚡ 最高连胜</label><value id="maxStreak">0</value></div>
            </div>

            <div class="stake-txt">✨ 流光注码 ✨</div>
            <div class="timer-text" id="timerDisplay">⏱️ 1.5s</div>
            <div class="speed-select">
                <button class="speed-btn" data-speed="1">🐢 1x</button>
                <button class="speed-btn active" data-speed="2">⚡ 2x</button>
                <button class="speed-btn" data-speed="3">🔥 3x</button>
            </div>

            <div class="history-area">
                <div class="history-title">📜 灵境回响</div>
                <div class="history-grid" id="historyGrid"></div>
                <div class="record-list" id="recordList"><div style="text-align:center; color:#aaa;">✨ 无痕 ✨</div></div>
            </div>

            <div class="exec-row">
                <button class="exec-btn main-go" id="startBattleBtn">🐉⚔️🐅 龙虎裁决</button>
                <button class="exec-btn my-history-btn" id="clearStatsBtn">🌊 清空印记</button>
            </div>

            <div class="bottom-stats">
                <div class="stat-card"><span>🏆 总场次</span><span id="totalRounds">0</span></div>
                <div class="stat-card"><span>📈 胜率</span><span id="winRate">0%</span></div>
            </div>
        </div>
    </div>
</div>

<script>
    // ---------- 游戏核心 ----------
    let balance = 10000;
    let dragonBet = 0, tigerBet = 0, tieBet = 0;
    let totalRounds = 0, winCount = 0, currentStreak = 0, maxStreak = 0;
    let historyResults = [];
    let roundRecords = [];
    let currentSpeed = 2;
    let battleTimeout = null;
    let isBattling = false;
    let forceNextResult = null;
    
    // 续押记忆：保存上一局的注码（开战前记录的）
    let lastBet = { dragon: 0, tiger: 0, tie: 0 };

    // DOM
    const balanceSpan = document.getElementById('balanceAmount');
    const dragonAmountSpan = document.getElementById('dragonAmount');
    const tigerAmountSpan = document.getElementById('tigerAmount');
    const tieAmountSpan = document.getElementById('tieAmount');
    const totalBetSpan = document.getElementById('totalBetAmount');
    const timerDisplay = document.getElementById('timerDisplay');
    const historyGridDiv = document.getElementById('historyGrid');
    const recordListDiv = document.getElementById('recordList');
    const totalRoundsSpan = document.getElementById('totalRounds');
    const winRateSpan = document.getElementById('winRate');
    const maxStreakSpan = document.getElementById('maxStreak');
    const battleResultDiv = document.getElementById('battleResult');
    const dragonWord = document.getElementById('dragonWord');
    const tigerWord = document.getElementById('tigerWord');
    const sceneBgDiv = document.getElementById('sceneBg');

    function updateUI() {
        balanceSpan.innerText = Math.floor(balance);
        dragonAmountSpan.innerText = dragonBet;
        tigerAmountSpan.innerText = tigerBet;
        tieAmountSpan.innerText = tieBet;
        totalBetSpan.innerText = dragonBet + tigerBet + tieBet;
        document.querySelectorAll('.multi-bet-item').forEach(el => el.classList.remove('selected'));
        if(dragonBet > 0) document.getElementById('betDragonItem')?.classList.add('selected');
        if(tigerBet > 0) document.getElementById('betTigerItem')?.classList.add('selected');
        if(tieBet > 0) document.getElementById('betTieItem')?.classList.add('selected');
        totalRoundsSpan.innerText = totalRounds;
        let winRateVal = totalRounds === 0 ? 0 : ((winCount / totalRounds)*100).toFixed(1);
        winRateSpan.innerText = winRateVal + '%';
        maxStreakSpan.innerText = maxStreak;
    }

    function updateHistoryVisual() {
        historyGridDiv.innerHTML = '';
        [...historyResults].slice(-10).reverse().forEach(res => {
            let cell = document.createElement('div');
            cell.classList.add('history-cell');
            if(res === '龙') { cell.classList.add('dragon'); cell.innerText = '龍'; }
            else if(res === '虎') { cell.classList.add('tiger'); cell.innerText = '虎'; }
            else if(res === '和') { cell.classList.add('tie'); cell.innerText = '和'; }
            else cell.innerText = '?';
            historyGridDiv.appendChild(cell);
        });
        recordListDiv.innerHTML = roundRecords.length === 0 ? '<div style="text-align:center; color:#aaa;">✨ 无痕 ✨</div>' : '';
        roundRecords.slice().reverse().forEach(rec => {
            let div = document.createElement('div');
            div.className = 'record-item';
            div.innerHTML = `<span>${rec.time}</span><span class="${rec.status === 'win' ? 'record-win' : 'record-lose'}">${rec.status === 'win' ? '✓ +' + rec.profit : '✗ -' + rec.loss}</span>`;
            recordListDiv.appendChild(div);
        });
    }

    function addHistoryRecord(result) { historyResults.unshift(result); if(historyResults.length > 10) historyResults.pop(); updateHistoryVisual(); }
    function addRoundRecord(isWin, profitOrLoss, amount) {
        let timeStr = new Date().toLocaleTimeString().slice(0,8);
        roundRecords.unshift({ time: timeStr, status: isWin ? 'win' : 'lose', profit: profitOrLoss, loss: amount });
        if(roundRecords.length > 15) roundRecords.pop();
        updateHistoryVisual();
    }
    function modifyBet(type, delta) {
        if(isBattling) return;
        let newVal = Math.max(0, (type==='dragon'? dragonBet : type==='tiger'? tigerBet : tieBet) + delta);
        let totalOther = (type!=='dragon'? dragonBet:0) + (type!=='tiger'? tigerBet:0) + (type!=='tie'? tieBet:0);
        if(totalOther + newVal > balance) return;
        if(type === 'dragon') dragonBet = newVal;
        else if(type === 'tiger') tigerBet = newVal;
        else tieBet = newVal;
        updateUI();
    }
    function setQuickBet(type, amount) {
        if(isBattling) return;
        let oldVal = type==='dragon'? dragonBet : type==='tiger'? tigerBet : tieBet;
        let newVal = oldVal + amount;
        let totalOther = (type!=='dragon'? dragonBet:0) + (type!=='tiger'? tigerBet:0) + (type!=='tie'? tieBet:0);
        if(totalOther + newVal > balance) return;
        if(type === 'dragon') dragonBet = newVal;
        else if(type === 'tiger') tigerBet = newVal;
        else tieBet = newVal;
        updateUI();
    }
    
    // 续押功能
    function repeatLastBet() {
        if(isBattling) return;
        let totalRequired = lastBet.dragon + lastBet.tiger + lastBet.tie;
        if(totalRequired === 0) {
            battleResultDiv.innerText = '⚠️ 无上一局记录 ⚠️';
            setTimeout(() => { if(battleResultDiv.innerText === '⚠️ 无上一局记录 ⚠️') battleResultDiv.innerText = '⚔️ 霓虹战域 ⚔️'; }, 800);
            return;
        }
        if(totalRequired > balance) {
            battleResultDiv.innerText = '❌ 余额不足续押 ❌';
            return;
        }
        dragonBet = lastBet.dragon;
        tigerBet = lastBet.tiger;
        tieBet = lastBet.tie;
        updateUI();
        battleResultDiv.innerText = '🔄 已续押上局注码';
        setTimeout(() => { if(battleResultDiv.innerText === '🔄 已续押上局注码') battleResultDiv.innerText = '⚔️ 霓虹战域 ⚔️'; }, 1000);
    }

    function getBattleInterval() { return currentSpeed === 1 ? 2000 : currentSpeed === 2 ? 1500 : 1000; }

    function startBattle() {
        if(isBattling) return;
        let totalBet = dragonBet + tigerBet + tieBet;
        if(totalBet === 0) { battleResultDiv.innerText = '⚠️ 凝注灵蕴 ⚠️'; setTimeout(() => { if(battleResultDiv.innerText === '⚠️ 凝注灵蕴 ⚠️') battleResultDiv.innerText = '⚔️ 霓虹战域 ⚔️'; }, 800); return; }
        if(totalBet > balance) { battleResultDiv.innerText = '❌ 灵蕴不足 ❌'; return; }
        
        // 记录当前注码到续押记忆（开战前）
        lastBet = { dragon: dragonBet, tiger: tigerBet, tie: tieBet };
        
        isBattling = true;
        balance -= totalBet;
        updateUI();

        let result = forceNextResult;
        if(!result) {
            let rand = Math.random() * 100;
            if(rand < 45) result = '龙';
            else if(rand < 90) result = '虎';
            else result = '和';
        } else { forceNextResult = null; }

        let winAmount = 0, isPlayerWin = false;
        if(result === '龙' && dragonBet > 0) { winAmount = dragonBet * 2; isPlayerWin = true; }
        else if(result === '虎' && tigerBet > 0) { winAmount = tigerBet * 2; isPlayerWin = true; }
        else if(result === '和' && tieBet > 0) { winAmount = tieBet * 8; isPlayerWin = true; }

        if(isPlayerWin) { balance += winAmount; winCount++; currentStreak++; if(currentStreak > maxStreak) maxStreak = currentStreak; addRoundRecord(true, winAmount, 0); battleResultDiv.innerText = `✨ ${result} 胜 · +${winAmount} ✨`; }
        else { currentStreak = 0; let lossTotal = result === '龙'? dragonBet : (result==='虎'? tigerBet : tieBet); addRoundRecord(false, 0, lossTotal); battleResultDiv.innerText = `🌑 ${result} 噬光 · 败 🌑`; }
        totalRounds++; maxStreak = Math.max(maxStreak, currentStreak);
        addHistoryRecord(result);
        if(result === '龙') { dragonWord.classList.add('highlight-win'); setTimeout(() => dragonWord.classList.remove('highlight-win'), 300); }
        else if(result === '虎') { tigerWord.classList.add('highlight-win'); setTimeout(() => tigerWord.classList.remove('highlight-win'), 300); }
        else { dragonWord.classList.add('highlight-win'); tigerWord.classList.add('highlight-win'); setTimeout(() => { dragonWord.classList.remove('highlight-win'); tigerWord.classList.remove('highlight-win'); }, 300); }
        document.getElementById('battleResult').classList.add('pop'); setTimeout(() => document.getElementById('battleResult').classList.remove('pop'), 200);
        updateUI();
        dragonBet = 0; tigerBet = 0; tieBet = 0; updateUI();
        if(battleTimeout) clearTimeout(battleTimeout);
        battleTimeout = setTimeout(() => { isBattling = false; if(totalRounds >= 0) battleResultDiv.innerText = '⚔️ 霓虹战域 ⚔️'; battleTimeout = null; }, 1500);
    }

    function resetGame() { if(isBattling) return; balance = 10000; dragonBet = tigerBet = tieBet = 0; totalRounds = winCount = currentStreak = maxStreak = 0; historyResults = []; roundRecords = []; lastBet = { dragon:0, tiger:0, tie:0 }; updateUI(); updateHistoryVisual(); battleResultDiv.innerText = '✨ 灵蕴重生 ✨'; setTimeout(() => { if(battleResultDiv.innerText === '✨ 灵蕴重生 ✨') battleResultDiv.innerText = '⚔️ 霓虹战域 ⚔️'; }, 1200); if(battleTimeout) clearTimeout(battleTimeout); isBattling = false; }
    function clearStatsOnly() { if(isBattling) return; totalRounds = winCount = currentStreak = maxStreak = 0; historyResults = []; roundRecords = []; updateUI(); updateHistoryVisual(); battleResultDiv.innerText = '🌊 印记归零 🌊'; setTimeout(() => { if(battleResultDiv.innerText === '🌊 印记归零 🌊') battleResultDiv.innerText = '⚔️ 霓虹战域 ⚔️'; }, 1000); }

    // 背景上传功能
    function setBackgroundFromFile(file) {
        if(!file) return;
        const url = URL.createObjectURL(file);
        const isVideo = file.type.startsWith('video/');
        sceneBgDiv.innerHTML = '';
        if(isVideo) {
            const video = document.createElement('video');
            video.src = url;
            video.autoplay = true;
            video.loop = true;
            video.muted = true;
            video.playsInline = true;
            sceneBgDiv.appendChild(video);
            video.play().catch(e=>console.log);
        } else {
            const img = document.createElement('img');
            img.src = url;
            sceneBgDiv.appendChild(img);
        }
    }

    // 管理员面板（带背景上传）
    function showAdminModal() {
        let modal = document.createElement('div');
        modal.className = 'admin-modal';
        modal.innerHTML = `
            <div class="admin-panel">
                <h3>🔐 管理员控制台</h3>
                <div class="admin-row"><label>余额修改</label><input type="number" id="adminBalance" value="${Math.floor(balance)}"><button id="setBalanceBtn">设置</button></div>
                <div class="admin-row"><label>🎲 强制开牌</label>
                    <div class="force-result-group">
                        <button class="force-btn" data-force="龙">🐉 龙</button>
                        <button class="force-btn" data-force="虎">🐅 虎</button>
                        <button class="force-btn" data-force="和">⚖️ 和</button>
                        <button class="force-btn" data-force="null">🚫 取消</button>
                    </div>
                </div>
                <div class="admin-row"><label>🖼️ 背景上传</label>
                    <div class="bg-upload-group">
                        <button class="bg-upload-btn" id="uploadImageBtn">📷 上传图片</button>
                        <button class="bg-upload-btn" id="uploadVideoBtn">🎬 上传视频</button>
                        <button class="bg-upload-btn" id="resetBgBtn">🌌 重置背景</button>
                    </div>
                </div>
                <div class="admin-row"><label>📊 总场次: ${totalRounds}</label><label>胜率: ${totalRounds===0?0:((winCount/totalRounds)*100).toFixed(1)}%</label></div>
                <button class="admin-close" id="closeAdminBtn">关闭面板</button>
            </div>
        `;
        document.body.appendChild(modal);
        
        document.getElementById('setBalanceBtn')?.addEventListener('click', () => {
            let newBal = parseInt(document.getElementById('adminBalance').value);
            if(!isNaN(newBal) && newBal >= 0) { balance = newBal; updateUI(); battleResultDiv.innerText = '⚙️ 余额已修改'; setTimeout(() => { if(battleResultDiv.innerText === '⚙️ 余额已修改') battleResultDiv.innerText = '⚔️ 霓虹战域 ⚔️'; }, 1200); }
            modal.remove();
        });
        modal.querySelectorAll('.force-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                let forceVal = btn.getAttribute('data-force');
                if(forceVal === 'null') forceNextResult = null;
                else forceNextResult = forceVal;
                battleResultDiv.innerText = forceNextResult ? `🔮 已强制: ${forceNextResult}` : `🔮 取消强制`;
                setTimeout(() => { if(battleResultDiv.innerText.includes('强制')) battleResultDiv.innerText = '⚔️ 霓虹战域 ⚔️'; }, 1500);
                modal.remove();
            });
        });
        document.getElementById('uploadImageBtn')?.addEventListener('click', () => {
            let input = document.createElement('input');
            input.type = 'file';
            input.accept = 'image/*';
            input.onchange = (e) => { if(e.target.files[0]) setBackgroundFromFile(e.target.files[0]); modal.remove(); };
            input.click();
        });
