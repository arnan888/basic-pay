    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: bold;
    background: #1a1a28;
    box-shadow: inset 1px 1px 3px black, inset -1px -1px 2px rgba(255,255,255,0.05);
}
.history-cell.dragon { background: #ff3366; color: white; box-shadow: 0 0 12px #ff3366; }
.history-cell.tiger { background: #33aaff; color: white; box-shadow: 0 0 12px #33aaff; }
.history-cell.tie { background: #aa66ff; color: white; box-shadow: 0 0 12px #aa66ff; }
.record-list {
    max-height: 130px;
    overflow-y: auto;
    font-size: 13px;
}
.record-item {
    display: flex;
    justify-content: space-between;
    padding: 8px 15px;
    border-bottom: 1px solid rgba(255,200,100,0.15);
    color: #ddd;
}
.record-win { color: #88ffaa; font-weight: bold; text-shadow: 0 0 3px #00cc66; }
.record-lose { color: #ff8888; font-weight: bold; }

.exec-row {
    display: flex;
    gap: 20px;
    margin: 20px 0 20px;
}
.exec-btn {
    flex: 1;
    padding: 16px 8px;
    border-radius: 50px;
    font-weight: bold;
    font-size: 18px;
    text-align: center;
    cursor: pointer;
    background: #1f1f30;
    color: #f5f0e0;
    border: none;
    box-shadow: 5px 7px 12px rgba(0,0,0,0.6), -2px -2px 4px rgba(255,255,255,0.02);
    transition: 0.04s linear;
}
.exec-btn:active {
    transform: translateY(3px);
    box-shadow: inset 3px 3px 6px black;
}
.main-go {
    background: linear-gradient(135deg, #ff6644, #dd4422);
    color: #fff6cf;
    text-shadow: 0 0 6px #ff8844;
    box-shadow: 0 0 15px #ff6644;
}
.my-history-btn {
    background: #1f5a3e;
    box-shadow: 0 0 8px #44dd88;
}
.bottom-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: 18px;
    margin-bottom: 8px;
}
.stat-card {
    background: #12121e;
    border-radius: 30px;
    padding: 12px 8px;
    text-align: center;
    box-shadow: 6px 6px 12px black, -2px -2px 5px rgba(255,255,255,0.02);
}
.stat-card span:first-child {
    display: block;
    font-size: 13px;
    color: #bbaaff;
}
.stat-card span:last-child {
    font-size: 28px;
    font-weight: bold;
    color: #ffcc66;
    text-shadow: 0 0 8px #ffaa44;
}

/* 管理员面板样式 */
.admin-modal {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.92);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
}
.admin-panel {
    background: #12121f;
    width: 90%;
    max-width: 420px;
    border-radius: 48px;
    padding: 24px 20px;
    border: 1px solid #ffaa55;
    box-shadow: 0 0 50px rgba(255,170,0,0.3);
    max-height: 85vh;
    overflow-y: auto;
}
.admin-panel h3 {
    color: #ffcc77;
    text-align: center;
    margin-bottom: 20px;
    font-size: 24px;
}
.admin-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 16px 0;
    gap: 12px;
    flex-wrap: wrap;
}
.admin-row label {
    color: #ddd;
    font-weight: bold;
    min-width: 90px;
}
.admin-row input, .admin-row select {
    flex: 1;
    background: #1e1e30;
    border: 1px solid #ffaa66;
    border-radius: 40px;
    padding: 10px 16px;
    color: #ffdd99;
    font-size: 16px;
    outline: none;
}
.admin-row button {
    background: #ffaa44;
    border: none;
    border-radius: 40px;
    padding: 10px 20px;
    font-weight: bold;
    cursor: pointer;
}
.admin-close {
    width: 100%;
    margin-top: 20px;
    background: #333355;
    color: white;
}
.force-result-group {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 12px;
    flex-wrap: wrap;
}
.force-btn {
    background: #2a2a4a;
    border: none;
    border-radius: 30px;
    padding: 8px 20px;
    color: #ffcc88;
