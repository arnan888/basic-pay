
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>龙虎斗 · 充值口资料</title>
    <style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
}
body {
    background: #0a0a0f;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: "PingFang SC", "Microsoft YaHei", "Helvetica Neue", sans-serif;
    padding: 16px;
}

/* 外框 */
.container-outer {
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    background: linear-gradient(145deg, #0f0f17, #08080c);
    border-radius: 32px;
    padding: 14px;
    box-shadow: 0 20px 35px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.05);
    position: relative;
}
.container-outer::after {
    content: '';
    position: absolute;
    top: -3px;
    left: -3px;
    right: -3px;
    bottom: -3px;
    background: radial-gradient(circle at 30% 20%, rgba(255, 80, 40, 0.55), rgba(255, 50, 30, 0.2), transparent 70%);
    border-radius: 34px;
    z-index: -1;
    filter: blur(18px);
    opacity: 0.65;
}
.container {
    background: #0f0f16;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: inset 0 0 15px rgba(0,0,0,0.5), inset 0 0 4px rgba(255,255,255,0.05);
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
}

/* 战斗场景 */
.battle-scene {
    position: relative;
    margin: 18px;
    border-radius: 24px;
    overflow: hidden;
    background: #030308;
    height: 32vh;
    min-height: 200px;
    flex-shrink: 0;
    box-shadow: 0 10px 25px rgba(0,0,0,0.6), inset 0 0 40px rgba(255,80,40,0.2);
}
.scene-bg {
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 30% 40%, #1a1218, #050508);
    background-size: cover;
    background-position: center;
    z-index: 1;
}
.dragon-word, .tiger-word {
    position: absolute;
    bottom: 20px;
    font-size: 64px;
    font-weight: 900;
    text-shadow: 0 0 20px currentColor, 0 0 40px currentColor, 6px 6px 0 rgba(0,0,0,0.5);
    z-index: 15;
    transition: all 0.12s cubic-bezier(0.34, 1.2, 0.64, 1);
    opacity: 0.98;
}
.dragon-word { left: 18px; color: #ff3366; text-shadow: 0 0 20px #ff3366, 0 0 40px #ff1144; }
.tiger-word { right: 18px; color: #33aaff; text-shadow: 0 0 20px #33aaff, 0 0 40px #0088ff; }
.highlight-win {
    transform: scale(1.35);
    text-shadow: 0 0 55px currentColor, 0 0 90px currentColor;
    opacity: 1;
}
.battle-result {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(10,10,20,0.85);
    backdrop-filter: blur(12px);
    padding: 6px 24px;
    border-radius: 60px;
    color: #ffcc88;
    font-weight: bold;
    font-size: 20px;
    z-index: 25;
    white-space: nowrap;
    border: 1px solid #ffaa55;
    box-shadow: 0 0 30px rgba(255,170,85,0.5);
    pointer-events: none;
}
.battle-result.pop {
    transform: translateX(-50%) scale(1.15);
    background: rgba(255,180,60,0.95);
    color: #120f1a;
}

/* 投注区 */
.bet-section {
    background: #0c0c14;
    margin: 16px 18px 20px 18px;
    border-radius: 28px;
    padding: 18px 14px;
    max-height: calc(100vh - 280px);
    overflow-y: auto;
}

/* 顶部用户栏 */
.user-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #09090f;
    border-radius: 40px;
    padding: 10px 20px;
    margin-bottom: 20px;
}
.user-info {
    display: flex;
    align-items: center;
    gap: 12px;
}
.avatar {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #ffaa44, #ff6644);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
}
.user-details {
    display: flex;
    flex-direction: column;
}
.username {
    color: #ffcc88;
    font-weight: bold;
    font-size: 16px;
}
.user-id {
    color: #888;
    font-size: 11px;
}
.balance-area {
    text-align: right;
}
.balance-label {
    font-size: 11px;
    color: #aaa;
}
.balance-amount {
    font-size: 22px;
    font-weight: bold;
    color: #ffcc66;
    text-shadow: 0 0 6px #ffaa33;
}
.btn-icon {
    background: #1e1e2c;
    border: none;
    border-radius: 30px;
    padding: 6px 14px;
    color: #ffecb3;
    font-size: 12px;
    cursor: pointer;
    margin-left: 8px;
}
.btn-icon:active { transform: translateY(1px); }

/* 充值提现按钮行 */
.action-buttons {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
}
.action-btn {
    flex: 1;
    background: linear-gradient(135deg, #2a2a4a, #1f1f3a);
    border: 1px solid #ffaa55;
    border-radius: 40px;
    padding: 12px;
    text-align: center;
    color: #ffdd99;
    font-weight: bold;
    cursor: pointer;
}
.action-btn:active { transform: translateY(2px); }
.recharge { background: linear-gradient(135deg, #3a5a3a, #2a4a2a); border-color: #88ff88; color: #ccffcc; }
.withdraw { background: linear-gradient(135deg, #5a3a3a, #4a2a2a); border-color: #ff8888; color: #ffcccc; }

/* 续押按钮 */
.repeat-row { margin-bottom: 18px; }
.repeat-bet-btn {
    width: 100%;
    background: linear-gradient(135deg, #2a2a4a, #1f1f3a);
    border: 1px solid #ffaa55;
    border-radius: 60px;
    padding: 12px;
    color: #ffdd99;
    font-size: 18px;
    font-weight: bold;
    text-align: center;
    cursor: pointer;
}
.repeat-bet-btn:active { transform: translateY(2px); }

/* 投注卡片 */
.multi-bet-item {
    background: #13131c;
    border-radius: 32px;
    padding: 14px 8px;
    text-align: center;
    margin-bottom: 18px;
    border: 1px solid rgba(255,170,100,0.15);
}
.multi-bet-item.selected {
    background: linear-gradient(135deg, #ffaa44, #ff8844);
    transform: scale(0.98);
    box-shadow: 0 0 25px #ffaa44;
}
.multi-bet-name {
    font-size: 32px;
    font-weight: 900;
    margin-bottom: 10px;
}
.multi-bet-name.dragon { color: #ff6688; }
.multi-bet-name.tiger { color: #66aaff; }
.multi-bet-name.tie { color: #cc88ff; }
.multi-bet-item.selected .multi-bet-name { color: #2a1f0a; }
.multi-bet-amount {
    font-size: 38px;
    font-weight: 900;
    color: #ffcc66;
}
.multi-bet-control {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin: 12px 0 8px;
}
.multi-bet-control button {
    background: #1a1a28;
    border: none;
    border-radius: 36px;
    padding: 6px 18px;
    color: #ffcc77;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
}
.quick-bet-row {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 12px;
    flex-wrap: wrap;
}
.quick-bet {
    background: #181826;
    border: none;
    border-radius: 40px;
    padding: 6px 18px;
    color: #ffcc77;
    font-size: 14px;
    cursor: pointer;
}

/* 数据面板 */
.data-stack {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 20px 0 16px;
}
.data-item {
    background: #0e0e18;
    border-radius: 28px;
    padding: 14px 8px;
    text-align: center;
}
.data-item label { font-size: 14px; color: #aa99dd; }
.data-item value { font-size: 32px; font-weight: bold; color: #ffcc66; display: block; }

.timer-text {
    text-align: center;
    font-size: 24px;
    color: #ffdd88;
    margin: 10px 0;
}
.speed-select {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin: 10px 0 12px;
}
.speed-btn {
    background: #18182a;
    border: none;
    border-radius: 60px;
    padding: 6px 28px;
    color: #aaaacc;
    cursor: pointer;
}
.speed-btn.active {
    background: #ffaa44;
    color: #121212;
}

/* 历史 */
.history-area {
    background: #0b0b12;
    border-radius: 32px;
    padding: 16px;
    margin: 16px 0;
}
.history-title { font-size: 15px; color: #ffcc77; text-align: center; margin-bottom: 14px; }
.history-grid {
    display: grid;
    grid-template-columns: repeat(10, 34px);
    gap: 8px;
    justify-content: center;
    margin-bottom: 18px;
}
.history-cell {
    width: 34px;
    height: 34px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    background: #1a1a28;
}
.history-cell.dragon { background: #ff3366; color: white; }
.history-cell.tiger { background: #33aaff; color: white; }
.history-cell.tie { background: #aa66ff; color: white; }
.record-list { max-height: 130px; overflow-y: auto; font-size: 13px; }
.record-item {
    display: flex;
    justify-content: space-between;
    padding: 8px 15px;
    border-bottom: 1px solid rgba(255,200,100,0.15);
    color: #ddd;
}
.record-win { color: #88ffaa; }
.record-lose { color: #ff8888; }

.exec-row {
    display: flex;
    gap: 20px;
    margin: 20px 0 20px;
}
.exec-btn {
    flex: 1;
    padding: 16px 8px;
    border-radius: 50px;
    font-weight: bold;
    font-size: 18px;
    text-align: center;
    cursor: pointer;
    background: #1f1f30;
    color: #f5f0e0;
    border: none;
}
.exec-btn:active { transform: translateY(2px); }
.main-go {
    background: linear-gradient(135deg, #ff6644, #dd4422);
    box-shadow: 0 0 15px #ff6644;
}
.bottom-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: 18px;
}
.stat-card {
    background: #12121e;
    border-radius: 30px;
    padding: 12px 8px;
    text-align: center;
}
.stat-card span:first-child { font-size: 13px; color: #bbaaff; }
.stat-card span:last-child { font-size: 28px; font-weight: bold; color: #ffcc66; }

/* 模态框 */
.modal {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.95);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
}
.modal-content {
    background: #12121f;
    width: 85%;
    max-width: 380px;
    border-radius: 48px;
    padding: 28px 20px;
    border: 1px solid #ffaa55;
}
.modal-content h3 { color: #ffcc77; text-align: center; margin-bottom: 20px; }
.modal-content input {
    width: 100%;
    background: #1e1e30;
    border: 1px solid #ffaa66;
    border-radius: 40px;
    padding: 12px 16px;
    color: #ffdd99;
    font-size: 16px;
    margin: 12px 0;
}
.modal-content button {
    background: #ffaa44;
    border: none;
    border-radius: 40px;
    padding: 12px;
    font-weight: bold;
    width: 100%;
    margin-top: 8px;
    cursor: pointer;
}
.modal-close {
    background: #333355;
    color: white;
    margin-top: 12px;
}
.recharge-option {
    display: flex;
    gap: 12px;
    margin: 12px 0;
}
.recharge-option button {
    flex: 1;
    background: #2a2a4a;
    color: #ffcc88;
}
</style>
</head>
<body>
<div class="container-outer" id="app">
    <div class="container">
        <div class="battle-scene">
            <div class="scene-bg" id="sceneBg"><div style="width:100%;height:100%;background:radial-gradient(circle at 30% 40%, #1a1218, #050508);"></div></div>
            <div class="dragon-word" id="dragonWord">龍</div>
            <div class="tiger-word" id="tigerWord">虎</div>
            <div class="battle-result" id="battleResult">⚔️ 龙虎相争 ⚔️</div>
        </div>
        <div class="bet-section" id="mainContent"></div>
    </div>
</div>

<script>
    // ---------- 用户系统 ----------
    let currentUser = null;
    let users = JSON.parse(localStorage.getItem('dragon_users') || '[]');
    
    // 游戏状态
    let balance = 0;
    let dragonBet = 0, tigerBet = 0, tieBet = 0;
    let totalRounds = 0, winCount = 0, currentStreak = 0, maxStreak = 0;
    let historyResults = [];
    let roundRecords = [];
    let currentSpeed = 2;
    let isBattling = false;
    let battleTimeout = null;
    let forceNextResult = null;
    let lastBet = { dragon: 0, tiger: 0, tie: 0 };
    
    // 保存用户数据
    function saveUserData() {
        if(!currentUser) return;
        const user = users.find(u => u.id === currentUser.id);
        if(user) {
            user.balance = balance;
            user.totalRounds = totalRounds;
            user.winCount = winCount;
            user.maxStreak = maxStreak;
            user.historyResults = historyResults;
            user.roundRecords = roundRecords;
            localStorage.setItem('dragon_users', JSON.stringify(users));
        }
    }
    
    function loadUserData() {
        if(!currentUser) return;
        balance = currentUser.balance ?? 1000;
        totalRounds = currentUser.totalRounds ?? 0;
        winCount = currentUser.winCount ?? 0;
        maxStreak = currentUser.maxStreak ?? 0;
        historyResults = currentUser.historyResults ?? [];
        roundRecords = currentUser.roundRecords ?? [];
        currentStreak = 0;
        dragonBet = tigerBet = tieBet = 0;
        updateUI();
        updateHistoryVisual();
    }
    
    // 注册/登录
    function showLoginModal() {
        const modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `
            <div class="modal-content">
                <h3>🔐 登录 / 注册</h3>
                <input type="text" id="loginUsername" placeholder="用户名" autocomplete="off">
                <input type="password" id="loginPassword" placeholder="密码">
                <button id="doLoginBtn">登录</button>
                <button id="doRegisterBtn">注册新账号</button>
                <button class="modal-close" id="closeLoginBtn">关闭</button>
            </div>
        `;
        document.body.appendChild(modal);
        
        document.getElementById('doLoginBtn').onclick = () => {
            const username = document.getElementById('loginUsername').value.trim();
            const pwd = document.getElementById('loginPassword').value;
            const user = users.find(u => u.username === username && u.password === pwd);
            if(user) {
                currentUser = user;
                loadUserData();
                renderMainUI();
                modal.remove();
            } else {
                alert('用户名或密码错误');
            }
        };
        document.getElementById('doRegisterBtn').onclick = () => {
            const username = document.getElementById('loginUsername').value.trim();
            const pwd = document.getElementById('loginPassword').value;
            if(!username || !pwd) { alert('请输入用户名和密码'); return; }
            if(users.find(u => u.username === username)) { alert('用户名已存在'); return; }
            const newUser = {
                id: Date.now(),
                username,
                password: pwd,
                balance: 1000,
                totalRounds: 0,
                winCount: 0,
                maxStreak: 0,
                historyResults: [],
                roundRecords: []
            };
            users.push(newUser);
            localStorage.setItem('dragon_users', JSON.stringify(users));
            currentUser = newUser;
            loadUserData();
            renderMainUI();
            modal.remove();
        };
        document.getElementById('closeLoginBtn').onclick = () => modal.remove();
    }
    
    // 充值弹窗
    function showRechargeModal() {
        const modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `
            <div class="modal-content">
                <h3>💰 模拟充值</h3>
                <div class="recharge-option">
                    <button data-amount="100">+100</button>
                    <button data-amount="500">+500</button>
                    <button data-amount="1000">+1000</button>
                    <button data-amount="5000">+5000</button>
                </div>
                <input type="number" id="customAmount" placeholder="自定义金额">
                <button id="confirmRechargeBtn">确认充值</button>
                <button class="modal-close" id="closeRechargeBtn">关闭</button>
            </div>
        `;
        document.body.appendChild(modal);
        
        modal.querySelectorAll('[data-amount]').forEach(btn => {
            btn.onclick = () => {
                const amt = parseInt(btn.getAttribute('data-amount'));
                balance += amt;
                saveUserData();
                updateUI();
                battleResultDiv.innerText = `💰 充值 +${amt}`;
                setTimeout(() => { if(battleResultDiv.innerText.includes('充值')) battleResultDiv.innerText = '⚔️ 龙虎相争 ⚔️'; }, 1500);
                modal.remove();
            };
        });
        document.getElementById('confirmRechargeBtn').onclick = () => {
            const amt = parseInt(document.getElementById('customAmount').value);
            if(amt > 0 && amt <= 100000) {
                balance += amt;
                saveUserData();
                updateUI();
                battleResultDiv.innerText = `💰 充值 +${amt}`;
                setTimeout(() => { if(battleResultDiv.innerText.includes('充值')) battleResultDiv.innerText = '⚔️ 龙虎相争 ⚔️'; }, 1500);
                modal.remove();
            } else { alert('请输入1-100000之间的金额'); }
        };
        document.getElementById('closeRechargeBtn').onclick = () => modal.remove();
    }
    
    // 提现弹窗
    function showWithdrawModal() {
        const modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `
            <div class="modal-content">
                <h3>💸 模拟提现</h3>
                <input type="number" id="withdrawAmount" placeholder="提现金额">
                <input type="text" id="withdrawAccount" placeholder="支付宝/微信账号">
                <button id="confirmWithdrawBtn">提交申请</button>
                <button class="modal-close" id="closeWithdrawBtn">关闭</button>
            </div>
        `;
        document.body.appendChild(modal);
        document.getElementById('confirmWithdrawBtn').onclick = () => {
            const amt = parseInt(document.getElementById('withdrawAmount').value);
            const account = document.getElementById('withdrawAccount').value.trim();
            if(amt > 0 && amt <= balance && account) {
                balance -= amt;
                saveUserData();
                updateUI();
                battleResultDiv.innerText = `💸 提现申请已提交 -${amt}`;
                setTimeout(() => { if(battleResultDiv.innerText.includes('提现')) battleResultDiv.innerText = '⚔️ 龙虎相争 ⚔️'; }, 1500);
                modal.remove();
            } else { alert('金额无效或余额不足或未填写账号'); }
        };
        document.getElementById('closeWithdrawBtn').onclick = () => modal.remove();
    }
    
    // 个人中心
    function showProfileModal() {
        const modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `
            <div class="modal-content">
                <h3>👤 个人中心</h3>
                <p style="color:#ddd; text-align:center; margin:10px 0">用户名: ${currentUser?.username}</p>
                <p style="color:#ddd; text-align:center">用户ID: ${currentUser?.id}</p>
                <button id="logoutBtn">🚪 退出登录</button>
                <button class="modal-close" id="closeProfileBtn">关闭</button>
            </div>
        `;
        document.body.appendChild(modal);
        document.getElementById('logoutBtn').onclick = () => {
            currentUser = null;
            modal.remove();
            renderMainUI();
        };
        document.getElementById('closeProfileBtn').onclick = () => modal.remove();
    }
    
    // 游戏核心函数
    const battleResultDiv = document.getElementById('battleResult');
    const dragonWord = document.getElementById('dragonWord');
    const tigerWord = document.getElementById('tigerWord');
    
    function updateUI() {
        document.getElementById('balanceAmount').innerText = Math.floor(balance);
        document.getElementById('dragonAmount').innerText = dragonBet;
        document.getElementById('tigerAmount').innerText = tigerBet;
        document.getElementById('tieAmount').innerText = tieBet;
        document.getElementById('totalBetAmount').innerText = dragonBet + tigerBet + tieBet;
        document.getElementById('totalRounds').innerText = totalRounds;
        const winRateVal = totalRounds === 0 ? 0 : ((winCount / totalRounds)*100).toFixed(1);
        document.getElementById('winRate').innerText = winRateVal + '%';
        document.getElementById('maxStreak').innerText = maxStreak;
        document.querySelectorAll('.multi-bet-item').forEach(el => el.classList.remove('selected'));
        if(dragonBet > 0) document.getElementById('betDragonItem')?.classList.add('selected');
        if(tigerBet > 0) document.getElementById('betTigerItem')?.classList.add('selected');
        if(tieBet > 0) document.getElementById('betTieItem')?.classList.add('selected');
        document.getElementById('usernameDisplay').innerText = currentUser?.username || '游客';
        document.getElementById('userIdDisplay').innerText = `ID:${currentUser?.id}`;
    }
    
    function updateHistoryVisual() {
        const grid = document.getElementById('historyGrid');
        if(grid) {
            grid.innerHTML = '';
            [...historyResults].slice(-10).reverse().forEach(res => {
                const cell = document.createElement('div');
                cell.classList.add('history-cell');
                if(res === '龙') { cell.classList.add('dragon'); cell.innerText = '龍'; }
                else if(res === '虎') { cell.classList.add('tiger'); cell.innerText = '虎'; }
                else if(res === '和') { cell.classList.add('tie'); cell.innerText = '和'; }
                grid.appendChild(cell);
            });
        }
        const recordDiv = document.getElementById('recordList');
        if(recordDiv) {
            recordDiv.innerHTML = roundRecords.length === 0 ? '<div style="text-align:center; color:#aaa;">✨ 无记录 ✨</div>' : '';
            roundRecords.slice().reverse().forEach(rec => {
                const div = document.createElement('div');
                div.className = 'record-item';
                div.innerHTML = `<span>${rec.time}</span><span class="${rec.status === 'win' ? 'record-win' : 'record-lose'}">${rec.status === 'win' ? '✓ +' + rec.profit : '✗ -' + rec.loss}</span>`;
                recordDiv.appendChild(div);
            });
        }
    }
    
    function addHistoryRecord(result) { historyResults.unshift(result); if(historyResults.length > 10) historyResults.pop(); updateHistoryVisual(); saveUserData(); }
    function addRoundRecord(isWin, profitOrLoss, amount) {
        const timeStr = new Date().toLocaleTimeString().slice(0,8);
        roundRecords.unshift({ time: timeStr, status: isWin ? 'win' : 'lose', profit: profitOrLoss, loss: amount });
        if(roundRecords.length > 15) roundRecords.pop();
        updateHistoryVisual(); saveUserData();
    }
    function modifyBet(type, delta) {
        if(isBattling) return;
        let newVal = Math.max(0, (type==='dragon'? dragonBet : type==='tiger'? tigerBet : tieBet) + delta);
        const totalOther = (type!=='dragon'? dragonBet:0) + (type!=='tiger'? tigerBet:0) + (type!=='tie'? tieBet:0);
        if(totalOther + newVal > balance) return;
        if(type === 'dragon') dragonBet = newVal;
        else if(type === 'tiger') tigerBet = newVal;
        else tieBet = newVal;
        updateUI();
    }
    function setQuickBet(type, amount) {
        if(isBattling) return;
        const oldVal = type==='dragon'? dragonBet : type==='tiger'? tigerBet : tieBet;
        const newVal = oldVal + amount;
        const totalOther = (type!=='dragon'? dragonBet:0) + (type!=='tiger'? tigerBet:0) + (type!=='tie'? tieBet:0);
        if(totalOther + newVal > balance) return;
        if(type === 'dragon') dragonBet = newVal;
        else if(type === 'tiger') tigerBet = newVal;
        else tieBet = newVal;
        updateUI();
    }
    function repeatLastBet() {
        if(isBattling) return;
        const totalRequired = lastBet.dragon + lastBet.tiger + lastBet.tie;
        if(totalRequired === 0) { battleResultDiv.innerText = '⚠️ 无上局记录'; setTimeout(() => { if(battleResultDiv.innerText === '⚠️ 无上局记录') battleResultDiv.innerText = '⚔️ 龙虎相争 ⚔️'; }, 800); return; }
        if(totalRequired > balance) { battleResultDiv.innerText = '❌ 余额不足'; return; }
        dragonBet = lastBet.dragon; tigerBet = lastBet.tiger; tieBet = lastBet.tie;
        updateUI();
        battleResultDiv.innerText = '🔄 已续押';
        setTimeout(() => { if(battleResultDiv.innerText === '🔄 已续押') battleResultDiv.innerText = '⚔️ 龙虎相争 ⚔️'; }, 1000);
    }
    function getBattleInterval() { return currentSpeed === 1 ? 2000 : currentSpeed === 2 ? 1500 : 1000; }
    function startBattle() {
        if(isBattling) return;
        const totalBet = dragonBet + tigerBet + tieBet;
        if(totalBet === 0) { battleResultDiv.innerText = '⚠️ 请下注'; setTimeout(() => { if(battleResultDiv.innerText === '⚠️ 请下注') battleResultDiv.innerText = '⚔️ 龙虎相争 ⚔️'; }, 800); return; }
        if(totalBet > balance) { battleResultDiv.innerText = '❌ 余额不足'; return; }
        lastBet = { dragon: dragonBet, tiger: tigerBet, tie: tieBet };
        isBattling = true;
        balance -= totalBet;
        updateUI();
        let result = forceNextResult;
        if(!result) { const rand = Math.random() * 100; if(rand < 45) result = '龙'; else if(rand < 90) result = '虎'; else result = '和'; }
        else { forceNextResult = null; }
        let winAmount = 0, isPlayerWin = false;
        if(result === '龙' && dragonBet > 0) { winAmount = dragonBet * 2; isPlayerWin = true; }
        else if(result === '虎' && tigerBet > 0) { winAmount = tigerBet * 2; isPlayerWin = true; }
        else if(result === '和' && tieBet > 0) { winAmount = tieBet * 8; isPlayerWin = true; }
        if(isPlayerWin) { balance += winAmount; winCount++; currentStreak++; if(currentStreak > maxStreak) maxStreak = currentStreak; addRoundRecord(true, winAmount, 0); battleResultDiv.innerText = `✨ ${result} 胜 +${winAmount}`; }
        else { currentStreak = 0; const lossTotal = result === '龙'? dragonBet : (result==='虎'? tigerBet : tieBet); addRoundRecord(false, 0, lossTotal); battleResultDiv.innerText = `🌑 ${result} 胜 败北`; }
        totalRounds++; maxStreak = Math.max(maxStreak, currentStreak);
        addHistoryRecord(result);
        if(result === '龙') { dragonWord.classList.add('highlight-win'); setTimeout(() => dragonWord.classList.remove('highlight-win'), 300); }
        else if(result === '虎') { tigerWord.classList.add('highlight-win'); setTimeout(() => tigerWord.classList.remove('highlight-win'), 300); }
        else { dragonWord.classList.add('highlight-win'); tigerWord.classList.add('highlight-win'); setTimeout(() => { dragonWord.classList.remove('highlight-win'); tigerWord.classList.remove('highlight-win'); }, 300); }
        document.getElementById('battleResult').classList.add('pop'); setTimeout(() => document.getElementById('battleResult').classList.remove('pop'), 200);
        updateUI(); saveUserData();
        dragonBet = tigerBet = tieBet = 0; updateUI();
        if(battleTimeout) clearTimeout(battleTimeout);
        battleTimeout = setTimeout(() => { isBattling = false; battleResultDiv.innerText = '⚔️ 龙虎相争 ⚔️'; battleTimeout = null; }, 1500);
    }
    function resetGame() { if(isBattling) return; balance = 1000; dragonBet = tigerBet = tieBet = 0; totalRounds = winCount = currentStreak = maxStreak = 0; historyResults = []; roundRecords = []; lastBet = { dragon:0, tiger:0, tie:0 }; updateUI(); updateHistoryVisual(); saveUserData(); battleResultDiv.innerText = '✨ 重置完成'; setTimeout(() => { if(battleResultDiv.innerText === '✨ 重置完成') battleResultDiv.innerText = '⚔️ 龙虎相争 ⚔️'; }, 1200); if(battleTimeout) clearTimeout(battleTimeout); isBattling = false; }
    
    function renderMainUI() {
        if(!currentUser) { showLoginModal(); return; }
        document.getElementById('mainContent').innerHTML = `
            <div class="user-bar">
                <div class="user-info">
                    <div class="avatar">🐉</div>
                    <div class="user-details">
                        <span class="username" id="usernameDisplay">${currentUser.username}</span>
                        <span class="user-id" id="userIdDisplay">ID:${currentUser.id}</span>
                    </div>
                </div>
                <div class="balance-area">
                    <div class="balance-label">灵蕴余额</div>
                    <div class="balance-amount" id="balanceAmount">${balance}</div>
                </div>
                <button class="btn-icon" id="profileBtn">👤</button>
            </div>
            <div class="action-buttons">
                <div class="action-btn recharge" id="rechargeBtn">💰 充值</div>
                <div class="action-btn withdraw" id="withdrawBtn">💸 提现</div>
            </div>
            <div class="repeat-row"><div class="repeat-bet-btn" id="repeatBetBtn">🔄 续押 · 复制上局注码</div></div>
            <div style="display:flex; gap:14px; flex-wrap:wrap;">
                <div class="multi-bet-item" id="betDragonItem"><div class="multi-bet-name dragon">🐉 龙</div><div class="bet-amount-wrapper"><div class="bet-label-text">注码</div><div class="multi-bet-amount" id="dragonAmount">0</div></div><div class="multi-bet-control"><button class="decBet" data-type="dragon">-</button><button class="incBet" data-type="dragon">+</button></div><div class="quick-bet-row"><button class="quick-bet" data-type="dragon" data-val="100">+100</button><button class="quick-bet" data-type="dragon" data-val="500">+500</button><button class="quick-bet" data-type="dragon" data-val="1000">+1k</button></div></div>
                <div class="multi-bet-item" id="betTigerItem"><div class="multi-bet-name tiger">🐅 虎</div><div class="bet-amount-wrapper"><div class="bet-label-text">注码</div><div class="multi-bet-amount" id="tigerAmount">0</div></div><div class="multi-bet-control"><button class="decBet" data-type="tiger">-</button><button class="incBet" data-type="tiger">+</button></div><div class="quick-bet-row"><button class="quick-bet" data-type="tiger" data-val="100">+100</button><button class="quick-bet" data-type="tiger" data-val="500">+500</button><button class="quick-bet" data-type="tiger" data-val="1000">+1k</button></div></div>
                <div class="multi-bet-item" id="betTieItem"><div class="multi-bet-name tie">⚖️ 和</div><div class="bet-amount-wrapper"><div class="bet-label-text">注码</div><div class="multi-bet-amount" id="tieAmount">0</div></div><div class="multi-bet-control"><button class="decBet" data-type="tie">-</button><button class="incBet" data-type="tie">+</button></div><div class="quick-bet-row"><button class="quick-bet" data-type="tie" data-val="100">+100</button><button class="quick-bet" data-type="tie" data-val="500">+500</button><button class="quick-bet" data-type="tie" data-val="1000">+1k</button></div></div>
            </div>
            <div class="data-stack"><div class="data-item"><label>🌀 总下注</label><value id="totalBetAmount">0</value></div><div class="data-item"><label>⚡ 最高连胜</label><value id="maxStreak">0</value></div></div>
            <div class="timer-text" id="timerDisplay">⏱️ 1.5s</div>
            <div class="speed-select"><button class="speed-btn" data-speed="1">🐢 1x</button><button class="speed-btn active" data-speed="2">⚡ 2x</button><button class="speed-btn" data-speed="3">🔥 3x</button></div>
            <div class="history-area"><div class="history-title">📜 灵境回响</div><div class="history-grid" id="historyGrid"></div><div class="record-list" id="recordList"></div></div>
            <div class="exec-row"><button class="exec-btn main-go" id="startBattleBtn">🐉⚔️🐅 龙虎裁决</button><button class="exec-btn my-history-btn" id="resetGameBtn">🌊 重置游戏</button></div>
            <div class="bottom-stats"><div class="stat-card"><span>🏆 总场次</span><span id="totalRounds">0</span></div><div class="stat-card"><span>📈 胜率</span><span id="winRate">0%</span></div></div>
        `;
        updateUI(); updateHistoryVisual();
        document.getElementById('timerDisplay').innerText = '⏱️ 1.5s';
        document.getElementById('repeatBetBtn')?.addEventListener('click', repeatLastBet);
        document.getElementById('rechargeBtn')?.addEventListener('click', showRechargeModal);
        document.getElementById('withdrawBtn')?.addEventListener('click', showWithdrawModal);
        document.getElementById('profileBtn')?.addEventListener('click', showProfileModal);
        document.getElementById('startBattleBtn')?.addEventListener('click', startBattle);
        document.getElementById('resetGameBtn')?.addEventListener('click', resetGame);
        document.querySelectorAll('.decBet').forEach(btn => btn.addEventListener('click', (e) => { e.stopPropagation(); modifyBet(btn.getAttribute('data-type'), -100); }));
        document.querySelectorAll('.incBet').forEach(btn => btn.addEventListener('click', (e) => { e.stopPropagation(); modifyBet(btn.getAttribute('data-type'), 100); }));
        document.querySelectorAll('.quick-bet').forEach(btn => btn.addEventListener('click', (e) => { e.stopPropagation(); setQuickBet(btn.getAttribute('data-type'), parseInt(btn.getAttribute('data-val'))); }));
        document.querySelectorAll('.speed-btn').forEach(btn => btn.addEventListener('click', () => { document.querySelectorAll('.speed-btn').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); currentSpeed = parseInt(btn.getAttribute('data-speed')); const iv = getBattleInterval(); document.getElementById('timerDisplay').innerText = `⏱️ ${(iv/1000).toFixed(1)}s`; }));
    }
    renderMainUI();
</script>
</body>
</html>






