<body onclick="initSystem()">

    <canvas id="fxCanvas"></canvas>

    <div class="app-container" id="main-view">
        <div class="data-header">
            <div class="bal-group">
                <div class="label">SECURE BALANCE</div>
                <div class="val" id="bal-ui">1,000</div>
            </div>
            <div class="stat-group">
                <div>SYSTEM: ACTIVE</div>
                <div id="mult-status">MOD: STABLE</div>
            </div>
        </div>

        <div class="matrix-stage">
            <div class="scanner-line"></div>
            <!-- 外层：倍率阵列 -->
            <div id="disk-o" class="disk-outer"></div>
            <!-- 中层：神兽阵列 -->
            <div id="disk-m" class="disk-mid"></div>
            <!-- 启动核心 -->
            <div class="igniter" onclick="ignite()">
                <div class="btn-text">RUN</div>
                <div class="sub-text">INITIATE</div>
            </div>
        </div>

        <div class="control-deck">
            <div id="console-log">STANDBY</div>
            <div class="energy-bar-wrap"><div id="energy-fill"></div></div>
            <div class="bet-interface">
                <div class="op-btn" onclick="adj(-10)">-</div>
                <div class="bet-input-val" id="bet-ui">1</div>
                <div class="op-btn" onclick="adj(10)">+</div>
            </div>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp; tg.expand();
        let bal = 1000, bet = 1, rO = 0, rM = 0, busy = false, ctx, stars = [];
        const icons = ['👑','🦁','🐯','🦅','🐺','🐕'];
        let currentMults = [88, 50, 20, 10, 5, 2];

        function initSystem() {
            if(ctx) return;
            const cvs = document.getElementById('fxCanvas');
            ctx = cvs.getContext('2d');
            cvs.width = window.innerWidth; cvs.height = window.innerHeight;
            for(let i=0; i<150; i++) stars.push({x:Math.random()*cvs.width, y:Math.random()*cvs.height, z:Math.random()*cvs.width});
            
            // 注入多重矩阵
            const dO = document.getElementById('disk-o');
            const dM = document.getElementById('disk-m');
            icons.forEach((icon, i) => {
                const ang = i * 60;
                // 外层倍率
                const mNode = document.createElement('div');
                mNode.className = 'mult-tag'; mNode.style.transform = `rotate(${ang}deg)`;
                mNode.innerHTML = `<span id="m-${i}">x${currentMults[i]}</span>`;
                dO.appendChild(mNode);
                // 中层神兽
                const iNode = document.createElement('div');
                iNode.className = 'icon-node'; iNode.style.transform = `rotate(${ang}deg)`;
                iNode.innerHTML = `<b>${icon}</b>`;
                dM.appendChild(iNode);
            });
            draw();
        }

        function draw() {
            ctx.fillStyle = 'rgba(0,0,0,0.2)'; ctx.fillRect(0,0,ctx.canvas.width, ctx.canvas.height);
            stars.forEach(s => {
                s.z -= busy ? 25 : 2;
                if(s.z <= 0) s.z = ctx.canvas.width;
                const px = (s.x - ctx.canvas.width/2) * (ctx.canvas.width/s.z) + ctx.canvas.width/2;
                const py = (s.y - ctx.canvas.height/2) * (ctx.canvas.width/s.z) + ctx.canvas.height/2;
                ctx.fillStyle = busy ? `hsl(${Date.now()%360}, 100%, 50%)` : '#333';
                ctx.fillRect(px, py, 2, 2);
            });
            requestAnimationFrame(draw);
        }

        function adj(v) {
            if(busy) return;
            bet = Math.max(1, Math.min(bal, bet + v));
            document.getElementById('bet-ui').innerText = bet;
            document.getElementById('energy-fill').style.width = Math.min(100, (bet/bal)*200) + '%';
            tg.HapticFeedback.selectionChanged();
        }

        function ignite() {
            if(busy || bal < bet) return;
            busy = true; bal -= bet;
            document.getElementById('bal-ui').innerText = bal.toLocaleString();
            document.getElementById('main-view').classList.add('shake');
            document.getElementById('console-log').innerText = "WARMING UP...";
            tg.HapticFeedback.impactOccurred('heavy');

            // 1.5秒预热后开始正式旋转
            setTimeout(() => {
                document.getElementById('main-view').classList.remove('shake');
                document.getElementById('console-log').innerText = "VORTEX ACTIVE";
                
                // 随机化本次倍率
                currentMults = currentMults.map(() => Math.floor(Math.random()*100) + 2);
                currentMults.forEach((m, i) => document.getElementById(`m-${i}`).innerText = 'x' + m);

                let target = Math.floor(Math.random()*6);
                rO += (3600 + target*60);
                rM += (7200 + target*60); // 中层转得更快

                document.getElementById('disk-o').style.transform = `rotate(-${rO}deg)`;
                document.getElementById('disk-m').style.transform = `rotate(-${rM}deg)`;
                
                // 图标补偿自转
                document.querySelectorAll('.icon-node b').forEach(b => b.style.transform = `rotate(${rM}deg)`);

                setTimeout(() => {
                    let win = bet * currentMults[target];
                    bal += win;
                    document.getElementById('bal-ui').innerText = bal.toLocaleString();
                    document.getElementById('console-log').innerText = win > 0 ? `SUCCESS: +${win}` : "NULL DATA";
                    tg.HapticFeedback.notificationOccurred(win > 0 ? 'success' : 'error');
                    busy = false;
                }, 7000);
            }, 1500);
        }
    </script>
</body>
</html>




