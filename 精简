        document.getElementById('balance').innerText = balance.toLocaleString();

        // 🔊 暴力合成器音效逻辑
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function beep(freq, type, vol, dur) {
            const osc = audioCtx.createOscillator();
            const g = audioCtx.createGain();
            osc.type = type; osc.frequency.value = freq;
            g.gain.setValueAtTime(vol, audioCtx.currentTime);
            osc.connect(g); g.connect(audioCtx.destination);
            osc.start(); osc.stop(audioCtx.currentTime + dur);
        }

        function start() {
            if(balance < 100) { tg.showAlert("余额不足！请联系管理员上分"); return; }
            balance -= 100;
            updateDisplay();
            
            const wheel = document.getElementById('wheel');
            const symbol = document.getElementById('symbol');
            const btn = document.getElementById('btn');
            const winText = document.getElementById('win-amt');
            
            btn.disabled = true;
            winText.innerText = "WIN: 0";

            // 1. 物理旋转：随机转 5-8 圈
            const deg = 1800 + Math.random() * 1800;
            wheel.style.transform = `rotate(${deg}deg)`;
            
            // 2. 暴力音效：旋转时的轰鸣声
            beep(100, 'square', 0.2, 0.5); 
            tg.HapticFeedback.impactOccurred('heavy');

            // 3. 旋转中的快速换图 + 咔哒声
            let count = 0;
            let timer = setInterval(() => {
                symbol.innerText = symbols[Math.floor(Math.random() * symbols.length)];
                beep(400 + count*20, 'sine', 0.05, 0.05); 
                count++;
                if(count > 40) clearInterval(timer);
            }, 80);

            // 4. 停止判定
            setTimeout(() => {
                const final = symbols[Math.floor(Math.random() * symbols.length)];
                symbol.innerText = final;
                
                let win = (final === '💎' || final === '7️⃣') ? 2500 : (Math.random() > 0.8 ? 500 : 0);
                
                if(win > 0) {
                    // 5. 中奖音效 + 震动
                    beep(880, 'triangle', 0.2, 0.2); 
                    setTimeout(()=>beep(1056, 'triangle', 0.2, 0.4), 150);
                    tg.HapticFeedback.notificationOccurred('success');
                    
                    // 数字滚动上涨
                    let currentWin = 0;
                    let winTimer = setInterval(() => {
                        currentWin += Math.ceil(win / 10);
                        if(currentWin >= win) {
                            currentWin = win;
                            clearInterval(winTimer);
                        }
                        winText.innerText = "WIN: " + currentWin;
                    }, 50);
                    
                    balance += win;
                } else {
                    beep(200, 'sawtooth', 0.1, 0.3); // 没中奖的闷响
                }

                updateDisplay();
                btn.disabled = false;
                
                // 重置转盘角度方便下次转
                setTimeout(() => {
                    wheel.style.transition = 'none';
                    wheel.style.transform = 'rotate(0deg)';
                    setTimeout(() => wheel.style.transition = 'transform 4s cubic-bezier(0.1, 0, 0.1, 1)', 50);
                }, 500);
            }, 4000);
        }

        function updateDisplay() {
            document.getElementById('balance').innerText = balance.toLocaleString();
        }
    </script>
</body>
</html>