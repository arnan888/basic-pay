        /* 激光刻度指针 */
        .scanner-line { position: absolute; top: 0; width: 1px; height: 100%; background: linear-gradient(to bottom, transparent, var(--c-warn), transparent); z-index: 50; animation: scan 4s linear infinite; }
        @keyframes scan { 0% { left: 45%; opacity:0; } 50% { left: 50%; opacity:1; } 100% { left: 55%; opacity:0; } }

        .disk-outer { position: absolute; inset: 0; border: 1px solid rgba(255,255,255,0.05); border-radius: 50%; transition: 6s cubic-bezier(0.1, 0, 0, 1); }
        .disk-mid { position: absolute; inset: 15%; border-radius: 50%; background: radial-gradient(circle, #111, #000); border: 2px solid #222; transition: 6.5s cubic-bezier(0.15, 0, 0.05, 1); }

        /* 倍率浮动标签 */
        .mult-tag { position: absolute; width: 100%; height: 100%; display: flex; align-items: center; justify-content: flex-end; padding-right: 2%; font-size: 14px; color: var(--c-gold); font-weight: 900; }
