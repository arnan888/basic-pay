        .energy-bar-wrap { width: 80%; height: 4px; background: #111; border-radius: 2px; overflow: hidden; position: relative; }
        #energy-fill { width: 10%; height: 100%; background: var(--c-neon); box-shadow: 0 0 10px var(--c-neon); transition: 0.3s; }

        .bet-interface { display: flex; align-items: center; gap: 40px; }
