<body>
    <div class="header"><div id="balance">0</div></div>

    <div style="position:relative;">
        <div class="wheel-box" id="wheel"><div id="symbol">🐱</div></div>
        <button class="spin-btn" id="btn" onclick="start()">SPIN</button>
    </div>

