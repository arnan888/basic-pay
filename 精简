            winSlot.classList.add('win');
        }

        // 新增：关闭中奖弹窗
        function closeWinModal() {
            domElements.winModal.classList.remove('active');
            // 移除所有槽位高亮
            domElements.slots.forEach(slot => slot.querySelector('.content').classList.remove('win'));
        }

        // 新增：本地数据存储与恢复
        function saveData() {
            const data = { balance, totalIn, totalOut, wheelRotation };
            localStorage.setItem(storageKey, JSON.stringify(data));
        }

        function loadData() {
            const saved = localStorage.getItem(storageKey);
            if (saved) {
                const data = JSON.parse(saved);
                balance = data.balance || 89123.0;
                totalIn = data.totalIn || 0;
                totalOut = data.totalOut || 0;
                wheelRotation = data.wheelRotation || 0;
                domElements.wheel.style.transform = `rotate(${wheelRotation}deg)`;
            }
        }

        function formatNumber(num) {
            if (typeof num !== 'number' || isNaN(num)) return '0.00';
            return num.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
        }

        function exec() {
            try {
                if (isBusy || balance < 1) return;
                
                isBusy = true;
                domElements.mainBtn.classList.add('busy');
                domElements.loading.classList.add('active');
                domElements.pointer.classList.add('active');
                domElements.adminBar.classList.add('update');
                
                // 扣除积分时显示变化
                totalIn++;
                balance--;
                showBalanceChange(false);
                syncUI();
                showValueChange(domElements.totalIn);
                showValueChange(domElements.balance);

                const currentRtp = totalIn > 0 ? (totalOut / totalIn) : 0;
                let selectedReward;

                if (totalIn > 3 && currentRtp > 0.95) {
                    const lowRewardSet = rewardMatrix.filter(item => item.value <= 15);
                    selectedReward = lowRewardSet[Math.floor(Math.random() * lowRewardSet.length)];
                } else {
                    selectedReward = rewardMatrix[Math.floor(Math.random() * rewardMatrix.length)];
                }

                const baseSpins = (Math.floor(Math.random() * 5) + 12) * 360;
                const targetAngle = 360 - selectedReward.angle;
                wheelRotation += baseSpins + (targetAngle - (wheelRotation % 360)) + 360;
                
                domElements.wheel.style.transform = `rotate(${wheelRotation}deg)`;

                setTimeout(() => {
                    totalOut += selectedReward.value;
                    balance += selectedReward.value;
                    // 奖励到账时显示变化
                    showBalanceChange(selectedReward.value > 0);
                    syncUI();
                    saveData(); // 保存数据
                    
                    showValueChange(domElements.totalOut);
                    showValueChange(domElements.rtp);
                    showValueChange(domElements.balance);
                    
                    // 显示中奖提示
                    showWinModal(selectedReward);

                    isBusy = false;
                    domElements.mainBtn.classList.remove('busy');
                    domElements.loading.classList.remove('active');
                    domElements.pointer.classList.remove('active');
                    setTimeout(() => domElements.adminBar.classList.remove('update'), 500);
                }, 5500);
            } catch (error) {
                console.error('操作执行异常:', error);
                isBusy = false;
                domElements.mainBtn.classList.remove('busy');
                domElements.loading.classList.remove('active');
                domElements.pointer.classList.remove('active');
                domElements.adminBar.classList.remove('update');
            }
        }

        function syncUI() {
            domElements.balance.innerText = formatNumber(balance);
            domElements.totalIn.innerText = totalIn;
            domElements.totalOut.innerText = totalOut;
            
            const rtpValue = totalIn > 0 ? (totalOut / totalIn * 100).toFixed(1) : "0.0";
            domElements.rtp.innerText = `${rtpValue}%`;
        }

        // 新增：页面卸载前保存数据
        window.addEventListener('beforeunload', saveData);

        document.addEventListener('DOMContentLoaded', () => {
            loadData(); // 恢复本地数据
            syncUI(); 
            createStars(); // 创建星光背景
            
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && !isBusy) {
                    exec();
                }
                // ESC关闭弹窗
                if (e.key === 'Escape' && domElements.winModal.classList.contains('active')) {
                    closeWinModal();
                }
            });

            // 新增：点击空白处关闭弹窗
            domElements.winModal.addEventListener('click', (e) => {
                if (e.target === domElements.winModal) closeWinModal();
            });
        });
    </script>
</body>
</html>