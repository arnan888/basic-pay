<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>3D_RACE_TOP</title>
    <style>
        :root { --red: #ff0055; --blue: #00f2ff; }
        body { margin: 0; background: #050505; color: #fff; font-family: 'Arial Black', sans-serif; height: 100vh; overflow: hidden; perspective: 1200px; position: relative; }
        .hud { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); width: 85%; background: rgba(0,242,255,0.05); border: 1px solid var(--blue); border-radius: 10px; padding: 15px; z-index: 10; }
        .track { position: absolute; top: 120px; width: 100%; height: 350px; background: #111; border-top: 6px solid #333; border-bottom: 6px solid #333; transform: rotateX(20deg); overflow: hidden; }
        .car { position: absolute; left: 15px; font-size: 80px; transition: left 0.1s linear; filter: drop-shadow(0 0 20px currentColor); }
        .btns { position: absolute; bottom: 50px; left: 50%; transform: translateX(-50%); width: 90%; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .btn { padding: 22px; border-radius: 12px; border: none; font-size: 20px; font-weight: 900; cursor: pointer; color:#fff; box-shadow: 0 8px 0 #000; }
        .ovl { position: fixed; inset:0; background:rgba(0,0,0,0.9); display:none; flex-direction:column; align-items:center; justify-content:center; z-index:100; }
    </style>
</head>
<body>
    <div class="hud"><div style="font-size:14px;color:var(--blue)">RACING_V45</div><div id="bal" style="font-size:28px; font-weight:900">1,000 TRX</div></div>
    <div class="track"><div id="c1" class="car" style="top:20px;color:var(--red)">🏎️</div><div id="c2" class="car" style="top:180px;color:var(--blue)">🏎️</div></div>
    <div class="btns" id="ctrl"><button class="btn" style="background:#ff0055" onclick="race('red')">RED</button><button class="btn" style="background:#00f2ff" onclick="race('blue')">BLUE</button></div>
    <div class="ovl" id="ovl"><div id="res-txt" style="font-size:50px; font-weight:900"></div><button style="margin-top:40px;padding:15px 40px;background:#fff;border:none;border-radius:8px;font-weight:bold;" onclick="location.reload()">RELOAD</button></div>
    <script>
        let b=1000; function race(bet){ if(b<50)return alert('余额不足'); b-=50; document.getElementById('bal').innerText=b+" TRX"; document.getElementById('ctrl').style.pointerEvents='none';
            let p1=15, p2=15; const goal=window.innerWidth-120;
            let loop=setInterval(()=>{ p1+=Math.random()*20; p2+=Math.random()*20; document.getElementById('c1').style.left=p1+'px'; document.getElementById('c2').style.left=p2+'px';
                if(p1>=goal||p2>=goal){ clearInterval(loop); let w=p1>p2?'red':'blue'; if(bet===w)b+=100; document.getElementById('bal').innerText=b+" TRX"; document.getElementById('ovl').style.display='flex'; document.getElementById('res-txt').innerText=w.toUpperCase()+" WINS!"; document.getElementById('res-txt').style.color=w==='red'?'#ff0055':'#00f2ff'; }
            },60); }
    </script>
</body>









<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DOLA_旗舰终端_V45_修正布局版</title>
    <style>
        :root { --neon: #00f2ff; --pink: #ff0055; --gold: #ffcc00; }
        * { box-sizing: border-box; }
        body { 
            margin: 0; padding: 0; background: #000; color: #fff; 
            font-family: 'Arial Black', sans-serif; 
            height: 100vh; width: 100vw; overflow: hidden;
            background: url('https://img.freepik.com/free-vector/abstract-technology-particle-background_23-2148426649.jpg') no-repeat center center;
            background-size: cover; position: relative;
            display: flex; flex-direction: column; align-items: center;
        }

        body::after {
            content: ""; position: fixed; inset: 0;
            background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.8) 100%);
            pointer-events: none; z-index: 1; 
        }

        /* 顶部 HUD 容器 */
        .hud-container {
            width: 90%; margin-top: 20px; z-index: 100;
            background: rgba(0,0,0,0.7); border: 2px solid var(--neon);
            border-radius: 15px; padding: 15px; text-align: center;
            backdrop-filter: blur(10px); box-shadow: 0 0 20px rgba(0,242,255,0.4);
        }

        .balance-row { font-size: 24px; color: var(--neon); text-shadow: 0 0 10px var(--neon); margin-bottom: 10px; }

        .bet-row {
            display: flex; align-items: center; justify-content: center; gap: 20px;
            border-top: 1px solid rgba(255,255,255,0.1); pt: 10px;
        }

        .bet-btn {
            width: 45px; height: 45px; background: #111; border: 2px solid var(--gold);
            color: var(--gold); border-radius: 10px; font-size: 24px; cursor: pointer;
            display: flex; align-items: center; justify-content: center; transition: 0.2s;
        }
        .bet-btn:active { transform: scale(0.9); background: var(--gold); color: #000; }

        .bet-val { font-size: 22px; color: var(--gold); min-width: 100px; font-weight: 900; }

        /* 转盘容器：恢复大尺寸 */
        .wheel-box { 
            margin-top: 40px; position: relative; z-index: 50; 
            width: 320px; height: 320px;
        }

        .wheel { 
            width: 320px; height: 320px; border-radius: 50%; border: 8px solid #111;
            background: conic-gradient(from 0deg, #ff0055 0 60deg, #1a1a1a 60deg 120deg, #00f2ff 120deg 180deg, #1a1a1a 180deg 240deg, #ffcc00 240deg 300deg, #1a1a1a 300deg 360deg);
            box-shadow: 0 0 60px rgba(0,0,0,0.9), 0 0 30px var(--neon);
            transition: transform 4s cubic-bezier(0.1, 0, 0.1, 1);
            display: flex; align-items: center; justify-content: center; position: relative;
        }

        .item { position: absolute; font-size: 32px; }
        .i1 { transform: rotate(30deg) translateY(-120px); } 
        .i2 { transform: rotate(90deg) translateY(-120px); } 
        .i3 { transform: rotate(150deg) translateY(-120px); } 
        .i4 { transform: rotate(210deg) translateY(-120px); } 
        .i5 { transform: rotate(270deg) translateY(-120px); } 
        .i6 { transform: rotate(330deg) translateY(-120px); }

        .spin-btn { 
            position: absolute; width: 75px; height: 75px; background: #000; 
            border: 4px solid var(--pink); border-radius: 50%; 
            color: #fff; font-size: 18px; font-weight: bold; cursor: pointer; z-index: 60; 
            display: flex; align-items: center; justify-content: center; 
            box-shadow: 0 0 25px var(--pink); 
        }

        .pointer { 
            position: absolute; top: -20px; left: 50%; transform: translateX(-50%); 
            width: 0; height: 0; border-left: 20px solid transparent; border-right: 20px solid transparent; 
            border-top: 35px solid #fff; z-index: 70; filter: drop-shadow(0 0 15px var(--neon));
        }

        .ovl { position: fixed; inset: 0; background: rgba(0,0,0,0.9); display: none; flex-direction: column; align-items: center; justify-content: center; z-index: 200; }
    </style>
</head>
<body>
    <div class="hud-container">
        <div class="balance-row">BALANCE: <b id="bal">1,000</b></div>
        <div class="bet-row">
            <button class="bet-btn" onclick="changeBet(-50)">-</button>
            <div class="bet-val">BET: <span id="bet">50</span></div>
            <button class="bet-btn" onclick="changeBet(50)">+</button>
        </div>
    </div>

    <div class="wheel-box">
        <div class="pointer"></div>
        <div class="wheel" id="wheel">
            <div class="item i1">💎</div><div class="item i2">💀</div><div class="item i3">💰</div><div class="item i4">💀</div><div class="item i5">🎁</div><div class="item i6">💀</div>
            <div class="spin-btn" id="spin-btn" onclick="spin()">SPIN</div>
        </div>
    </div>

    <div class="ovl" id="ovl">
        <div id="res-txt" style="font-size:50px; font-weight:900; text-shadow: 0 0 20px #fff;"></div>
        <button style="margin-top:40px; padding:15px 40px; background:var(--neon); border:none; border-radius:10px; font-size:20px; font-weight:bold; color:#000;" onclick="closeOvl()">CONTINUE</button>
    </div>

    <script>
        let b = parseFloat(localStorage.getItem('user_gold') || '1000'); 
        let currentBet = 50; 
        let r = 0;
        let spinning = false;

        function updateUI() {
            document.getElementById('bal').innerText = Math.floor(b).toLocaleString();
            document.getElementById('bet').innerText = currentBet;
            localStorage.setItem('user_gold', b.toString());
        }

        window.changeBet = (val) => {
            if (spinning) return;
            let nextBet = currentBet + val;
            if (nextBet < 50) nextBet = 50; // 最小下注 50
            if (nextBet > b) nextBet = Math.max(50, Math.floor(b)); 
            currentBet = nextBet;
            updateUI();
        };

        updateUI();

        function spin() { 
            if (spinning) return;
            if (b < currentBet) return alert('余额不足！请同步额度'); 

            spinning = true;
            b -= currentBet; 
            updateUI(); 

            let add = 1800 + Math.floor(Math.random() * 360); 
            r += add; 
            document.getElementById('wheel').style.transform = "rotate(" + r + "deg)";

            setTimeout(() => { 
                let prizePool = [10, 0, 2, 0, 5, 0]; // 对应奖项倍率
                let m = prizePool[Math.floor(Math.random() * 6)]; 
                let win = currentBet * m;
                b += win; 
                updateUI(); 

                document.getElementById('ovl').style.display = 'flex'; 
                document.getElementById('res-txt').innerText = win > 0 ? "WIN: " + win : "LOSE"; 
                document.getElementById('res-txt').style.color = win > 0 ? '#00f2ff' : '#ff0055'; 
                spinning = false;
            }, 4000); 
        }

        window.closeOvl = () => { document.getElementById('ovl').style.display = 'none'; };

        // 充值同步
        window.syncGold = (n) => { b += n; updateUI(); };
    </script>
</body>
</html>





<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
    <title>五兽至尊_V3000_METAL_LUXE</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        :root { --gold: #d4af37; --dark-gold: #aa8a2e; --metal: #1a1c1e; --bg: #050607; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin: 0; padding: 0; }
        
        body { 
            background: var(--bg); color: #fff; font-family: 'Georgia', serif; 
            height: 100vh; width: 100vw; display: flex; flex-direction: column; align-items: center; overflow: hidden;
            background-image: radial-gradient(circle at center, #15181b 0%, #050607 100%);
        }

        /* 顶部：奢侈品风格状态栏 */
        .top-bar { width: 100%; height: 15vh; display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 10; }
        .bal-title { font-size: 12px; color: var(--gold); letter-spacing: 4px; margin-bottom: 5px; opacity: 0.8; }
        .bal-val { font-size: 52px; font-weight: 800; color: #fff; text-shadow: 0 2px 10px rgba(0,0,0,0.5); font-family: 'Arial Black'; }

        /* 核心区：重工机械轮盘 */
        .stage { flex: 1; display: flex; align-items: center; justify-content: center; width: 100%; position: relative; }
        
        /* 物理底座外圈 */
        .metal-frame {
            position: relative; width: 88vw; max-width: 380px; aspect-ratio: 1/1; 
            border-radius: 50%; padding: 10px;
            background: linear-gradient(145deg, #2c2f33, #000);
            box-shadow: 0 25px 50px rgba(0,0,0,0.9), inset 0 2px 5px rgba(255,255,255,0.1);
            border: 1px solid #333;
        }

        /* 黄金刻度圈 */
        .metal-frame::before {
            content: ""; position: absolute; inset: 5px; border-radius: 50%;
            border: 2px solid var(--dark-gold); opacity: 0.3;
        }

        /* 转盘主体：拉丝金属 */
        .wheel-main { 
            width: 100%; height: 100%; border-radius: 50%;
            background: 
                radial-gradient(circle at center, transparent 35%, rgba(0,0,0,0.4) 100%),
                conic-gradient(from 0deg, #1a1c1e 0%, #2c2f33 25%, #1a1c1e 50%, #2c2f33 75%, #1a1c1e 100%);
            border: 8px solid #111; position: relative; overflow: hidden;
            transition: transform 7s cubic-bezier(0.15, 0.05, 0, 1);
            box-shadow: inset 0 0 30px #000;
        }
        
        /* 扇区划分线 */
        .divider { position: absolute; width: 100%; height: 2px; background: rgba(212,175,55,0.1); top: 50%; left: 0; transform-origin: center; z-index: 1; }

        .sector { 
            position: absolute; width: 100%; height: 100%; 
            clip-path: polygon(50% 50%, 100% 21%, 100% 79%); 
            transform-origin: center; display: flex; align-items: center; justify-content: flex-end; padding-right: 8%; 
        }
        
        /* 图标：浮雕感 */
        .icon { 
            transform: rotate(90deg); font-size: 76px; 
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.8)) grayscale(0.2); 
            transition: 0.3s; 
        }

        /* 黄金中轴按钮 */
        .center-hub { 
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); 
            width: 95px; height: 95px; border-radius: 50%; z-index: 100;
            background: radial-gradient(circle at 30% 30%, var(--gold), #634d08);
            border: 4px solid #111; display: flex; align-items: center; justify-content: center;
            box-shadow: 0 10px 20px rgba(0,0,0,0.6), inset 0 2px 5px rgba(255,255,255,0.4);
            cursor: pointer;
        }
        .center-hub span { color: #000; font-weight: 900; font-size: 22px; letter-spacing: 1px; }

        /* 顶部物理指针 */
        .needle { 
            position: absolute; top: -15px; left: 50%; transform: translateX(-50%); 
            width: 30px; height: 50px; background: var(--gold); 
            clip-path: polygon(50% 100%, 0 0, 100% 0); z-index: 110;
            filter: drop-shadow(0 4px 5px rgba(0,0,0,0.5));
        }

        /* 底部：精密控制台 */
        .footer { width: 100%; height: 20vh; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 15px; }
        .bet-panel { 
            display: flex; align-items: center; gap: 50px; background: #111; 
            padding: 10px 40px; border-radius: 10px; border: 1px solid #333;
            box-shadow: inset 0 2px 10px #000;
        }
        .adj-btn { background: none; border: none; color: var(--gold); font-size: 36px; font-weight: bold; width: 40px; cursor: pointer; }
        #bet-val { font-size: 44px; font-weight: 900; color: #fff; min-width: 100px; text-align: center; font-family: 'Arial'; }
        #status-msg { color: var(--gold); font-size: 18px; font-weight: bold; letter-spacing: 3px; text-transform: uppercase; opacity: 0.7; }
    </style>
</head>
<body onclick="initAudio()">

    <div class="top-bar">
        <div class="bal-title">TOTAL CREDITS</div>
        <div class="bal-val"><span id="bal">1,000</span></div>
    </div>

    <div class="stage">
        <div class="metal-frame">
            <div class="needle"></div>
            <div id="wheel" class="wheel-main">
                <div class="divider" style="transform:rotate(0deg)"></div>
                <div class="divider" style="transform:rotate(60deg)"></div>
                <div class="divider" style="transform:rotate(120deg)"></div>
                <div class="sector" style="transform:rotate(-90deg)"><b class="icon">👑</b></div>
                <div class="sector" style="transform:rotate(-30deg)"><b class="icon">🦁</b></div>
                <div class="sector" style="transform:rotate(30deg)"><b class="icon">🐯</b></div>
                <div class="sector" style="transform:rotate(90deg)"><b class="icon">🦅</b></div>
                <div class="sector" style="transform:rotate(150deg)"><b class="icon">🐺</b></div>
                <div class="sector" style="transform:rotate(210deg)"><b class="icon">🐕</b></div>
            </div>
            <div class="center-hub" onclick="run()">
                <span>RUN</span>
            </div>
        </div>
    </div>

    <div class="footer">
        <div id="status-msg">SYSTEM READY</div>
        <div class="bet-panel">
            <button class="adj-btn" onclick="adj(-10)">-</button>
            <div id="bet-val">1</div>
            <button class="adj-btn" onclick="adj(10)">+</button>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp; tg.expand();
        let b = 1000, bet = 1, r = 0, spinning = false, aCtx;

        function initAudio() {
            if(!aCtx) { aCtx = new (window.AudioContext || window.webkitAudioContext)(); }
        }

        function play(f, d, v=0.1) {
            if(!aCtx) return;
            const o = aCtx.createOscillator(); const g = aCtx.createGain();
            o.type = 'sine'; o.frequency.setValueAtTime(f, aCtx.currentTime);
            g.gain.setValueAtTime(v, aCtx.currentTime);
            g.gain.exponentialRampToValueAtTime(0.0001, aCtx.currentTime + d);
            o.connect(g); g.connect(aCtx.destination);
            o.start(); o.stop(aCtx.currentTime + d);
        }

        function adj(v) {
            if(spinning) return;
            bet = Math.max(1, Math.min(b, bet+v));
            document.getElementById('bet-val').innerText = bet;
            tg.HapticFeedback.selectionChanged();
            play(400, 0.1, 0.05);
        }

        function run() {
            if(spinning || b < bet) return;
            spinning = true; b -= bet;
            document.getElementById('bal').innerText = b.toLocaleString();
            tg.HapticFeedback.impactOccurred('heavy');
            
            // 模拟机械齿轮哒哒声
            let tick = setInterval(() => { if(spinning) play(150, 0.05, 0.03); }, 100);

            let idx = Math.floor(Math.random()*6);
            r += (3600 + idx*60);
            document.getElementById('wheel').style.transform = `rotate(-${r}deg)`;
            document.getElementById('status-msg').innerText = "ENGAGING GEARS...";

            setTimeout(() => {
                clearInterval(tick);
                const multi = [88, 15, 10, 5, 2, 0];
                let win = Math.floor(bet * multi[idx]);
                b += win;
                document.getElementById('bal').innerText = b.toLocaleString();
                
                if(win > 0) {
                    document.getElementById('status-msg').innerText = "WIN: " + win;
                    tg.HapticFeedback.notificationOccurred('success');
                    for(let i=0; i<8; i++) setTimeout(()=>play(300+i*50, 0.2, 0.1), i*80);
                } else {
                    document.getElementById('status-msg').innerText = "TRY AGAIN";
                    play(100, 0.5, 0.1);
                }
                spinning = false;
            }, 7000);
        }
    </script>
</body>
</html>






<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
    <title>五兽至尊_V5000_QUANTUM</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        :root { --c: #00f2ff; --p: #ff0055; --bg: #000; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin: 0; padding: 0; }
        
        body { background: var(--bg); color: #fff; font-family: 'Exo', sans-serif; height: 100vh; overflow: hidden; perspective: 1000px; }

        /* 3D 深空画布 */
        #warp { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }

        .app-view { position: relative; z-index: 10; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 40px 0; pointer-events: none; }
        .app-view * { pointer-events: auto; }

        /* 顶部：全息数字 */
        .hologram-bal { text-align: center; transform: translateZ(50px); }
        .num { font-size: 68px; font-weight: 900; background: linear-gradient(to bottom, #fff, #888); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0 0 20px var(--c)); letter-spacing: -2px; }
        .label { font-size: 10px; color: var(--c); letter-spacing: 5px; opacity: 0.6; }

        /* 核心区：3D 旋转星轨 */
        .stage-3d { 
            position: relative; width: 100vw; height: 40vh; 
            display: flex; align-items: center; justify-content: center;
            transform-style: preserve-3d;
        }
        
        .orbit-wrap {
            position: absolute; width: 400px; height: 400px;
            transform-style: preserve-3d;
            transition: transform 7s cubic-bezier(0.1, 0, 0, 1);
        }

        .node {
            position: absolute; width: 100px; height: 100px;
            top: 150px; left: 150px;
            display: flex; align-items: center; justify-content: center;
            transform-style: preserve-3d;
        }
        .node b { 
            font-size: 80px; filter: drop-shadow(0 0 15px rgba(255,255,255,0.3));
            transition: 0.5s; 
        }

        /* 这种聚焦框代替了指针 */
        .focus-lock {
            position: absolute; width: 120px; height: 120px;
            border: 2px solid var(--c); border-radius: 20px;
            box-shadow: 0 0 30px var(--c);
            opacity: 0.1; animation: breathe 2s infinite;
            z-index: 20; top: -140px; /* 锁定在正上方 */
        }
        @keyframes breathe { 0%,100% { transform: scale(1); opacity: 0.2; } 50% { transform: scale(1.1); opacity: 0.5; } }

        /* 启动核心 */
        .ignite {
            width: 100px; height: 100px; border-radius: 50%;
            background: radial-gradient(circle, #222, #000);
            border: 1px solid rgba(255,255,255,0.2);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; box-shadow: 0 0 40px rgba(0,242,255,0.2);
            z-index: 100; transform: translateZ(100px);
        }
        .ignite span { font-size: 18px; font-weight: 900; color: #fff; letter-spacing: 2px; }

        /* 底部：精密控制 */
        .ctrl { width: 100%; display: flex; flex-direction: column; align-items: center; gap: 15px; }
        .bet-set { display: flex; align-items: center; gap: 50px; }
        .btn-adj { font-size: 40px; font-weight: 100; color: #fff; opacity: 0.3; width: 40px; text-align: center; cursor: pointer; }
        .bet-val { font-size: 56px; font-weight: 900; color: #fff; text-shadow: 0 0 15px var(--p); }
        #msg { height: 20px; font-size: 20px; color: var(--c); letter-spacing: 5px; opacity: 0.8; }
    </style>
</head>
<body onclick="init()">

    <canvas id="warp"></canvas>

    <div class="app-view">
        <div class="hologram-bal">
            <div class="num" id="bal-ui">1,000</div>
            <div class="label">QUANTUM ASSETS</div>
        </div>

        <div class="stage-3d">
            <div class="focus-lock"></div>
            <div id="orbit" class="orbit-wrap">
                <!-- 3D 节点由 JS 生成 -->
            </div>
            <div class="ignite" onclick="spin()">
                <span>RUN</span>
            </div>
        </div>

        <div class="ctrl">
            <div id="msg">AWAITING IGNITION</div>
            <div class="bet-set">
                <div class="btn-adj" onclick="adj(-10)">-</div>
                <div class="bet-val" id="bet-ui">1</div>
                <div class="btn-adj" onclick="adj(10)">+</div>
            </div>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp; tg.expand();
        let b = 1000, bet = 1, rot = 0, isS = false, ctx, stars = [];
        const icons = ['👑','🦁','🐯','🦅','🐺','🐕'];

        function init() {
            if(ctx) return;
            const cvs = document.getElementById('warp');
            ctx = cvs.getContext('2d');
            cvs.width = window.innerWidth; cvs.height = window.innerHeight;
            for(let i=0; i<200; i++) stars.push({x:Math.random()*cvs.width-cvs.width/2, y:Math.random()*cvs.height-cvs.height/2, z:Math.random()*cvs.width});
            
            const orbit = document.getElementById('orbit');
            icons.forEach((icon, i) => {
                const node = document.createElement('div');
                node.className = 'node';
                const angle = (i * 60) * (Math.PI / 180);
                const r = 160; 
                const tx = r * Math.cos(angle - Math.PI/2);
                const ty = r * Math.sin(angle - Math.PI/2);
                node.style.transform = `translate3d(${tx}px, ${ty}px, 0px)`;
                node.innerHTML = `<b>${icon}</b>`;
                orbit.appendChild(node);
            });
            draw();
        }

        function draw() {
            ctx.fillStyle = 'black'; ctx.fillRect(0,0,cvs.width, cvs.height);
            stars.forEach(s => {
                s.z -= isS ? 15 : 1;
                if(s.z <= 0) s.z = cvs.width;
                const sx = (s.x * (cvs.width/s.z)) + cvs.width/2;
                const sy = (s.y * (cvs.width/s.z)) + cvs.height/2;
                const size = (1 - s.z/cvs.width) * 3;
                ctx.fillStyle = isS ? '#00f2ff' : 'white';
                ctx.beginPath(); ctx.arc(sx, sy, size, 0, Math.PI*2); ctx.fill();
            });
            requestAnimationFrame(draw);
        }

        function adj(v) {
            if(isS) return;
            bet = Math.max(1, Math.min(b, bet+v));
            document.getElementById('bet-ui').innerText = bet;
            tg.HapticFeedback.selectionChanged();
        }

        function spin() {
            if(isS || b < bet) return;
            isS = true; b -= bet;
            document.getElementById('bal-ui').innerText = b.toLocaleString();
            document.getElementById('msg').innerText = "WARP DRIVE ACTIVE";
            tg.HapticFeedback.impactOccurred('medium');

            let idx = Math.floor(Math.random()*6);
            rot += (3600 + idx*60);
            document.getElementById('orbit').style.transform = `rotateZ(-${rot}deg)`;
            
            // 图标反向自转，保持绝对正立
            const nodes = document.querySelectorAll('.node b');
            nodes.forEach(n => n.style.transform = `rotateZ(${rot}deg)`);

            setTimeout(() => {
                const multi = [88, 15, 10, 5, 2, 0];
                let win = Math.floor(bet * multi[idx]);
                b += win;
                document.getElementById('bal-ui').innerText = b.toLocaleString();
                
                if(win > 0) {
                    document.getElementById('msg').innerText = "TARGET CAPTURED";
                    nodes[idx].classList.add('winning'); // 中奖图标发光缩放
                    tg.HapticFeedback.notificationOccurred('success');
                } else {
                    document.getElementById('msg').innerText = "MISSION FAILED";
                }
                setTimeout(() => { isS = false; }, 1000);
            }, 7000);
        }
    </script>
</body>
</html>