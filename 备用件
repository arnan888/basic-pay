<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DOLA_GAME_HUB</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        :root { --neon: #00f2ff; --pink: #ff0055; --gold: #ffcc00; }
        body { 
            margin: 0; background: #080808; color: #fff; font-family: 'Arial', sans-serif;
            padding: 20px; overflow-y: auto; -webkit-tap-highlight-color: transparent;
        }
        
        /* 顶部余额 HUD */
        .header {
            background: rgba(255,255,255,0.05); border: 1px solid var(--neon);
            border-radius: 20px; padding: 20px; text-align: center;
            margin-bottom: 30px; backdrop-filter: blur(10px);
            box-shadow: 0 0 20px rgba(0,242,255,0.2);
        }
        .bal-val { font-size: 32px; font-weight: 900; color: var(--neon); text-shadow: 0 0 10px var(--neon); }

        /* 核心：3列网格布局 */
        .game-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
        }

        /* 游戏按钮样式 */
        .game-card {
            aspect-ratio: 1 / 1; /* 正方形 */
            background: linear-gradient(145deg, #1a1a1a, #000);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 18px;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative; overflow: hidden;
        }
        
        /* 激活状态按钮（有名字的） */
        .game-card.active { border-color: var(--neon); box-shadow: 0 0 15px rgba(0,242,255,0.3); }
        .game-card.active:active { transform: scale(0.92); filter: brightness(1.2); }
        
        /* 空白占位样式（没名字的） */
        .game-card.empty { opacity: 0.4; filter: grayscale(1); }
        .game-card.empty::after { content: "🔒"; font-size: 20px; opacity: 0.5; }

        .game-icon { font-size: 35px; margin-bottom: 8px; }
        .game-name { font-size: 11px; font-weight: bold; text-transform: uppercase; color: #aaa; letter-spacing: 1px; }

        /* 底部动态文字 */
        .footer-text { text-align: center; font-size: 10px; color: #444; margin-top: 40px; letter-spacing: 2px; }
    </style>
</head>
<body>

    <div class="header">
        <div style="font-size:12px; color:#888; margin-bottom:5px;">WALLET BALANCE</div>
        <div class="bal-val" id="bal">1,000 TRX</div>
    </div>

    <div class="game-grid">
        <!-- 焊死的游戏 1 -->
        <div class="game-card active" onclick="go('zhuanpan')">
            <div class="game-icon">🎡</div>
            <div class="game-name">转盘</div>
        </div>

        <!-- 焊死的游戏 2 -->
        <div class="game-card active" onclick="go('saiche')">
            <div class="game-icon">🏎️</div>
            <div class="game-name">赛车</div>
        </div>

        <!-- 焊死的游戏 3 -->
        <div class="game-card active" onclick="go('shuzi')">
            <div class="game-icon">💰</div>
            <div class="game-name">猜数</div>
        </div>

        <!-- 下面全是五六排的空位 (自动生成 15 个空位) -->
        <script>
            const grid = document.querySelector('.game-grid');
            for(let i=0; i<15; i++) {
                let div = document.createElement('div');
                div.className = 'game-card empty';
                grid.appendChild(div);
            }

            function go(name) {
                window.Telegram.WebApp.HapticFeedback.impactOccurred('light');
                // 跳转逻辑：跳转到同仓库下的文件夹
                window.location.href = "../" + name + "/index.html";
            }
        </script>
    </div>

    <div class="footer-text">DOLA FLAGSHIP TERMINAL V4.5</div>

    <script>
        // 初始化 TG WebApp
        window.Telegram.WebApp.expand();
        // 这里可以写从机器人获取余额的逻辑
    </script>
</body>
</html>
