<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
    <title>TERMINAL_V20000_WAKEUP</title>
    <!-- 逻辑前置，确保启动即加载 -->
    <script>
        var bal = 1000, bet = 1, rot = 0, busy = false;
        function adj(v) {
            if(busy) return;
            bet = Math.max(1, Math.min(bal, bet + v));
            document.getElementById('b-val').innerText = bet;
            if(window.Telegram) window.Telegram.WebApp.HapticFeedback.selectionChanged();
        }
        function run() {
            if(busy || bal < bet) return;
            busy = true; bal -= bet;
            document.getElementById('a-val').innerText = bal.toLocaleString();
            document.getElementById('msg').innerText = "VORTEX ACTIVE";
            document.getElementById('view').className = "app bass";
            
            var tg = window.Telegram ? window.Telegram.WebApp : null;
            if(tg) tg.HapticFeedback.impactOccurred('heavy');

            var target = Math.floor(Math.random()*6);
            rot += (3600 + target * 60);
            document.getElementById('core').style.transform = "rotate(-" + rot + "deg)";

            setTimeout(function(){
                document.getElementById('view').className = "app";
                var multi = [88, 15, 10, 5, 2, 0];
                var win = Math.floor(bet * multi[target]);
                bal += win;
                document.getElementById('a-val').innerText = bal.toLocaleString();
                document.getElementById('msg').innerText = win > 0 ? "SUCCESS: +" + win : "CORE NULL";
                if(tg) tg.HapticFeedback.notificationOccurred(win > 0 ? 'success' : 'error');
                busy = false;
            }, 6000);
        }
    </script>
    <style>
        body { background: #000; color: #fff; margin: 0; font-family: sans-serif; overflow: hidden; height: 100vh; }
        .app { height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-around; padding: 30px 0; }
        
        /* 截图还原：青色霓虹余额 */
        .bal-box { border: 2px solid #00f2ff; padding: 10px 40px; border-radius: 15px; box-shadow: 0 0 20px #00f2ff; }
        .bal-num { font-size: 48px; font-weight: 900; color: #fff; text-shadow: 0 0 10px #00f2ff; }

        /* 核心区：禁锢转盘 */
        .stage { position: relative; width: 320px; height: 320px; display: flex; align-items: center; justify-content: center; }
        .pointer { position: absolute; top: -10px; width: 3px; height: 60px; background: #fff; box-shadow: 0 0 15px #fff; z-index: 50; }
        
        .wheel { 
            width: 100%; height: 100%; border-radius: 50%; background: #111; 
            border: 2px solid #333; position: relative; overflow: hidden;
            transition: transform 6s cubic-bezier(0.15, 0, 0.05, 1);
        }
        .item { position: absolute; width: 100%; height: 100%; display: flex; align-items: center; justify-content: flex-end; padding-right: 15%; transform-origin: center; }
        .item b { font-size: 60px; transform: rotate(90deg); }

        /* 截图还原：深红 RUN */
        .run-btn { 
            position: absolute; width: 100px; height: 100px; border-radius: 50%; 
            background: #000; border: 4px solid #ff0055; color: #ff0055; 
            display: flex; align-items: center; justify-content: center;
            font-size: 24px; font-weight: 900; cursor: pointer; z-index: 100;
            box-shadow: 0 0 30px #ff0055;
        }

        /* 底部控制台 */
        #msg { font-size: 24px; color: #ffcc00; font-weight: 900; height: 30px; }
        .bet-ctrl { display: flex; align-items: center; gap: 40px; }
        .btn-adj { font-size: 60px; color: #444; cursor: pointer; user-select: none; width: 60px; text-align: center; }
        .bet-val { font-size: 60px; font-weight: 900; min-width: 120px; text-align: center; }

        /* 震耳欲聋动画 */
        .bass { animation: b-shake 0.05s infinite; filter: contrast(1.5); }
        @keyframes b-shake { 0% { transform: scale(1.02) translate(1px, 1px); } 50% { transform: scale(0.98) translate(-1px, -1px); } }
    </style>
</head>
<body>

    <div class="app" id="view">
        <!-- 余额 -->
        <div class="bal-box">
            <div class="bal-num" id="a-val">1,000</div>
        </div>

        <!-- 转盘容器 -->
        <div class="stage">
            <div class="pointer"></div>
            <div class="wheel" id="core">
                <div class="item" style="transform:rotate(-90deg)"><b>👑</b></div>
                <div class="item" style="transform:rotate(-30deg)"><b>🦁</b></div>
                <div class="item" style="transform:rotate(30deg)"><b>🐯</b></div>
                <div class="item" style="transform:rotate(90deg)"><b>🦅</b></div>
                <div class="item" style="transform:rotate(150deg)"><b>🐺</b></div>
                <div class="item" style="transform:rotate(210deg)"><b>🐕</b></div>
            </div>
            <!-- 强制触发按钮 -->
            <div class="run-btn" onclick="run()">RUN</div>
        </div>

        <!-- 控制台 -->
        <div style="text-align: center;">
            <div id="msg">READY_SYSTEM</div>
            <div class="bet-ctrl">
                <div class="btn-adj" onclick="adj(-10)">-</div>
                <div class="bet-val" id="b-val">1</div>
                <div class="btn-adj" onclick="adj(10)">+</div>
            </div>
        </div>
    </div>

    <script>
        if(window.Telegram) window.Telegram.WebApp.expand();
    </script>
</body>
</html>