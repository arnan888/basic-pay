<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>AI_QUANT_GLOW_MAX</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
        
        /* 1. 背景全域大幅提亮：极光浅墨绿 */
        body { 
            background: #2d5a45; 
            background-image: radial-gradient(circle at 50% 50%, #4a8c6d 0%, #2d5a45 100%);
            color:#FFF; font-family: "PingFang SC", sans-serif; 
            height:100vh; overflow:hidden; display:flex; flex-direction:column;
            /* 四边外凸的高亮阴影 */
            box-shadow: inset 0 0 50px rgba(255,255,255,0.1);
        }

        .status-bar { background: rgba(0,0,0,0.5); height:28px; display:flex; align-items:center; padding:0 15px; font-size:10px; color:#42ff78; justify-content:center; }

        .core-section { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:flex-start; padding:15px; gap:15px; }

        /* 功能板块保持深色内陷 */
        .panel-inset {
            width:100%; background: #0a0f0d; border-radius:20px;
            border: 1px solid #000;
            box-shadow: inset 10px 10px 20px rgba(0,0,0,0.8), 0 4px 10px rgba(0,0,0,0.3);
        }

        /* 2. 余额数字：恢复强力荧光绿发光 */
        .balance-card { padding:22px; text-align:center; }
        .bal-val { 
            font-size:62px; font-weight:900; 
            color:#42ff78; /* 恢复高亮绿 */
            text-shadow: 0 0 25px rgba(66,255,120,0.8), 0 0 10px rgba(66,255,120,0.5); 
            font-family: 'Verdana', sans-serif; 
        }

        .wheel-well { 
            position:relative; width:100%; max-width:320px; aspect-ratio: 1/1;
            display:flex; align-items:center; justify-content:center;
        }
        
        .wheel-outer {
            width: 82%; height: 82%; border-radius: 50%; position: relative; 
            border: 6px solid #000; background: #050807; overflow: hidden;
            transition: transform 5s cubic-bezier(0.15, 0, 0.15, 1);
        }
        
        .wheel-center-val {
            position: absolute; z-index: 10; width: 75px; height: 75px; background: #0d1110;
            border-radius: 50%; border: 1px solid #1a1a1a; display: flex; align-items:center; justify-content:center;
            color: #42ff78; font-size: 22px; font-weight: 900; text-shadow: 0 0 15px #42ff78;
        }
        
        .slot-content { position:absolute; width:100%; height:100%; display:flex; flex-direction:column; align-items:center; padding-top:10px; }
        .beast-ico { font-size: 26px; }
        .beast-txt { font-size: 10px; color:#555; font-weight:bold; }
        .pointer-line { position:absolute; top:5px; left:50%; transform:translateX(-50%); width:4px; height:45px; background:#ff0000; z-index:100; box-shadow: 0 0 15px #ff0000; border-radius:2px; }

        /* 3. 底部控制区：按键独立发光 */
        .console-area { 
            width:100%; background:#0d1110; padding:20px 20px 85px 20px; 
            border-radius: 25px 25px 0 0; border-top: 1px solid #000;
        }
        
        .main-row { display:flex; gap:12px; margin-bottom:15px; }

        .btn-inset {
            background: #111; border: 1px solid #222; color:#fff; font-size:32px; border-radius:12px;
            display:flex; align-items:center; justify-content:center;
            box-shadow: inset 4px 4px 10px rgba(0,0,0,0.8);
        }
        .adj { width:65px; height:60px; }

        /* 3. 核心按钮：恢复强力大红发光 */
        .exec-glow { 
            flex:1; height:60px; 
            background: #ff0000; /* 恢复明亮大红 */
            border: none; color:#fff; font-size:24px; font-weight:900; 
            border-radius:12px; letter-spacing:4px;
            /* 强力发光阴影 */
            box-shadow: 0 0 20px rgba(255,0,0,0.6), inset 0 0 10px rgba(255,255,255,0.3);
            text-shadow: 0 0 10px rgba(255,255,255,0.5);
            transition: all 0.2s;
        }
        .exec-glow:active { transform: scale(0.98); box-shadow: 0 0 10px rgba(255,0,0,0.4); }
        
        .tech-row { display:grid; grid-template-columns: 1fr 1fr; gap:12px; }
        .mode-btn { 
            padding:14px; background:#0a0f0d; border: 1px solid #222; color:#666; font-size:12px; border-radius:10px; text-align:center;
            box-shadow: inset 4px 4px 8px rgba(0,0,0,0.5);
        }
        .mode-btn.on { color:#42ff78; border-color:#42ff78; text-shadow: 0 0 10px #42ff78; }

        .nav { position:fixed; bottom:0; width:100%; height:75px; background:#000; border-top:1px solid #111; display:grid; grid-template-columns: repeat(4, 1fr); }
        .nav-n { display:flex; flex-direction:column; align-items:center; justify-content:center; color:#444; font-size:11px; font-weight:bold; }
        .nav-n.act { color:#ff0000; }
    </style>
</head>
<body>

    <div class="status-bar">● QUANTUM_GLOW_TERMINAL ● </div>

    <div class="core-section">
        <!-- 余额区：极暗背景凸显高亮数字 -->
        <div class="panel-inset balance-card">
            <div style="font-size:10px; color:#2d5a45; margin-bottom:12px; letter-spacing:1px; font-weight:900;">AVAILABLE BALANCE (USDT)</div>
            <div class="bal-val" id="ui_bal">100.3</div>
            <div style="font-size:11px; color:#1a2f23; margin-top:8px;">UNIT_BET: <span id="ui_bet" style="color:#42ff78">0.5</span></div>
        </div>

        <!-- 转盘区：内陷结构 -->
        <div class="panel-inset wheel-well">
            <div class="pointer-line"></div>
            <div class="wheel-center-val" id="center_val">X88</div>
            <div id="ui_wheel" class="wheel-outer">
                <div class="slot-content" style="transform:rotate(0deg)"><span class="beast-ico">🦢</span><span class="beast-txt">孤鸿</span></div>
                <div class="slot-content" style="transform:rotate(45deg)"><span class="beast-ico">🐺</span><span class="beast-txt">孤狼</span></div>
                <div class="slot-content" style="transform:rotate(90deg)"><span class="beast-ico">🐢</span><span class="beast-txt">玄武</span></div>
                <div class="slot-content" style="transform:rotate(135deg)"><span class="beast-ico">🦌</span><span class="beast-txt">麒麟</span></div>
                <div class="slot-content" style="transform:rotate(180deg)"><span class="beast-ico">🐲</span><span class="beast-txt" style="color:#42ff78">神龙</span></div>
                <div class="slot-content" style="transform:rotate(225deg)"><span class="beast-ico">🔥</span><span class="beast-txt">凤凰</span></div>
                <div class="slot-content" style="transform:rotate(270deg)"><span class="beast-ico">🦅</span><span class="beast-txt">大鹏</span></div>
                <div class="slot-content" style="transform:rotate(315deg)"><span class="beast-ico">🦢</span><span class="beast-txt">仙鹤</span></div>
            </div>
        </div>
    </div>

    <!-- 控制台：深色不内陷 -->
    <div class="console-area">
        <div class="main-row">
            <div class="btn-inset adj" onclick="changeBet(-0.5)">－</div>
            <!-- 大红发光按钮 -->
            <button id="go_btn" class="exec-glow" onclick="go()">开始执行</button>
            <div class="btn-inset adj" onclick="changeBet(0.5)">＋</div>
        </div>
        <div class="tech-row">
            <div id="auto_btn" class="mode-btn" onclick="toggleAuto()">🤖 自动模式: 关</div>
            <div id="speed_btn" class="mode-btn" onclick="cycleSpeed()">⚡ 变速模式: 1X</div>
        </div>
    </div>

    <div class="nav">
        <div class="nav-n">行情</div><div class="nav-n">资产中心</div><div class="nav-n">历史记录</div><div class="nav-n act">量化终端</div>
    </div>

    <script>
        let balance = 100.3, bet = 0.5, rot = 0, busy = false, isAuto = false, speedMode = 1;
        const beastNames = ["X0", "X0", "X120", "X500", "X50", "X88", "X50", "X20"];
        const multis = [0, 0, 120, 500, 50, 88, 50, 20];

        function toggleAuto() {
            isAuto = !isAuto;
            document.getElementById('auto_btn').className = isAuto ? 'mode-btn on' : 'mode-btn';
            document.getElementById('auto_btn').innerHTML = `🤖 自动模式: ${isAuto ? '开' : '关'}`;
            if(isAuto && !busy) go();
        }

        function cycleSpeed() {
            speedMode = (speedMode % 3) + 1;
            const btn = document.getElementById('speed_btn');
            btn.innerHTML = `⚡ 变速模式: ${speedMode}X`;
            const times = ["", "5s", "1.2s", "0.5s"];
            document.getElementById('ui_wheel').style.transitionDuration = times[speedMode];
        }

        function changeBet(val) {
            if (busy) return;
            let n = bet + val;
            if (n >= 0.5) { bet = n; document.getElementById('ui_bet').innerText = bet.toFixed(1); }
        }

        function go() {
            if (busy || balance < bet) { isAuto = false; return; }
            busy = true;
            document.getElementById('go_btn').style.opacity = "0.7";
            const r = Math.floor(Math.random() * 1000);
            let idx = (r < 500) ? 0 : (r < 850 ? 1 : (r < 950 ? 7 : (r < 980 ? 6 : (r < 990 ? 2 : (r < 996 ? 5 : (r < 999 ? 4 : 3))))));
            const targetAngle = idx * 45; 
            rot += (Math.floor(Math.random() * 5) + 10) * 360 + (360 - targetAngle - (rot % 360)) + 360;
            document.getElementById('ui_wheel').style.transform = `rotate(${rot}deg)`;
            const waitTimes = [0, 5000, 1200, 500];
            setTimeout(() => {
                const prize = multis[idx] * bet;
                balance = (balance - bet) + prize;
                document.getElementById('ui_bal').innerText = balance.toFixed(1);
                document.getElementById('center_val').innerText = beastNames[idx];
                if(isAuto) setTimeout(go, 800);
                setTimeout(() => { busy = false; document.getElementById('go_btn').style.opacity = "1"; }, 500);
            }, waitTimes[speedMode]);
        }
    </script>
</body>
</html>