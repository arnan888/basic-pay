        let b = 1000, bet = 1, r = 0, isS = false, audio;

        // 🎵 顶级提神音效：高能电音节奏引擎
        function startMusic() {
            if(!audio) {
                audio = new (window.AudioContext || window.webkitAudioContext)();
                const master = audio.createGain(); master.gain.setValueAtTime(0.08, audio.currentTime); master.connect(audio.destination);

                // 循环背景 Techno 节奏
                const playLoop = () => {
                    const o = audio.createOscillator(); const g = audio.createGain();
                    o.type = 'sawtooth'; o.frequency.setValueAtTime(50, audio.currentTime);
