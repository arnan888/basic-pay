        :root { --neon: #00f2ff; --pink: #ff0055; --gold: #ffcc00; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin: 0; padding: 0; }
        
        body { background: #000; color: #fff; font-family: 'JetBrains Mono', monospace; height: 100vh; overflow: hidden; }

        /* 3D 空间画布 */
        #fxCanvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }

        .ui-root { position: relative; z-index: 10; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 40px 0; }

        /* 截图同款：霓虹余额框 */
        .bal-frame {
            background: rgba(0,0,0,0.8); border: 2px solid var(--neon);
            padding: 12px 50px; border-radius: 20px;
            box-shadow: 0 0 20px var(--neon), inset 0 0 10px var(--neon);
            display: flex; align-items: center; gap: 15px;
        }
        .bal-num { font-size: 56px; font-weight: 900; letter-spacing: -2px; text-shadow: 0 0 15px var(--neon); }

        /* 核心区：三层联动矩阵 */
        .core-stage { position: relative; width: 95vw; max-width: 420px; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; }
        
        /* 极简白色指针 */
        .p-needle { position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 3px; height: 70px; background: #fff; z-index: 100; box-shadow: 0 0 15px #fff; }

        .layer-m { position: absolute; inset: 0; border-radius: 50%; border: 1px dashed rgba(255,255,255,0.1); transition: 7.5s cubic-bezier(0.1, 0, 0, 1); }
        .layer-i { position: absolute; inset: 15%; border-radius: 50%; background: radial-gradient(circle, #111, #000); transition: 7s cubic-bezier(0.15, 0, 0.05, 1); }

