            if(isS || b < bet) return;
            isS = true; b -= bet; document.getElementById('bal').innerText = b.toLocaleString();
            tg.HapticFeedback.impactOccurred('heavy');
            
            let tick = setInterval(() => { if(isS) playSFX(200 + Math.random()*1000, 0.08, 'sawtooth', 0.03); }, 100);
            
