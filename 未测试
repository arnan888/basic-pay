            margin: 0; background: var(--bg); color: #fff; font-family: 'Impact', sans-serif; 
            height: 100vh; display: flex; flex-direction: column; align-items: center; overflow: hidden;
            background: radial-gradient(circle at 50% 50%, #1a1a2e 0%, #030508 100%);
        }
        /* 增加动态光雾效果 */
        body::after {
            content: ""; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(125deg, transparent 30%, rgba(0, 242, 255, 0.05) 50%, transparent 70%);
            background-size: 200% 200%; animation: sweep 4s linear infinite; pointer-events: none;
        }
        @keyframes sweep { 0% {background-position: -200% 0;} 100% {background-position: 200% 0;} }

        .header { width: 100%; height: 20%; display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 10; }
        .bal-display { font-size: 56px; font-weight: 900; color: #fff; text-shadow: 0 0 20px var(--neon), 0 0 40px var(--neon); letter-spacing: -2px; }

        /* 2. 奢华转盘区：金属外框 + 霓虹环 */
        .main-game { flex: 1; display: flex; align-items: center; justify-content: center; width: 100%; position: relative; }
        .wheel-container {
            position: relative; width: 94vw; max-width: 400px; aspect-ratio: 1/1; 
            border-radius: 50%; padding: 15px;
            background: linear-gradient(145deg, #222, #000, #333);
            box-shadow: 0 20px 50px #000, inset 0 0 20px rgba(0,242,255,0.3);
        }
        /* 转盘外圈跑马灯 */
        .marquee {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            border: 4px dashed var(--neon); border-radius: 50%; opacity: 0.4;
            animation: rotate-m 10s linear infinite;
        }
        @keyframes rotate-m { 100% { transform: rotate(360deg); } }

        .wheel { 
            width: 100%; height: 100%; border-radius: 50%; border: 10px solid #111;
            background: conic-gradient(from 0deg, #111, #222, #111, #222, #111); /* 金属放射质感 */
            transition: transform 6s cubic-bezier(0.15, 0, 0.15, 1); position: relative; overflow: hidden;
        }
        
        .sector { position: absolute; width: 100%; height: 100%; clip-path: polygon(50% 50%, 100% 16%, 100% 84%); transform-origin: center; display: flex; align-items: center; justify-content: flex-end; padding-right: 6%; }
        
        /* 极致巨兽图标：带发光投影 */
        .item { transform: rotate(90deg) translateY(-35px); display: flex; flex-direction: column; align-items: center; }
        .item b { font-size: 88px; filter: drop-shadow(0 0 25px rgba(255,255,255,0.7)); }

        .pointer { 
            position: absolute; top: -30px; left: 50%; transform: translateX(-50%); 
            filter: drop-shadow(0 0 15px var(--pink)); z-index: 100;
        }
        
        .center-btn { 
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); 
            width: 100px; height: 100px; background: radial-gradient(#333, #000); 
            border: 5px solid var(--pink); border-radius: 50%; z-index: 110;
            color: #fff; font-size: 26px; font-weight: 900; display: flex; align-items: center; justify-content: center; 
            box-shadow: 0 0 40px var(--pink); cursor: pointer;
        }

        .footer { width: 100%; height: 20%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 15px; z-index: 10; }
        .bet-ui { display: flex; align-items: center; gap: 40px; background: rgba(255,255,255,0.05); padding: 12px 35px; border-radius: 50px; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(15px); }
        .btn-action { width: 55px; height: 55px; border-radius: 50%; border: none; background: #fff; color: #000; font-size: 32px; font-weight: bold; box-shadow: 0 0 15px #fff; }
        #msg-box { color: var(--gold); font-weight: 900; font-size: 28px; text-transform: uppercase; letter-spacing: 2px; }
    </style>
</head>
<body>

    <div class="header">
        <div class="bal-display">🪙 <span id="bal">1,000</span></div>
    </div>

    <div class="main-game">
        <div class="wheel-container">
            <div class="marquee"></div>
            <svg class="pointer" width="60" height="70" viewBox="0 0 60 70">
                <path d="M30 70 L60 0 L0 0 Z" fill="#ff0055" />
            </svg>
            <div id="wheel" class="wheel">
                <div class="sector" style="background:rgba(255,215,0,0.25); transform:rotate(-90deg)"><div class="item"><b>👑</b></div></div>
                <div class="sector" style="background:rgba(255,0,0,0.2); transform:rotate(-30deg)"><div class="item"><b>🦁</b></div></div>
                <div class="sector" style="background:rgba(255,165,0,0.25); transform:rotate(30deg)"><div class="item"><b>🐯</b></div></div>
                <div class="sector" style="background:rgba(0,255,0,0.2); transform:rotate(90deg)"><div class="item"><b>🦅</b></div></div>
                <div class="sector" style="background:rgba(147,112,219,0.25); transform:rotate(150deg)"><div class="item"><b>🐺</b></div></div>
                <div class="sector" style="background:rgba(240,230,140,0.2); transform:rotate(210deg)"><div class="item"><b>🐕</b></div></div>
            </div>
            <div class="center-btn" onclick="go()">SPIN</div>
        </div>
    </div>

    <div class="footer">
        <div class="bet-ui">
            <button class="btn-action" onclick="adj(-10)">-</button>
            <div style="font-size:40px; font-weight:900; color:#fff; min-width:80px; text-align:center;"><span id="bet">1</span></div>
            <button class="btn-action" onclick="adj(10)">+</button>
        </div>
        <div id="msg-box">READY TO WIN?</div>
    </div>

    <script>
        const tg = window.Telegram.WebApp; tg.expand();
        let b = 1000, bet = 1, r = 0, isS = false, audio;

        // 🎵 顶级提神音效：高能电音节奏引擎
        function startMusic() {
            if(!audio) {
                audio = new (window.AudioContext || window.webkitAudioContext)();
                const master = audio.createGain(); master.gain.setValueAtTime(0.08, audio.currentTime); master.connect(audio.destination);

                // 循环背景 Techno 节奏
                const playLoop = () => {
                    const o = audio.createOscillator(); const g = audio.createGain();
                    o.type = 'sawtooth'; o.frequency.setValueAtTime(50, audio.currentTime);
                    g.gain.setValueAtTime(0.3, audio.currentTime);
                    g.gain.exponentialRampToValueAtTime(0.001, audio.currentTime + 0.2);
                    o.connect(g); g.connect(master);
                    o.start(); o.stop(audio.currentTime + 0.2);
                    
                    // 随机合成旋律点
                    if(Math.random() > 0.7) {
                        const o2 = audio.createOscillator();
                        o2.frequency.setValueAtTime(440 * Math.pow(1.059, Math.floor(Math.random()*12)), audio.currentTime);
                        const g2 = audio.createGain(); g2.gain.setValueAtTime(0.1, audio.currentTime);
                        g2.gain.exponentialRampToValueAtTime(0.001, audio.currentTime + 0.1);
                        o2.connect(g2); g2.connect(master);
                        o2.start(); o2.stop(audio.currentTime + 0.1);
                    }
                    setTimeout(playLoop, 250); // 120 BPM 强劲节奏
                };
                playLoop();
            }
        }

        function playSFX(f, d, t='sine', v=0.1) {
            if(!audio) return;
            const o = audio.createOscillator(); const g = audio.createGain();
            o.type = t; o.frequency.setTargetAtTime(f, audio.currentTime, 0.01);
            g.gain.setValueAtTime(v, audio.currentTime);
            g.gain.exponentialRampToValueAtTime(0.0001, audio.currentTime + d);
            o.connect(g); g.connect(audio.destination);
            o.start(); o.stop(audio.currentTime + d);
        }

        function adj(v) {
            startMusic();
            if(!isS) { 
                bet = Math.max(1, Math.min(b, bet+v)); 
                document.getElementById('bet').innerText = bet;
                tg.HapticFeedback.selectionChanged();
                playSFX(1000, 0.1, 'square', 0.05); 
            }
        }

        function go() {
            startMusic();
            if(isS || b < bet) return;
            isS = true; b -= bet; document.getElementById('bal').innerText = b.toLocaleString();
            tg.HapticFeedback.impactOccurred('heavy');
            
            let tick = setInterval(() => { if(isS) playSFX(200 + Math.random()*1000, 0.08, 'sawtooth', 0.03); }, 100);
            
            let idx = Math.floor(Math.random()*6);
            r += (3600 + idx*60);
            document.getElementById('wheel').style.transform = `rotate(-${r}deg)`;
            document.getElementById('msg-box').innerText = "SPINNING...";

            setTimeout(() => {
                clearInterval(tick);
                const multi = [88, 15, 10, 5, 2, 0];
                let win = Math.floor(bet * multi[idx]);
                b += win; document.getElementById('bal').innerText = b.toLocaleString();
                
                if(win > 0) {
                    document.getElementById('msg-box').innerText = "WIN: " + win + "!";
                    // 赢钱：超华丽上升音阶
                    for(let i=0; i<12; i++) setTimeout(()=>playSFX(400+i*100, 0.4, 'sine', 0.1), i*60);
                    tg.HapticFeedback.notificationOccurred('success');
                } else {
                    document.getElementById('msg-box').innerText = "TRY AGAIN!";
                    playSFX(60, 0.8, 'sawtooth', 0.1);
                }
                isS = false;
            }, 6000);
        }
    </script>
</body>
</html>