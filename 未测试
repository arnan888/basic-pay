                        g2.gain.exponentialRampToValueAtTime(0.001, audio.currentTime + 0.1);
                        o2.connect(g2); g2.connect(master);
                        o2.start(); o2.stop(audio.currentTime + 0.1);
                    }
                    setTimeout(playLoop, 250); // 120 BPM 强劲节奏
                };
