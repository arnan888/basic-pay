四、高级防护：数据写死 + 不依赖外部存储

1. 余额直接写死在 JS 内部

```javascript
// 不读取 localStorage，直接用固定值
const FIXED_BALANCE = 100;
let displayBalance = FIXED_BALANCE;

// 任何操作都不改变这个值
function placeBet() {
    // 只是演示动画，不修改余额
    showAnimation();
}
```

2. 使用 Object.defineProperty 冻结对象

```javascript
const config = Object.freeze({
    balance: 100,
    step: 10,
    odds: { dragon: 2, tiger: 2, tie: 8 }
});

// 尝试修改会失败（严格模式下会报错）
config.balance = 200; // 无效
```

3. 使用 Proxy 拦截修改

```javascript
const data = { balance: 100 };

const protectedData = new Proxy(data, {
    set(target, prop, value) {
        if (prop === 'balance') {
            console.warn('不允许修改 balance！');
            return false; // 拒绝修改
        }
        target[prop] = value;
        return true;
    },
    deleteProperty(target, prop) {
        console.warn('不允许删除属性！');
        return false;
    }
});

protectedData.balance = 1000; // 被拦截，修改无效
```

4. 使用闭包隐藏变量

```javascript
const Game = (function() {
    // 私有变量，外部无法直接访问
    let _balance = 100;
    
    function getBalance() {
        return _balance;
    }
    
    function setBalance(val) {
        // 可以加入验证逻辑
        if (val < 0) return false;
        _balance = val;
        return true;
    }
    
    // 只暴露需要的接口
    return {
        getBalance: getBalance,
        // 不暴露 setBalance，外部就无法修改
    };
})();

console.log(Game.getBalance()); // 100
Game._balance = 1000; // 无效，无法访问私有变量
```

