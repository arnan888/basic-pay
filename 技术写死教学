六、综合防护示例代码

```html
<!DOCTYPE html>
<html>
<head>
    <title>防护示例</title>
    <style>/* 正常样式 */</style>
</head>
<body>
    <div id="app">加载中...</div>

    <script>
    // ========== 1. 禁用开发者工具 ==========
    (function disableDevTools() {
        // 禁用右键
        document.addEventListener('contextmenu', e => e.preventDefault());
        
        // 禁用快捷键
        document.addEventListener('keydown', e => {
            const keys = ['F12', 'I', 'J', 'C', 'U'];
            if (e.key === 'F12' || (e.ctrlKey && keys.includes(e.key))) {
                e.preventDefault();
                return false;
            }
        });
        
        // 检测开发者工具
        setInterval(() => {
            if (window.devtools && window.devtools.open) {
                location.reload();
            }
        }, 1000);
    })();
    
    // ========== 2. 数据写死（闭包 + 冻结） ==========
    const GameCore = (function() {
        // 私有变量
        const _CONFIG = Object.freeze({
            balance: 100,
            step: 10,
            maxBet: 1000
        });
        
        let _currentBalance = _CONFIG.balance;
        
        // 不暴露修改方法
        function getBalance() {
            return _currentBalance;
        }
        
        // 只允许内部调用
        function _setBalance(val) {
            if (val >= 0) _currentBalance = val;
        }
        
        return {
            getBalance: getBalance,
            // 故意不暴露 setBalance
            config: _CONFIG  // 只读
        };
    })();
    
    // ========== 3. 界面渲染 ==========
    document.getElementById('app').innerHTML = `
        <div>余额：${GameCore.getBalance()}</div>
        <div>配置：${JSON.stringify(GameCore.config)}</div>
        <button id="test">尝试修改余额</button>
    `;
    
    document.getElementById('test').onclick = () => {
        // 这里无法修改 GameCore 内部的余额
        alert('当前余额：' + GameCore.getBalance());
    };
    </script>
</body>
</html>
```

