五、终极方案：核心逻辑放在后端

架构图

```
用户浏览器（前端）
     ↓ 发送投注请求
后端服务器（Node.js/PHP/Java）
     ↓ 验证余额、计算结果
数据库
     ↓ 返回结果
用户浏览器（显示结果）
```

前端只负责展示

```javascript
// 前端代码
async function placeBet(type, amount) {
    const response = await fetch('/api/bet', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
            type: type, 
            amount: amount,
            token: localStorage.getItem('token') // 用户身份验证
        })
    });
    const result = await response.json();
    
    if (result.success) {
        showResult(result.winAmount);
        updateBalance(result.newBalance);
    } else {
        alert(result.error);
    }
}
```

后端验证逻辑（Node.js 示例）

```javascript
// server.js
const express = require('express');
const app = express();

// 用户余额存在服务器内存/数据库
const userBalances = new Map();

app.post('/api/bet', (req, res) => {
    const { userId, type, amount } = req.body;
    
    // 1. 验证用户身份
    if (!isValidUser(userId)) {
        return res.json({ success: false, error: '无效用户' });
    }
    
    // 2. 检查余额是否足够
    let balance = userBalances.get(userId) || 100;
    if (balance < amount) {
        return res.json({ success: false, error: '余额不足' });
    }
    
    // 3. 服务器随机产生结果
    const result = ['龙', '虎', '和'][Math.floor(Math.random() * 3)];
    let win = 0;
    if (type === result) {
        win = amount * (result === '和' ? 8 : 2);
    }
    
    // 4. 更新余额（服务器端）
    balance = balance - amount + win;
    userBalances.set(userId, balance);
    
    // 5. 返回结果
    res.json({
        success: true,
        result: result,
        winAmount: win,
        newBalance: balance
    });
});
```

