<script>
// ==================== 本地状态 ====================
let state = {
    balance: 10000,
    betStep: 10,
    bets: { DRAGON: 0, TIGER: 0, TIE: 0 },
    betRolling: false,
    pool: 50000,
    countdown: 30,
    countdownInterval: null
};

// ==================== UI更新 ====================
function updateUI() {
    document.getElementById('balanceDisplay').innerText = state.balance.toFixed(2);
    document.getElementById('poolDisplay').innerText = state.pool.toFixed(2);
    document.getElementById('betDragonAmount').innerText = state.bets.DRAGON;
    document.getElementById('betTigerAmount').innerText = state.bets.TIGER;
    document.getElementById('betTieAmount').innerText = state.bets.TIE;

    const totalBet = state.bets.DRAGON + state.bets.TIGER + state.bets.TIE;
    document.getElementById('totalBetAmount').innerText = totalBet.toFixed(2);

    let maxWin = 0;
    if (state.bets.DRAGON > 0) maxWin = Math.max(maxWin, state.bets.DRAGON * 2);
    if (state.bets.TIGER > 0) maxWin = Math.max(maxWin, state.bets.TIGER * 2);
    if (state.bets.TIE > 0) maxWin = Math.max(maxWin, state.bets.TIE * 8);
    document.getElementById('val-win').innerText = maxWin.toFixed(2);

    document.querySelectorAll('.multi-bet-item').forEach(el => {
        const type = el.dataset.type;
        el.classList.toggle('selected', state.bets[type] > 0);
    });
}

function adjustBet(type, delta) {
    if (state.betRolling) return;
    let newVal = state.bets[type] + delta;
    if (newVal < 0) newVal = 0;
    state.bets[type] = newVal;
    updateUI();
}

function adjustStep(dir) {
    let newStep = state.betStep + dir * 10;
    if (newStep < 10) newStep = 10;
    if (newStep > 500) newStep = 500;
    state.betStep = newStep;
    document.getElementById('stepValue').innerText = state.betStep;
}

// ==================== 特效函数 ====================
function triggerFightEffect() {
    const effect = document.getElementById('fight-effect');
    effect.classList.remove('flash');
    setTimeout(() => effect.classList.add('flash'), 10);
}

function showResultBig(result, isWin) {
    const resultBig = document.getElementById('resultBig');
    let displayChar = '';
    if (result === '龙') displayChar = '🐉 龙！';
    else if (result === '虎') displayChar = '🐯 虎！';
    else displayChar = '⚖️ 和！';
    resultBig.innerText = displayChar;
    resultBig.classList.remove('animate');
    void resultBig.offsetWidth; // 强制重绘
    resultBig.classList.add('animate');
    // 如果中奖，额外增加粒子效果
    if (isWin) {
        createWinParticles();
    }
}

function createWinParticles() {
    const container = document.getElementById('particlesContainer');
    const scene = document.getElementById('battleScene');
    const rect = scene.getBoundingClientRect();
    const centerX = rect.width / 2;
    const centerY = rect.height / 2;
    for (let i = 0; i < 40; i++) {
        const particle = document.createElement('div');
        particle.className = 'particle';
        const angle = Math.random() * Math.PI * 2;
        const distance = 30 + Math.random() * 80;
        const dx = Math.cos(angle) * distance;
        const dy = Math.sin(angle) * distance;
        particle.style.setProperty('--dx', dx + 'px');
        particle.style.setProperty('--dy', dy + 'px');
        particle.style.left = centerX + 'px';
        particle.style.top = centerY + 'px';
        container.appendChild(particle);
        setTimeout(() => particle.remove(), 1000);
    }
}

// ==================== 开奖逻辑 ====================
function performDraw() {
    if (state.betRolling) return;

    const totalBet = state.bets.DRAGON + state.bets.TIGER + state.bets.TIE;
    if (totalBet === 0) {
        document.getElementById('battle-result').innerText = '⏳ 无人押注，跳过此局';
        clearCountdown();
        startCountdown(30);
        return;
    }

    // 选择押注金额最大的选项
    let selectedType = null;
    let selectedAmount = 0;
    if (state.bets.DRAGON > 0) { selectedType = "DRAGON"; selectedAmount = state.bets.DRAGON; }
    if (state.bets.TIGER > selectedAmount) { selectedType = "TIGER"; selectedAmount = state.bets.TIGER; }
    if (state.bets.TIE > selectedAmount) { selectedType = "TIE"; selectedAmount = state.bets.TIE; }

    if (!selectedType) return;

    const typeMap = { "DRAGON": "龙", "TIGER": "虎", "TIE": "和" };
    const betType = typeMap[selectedType];
    const betAmount = selectedAmount;

    if (betAmount > state.balance) {
        document.getElementById('battle-result').innerText = '⚠️ 余额不足，跳过此局';
        clearCountdown();
        startCountdown(30);
        return;
    }

    state.betRolling = true;
    document.getElementById('battle-result').innerText = '🎲 开奖中... 🎲';

    // 模拟随机结果
    const result = (() => {
        const r = Math.random();
        if (r < 0.4) return "龙";
        if (r < 0.8) return "虎";
        return "和";
    })();

    let win = 0;
    let isWin = false;
    if (betType === result) {
        win = betAmount * (result === "和" ? 8 : 2);
        state.balance += win;
        isWin = true;
    } else {
        state.balance -= betAmount;
    }

    updateUI();
    triggerFightEffect();
    showResultBig(result, isWin);

    const resultMsg = win > 0 
        ? `🎲 开奖: ${result}  ✅ 中奖 +${win} TRX`
        : `🎲 开奖: ${result}  ❌ 未中奖`;
    document.getElementById('battle-result').innerText = resultMsg;

    // 清空押注
    state.bets = { DRAGON: 0, TIGER: 0, TIE: 0 };
    updateUI();

    // 15秒后恢复默认文字，并开始下一轮倒计时
    setTimeout(() => {
        document.getElementById('battle-result').innerText = '龙虎相争·一触即发';
        state.betRolling = false;
        startCountdown(30);
    }, 15000);
}

// ==================== 倒计时管理 ====================
function startCountdown(seconds) {
    if (state.countdownInterval) clearInterval(state.countdownInterval);
    state.countdown = seconds;
    document.getElementById('timerText').innerText = `下一局: ${state.countdown}秒`;
    state.countdownInterval = setInterval(() => {
        if (state.countdown <= 1) {
            clearInterval(state.countdownInterval);
            state.countdownInterval = null;
            performDraw();
        } else {
            state.countdown--;
            document.getElementById('timerText').innerText = `下一局: ${state.countdown}秒`;
        }
    }, 1000);
}

function clearCountdown() {
    if (state.countdownInterval) {
        clearInterval(state.countdownInterval);
        state.countdownInterval = null;
    }
}

// ==================== 彩金池波动 ====================
function startPoolFluctuation() {
    setInterval(() => {
        let change = Math.floor(Math.random() * 61) - 30;
        let newPool = state.pool + change;
        if (newPool < 10000) newPool = 10000;
        if (newPool > 100000) newPool = 100000;
        state.pool = newPool;
        document.getElementById('poolDisplay').innerText = state.pool.toFixed(2);
    }, 1000);
}

// ==================== 手动刷新 ====================
function refreshBalance() {
    updateUI();
    document.getElementById('battle-result').innerText = '💰 余额已刷新';
    setTimeout(() => {
        if (!state.betRolling && document.getElementById('battle-result').innerText === '💰 余额已刷新') {
            document.getElementById('battle-result').innerText = '龙虎相争·一触即发';
        }
    }, 2000);
}

// ==================== 事件绑定 ====================
function bindEvents() {
    document.getElementById('refreshBtn').onclick = refreshBalance;
    document.getElementById('stepMinus').onclick = () => adjustStep(-1);
    document.getElementById('stepPlus').onclick = () => adjustStep(1);

    const decButtons = document.querySelectorAll('.bet-dec');
    const incButtons = document.querySelectorAll('.bet-inc');

    decButtons.forEach(btn => {
        btn.onclick = (e) => {
            e.stopPropagation();
            const type = btn.dataset.type;
            adjustBet(type, -state.betStep);
        };
    });
    incButtons.forEach(btn => {
        btn.onclick = (e) => {
            e.stopPropagation();
            const type = btn.dataset.type;
            adjustBet(type, state.betStep);
        };
    });
}

// ==================== 初始化 ====================
function init() {
    bindEvents();
    updateUI();
    startPoolFluctuation();
    startCountdown(30);
}

window.onload = init;
</script>
