        // 创建3D骰子函数
        function create3DDice(containerId, initialRotateX = 0, initialRotateY = 0) {
            const container = document.getElementById(containerId);
            if (!container) return null;
            const dice = document.createElement('div');
            dice.className = 'dice';
            const directions = [
                { name: 'front', transform: 'translateZ(30px)' },
                { name: 'right', transform: 'translateZ(30px) rotateY(90deg)' },
                { name: 'back',  transform: 'translateZ(30px) rotateY(180deg)' },
                { name: 'left',  transform: 'translateZ(30px) rotateY(-90deg)' },
                { name: 'top',   transform: 'translateZ(30px) rotateX(90deg)' },
                { name: 'bottom',transform: 'translateZ(30px) rotateX(-90deg)' }
            ];
            directions.forEach((dir, idx) => {
                const face = document.createElement('div');
                face.className = `dice-face ${dir.name}`;
                face.style.backgroundImage = `url('${faceImages[idx]}')`;
                face.style.backgroundSize = 'cover';
                face.style.backgroundPosition = 'center';
                face.style.transform = dir.transform;
                dice.appendChild(face);
            });
            dice.style.transform = `rotateX(${initialRotateX}deg) rotateY(${initialRotateY}deg)`;
            container.appendChild(dice);
            return dice;
        }

        // 初始化三个骰子
        const diceElements = [];
        for (let i = 0; i < 3; i++) {
            const randX = Math.floor(Math.random() * 360);
            const randY = Math.floor(Math.random() * 360);
            const dice = create3DDice(`diceContainer${i}`, randX, randY);
            diceElements.push(dice);
        }

        // 旋转骰子到指定图案
        function rotateDiceToPattern(dice, patternName) {
            const patternIndex = facePatterns.indexOf(patternName);
            if (patternIndex === -1) return;
            let rotateX = 0, rotateY = 0;
            switch (patternIndex) {
                case 0: rotateX = 0; rotateY = 0; break;
                case 1: rotateX = 0; rotateY = -90; break;
                case 2: rotateX = 0; rotateY = 180; break;
                case 3: rotateX = 0; rotateY = 90; break;
                case 4: rotateX = -90; rotateY = 0; break;
                case 5: rotateX = 90; rotateY = 0; break;
            }
            const extraX = 360 * (1 + Math.floor(Math.random() * 2));
            const extraY = 360 * (1 + Math.floor(Math.random() * 2));
            dice.style.transform = `rotateX(${rotateX + extraX}deg) rotateY(${rotateY + extraY}deg)`;
        }

        // 摇骰子动画并最终定格
        async function rollAllDiceToPatterns(targetPatterns) {
            // 快速随机旋转
            for (let i = 0; i < 3; i++) {
                const dice = diceElements[i];
                dice.style.transition = 'none';
                const randX = Math.floor(Math.random() * 360);
                const randY = Math.floor(Math.random() * 360);
                dice.style.transform = `rotateX(${randX}deg) rotateY(${randY}deg)`;
            }
            await new Promise(r => setTimeout(r, 50));
            for (let i = 0; i < 3; i++) {
                diceElements[i].style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
            }
            // 跳动
            for (let step = 0; step < 10; step++) {
                for (let i = 0; i < 3; i++) {
                    const randX = Math.floor(Math.random() * 360);
                    const randY = Math.floor(Math.random() * 360);
                    diceElements[i].style.transform = `rotateX(${randX}deg) rotateY(${randY}deg)`;
                }
                await new Promise(r => setTimeout(r, 80));
            }
            // 最终定格
            for (let i = 0; i < 3; i++) {
                rotateDiceToPattern(diceElements[i], targetPatterns[i]);
            }
            await new Promise(r => setTimeout(r, 500));
        }

        // ========== 游戏逻辑 ==========
