        function modifyBalance(delta) { setUserBalance(getUserBalance() + delta); updateUI(); }

        function addBetPattern(id, val) {
            if (hasGrabbed) { showToast("庄家不能下注"); return; }
            let total = getTotalBet();
            if (val > MAX_SINGLE) { showToast(`单注上限${MAX_SINGLE}`); return; }
