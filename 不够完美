    const SEGMENTS = [
        { name: '🐉 龙', color1: '#ff4444', color2: '#cc0000', chn: '龙' },
        { name: '🐯 虎', color1: '#4488ff', color2: '#0066cc', chn: '虎' },
        { name: '⚖️ 和', color1: '#aa66ff', color2: '#8844cc', chn: '和' }
    ];
    
    const wheelCanvas = document.getElementById('premiumWheelCanvas');
    if (wheelCanvas) {
        const size = 400;
        wheelCanvas.width = size;
        wheelCanvas.height = size;
        wheelCanvas.style.width = '100%';
        wheelCanvas.style.height = '100%';
        
        const ctx = wheelCanvas.getContext('2d');
        const centerX = size / 2;
        const centerY = size / 2;
        const radius = size / 2 - 8;
        const TAU = Math.PI * 2;
        let currentRotation = 0;
        let isWheelSpinning = false;
        
        function drawSegment(startAngle, endAngle, color1, color2, label) {
            const gradient = ctx.createLinearGradient(
                centerX + Math.cos(startAngle) * radius * 0.3,
                centerY + Math.sin(startAngle) * radius * 0.3,
                centerX + Math.cos(endAngle) * radius * 0.8,
                centerY + Math.sin(endAngle) * radius * 0.8
            );
            gradient.addColorStop(0, color1);
            gradient.addColorStop(1, color2);
            
            ctx.beginPath();
            ctx.moveTo(centerX, centerY);
            ctx.arc(centerX, centerY, radius, startAngle, endAngle);
            ctx.closePath();
            ctx.fillStyle = gradient;
            ctx.fill();
            ctx.strokeStyle = 'rgba(255,255,255,0.3)';
            ctx.lineWidth = 1.5;
            ctx.stroke();
            
            const midAngle = startAngle + (endAngle - startAngle) / 2;
            const textRadius = radius * 0.65;
            const x = centerX + Math.cos(midAngle) * textRadius;
            const y = centerY + Math.sin(midAngle) * textRadius;
            
            ctx.font = `bold ${Math.floor(radius * 0.16)}px "PingFang SC"`;
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillStyle = '#ffffff';
            ctx.shadowBlur = 3;
            ctx.fillText(label, x, y);
        }
        
        function drawWheel(rotation = 0) {
            ctx.clearRect(0, 0, size, size);
            const anglePer = TAU / SEGMENTS.length;
            for (let i = 0; i < SEGMENTS.length; i++) {
                const seg = SEGMENTS[i];
                const start = i * anglePer + rotation;
                const end = (i + 1) * anglePer + rotation;
                drawSegment(start, end, seg.color1, seg.color2, seg.name);
            }
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius * 0.16, 0, TAU);
            ctx.fillStyle = '#1a1a2e';
            ctx.fill();
            ctx.strokeStyle = '#ffaa44';
            ctx.lineWidth = 2.5;
            ctx.stroke();
        }
        
        function syncWheelToResult(resultChn) {
            if (isWheelSpinning) return;
            isWheelSpinning = true;
            const spinBtn = document.getElementById('premiumSpinBtn');
            if (spinBtn) spinBtn.disabled = true;
            
            let targetIndex = resultChn === '龙' ? 0 : (resultChn === '虎' ? 1 : 2);
            const anglePer = TAU / SEGMENTS.length;
            const pointerAngle = -Math.PI / 2;
            let currentHitAngle = (pointerAngle - currentRotation + TAU * 4) % TAU;
            let currentIndex = Math.floor(currentHitAngle / anglePer) % SEGMENTS.length;
            let deltaIndex = (targetIndex - currentIndex + SEGMENTS.length) % SEGMENTS.length;
            let targetRotation = currentRotation + deltaIndex * anglePer;
            if (Math.abs(targetRotation - currentRotation) > Math.PI) {
                targetRotation = currentRotation - (SEGMENTS.length - deltaIndex) * anglePer;
            }
            const spins = 4 + Math.random() * 5;
            const finalRot = currentRotation + (spins * TAU) + (targetRotation - currentRotation) % TAU;
            const startRot = currentRotation;
            const duration = 1200;
            const startTime = performance.now();
            
            function animate(now) {
                const elapsed = now - startTime;
                const progress = Math.min(1, elapsed / duration);
                const ease = 1 - Math.pow(1 - progress, 3);
                currentRotation = startRot + (finalRot - startRot) * ease;
                drawWheel(currentRotation);
                if (progress < 1) {
                    requestAnimationFrame(animate);
                } else {
                    currentRotation = finalRot % TAU;
                    drawWheel(currentRotation);
                    isWheelSpinning = false;
                    if (spinBtn) spinBtn.disabled = false;
                }
            }
            requestAnimationFrame(animate);
        }
        
        function spinWheelRandom() {
            if (isWheelSpinning) return;
            isWheelSpinning = true;
            const spinBtn = document.getElementById('premiumSpinBtn');
            if (spinBtn) spinBtn.disabled = true;
            if (window.navigator && window.navigator.vibrate) window.navigator.vibrate(50);
            
            const spins = 6 + Math.random() * 10;
            const randomAngle = Math.random() * TAU;
            const finalRot = currentRotation + (spins * TAU) + randomAngle;
            const startRot = currentRotation;
            const duration = 1200;
            const startTime = performance.now();
            
            function animate(now) {
                const elapsed = now - startTime;
                const progress = Math.min(1, elapsed / duration);
                const ease = 1 - Math.pow(1 - progress, 3);
                currentRotation = startRot + (finalRot - startRot) * ease;
                drawWheel(currentRotation);
                if (progress < 1) {
                    requestAnimationFrame(animate);
                } else {
                    currentRotation = finalRot % TAU;
                    drawWheel(currentRotation);
                    const pointerAngle = -Math.PI / 2;
                    const anglePer = TAU / SEGMENTS.length;
                    let hitAngle = (pointerAngle - currentRotation + TAU * 4) % TAU;
                    let idx = Math.floor(hitAngle / anglePer) % SEGMENTS.length;
                    const result = SEGMENTS[idx].chn;
                    const toast = document.getElementById('premiumWheelToast');
                    if (toast) {
                        toast.textContent = `✨ ${result} ✨`;
                        toast.style.opacity = '1';
                        setTimeout(() => toast.style.opacity = '0', 1200);
                    }
                    document.getElementById('battleResult').innerHTML = `🎡 ${result}`;
                    highlightWord(result);
                    flashResult();
                    if (window.speechSynthesis) {
                        const utter = new SpeechSynthesisUtterance(result);
                        utter.lang = 'zh-CN';
                        speechSynthesis.cancel();
                        speechSynthesis.speak(utter);
                    }
                    if (window.navigator && window.navigator.vibrate) window.navigator.vibrate([50, 30, 50]);
                    isWheelSpinning = false;
                    if (spinBtn) spinBtn.disabled = false;
                }
            }
            requestAnimationFrame(animate);
        }
        
        drawWheel(0);
        syncWheelToResultFunc = syncWheelToResult;
        document.getElementById('premiumSpinBtn').onclick = (e) => { e.stopPropagation(); spinWheelRandom(); };
        document.getElementById('premiumWheelContainer').onclick = (e) => {
            if (e.target === document.getElementById('premiumSpinBtn')) return;
            if (!isWheelSpinning) spinWheelRandom();
        };
    }

    function init() {
        bindEvents();
        syncBalance();
        startPoolFluctuation();
        setSpeed(1);
        updateUI();
        startCountdown(30);
        refreshRecordDisplay();
        updateHistoryGrid();
        if (!localStorage.getItem('visited_before')) {
            localStorage.setItem('visited_before', 'true');
            setTimeout(() => {
                showModal("🎉 龙虎斗至尊版\n• 初始余额：0 rmb\n• 30秒倒计时，最后3秒禁止下注\n• 下注后转盘同步开奖\n• 长按「续押」3秒进入后台\n• 中奖金额会滚动显示", "开始");
            }, 500);
        }
    }
    
    init();
})();
</script>
