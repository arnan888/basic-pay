        async function settleAndAnimate(finalPatterns) {
            await rollAllDiceToPatterns(finalPatterns);
            let points = finalPatterns.map(n => ({ "鱼": 1, "虾": 2, "蟹": 3, "葫芦": 4, "金钱": 5, "鸡": 6 }[n]));
            let sum = points.reduce((a, b) => a + b, 0);
            let isTriplet = (finalPatterns[0] === finalPatterns[1] && finalPatterns[1] === finalPatterns[2]);
            let totalBet = getTotalBet();
