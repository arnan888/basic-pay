            if (val > getUserBalance()) { showToast("余额不足"); return; }
            patternBets[id] += val;
            modifyBalance(-val);
            updateUI();
        }
        function subBetPattern(id, val) { let cur = patternBets[id]; if (cur < val) val = cur; if (val === 0) return; patternBets[id] -= val; modifyBalance(val); updateUI(); }
        function addBetSpecial(type, val) {
            if (hasGrabbed) { showToast("庄家不能下注"); return; }
            let total = getTotalBet();
            if (val > MAX_SINGLE) return;
            if (total + val > MAX_TOTAL) return;
