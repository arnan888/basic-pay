        resultDiv.classList.add('result-flash');
        setTimeout(() => resultDiv.classList.remove('result-flash'), 200);
    }

    // 滚动数字动画
    let rollingInterval = null;
    function startRollingNumber(finalAmount) {
        const rollingDiv = document.getElementById('rollingWinNumber');
        if (!rollingDiv) return;
        if (rollingInterval) clearInterval(rollingInterval);
        
        let step = 0;
        const totalSteps = 25;
        const stepDuration = 25;
        
        rollingDiv.classList.add('rolling-animation');
        
        rollingInterval = setInterval(() => {
            step++;
            let progress = step / totalSteps;
            let easeOut = 1 - Math.pow(1 - progress, 2);
            let showNum = finalAmount * easeOut;
            
            if (step >= totalSteps) {
                clearInterval(rollingInterval);
                rollingInterval = null;
                rollingDiv.classList.remove('rolling-animation');
                rollingDiv.innerText = finalAmount.toFixed(2);
            } else {
                rollingDiv.innerText = showNum.toFixed(2);
            }
        }, stepDuration);
    }

    // 游戏状态
    let state = {
        balance: getBalance(CURRENT_USER_ID),
        bets: { DRAGON: 0, TIGER: 0, TIE: 0 },
        betRolling: false,
        autoMode: true,
        speed: 1,
        pool: 50000,
        countdown: 30,
        countdownInterval: null
    };
    let lastBet = null;
    let isBetLocked = false;
    let isAnimating = false;

    function syncBalance() { state.balance = getBalance(CURRENT_USER_ID); updateUI(); }

    function enableBetButtons(enabled) {
        const betBtns = document.querySelectorAll('.quick-bet, .clear-bet, #fightBtn');
        betBtns.forEach(btn => {
            if(enabled) { btn.disabled = false; btn.style.opacity = '1'; }
            else { btn.disabled = true; btn.style.opacity = '0.5'; }
        });
    }

    let syncWheelToResultFunc = null;

    function placeBet(type, amount) {
        if (state.betRolling || isAnimating || amount<=0 || amount>state.balance) return false;
        state.betRolling = true;
        
        const outcomes = ['龙', '虎', '和'];
        const result = outcomes[Math.floor(Math.random() * 3)];
        let win = 0;
        if (type === result) win = amount * (result === '和' ? 8 : 2);
        
        // 滚动数字动画
        startRollingNumber(win);
        
        if (syncWheelToResultFunc) {
            syncWheelToResultFunc(result);
        }
        
        const newBalance = state.balance - amount + win;
        setBalance(CURRENT_USER_ID, newBalance);
        state.balance = newBalance;
        updateUI();
        addRecord(CURRENT_USER_ID, type, result, win, amount);
        pushResult(CURRENT_USER_ID, result);
        
        highlightWord(result);
        flashResult();
        
        const resultMsg = win > 0 ? `🎲 ${result} +${win}` : `🎲 ${result}`;
        document.getElementById('battleResult').innerHTML = resultMsg;
        
        speak(result);
        if (window.navigator && window.navigator.vibrate) window.navigator.vibrate(100);
        
        setTimeout(() => {
            if (state.autoMode) {
                clearCountdown();
                startCountdown(30);
            }
            state.betRolling = false;
        }, 500);
        
        return true;
    }

    function executeBet() {
        if (state.betRolling || isAnimating) return;
        flashButton(document.getElementById('fightBtn'));
        
        let selectedType = null, selectedAmount = 0;
        if (state.bets.DRAGON > selectedAmount) { selectedType = "DRAGON"; selectedAmount = state.bets.DRAGON; }
        if (state.bets.TIGER > selectedAmount) { selectedType = "TIGER"; selectedAmount = state.bets.TIGER; }
        if (state.bets.TIE > selectedAmount) { selectedType = "TIE"; selectedAmount = state.bets.TIE; }
        if (!selectedType) return;
        
        const betType = { DRAGON:"龙", TIGER:"虎", TIE:"和" }[selectedType];
        lastBet = { type: betType, amount: selectedAmount };
        clearCountdown();
        placeBet(betType, selectedAmount);
        state.bets = { DRAGON: 0, TIGER: 0, TIE: 0 };
        updateUI();
    }

    function repeatLastBet() { 
        if(lastBet && !state.betRolling && !isAnimating && !isBetLocked) {
            flashButton(document.getElementById('repeatBtn'));
            placeBet(lastBet.type, lastBet.amount);
        }
    }
    
    function cancelAllBets() { 
        if(!state.betRolling && !isAnimating && !isBetLocked){ 
            flashButton(document.getElementById('cancelBtn'));
            state.bets = { DRAGON:0, TIGER:0, TIE:0 }; 
            updateUI(); 
        }
    }

    function updateUI() {
        document.getElementById('balanceDisplay').innerText = state.balance.toFixed(2);
        document.getElementById('poolDisplay').innerText = state.pool.toFixed(2);
        document.getElementById('betDragonAmount').innerHTML = state.bets.DRAGON + " rmb";
        document.getElementById('betTigerAmount').innerHTML = state.bets.TIGER + " rmb";
        document.getElementById('betTieAmount').innerHTML = state.bets.TIE + " rmb";
        const total = state.bets.DRAGON + state.bets.TIGER + state.bets.TIE;
        document.getElementById('totalBetAmount').innerText = total.toFixed(2);
        let maxWin = 0;
        if (state.bets.DRAGON > 0) maxWin = Math.max(maxWin, state.bets.DRAGON * 2);
        if (state.bets.TIGER > 0) maxWin = Math.max(maxWin, state.bets.TIGER * 2);
        if (state.bets.TIE > 0) maxWin = Math.max(maxWin, state.bets.TIE * 8);
        document.getElementById('valWin').innerText = maxWin.toFixed(2);
        document.querySelectorAll('.multi-bet-item').forEach(el => { 
            const type = el.dataset.type; 
            if (state.bets[type] > 0) el.classList.add('selected'); 
            else el.classList.remove('selected'); 
        });
    }

    function addBetAmount(type, amount) {
        if(state.betRolling || isAnimating || isBetLocked) return;
        const btn = document.querySelector(`.quick-bet[data-type="${type}"][data-amount="${amount}"]`);
        flashButton(btn);
        let newVal = state.bets[type] + amount;
        if (newVal > state.balance) {
            if (window.navigator && window.navigator.vibrate) window.navigator.vibrate(200);
            showModal("❌ 余额不足！当前余额：" + state.balance.toFixed(2) + " rmb", "知道了");
            return;
        }
        if(newVal < 0) newVal = 0;
        state.bets[type] = newVal;
        updateUI();
    }

    function clearBet(type) {
        if(state.betRolling || isAnimating || isBetLocked) return;
        flashButton(document.querySelector(`.clear-bet[data-type="${type}"]`));
        state.bets[type] = 0;
        updateUI();
        if (window.navigator && window.navigator.vibrate) window.navigator.vibrate(30);
    }

    function startPoolFluctuation() { 
        setInterval(() => { 
            let change = Math.floor(Math.random()*61)-30; 
            let newPool = state.pool+change; 
            if(newPool<10000) newPool=10000; 
            if(newPool>100000) newPool=100000; 
            state.pool=newPool; 
            document.getElementById('poolDisplay').innerText=state.pool.toFixed(2); 
        }, 1000); 
    }

    function startCountdown(sec) {
        if(state.countdownInterval) clearInterval(state.countdownInterval);
        state.countdown = sec;
        const countdownSpan = document.getElementById('countdownNum');
        countdownSpan.innerText = state.countdown;
        countdownSpan.classList.remove('countdown-warning');
        
        isBetLocked = false;
        enableBetButtons(true);
        
        state.countdownInterval = setInterval(() => {
            if(state.countdown <= 1){
                clearInterval(state.countdownInterval);
                state.countdownInterval = null;
                isBetLocked = true;
                enableBetButtons(false);
                if(state.bets.DRAGON+state.bets.TIGER+state.bets.TIE > 0) executeBet();
                else startCountdown(30);
            } else {
                state.countdown--;
                countdownSpan.innerText = state.countdown;
                
                if(state.countdown <= 3 && !isBetLocked) {
                    isBetLocked = true;
                    enableBetButtons(false);
                    countdownSpan.classList.add('countdown-warning');
                    if (window.navigator && window.navigator.vibrate) window.navigator.vibrate(200);
                }
            }
        }, 1000);
    }

    function clearCountdown() { if(state.countdownInterval){ clearInterval(state.countdownInterval); state.countdownInterval=null; } }
    function refreshBalance() { syncBalance(); flashButton(document.getElementById('refreshBtn')); }

    function setSpeed(speed) {
        if(isAnimating) return;
        state.speed = speed;
        document.querySelectorAll('.speed-btn').forEach(btn => { 
