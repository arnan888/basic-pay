        .battle-scene {
            position: relative;
            margin: 16px;
            border-radius: 0;
            overflow: hidden;
            background: #0a0a0a;
            height: 35vh;
            flex-shrink: 0;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.6), 10px 10px 20px rgba(0,0,0,0.4), -4px -4px 8px rgba(255,255,255,0.05);
